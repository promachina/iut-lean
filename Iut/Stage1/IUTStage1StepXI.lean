      sourceData.iplDatum.link.source =
        sourceData.iplDatum.inputPrimeStrip ∧
      sourceData.iplDatum.link.target =
        sourceData.iplDatum.outputPrimeStrip ∧
      sourceData.targetLogVolume = sourceData.sourceLogVolume :=
