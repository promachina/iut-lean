    thetaPossibleImages := IUTStage1ThetaPilotPossibleImages.ofPackage package,
    thetaColumn := IUTStage1LogThetaVerticalColumn.zeroThetaPilot,
    qColumn := IUTStage1LogThetaVerticalColumn.oneQPilot,
    theta_column_eq := rfl,
