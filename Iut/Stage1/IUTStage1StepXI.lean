  let audit :=
    finiteTransport.synchronization.toStructuredSHESquareWeightTransportAudit
      |>.preservationAudit
  audit.sourceAverage

noncomputable def targetLogVolume
    (_sourceData :
      IUTStage1IPLLogVolumeTransportSource
        record l X C finiteTransport) :
