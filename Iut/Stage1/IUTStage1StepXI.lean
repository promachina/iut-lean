set_option linter.style.longLine false in
/--
Finite `F_l` procession action attached to the typed Theorem 3.11 quotient.

The generic choice type is not assumed to be `ZMod l`; the source-paper
procession action is therefore represented by a family of transitions indexed
by the gluing torsor parameter.  The zero/addition laws make this an
`F_l`-action shadow, while `transition_related` says that every transition stays
inside the quotient generated by the typed `(Ind1)/(Ind2)/(Ind3)` core.
-/
structure IUTStage1Theorem311FLProcessionAction
    (core : IUTStage1Theorem311TypedIndeterminacyCore index)
    (l : PrimeGeFive) where
  gluingTorsor : IUTStage1ThetaNFBridgeGluingTorsor l
  transition : ZMod l.value -> index -> index
  transition_zero : ∀ choice, transition 0 choice = choice
  transition_add :
    ∀ t u choice,
      transition (t + u) choice = transition t (transition u choice)
  transition_related :
    ∀ t choice, core.quotient.relation choice (transition t choice)

