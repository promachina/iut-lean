    (action : IUTStage1Theorem311FLProcessionAction core l)
    (t : ZMod l.value) (choice : index) :
    core.quotientMap choice = core.quotientMap (action.transition t choice) :=
  Quot.sound (action.transition_related t choice)

theorem gluing_card_eq
    (_action : IUTStage1Theorem311FLProcessionAction core l) :
    Fintype.card (ZMod l.value) = l.value := by
  rw [ZMod.card]

theorem endpoint
    (action : IUTStage1Theorem311FLProcessionAction core l) :
    Fintype.card (ZMod l.value) = l.value ∧
      (∀ choice, action.transition 0 choice = choice) ∧
      (∀ t u choice,
        action.transition (t + u) choice =
          action.transition t (action.transition u choice)) ∧
      (∀ t choice,
        core.quotientMap choice =
          core.quotientMap (action.transition t choice)) ∧
      (∀ t gluing,
        action.gluingTorsor.gluingTranslate t gluing =
          zmodLabelTranslate l t gluing) :=
  ⟨action.gluing_card_eq,
    action.transition_zero,
    action.transition_add,
    action.quotientMap_eq,
    fun _ _ => rfl⟩

end IUTStage1Theorem311FLProcessionAction

