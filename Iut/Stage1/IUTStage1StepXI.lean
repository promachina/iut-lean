                simpa [compatibilitySource, ofAdjustedDeterminantSource,
                  IUTStage1Remark395Ob3Ob4AdjustedDeterminantSource.normalizedDeterminantLogVolume]
                  using hbounded.2.2.1,
              by
                rw [hbounded.2.2.2.1]
                rfl,
              hbounded.2.2.2.2⟩⟩

