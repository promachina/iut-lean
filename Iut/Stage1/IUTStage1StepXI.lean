theorem coordinateEquiv_eq_factored
    (sourceData :
      IUTStage1FiniteHodgeSHETransportSource record l X C) :
    sourceData.coordinateEquiv =
      sourceData.synchronization.toFactoredObligations.coordinateEquiv :=
