theorem valuationRadius_thetaEstimate
    (predicateSource :
      ConcreteValuationBallThetaClassFiberTransportLocalThetaPredicateSource
        sourceData gluingTorsor selectedQChoice valuationSource)
    (index : β) :
    let factor :=
