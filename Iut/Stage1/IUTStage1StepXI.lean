    (core : IUTStage1Theorem311TypedIndeterminacyCore index)
    (l : PrimeGeFive) where
  gluingTorsor : IUTStage1ThetaNFBridgeGluingTorsor l
  transition : ZMod l.value -> index -> index
  transition_zero : ∀ choice, transition 0 choice = choice
  transition_add :
    ∀ t u choice,
      transition (t + u) choice = transition t (transition u choice)
  transition_related :
    ∀ t choice, core.equalityQuotient.relation choice (transition t choice)

