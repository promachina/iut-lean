theorem strictFiniteToyEqualityFLProcessionAction_endpoint
    (l : PrimeGeFive)
    (gluingTorsor : IUTStage1ThetaNFBridgeGluingTorsor l) :
    Fintype.card (ZMod l.value) = l.value ∧
      (∀ choice : Fin 2,
