            (construction.typedIndeterminacyCore.equalityQuotientMap
              construction.selectedQChoice) := by
        simpa [q_eq] using hx
      exact
        hullCompatibility.familySource.possibleRegion_subset_phi
          (construction.typedIndeterminacyCore.equalityQuotientMap
