set_option linter.style.longLine false in
/--
Vector-valued local coordinate image from landing plus simultaneous preimages.

This is the elementary product-image theorem used to lower the remaining
target-coordinate boundary.  To identify the image of a source region under
the local coordinate tuple \(x\mapsto(v\mapsto\ell_v(x))\), it suffices to
prove that every source point lands in each local coordinate region and that
every compatible tuple of local coordinates has a simultaneous source
preimage.
-/
theorem localLogCoordinateVector_image_eq_product_of_landing_and_preimage
    {α : Type u} {γlocal : Type v}
    (localCoord : γlocal -> α -> Real)
    (region : Set α)
    (localCoordRegion : γlocal -> Set Real)
    (landing :
      ∀ point : α, point ∈ region ->
        ∀ place : γlocal,
          localCoord place point ∈ localCoordRegion place)
    (preimage :
      ∀ coord : γlocal -> Real,
        (∀ place : γlocal, coord place ∈ localCoordRegion place) ->
          ∃ point : α,
            point ∈ region ∧
              ∀ place : γlocal, localCoord place point = coord place) :
    (fun point : α => fun place : γlocal => localCoord place point) '' region =
      { coord : γlocal -> Real |
        ∀ place : γlocal, coord place ∈ localCoordRegion place } := by
  ext coord
  constructor
  · intro hcoord
    rcases hcoord with ⟨point, hpoint, hcoord_eq⟩
    subst hcoord_eq
    exact landing point hpoint
  · intro hcoord
    rcases preimage coord hcoord with ⟨point, hpoint, hpoint_coord⟩
    refine ⟨point, hpoint, ?_⟩
    funext place
    exact hpoint_coord place

set_option linter.style.longLine false in
/--
Simultaneous local log-coordinate preimages from independent placewise
preimages and a direct-product assembly map.

This is the formal direct-product step beneath the vector-image theorem.  If
each local coordinate value can be realized in its own factor, and admissible
factor choices assemble to a source point whose local log coordinates are the
factor coordinates, then every compatible tuple of local coordinates has a
simultaneous source preimage.
-/
theorem simultaneousLocalLogCoordinatePreimage_of_placewise_factor_preimages
    {α : Type u} {γlocal : Type v} {B : γlocal -> Type w}
    (localCoord : γlocal -> α -> Real)
    (region : Set α)
    (localCoordRegion : γlocal -> Set Real)
    (localFactorRegion : ∀ place : γlocal, Set (B place))
    (localFactorCoord : ∀ place : γlocal, B place -> Real)
    (assemble : (∀ place : γlocal, B place) -> α)
    (localFactor_has_preimage :
      ∀ place : γlocal, ∀ value : Real,
        value ∈ localCoordRegion place ->
          ∃ factor : B place,
            factor ∈ localFactorRegion place ∧
              localFactorCoord place factor = value)
    (assemble_mem :
      ∀ factors : ∀ place : γlocal, B place,
        (∀ place : γlocal, factors place ∈ localFactorRegion place) ->
          assemble factors ∈ region)
    (assemble_coord :
      ∀ factors : ∀ place : γlocal, B place,
        (∀ place : γlocal, factors place ∈ localFactorRegion place) ->
          ∀ place : γlocal,
            localCoord place (assemble factors) =
              localFactorCoord place (factors place)) :
    ∀ coord : γlocal -> Real,
      (∀ place : γlocal, coord place ∈ localCoordRegion place) ->
        ∃ point : α,
          point ∈ region ∧
            ∀ place : γlocal, localCoord place point = coord place := by
