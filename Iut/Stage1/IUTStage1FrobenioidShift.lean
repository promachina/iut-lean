def sourceEvaluation
    (sync :
      IUTStage1TargetChartedThetaMonoidDegreeMatchedHodgeArakelovSynchronization
        part audited X C) :
    IUTStage1ZModSquareWeightProfile.IUTStage1HodgeArakelovThetaEvaluationSource
