  localKind : β -> IUTStage1IUTIVTheorem110LocalEstimateKind
  localMainLogContribution : β -> Real
  distinguishedProcessionBound : β -> Real
  archimedeanProcessionBound : β -> Real
  localPrimeErrorContribution_nonneg :
