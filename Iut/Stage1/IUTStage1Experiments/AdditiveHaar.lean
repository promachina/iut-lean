    GeneratedFullLabelFiniteDivisorVerticalIQRecordImageRealization
      (packageGenerated := packageGenerated) (packageFinite := packageFinite)
      (recordGenerated := recordGenerated) (recordFinite := recordFinite)
      sourceData finiteChoice :=
  { qSigned_eq := realization.qSigned_eq,
    thetaSigned_eq := realization.thetaSigned_eq,
