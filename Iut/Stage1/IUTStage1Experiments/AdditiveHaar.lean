    {source target : Copy} {coric : Type u} {π : Type v} [Fintype π]
    {l : PrimeGeFive}
    {packageGenerated :
      IUTStage1SourcePackage source target
        (IUTStage1ConcreteHodgeTheaterLogThetaChoice.LogThetaLabelProcessionVerticalLogKummerFrobenioidDivisorColumnComponentRepresentativeKernel.FullLabelGeneratedChoice
          (coric := coric) (l := l))}
    {recordGenerated :
      IUTStage1Theorem311MultiradialSourceRecord packageGenerated}
    {β : Type v} [Fintype β]
    (sourceData :
      GeneratedFullLabelQuotientCorridorSource
        (coric := coric) (π := π) (l := l)
        (package := packageGenerated) recordGenerated)
    (operation : RealLineCopy.AlgorithmicOutput.HullDetOperationId)
    (hullOperation : RealLineCopy.AlgorithmicOutput.HullOperationId)
    (determinantOperation :
      RealLineCopy.AlgorithmicOutput.DeterminantLogVolumeOperationId)
    (hullOperator :
      IUTStage1Remark395HolomorphicHullOperator (Point target))
    {γ : Type w} [Fintype γ]
    (ob3ob4Source :
      IUTStage1Remark395Ob3Ob4AdjustedDeterminantSource β γ)
    (compatibility :
      IUTStage1HullApproximantWeightedDeterminantCompatibility
        (IUTStage1HullLogVolumeApproximant.canonical
          (IUTStage1HolomorphicHullLogVolumeShadow.ofRemark395Operator
            hullOperator)
          (recordThetaPossibleImageUnion recordGenerated))
        ob3ob4Source.toWeightedDeterminantSource)
    (measure_eq_hullLogVolume :
      packageGenerated.preLedger.measure =
        (IUTStage1HolomorphicHullLogVolumeShadow.ofRemark395Operator
          hullOperator).toRegionMeasure)
    (tensorPower_bound :
      (IUTStage1NaiveFrobeniusTensorPowerLogVolume.ofWeightedDeterminant
          ob3ob4Source.toWeightedDeterminantSource).normalizedLogVolume <=
        packageGenerated.preLedger.thetaSigned)
    (hullDetBridge_eq :
      packageGenerated.preLedger.chartedContainer.commonContainer.hddShe.hdd.hullDetBridge =
        recordCanonicalHullTensorPowerHullDetDataOfQSubsetUnion
          (record := recordGenerated)
          operation hullOperation determinantOperation
          (IUTStage1HolomorphicHullLogVolumeShadow.ofRemark395Operator
            hullOperator)
          sourceData.toConstruction.selectedQRegion.toSet
          sourceData.toConstruction.selectedQRegion_subset_recordUnion
          ob3ob4Source.toWeightedDeterminantSource compatibility
          measure_eq_hullLogVolume tensorPower_bound)
    (q_pilot_positive : 0 < -packageGenerated.preLedger.qSigned)
    (normalization : packageGenerated.preLedger.normalization)
    (cTheta : Real)
    (canonicalCThetaScale_le_cTheta :
      (sourceData.toRemark395ConstructedHolomorphicHullDeterminantSource
        operation hullOperation determinantOperation hullOperator
        ob3ob4Source compatibility measure_eq_hullLogVolume
        tensorPower_bound hullDetBridge_eq q_pilot_positive
        normalization).canonicalCThetaScale <= cTheta) :
    sourceData.Audit ∧
      sourceData.HullCompatibilityAudit hullOperator ∧
      let constructedSource :=
        sourceData.toRemark395ConstructedHolomorphicHullDeterminantSource
          operation hullOperation determinantOperation hullOperator
          ob3ob4Source compatibility measure_eq_hullLogVolume
          tensorPower_bound hullDetBridge_eq q_pilot_positive normalization;
      constructedSource.qPilotRegion =
          sourceData.toConstruction.selectedQRegion.toSet ∧
        constructedSource.qPilotRegion =
          (sourceData.toConstruction.equalityQuotientPossibleImages.quotientImages.region
            (sourceData.toConstruction.typedIndeterminacyCore.equalityQuotientMap
              sourceData.selectedQChoice)).toSet ∧
        constructedSource.qPilotRegion =
          (sourceData.thetaClassImages.region
            (IUTStage1ConcreteHodgeTheaterLogThetaChoice.thetaPilotClass
              (sourceData.generatedSource.fullLabelToConcreteChoice
                sourceData.selectedQChoice))).toSet ∧
        packageGenerated.preLedger.qSigned <= packageGenerated.preLedger.thetaSigned ∧
        packageGenerated.preLedger.thetaSigned <=
          cTheta * (-packageGenerated.preLedger.qSigned) ∧
        constructedSource.hullOperator.logVolume constructedSource.qPilotRegion <=
          cTheta * (-packageGenerated.preLedger.qSigned) ∧
        ((packageGenerated.preLedger.qSigned =
            packageGenerated.preLedger.thetaSigned ∧
            packageGenerated.preLedger.thetaSigned < 0) ∨
          (-1 : Real) < cTheta) := by
  refine ⟨sourceData.audit, sourceData.hullCompatibilityAudit hullOperator, ?_⟩
  exact
    sourceData.toRemark395ConstructedGlobalCThetaScaleComparisonAudit_endpoint
      operation hullOperation determinantOperation hullOperator
      ob3ob4Source compatibility measure_eq_hullLogVolume
      tensorPower_bound hullDetBridge_eq q_pilot_positive normalization
      cTheta canonicalCThetaScale_le_cTheta

set_option linter.style.longLine false in
/--
Typed handoff from the generated full-label Theorem 3.11 quotient route to a
finite-divisor vertical-\(IQ\) source package.

This is not an identification by naming convention.  The handoff records the
exact source-side facts needed to read the finite-divisor package as realizing
the generated selected q-region: the signed pre-ledger quantities agree, the
finite-divisor record's possible image is the generated selected q-region, and
the finite-divisor pre-ledger target region for the selected packet is the same
region.  Constructing these fields from the paper-native local
log-Kummer/Frobenioid data is the next mathematical obligation.
-/
structure GeneratedFullLabelFiniteDivisorVerticalIQPackageHandoff
    {source target : Copy} {coric : Type u} {π : Type v} [Fintype π]
    {l : PrimeGeFive}
    {packageGenerated :
      IUTStage1SourcePackage source target
        (IUTStage1ConcreteHodgeTheaterLogThetaChoice.LogThetaLabelProcessionVerticalLogKummerFrobenioidDivisorColumnComponentRepresentativeKernel.FullLabelGeneratedChoice
          (coric := coric) (l := l))}
    {packageFinite :
      IUTStage1SourcePackage source target
        (IUTStage1PlaceAuditedDirectSummandPacketChoice
          coric IUTStage1PlaceKind.nonarchimedean)}
    {recordGenerated :
      IUTStage1Theorem311MultiradialSourceRecord packageGenerated}
    {recordFinite :
      IUTStage1Theorem311MultiradialSourceRecord packageFinite}
    (sourceData :
      GeneratedFullLabelQuotientCorridorSource
        (coric := coric) (π := π) (l := l)
        (package := packageGenerated) recordGenerated)
    (finiteChoice :
      IUTStage1PlaceAuditedDirectSummandPacketChoice
        coric IUTStage1PlaceKind.nonarchimedean) : Prop where
  qSigned_eq :
    packageFinite.preLedger.qSigned = packageGenerated.preLedger.qSigned
  thetaSigned_eq :
    packageFinite.preLedger.thetaSigned = packageGenerated.preLedger.thetaSigned
  selectedFiniteThetaPossibleImage_eq_generatedQRegion :
    recordThetaPossibleImage recordFinite finiteChoice =
      sourceData.toConstruction.selectedQRegion.toSet
  finiteTargetRegion_eq_generatedQRegion :
    (packageFinite.preLedger.output.comparison finiteChoice).targetRegion.toSet =
      sourceData.toConstruction.selectedQRegion.toSet

set_option linter.style.longLine false in
/--
Record-level target-region identity for a Theorem 3.11 source record.

The record possible image is not an auxiliary family: it is the source package's
target-region family read through `IUTStage1ThetaPilotPossibleImages`.
-/
theorem recordThetaPossibleImage_eq_targetRegion_toSet
    {source target : Copy} {index : Type u}
    {package : IUTStage1SourcePackage source target index}
    (record : IUTStage1Theorem311MultiradialSourceRecord package)
    (choice : index) :
    recordThetaPossibleImage record choice =
      (package.preLedger.output.comparison choice).targetRegion.toSet := by
  unfold recordThetaPossibleImage
  rw [record.thetaPossibleImages.choice_region_eq_targetRegion choice]

set_option linter.style.longLine false in
/--
Generated selected-record image as a theta-pilot-class image.

The generated full-label quotient source does not leave the selected possible
image opaque: the selected Theorem 3.11 record image is exactly the
theta-pilot-class region obtained by projecting the selected generated
full-label choice to the concrete Hodge-theater/log-theta choice.  This is the
bridge used by the finite packet layer below.
-/
theorem generatedFullLabelSelectedRecordThetaPossibleImage_eq_thetaClassRegion_toSet
    {source target : Copy} {coric : Type u} {π : Type v} [Fintype π]
    {l : PrimeGeFive}
    {packageGenerated :
      IUTStage1SourcePackage source target
        (IUTStage1ConcreteHodgeTheaterLogThetaChoice.LogThetaLabelProcessionVerticalLogKummerFrobenioidDivisorColumnComponentRepresentativeKernel.FullLabelGeneratedChoice
          (coric := coric) (l := l))}
    {recordGenerated :
      IUTStage1Theorem311MultiradialSourceRecord packageGenerated}
    (sourceData :
      GeneratedFullLabelQuotientCorridorSource
        (coric := coric) (π := π) (l := l)
        (package := packageGenerated) recordGenerated) :
    recordThetaPossibleImage recordGenerated sourceData.selectedQChoice =
      (sourceData.thetaClassImages.region
        (IUTStage1ConcreteHodgeTheaterLogThetaChoice.thetaPilotClass
          (sourceData.generatedSource.fullLabelToConcreteChoice
            sourceData.selectedQChoice))).toSet := by
  calc
    recordThetaPossibleImage recordGenerated sourceData.selectedQChoice =
        sourceData.toConstruction.selectedQRegion.toSet :=
      (sourceData.toConstruction.selectedQRegion_eq_recordThetaPossibleImage).symm
    _ =
        (sourceData.thetaClassImages.region
          (IUTStage1ConcreteHodgeTheaterLogThetaChoice.thetaPilotClass
            (sourceData.generatedSource.fullLabelToConcreteChoice
              sourceData.selectedQChoice))).toSet :=
      congrArg Region.toSet
        sourceData.audit.selected_region_projects_to_thetaClass

