    {recordGenerated :
      IUTStage1Theorem311MultiradialSourceRecord packageGenerated}
    {recordFinite :
      IUTStage1Theorem311MultiradialSourceRecord packageFinite}
    {sourceData :
      GeneratedFullLabelQuotientCorridorSource
        (coric := coric) (π := π) (l := l)
        (package := packageGenerated) recordGenerated}
    {finiteChoice :
      IUTStage1PlaceAuditedDirectSummandPacketChoice
        coric IUTStage1PlaceKind.nonarchimedean}
    (realization :
      GeneratedFullLabelFiniteDivisorVerticalIQThetaClassRecordImageRealization
        (packageGenerated := packageGenerated) (packageFinite := packageFinite)
        (recordGenerated := recordGenerated) (recordFinite := recordFinite)
