    (data :
      IUTStage1StructureSheafAdjustedLocalizedVectorBundleSource η γ)
    (adjustedRaw_pos : 0 < data.adjustedRawLogVolume) :
    0 < data.weightedAdjustedLogVolume := by
  exact mul_pos data.weight_real_pos adjustedRaw_pos

