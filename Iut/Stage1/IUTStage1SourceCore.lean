noncomputable def unitSubgroup
    (data :
      IUTStage1PadicFiniteExtensionValuedIntegerDilationQuotientCosetHaarCharacterNormalizationSource
        α p K hullSystem) : AddSubgroup K :=
  data.integerSource.integerAddSubgroup

