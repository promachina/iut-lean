/--
Source-facing direct-product cell log-volume law.

This is the local tensor/direct-product log-volume rule used in Step (xi-d):
the log-volume of the cell cut out simultaneously by finitely many local
factor regions is the finite sum of the local factor log-volumes.  Later
source layers should construct this object from the nonarchimedean normalized
log-volume on tensor packets; the charted cover source below consumes this
single-cell law instead of taking the resulting equality as a bare field.
-/
structure IUTStage1DirectProductCellLogVolumeSource
    (α : Type u) (γ : Type v)
    [Fintype γ]
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  product_logVolume_eq_sum :
    ∀ factorRegion : γ -> Set α,
      hullSystem.logVolume { point : α | ∀ place : γ, point ∈ factorRegion place } =
        Finset.univ.sum fun place =>
          hullSystem.logVolume (factorRegion place)

namespace IUTStage1DirectProductCellLogVolumeSource

variable {α : Type u} {γ : Type v}
variable [Fintype γ]
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

theorem directProductCell_logVolume_eq_sum
    (data : IUTStage1DirectProductCellLogVolumeSource α γ hullSystem)
    (factorRegion : γ -> Set α) :
    hullSystem.logVolume { point : α | ∀ place : γ, point ∈ factorRegion place } =
      Finset.univ.sum fun place =>
        hullSystem.logVolume (factorRegion place) :=
  data.product_logVolume_eq_sum factorRegion

theorem endpoint
    (data : IUTStage1DirectProductCellLogVolumeSource α γ hullSystem)
    (factorRegion : γ -> Set α) :
    hullSystem.logVolume { point : α | ∀ place : γ, point ∈ factorRegion place } =
      Finset.univ.sum fun place =>
        hullSystem.logVolume (factorRegion place) :=
  data.directProductCell_logVolume_eq_sum factorRegion

end IUTStage1DirectProductCellLogVolumeSource

/--
Finite tensor/direct-sum log-volume source for one direct-product cell.

This is the next source-facing layer beneath
`IUTStage1DirectProductCellLogVolumeSource`.  It records the actual tensor
product region attached to a finite family of local factor regions, identifies
that tensor region with the direct-product cell, reads each local factor
log-volume from the hull-system log-volume, and computes the tensor product
log-volume as the finite direct-sum of these local terms.
-/
structure IUTStage1FiniteTensorDirectSumLogVolumeSource
    (α : Type u) (γ : Type v)
    [Fintype γ]
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α)
    (factorRegion : γ -> Set α) where
  tensorProductRegion : Set α
  tensorProductRegion_eq_directProduct :
    tensorProductRegion = { point : α | ∀ place : γ, point ∈ factorRegion place }
  tensorProductLogVolume : Real
  tensorProductLogVolume_eq_region :
    tensorProductLogVolume = hullSystem.logVolume tensorProductRegion
  factorLogVolume : γ -> Real
  factorLogVolume_eq_region :
    ∀ place : γ, factorLogVolume place = hullSystem.logVolume (factorRegion place)
  tensorProductLogVolume_eq_factorSum :
    tensorProductLogVolume = Finset.univ.sum factorLogVolume

namespace IUTStage1FiniteTensorDirectSumLogVolumeSource

variable {α : Type u} {γ : Type v}
variable [Fintype γ]
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}
variable {factorRegion : γ -> Set α}

theorem directProduct_logVolume_eq_factorSum
    (data :
      IUTStage1FiniteTensorDirectSumLogVolumeSource
        α γ hullSystem factorRegion) :
    hullSystem.logVolume { point : α | ∀ place : γ, point ∈ factorRegion place } =
      Finset.univ.sum fun place =>
        hullSystem.logVolume (factorRegion place) := by
  calc
    hullSystem.logVolume
        { point : α | ∀ place : γ, point ∈ factorRegion place } =
        hullSystem.logVolume data.tensorProductRegion := by
      rw [data.tensorProductRegion_eq_directProduct]
    _ = data.tensorProductLogVolume :=
      data.tensorProductLogVolume_eq_region.symm
    _ = Finset.univ.sum data.factorLogVolume :=
      data.tensorProductLogVolume_eq_factorSum
    _ =
        Finset.univ.sum fun place =>
          hullSystem.logVolume (factorRegion place) := by
      exact Finset.sum_congr rfl
        (fun place _ => data.factorLogVolume_eq_region place)

theorem endpoint
    (data :
      IUTStage1FiniteTensorDirectSumLogVolumeSource
        α γ hullSystem factorRegion) :
    data.tensorProductRegion =
        { point : α | ∀ place : γ, point ∈ factorRegion place } ∧
      data.tensorProductLogVolume = hullSystem.logVolume data.tensorProductRegion ∧
      (∀ place : γ,
        data.factorLogVolume place =
          hullSystem.logVolume (factorRegion place)) ∧
      data.tensorProductLogVolume =
        Finset.univ.sum data.factorLogVolume ∧
      hullSystem.logVolume
          { point : α | ∀ place : γ, point ∈ factorRegion place } =
        Finset.univ.sum fun place =>
          hullSystem.logVolume (factorRegion place) :=
  ⟨data.tensorProductRegion_eq_directProduct,
    data.tensorProductLogVolume_eq_region,
    data.factorLogVolume_eq_region,
    data.tensorProductLogVolume_eq_factorSum,
    data.directProduct_logVolume_eq_factorSum⟩

end IUTStage1FiniteTensorDirectSumLogVolumeSource

/--
Local compact-open tensor factor source.

This is the local input beneath a finite tensor/direct-sum cell: a
nonarchimedean local ring label, a compact-open region in the current
mono-analytic real-line copy, and the normalized log-volume attached to that
region.  The compact-open predicate itself is still part of the source
interface; later local-field layers should construct it from the actual
`M(-)` compact-open subsets in the IUT papers.
-/
structure IUTStage1LocalCompactOpenTensorFactorSource
    (α : Type u) (η : Type v)
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  compactOpenRegion : Set α
  normalizedLogVolume : Real
  region_logVolume_eq_normalized :
    hullSystem.logVolume compactOpenRegion = normalizedLogVolume

namespace IUTStage1LocalCompactOpenTensorFactorSource

variable {α : Type u} {η : Type v}
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

theorem normalizedLogVolume_eq_region
    (data : IUTStage1LocalCompactOpenTensorFactorSource α η hullSystem) :
    data.normalizedLogVolume =
      hullSystem.logVolume data.compactOpenRegion :=
  data.region_logVolume_eq_normalized.symm

theorem endpoint
    (data : IUTStage1LocalCompactOpenTensorFactorSource α η hullSystem) :
    hullSystem.logVolume data.compactOpenRegion =
      data.normalizedLogVolume ∧
    data.normalizedLogVolume =
      hullSystem.logVolume data.compactOpenRegion :=
  ⟨data.region_logVolume_eq_normalized,
    data.normalizedLogVolume_eq_region⟩

end IUTStage1LocalCompactOpenTensorFactorSource

set_option linter.style.longLine false in
/--
Compact-open construction of a norm-square localized arithmetic vector bundle.

Each direct summand is represented by a local compact-open tensor factor.  If
the normalized compact-open log-volume is nonnegative, Lean constructs the
direct-summand norm as its real square root.  The resulting norm-square bundle
therefore projects to an ordinary localized arithmetic vector bundle whose
direct-summand log-volumes are exactly the compact-open normalized
log-volumes.
-/
structure IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
    (α : Type u) (η : Type v) (γ : Type w)
    [Fintype γ]
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  factor : γ -> IUTStage1LocalCompactOpenTensorFactorSource α η hullSystem
  factor_localRing_eq :
    ∀ summand : γ, (factor summand).localRing = localRing
  normalizedLogVolume_nonneg :
    ∀ summand : γ, 0 <= (factor summand).normalizedLogVolume
  rank_gt_one : 1 < Fintype.card γ

namespace IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource

variable {α : Type u} {η : Type v} {γ : Type w}
variable [Fintype γ]
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

noncomputable def directSummandNorm
    (data :
      IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
        α η γ hullSystem)
    (summand : γ) :
    Real :=
  Real.sqrt ((data.factor summand).normalizedLogVolume)

noncomputable def toNormSquareLocalizedArithmeticVectorBundle
    (data :
      IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
        α η γ hullSystem) :
    IUTStage1NormSquareLocalizedArithmeticVectorBundle η γ :=
  { localRing := data.localRing,
    directSummandNorm := data.directSummandNorm,
    rank_gt_one := data.rank_gt_one }

theorem directSummandNorm_sq_eq_normalizedLogVolume
    (data :
      IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
        α η γ hullSystem)
    (summand : γ) :
    data.directSummandNorm summand ^ 2 =
      (data.factor summand).normalizedLogVolume := by
  simpa [directSummandNorm] using
    Real.sq_sqrt (data.normalizedLogVolume_nonneg summand)

theorem projected_directSummandLogVolume_eq_normalizedLogVolume
    (data :
      IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
        α η γ hullSystem)
    (summand : γ) :
    data.toNormSquareLocalizedArithmeticVectorBundle.toLocalizedArithmeticVectorBundle.directSummandLogVolume
        summand =
      (data.factor summand).normalizedLogVolume := by
  exact data.directSummandNorm_sq_eq_normalizedLogVolume summand

theorem projected_directSummandLogVolume_eq_factorLogVolume
    (data :
      IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
        α η γ hullSystem)
    (summand : γ) :
    data.toNormSquareLocalizedArithmeticVectorBundle.toLocalizedArithmeticVectorBundle.directSummandLogVolume
        summand =
