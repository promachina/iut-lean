    (data : IUTStage1Remark395Ob3Ob4AdjustedDeterminantSource β γ) :
    (∀ index : β,
      data.adjustedRawLogVolume index =
        data.localizationBundleLogVolume index -
          data.structureSheafLogVolume index) ∧
      (∀ index : β,
        data.weightedAdjustedLogVolume index =
