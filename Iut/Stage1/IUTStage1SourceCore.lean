/--
Nonarchimedean local compact-open normalized log-volume source.

This is the source-facing local-field layer below a compact-open tensor factor.
It records a local carrier `K`, the integral structure and compact-open subset
there, their realization as regions in the current real-line copy, the residue
prime and finite-extension degree used for normalization, and the two
normalization laws from IUT IV, Proposition 1.4: integral structures have
normalized log-volume zero, and uniformizer multiplication shifts log-volume by
`-log(p)`.
-/
structure IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource
    (α : Type u) (η : Type v) (K : Type w)
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  residuePrime : Nat
  residue_prime : Nat.Prime residuePrime
  localDegree : Nat
  local_degree_pos : 0 < localDegree
  realization : K -> α
  integralStructure : Set K
  compactOpenSubset : Set K
  uniformizerScaledSubset : Set K
  integralRegion : Set α
  compactOpenRegion : Set α
  uniformizerScaledRegion : Set α
  integralRegion_eq_image :
    integralRegion = realization '' integralStructure
  compactOpenRegion_eq_image :
    compactOpenRegion = realization '' compactOpenSubset
  uniformizerScaledRegion_eq_image :
    uniformizerScaledRegion = realization '' uniformizerScaledSubset
  rawLogVolume : Real
  normalizedLogVolume : Real
  normalized_eq_degree :
    normalizedLogVolume = rawLogVolume / (localDegree : Real)
  integral_logVolume_zero :
    hullSystem.logVolume integralRegion = 0
  compactOpen_logVolume_eq_normalized :
    hullSystem.logVolume compactOpenRegion = normalizedLogVolume
  uniformizerScaled_logVolume_eq :
    hullSystem.logVolume uniformizerScaledRegion =
      normalizedLogVolume - Real.log (residuePrime : Real)

namespace IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource

variable {α : Type u} {η : Type v} {K : Type w}
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

theorem localDegree_ne_zero
    (data :
      IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource
        α η K hullSystem) :
    (data.localDegree : Real) ≠ 0 := by
  exact_mod_cast Nat.ne_of_gt data.local_degree_pos

theorem normalizedLogVolume_eq_region
    (data :
      IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource
        α η K hullSystem) :
    data.normalizedLogVolume =
      hullSystem.logVolume data.compactOpenRegion :=
  data.compactOpen_logVolume_eq_normalized.symm

def toLocalCompactOpenTensorFactorSource
    (data :
      IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource
        α η K hullSystem) :
    IUTStage1LocalCompactOpenTensorFactorSource α η hullSystem :=
  { localRing := data.localRing,
    compactOpenRegion := data.compactOpenRegion,
    normalizedLogVolume := data.normalizedLogVolume,
    region_logVolume_eq_normalized :=
      data.compactOpen_logVolume_eq_normalized }

theorem endpoint
    (data :
      IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource
        α η K hullSystem) :
    data.integralRegion = data.realization '' data.integralStructure ∧
      data.compactOpenRegion = data.realization '' data.compactOpenSubset ∧
      data.uniformizerScaledRegion =
        data.realization '' data.uniformizerScaledSubset ∧
      data.normalizedLogVolume =
        data.rawLogVolume / (data.localDegree : Real) ∧
      hullSystem.logVolume data.integralRegion = 0 ∧
      hullSystem.logVolume data.compactOpenRegion =
        data.normalizedLogVolume ∧
      hullSystem.logVolume data.uniformizerScaledRegion =
        data.normalizedLogVolume - Real.log (data.residuePrime : Real) ∧
      (data.toLocalCompactOpenTensorFactorSource).compactOpenRegion =
        data.compactOpenRegion ∧
      (data.toLocalCompactOpenTensorFactorSource).normalizedLogVolume =
        data.normalizedLogVolume :=
  ⟨data.integralRegion_eq_image,
    data.compactOpenRegion_eq_image,
    data.uniformizerScaledRegion_eq_image,
    data.normalized_eq_degree,
    data.integral_logVolume_zero,
    data.compactOpen_logVolume_eq_normalized,
    data.uniformizerScaled_logVolume_eq,
    rfl,
    rfl⟩

end IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource

/--
Finite-extension Haar normalized compact-open log-volume source.

This is the lower nonarchimedean input modeled on IUT IV, Proposition 1.4(i).
It records a raw Haar/log-volume function on local compact-open subsets of a
finite extension of `Q_p`, the degree-normalized version of that function, the
real-line realization of local subsets, and the two normalizations
`μlog(O_K) = 0` and `μlog(p · U) = μlog(U) - log(p)`.
-/
structure IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource
    (α : Type u) (η : Type v) (K : Type w)
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  residuePrime : Nat
  residue_prime : Nat.Prime residuePrime
  finiteExtensionDegree : Nat
  finite_extension_degree_pos : 0 < finiteExtensionDegree
  realization : K -> α
  realizedRegion : Set K -> Set α
  realizedRegion_eq_image :
    ∀ subset : Set K, realizedRegion subset = realization '' subset
  ringOfIntegers : Set K
  compactOpenSubset : Set K
  uniformizerScaledSubset : Set K
  rawHaarLogVolume : Set K -> Real
  normalizedHaarLogVolume : Set K -> Real
  normalizedHaarLogVolume_eq_degree :
    ∀ subset : Set K,
      normalizedHaarLogVolume subset =
        rawHaarLogVolume subset / (finiteExtensionDegree : Real)
  hull_logVolume_eq_normalized :
    ∀ subset : Set K,
      hullSystem.logVolume (realizedRegion subset) =
        normalizedHaarLogVolume subset
  ringOfIntegers_normalized_zero :
    normalizedHaarLogVolume ringOfIntegers = 0
  uniformizerScaled_normalized_eq :
    normalizedHaarLogVolume uniformizerScaledSubset =
      normalizedHaarLogVolume compactOpenSubset -
        Real.log (residuePrime : Real)

namespace IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource

variable {α : Type u} {η : Type v} {K : Type w}
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

theorem finiteExtensionDegree_ne_zero
    (data :
      IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource
        α η K hullSystem) :
    (data.finiteExtensionDegree : Real) ≠ 0 := by
  exact_mod_cast Nat.ne_of_gt data.finite_extension_degree_pos

def toNonarchimedeanLocalCompactOpenLogVolumeSource
    (data :
      IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource
        α η K hullSystem) :
    IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource
      α η K hullSystem :=
  { localRing := data.localRing,
    residuePrime := data.residuePrime,
    residue_prime := data.residue_prime,
    localDegree := data.finiteExtensionDegree,
    local_degree_pos := data.finite_extension_degree_pos,
    realization := data.realization,
    integralStructure := data.ringOfIntegers,
    compactOpenSubset := data.compactOpenSubset,
    uniformizerScaledSubset := data.uniformizerScaledSubset,
    integralRegion := data.realizedRegion data.ringOfIntegers,
    compactOpenRegion := data.realizedRegion data.compactOpenSubset,
    uniformizerScaledRegion :=
      data.realizedRegion data.uniformizerScaledSubset,
    integralRegion_eq_image :=
      data.realizedRegion_eq_image data.ringOfIntegers,
    compactOpenRegion_eq_image :=
      data.realizedRegion_eq_image data.compactOpenSubset,
    uniformizerScaledRegion_eq_image :=
      data.realizedRegion_eq_image data.uniformizerScaledSubset,
    rawLogVolume := data.rawHaarLogVolume data.compactOpenSubset,
    normalizedLogVolume :=
      data.normalizedHaarLogVolume data.compactOpenSubset,
    normalized_eq_degree :=
      data.normalizedHaarLogVolume_eq_degree data.compactOpenSubset,
    integral_logVolume_zero := by
      calc
        hullSystem.logVolume (data.realizedRegion data.ringOfIntegers) =
            data.normalizedHaarLogVolume data.ringOfIntegers :=
          data.hull_logVolume_eq_normalized data.ringOfIntegers
        _ = 0 :=
          data.ringOfIntegers_normalized_zero,
    compactOpen_logVolume_eq_normalized :=
      data.hull_logVolume_eq_normalized data.compactOpenSubset,
    uniformizerScaled_logVolume_eq := by
      calc
        hullSystem.logVolume
            (data.realizedRegion data.uniformizerScaledSubset) =
            data.normalizedHaarLogVolume data.uniformizerScaledSubset :=
          data.hull_logVolume_eq_normalized data.uniformizerScaledSubset
        _ =
            data.normalizedHaarLogVolume data.compactOpenSubset -
              Real.log (data.residuePrime : Real) :=
          data.uniformizerScaled_normalized_eq }

theorem endpoint
    (data :
      IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource
        α η K hullSystem) :
    (∀ subset : Set K,
      data.realizedRegion subset = data.realization '' subset) ∧
      (∀ subset : Set K,
        data.normalizedHaarLogVolume subset =
          data.rawHaarLogVolume subset /
            (data.finiteExtensionDegree : Real)) ∧
      data.normalizedHaarLogVolume data.ringOfIntegers = 0 ∧
      data.normalizedHaarLogVolume data.uniformizerScaledSubset =
        data.normalizedHaarLogVolume data.compactOpenSubset -
          Real.log (data.residuePrime : Real) ∧
      (data.toNonarchimedeanLocalCompactOpenLogVolumeSource).compactOpenRegion =
        data.realizedRegion data.compactOpenSubset ∧
      (data.toNonarchimedeanLocalCompactOpenLogVolumeSource).normalizedLogVolume =
        data.normalizedHaarLogVolume data.compactOpenSubset ∧
      ((data.toNonarchimedeanLocalCompactOpenLogVolumeSource)
        |>.toLocalCompactOpenTensorFactorSource).compactOpenRegion =
        data.realizedRegion data.compactOpenSubset :=
  ⟨data.realizedRegion_eq_image,
    data.normalizedHaarLogVolume_eq_degree,
    data.ringOfIntegers_normalized_zero,
    data.uniformizerScaled_normalized_eq,
    rfl,
    rfl,
    rfl⟩

end IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource

/--
Finite-extension compact-open topology Haar normalization source.

This is the next local boundary below the finite-extension Haar log-volume
source.  It records the compact-open predicate on the local carrier, the
ring-of-integers compact-open, the chosen local compact-open subset, the
uniformizer action on compact-opens, and the Haar/log-volume normalization laws
that are then totalized to the finite-extension source used downstream.
-/
structure IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
    (α : Type u) (η : Type v) (K : Type w)
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  residuePrime : Nat
  residue_prime : Nat.Prime residuePrime
  finiteExtensionDegree : Nat
  finite_extension_degree_pos : 0 < finiteExtensionDegree
  realization : K -> α
  realizedRegion : Set K -> Set α
  realizedRegion_eq_image :
    ∀ subset : Set K, realizedRegion subset = realization '' subset
  isCompactOpen : Set K -> Prop
  compactOpen_inter :
    ∀ ⦃left right : Set K⦄,
      isCompactOpen left -> isCompactOpen right -> isCompactOpen (left ∩ right)
  ringOfIntegers : Set K
  compactOpenSubset : Set K
  uniformizerScale : Set K -> Set K
  ringOfIntegers_compactOpen :
    isCompactOpen ringOfIntegers
  compactOpenSubset_compactOpen :
    isCompactOpen compactOpenSubset
  uniformizerScale_preserves_compactOpen :
    ∀ subset : Set K, isCompactOpen subset ->
      isCompactOpen (uniformizerScale subset)
  rawHaarMeasure : Set K -> Real
  rawHaarLogVolume : Set K -> Real
  normalizedHaarLogVolume : Set K -> Real
  rawHaarLogVolume_eq_measure_log :
    ∀ subset : Set K, isCompactOpen subset ->
      rawHaarLogVolume subset = Real.log (rawHaarMeasure subset)
  normalizedHaarLogVolume_eq_degree :
    ∀ subset : Set K,
      normalizedHaarLogVolume subset =
        rawHaarLogVolume subset / (finiteExtensionDegree : Real)
  hull_logVolume_eq_normalized :
    ∀ subset : Set K,
      hullSystem.logVolume (realizedRegion subset) =
        normalizedHaarLogVolume subset
  ringOfIntegers_normalized_zero :
    normalizedHaarLogVolume ringOfIntegers = 0
  uniformizerScaled_normalized_eq :
    normalizedHaarLogVolume (uniformizerScale compactOpenSubset) =
      normalizedHaarLogVolume compactOpenSubset -
        Real.log (residuePrime : Real)

namespace IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource

variable {α : Type u} {η : Type v} {K : Type w}
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

def uniformizerScaledSubset
    (data :
      IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
        α η K hullSystem) :
    Set K :=
  data.uniformizerScale data.compactOpenSubset

theorem uniformizerScaledSubset_compactOpen
    (data :
      IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
        α η K hullSystem) :
    data.isCompactOpen data.uniformizerScaledSubset :=
  data.uniformizerScale_preserves_compactOpen
    data.compactOpenSubset data.compactOpenSubset_compactOpen

theorem finiteExtensionDegree_ne_zero
    (data :
      IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
        α η K hullSystem) :
    (data.finiteExtensionDegree : Real) ≠ 0 := by
  exact_mod_cast Nat.ne_of_gt data.finite_extension_degree_pos

def toFiniteExtensionHaarCompactOpenLogVolumeSource
    (data :
      IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
        α η K hullSystem) :
    IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource
      α η K hullSystem :=
  { localRing := data.localRing,
    residuePrime := data.residuePrime,
    residue_prime := data.residue_prime,
    finiteExtensionDegree := data.finiteExtensionDegree,
    finite_extension_degree_pos := data.finite_extension_degree_pos,
    realization := data.realization,
    realizedRegion := data.realizedRegion,
    realizedRegion_eq_image := data.realizedRegion_eq_image,
    ringOfIntegers := data.ringOfIntegers,
    compactOpenSubset := data.compactOpenSubset,
    uniformizerScaledSubset := data.uniformizerScaledSubset,
    rawHaarLogVolume := data.rawHaarLogVolume,
    normalizedHaarLogVolume := data.normalizedHaarLogVolume,
    normalizedHaarLogVolume_eq_degree :=
      data.normalizedHaarLogVolume_eq_degree,
    hull_logVolume_eq_normalized :=
      data.hull_logVolume_eq_normalized,
    ringOfIntegers_normalized_zero :=
      data.ringOfIntegers_normalized_zero,
    uniformizerScaled_normalized_eq :=
      data.uniformizerScaled_normalized_eq }

theorem endpoint
    (data :
      IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
        α η K hullSystem) :
    data.isCompactOpen data.ringOfIntegers ∧
      data.isCompactOpen data.compactOpenSubset ∧
      data.isCompactOpen data.uniformizerScaledSubset ∧
      data.rawHaarLogVolume data.compactOpenSubset =
        Real.log (data.rawHaarMeasure data.compactOpenSubset) ∧
      data.normalizedHaarLogVolume data.compactOpenSubset =
        data.rawHaarLogVolume data.compactOpenSubset /
          (data.finiteExtensionDegree : Real) ∧
      data.normalizedHaarLogVolume data.ringOfIntegers = 0 ∧
      data.normalizedHaarLogVolume data.uniformizerScaledSubset =
        data.normalizedHaarLogVolume data.compactOpenSubset -
          Real.log (data.residuePrime : Real) ∧
      ((data.toFiniteExtensionHaarCompactOpenLogVolumeSource)
        |>.toNonarchimedeanLocalCompactOpenLogVolumeSource).compactOpenRegion =
        data.realizedRegion data.compactOpenSubset :=
  ⟨data.ringOfIntegers_compactOpen,
    data.compactOpenSubset_compactOpen,
    data.uniformizerScaledSubset_compactOpen,
    data.rawHaarLogVolume_eq_measure_log
      data.compactOpenSubset data.compactOpenSubset_compactOpen,
    data.normalizedHaarLogVolume_eq_degree data.compactOpenSubset,
    data.ringOfIntegers_normalized_zero,
    data.uniformizerScaled_normalized_eq,
    rfl⟩

end IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource

/--
Additive Haar-measure compact-open normalization source.

This lowers the compact-open topology source by replacing its arbitrary real
Haar-measure/log-volume functions with a mathlib Haar measure on the additive
local carrier.  The remaining supplied laws are the IUT IV finite-extension
normalization inputs: the ring of integers has Haar mass `1`, and the chosen
uniformizer scale changes the real Haar mass by the finite-extension residue
factor.  The normalized log-volume shift is then derived in Lean.
-/
structure IUTStage1AdditiveHaarCompactOpenNormalizationSource
    (α : Type u) (η : Type v) (K : Type w)
    [TopologicalSpace K] [MeasurableSpace K] [AddGroup K]
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  residuePrime : Nat
  residue_prime : Nat.Prime residuePrime
  finiteExtensionDegree : Nat
  finite_extension_degree_pos : 0 < finiteExtensionDegree
  realization : K -> α
  realizedRegion : Set K -> Set α
  realizedRegion_eq_image :
    ∀ subset : Set K, realizedRegion subset = realization '' subset
  haarMeasure : MeasureTheory.Measure K
  haar_isAddHaar :
    MeasureTheory.Measure.IsAddHaarMeasure haarMeasure
  isCompactOpen : Set K -> Prop
  compactOpen_is_open :
    ∀ ⦃subset : Set K⦄, isCompactOpen subset -> IsOpen subset
  compactOpen_is_compact :
    ∀ ⦃subset : Set K⦄, isCompactOpen subset -> IsCompact subset
  compactOpen_inter :
    ∀ ⦃left right : Set K⦄,
      isCompactOpen left -> isCompactOpen right -> isCompactOpen (left ∩ right)
  ringOfIntegers : Set K
  compactOpenSubset : Set K
  uniformizerScale : Set K -> Set K
  ringOfIntegers_compactOpen :
    isCompactOpen ringOfIntegers
  compactOpenSubset_compactOpen :
    isCompactOpen compactOpenSubset
  uniformizerScale_preserves_compactOpen :
    ∀ subset : Set K, isCompactOpen subset ->
      isCompactOpen (uniformizerScale subset)
  ringOfIntegers_measure_one :
    (haarMeasure ringOfIntegers).toReal = 1
  compactOpenSubset_measure_pos :
    0 < (haarMeasure compactOpenSubset).toReal
  uniformizerScaled_measure_toReal_eq :
    (haarMeasure (uniformizerScale compactOpenSubset)).toReal =
      (haarMeasure compactOpenSubset).toReal /
        (residuePrime : Real) ^ finiteExtensionDegree
  hull_logVolume_eq_normalized :
    ∀ subset : Set K,
      hullSystem.logVolume (realizedRegion subset) =
        Real.log ((haarMeasure subset).toReal) /
          (finiteExtensionDegree : Real)

namespace IUTStage1AdditiveHaarCompactOpenNormalizationSource

variable {α : Type u} {η : Type v} {K : Type w}
variable [TopologicalSpace K] [MeasurableSpace K] [AddGroup K]
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

def rawHaarMeasure
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem)
    (subset : Set K) :
    Real :=
  (data.haarMeasure subset).toReal

noncomputable def rawHaarLogVolume
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem)
    (subset : Set K) :
    Real :=
  Real.log (data.rawHaarMeasure subset)

noncomputable def normalizedHaarLogVolume
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem)
    (subset : Set K) :
    Real :=
  data.rawHaarLogVolume subset / (data.finiteExtensionDegree : Real)

def uniformizerScaledSubset
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    Set K :=
  data.uniformizerScale data.compactOpenSubset

theorem uniformizerScaledSubset_compactOpen
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    data.isCompactOpen data.uniformizerScaledSubset :=
  data.uniformizerScale_preserves_compactOpen
    data.compactOpenSubset data.compactOpenSubset_compactOpen

theorem residuePrime_real_pos
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    0 < (data.residuePrime : Real) := by
  exact_mod_cast data.residue_prime.pos

theorem finiteExtensionDegree_real_ne_zero
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    (data.finiteExtensionDegree : Real) ≠ 0 := by
  exact_mod_cast Nat.ne_of_gt data.finite_extension_degree_pos

theorem uniformizerScaled_rawHaarLogVolume_eq
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    data.rawHaarLogVolume data.uniformizerScaledSubset =
      data.rawHaarLogVolume data.compactOpenSubset -
        (data.finiteExtensionDegree : Real) *
          Real.log (data.residuePrime : Real) := by
  have hmeasure_ne :
      data.rawHaarMeasure data.compactOpenSubset ≠ 0 :=
    data.compactOpenSubset_measure_pos.ne'
  have hprime_ne :
      (data.residuePrime : Real) ^ data.finiteExtensionDegree ≠ 0 :=
    pow_ne_zero _ (data.residuePrime_real_pos.ne')
  calc
    data.rawHaarLogVolume data.uniformizerScaledSubset =
        Real.log
          (data.rawHaarMeasure data.compactOpenSubset /
            (data.residuePrime : Real) ^ data.finiteExtensionDegree) := by
      simp [rawHaarLogVolume, rawHaarMeasure, uniformizerScaledSubset,
        data.uniformizerScaled_measure_toReal_eq]
    _ = data.rawHaarLogVolume data.compactOpenSubset -
        Real.log ((data.residuePrime : Real) ^ data.finiteExtensionDegree) := by
      rw [Real.log_div hmeasure_ne hprime_ne]
      rfl
    _ = data.rawHaarLogVolume data.compactOpenSubset -
        (data.finiteExtensionDegree : Real) *
          Real.log (data.residuePrime : Real) := by
      rw [Real.log_pow]

theorem ringOfIntegers_normalizedHaarLogVolume_zero
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    data.normalizedHaarLogVolume data.ringOfIntegers = 0 := by
  simp [normalizedHaarLogVolume, rawHaarLogVolume, rawHaarMeasure,
    data.ringOfIntegers_measure_one]

theorem uniformizerScaled_normalizedHaarLogVolume_eq
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    data.normalizedHaarLogVolume data.uniformizerScaledSubset =
      data.normalizedHaarLogVolume data.compactOpenSubset -
        Real.log (data.residuePrime : Real) := by
  have hdegree_ne := data.finiteExtensionDegree_real_ne_zero
  rw [normalizedHaarLogVolume, normalizedHaarLogVolume,
    data.uniformizerScaled_rawHaarLogVolume_eq]
  field_simp [hdegree_ne]

noncomputable def toCompactOpenTopologyHaarNormalizationSource
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource
      α η K hullSystem :=
  { localRing := data.localRing,
    residuePrime := data.residuePrime,
    residue_prime := data.residue_prime,
    finiteExtensionDegree := data.finiteExtensionDegree,
    finite_extension_degree_pos := data.finite_extension_degree_pos,
    realization := data.realization,
    realizedRegion := data.realizedRegion,
    realizedRegion_eq_image := data.realizedRegion_eq_image,
    isCompactOpen := data.isCompactOpen,
    compactOpen_inter := data.compactOpen_inter,
    ringOfIntegers := data.ringOfIntegers,
    compactOpenSubset := data.compactOpenSubset,
    uniformizerScale := data.uniformizerScale,
    ringOfIntegers_compactOpen := data.ringOfIntegers_compactOpen,
    compactOpenSubset_compactOpen := data.compactOpenSubset_compactOpen,
    uniformizerScale_preserves_compactOpen :=
      data.uniformizerScale_preserves_compactOpen,
    rawHaarMeasure := data.rawHaarMeasure,
    rawHaarLogVolume := data.rawHaarLogVolume,
    normalizedHaarLogVolume := data.normalizedHaarLogVolume,
    rawHaarLogVolume_eq_measure_log := by
      intro subset _hcompact
      rfl,
    normalizedHaarLogVolume_eq_degree := by
      intro subset
      rfl,
    hull_logVolume_eq_normalized := by
      intro subset
      simpa [normalizedHaarLogVolume, rawHaarLogVolume, rawHaarMeasure] using
        data.hull_logVolume_eq_normalized subset,
    ringOfIntegers_normalized_zero :=
      data.ringOfIntegers_normalizedHaarLogVolume_zero,
    uniformizerScaled_normalized_eq := by
      simpa [uniformizerScaledSubset] using
        data.uniformizerScaled_normalizedHaarLogVolume_eq }

theorem endpoint
    (data :
      IUTStage1AdditiveHaarCompactOpenNormalizationSource
        α η K hullSystem) :
    IsOpen data.ringOfIntegers ∧
      IsCompact data.ringOfIntegers ∧
      IsOpen data.compactOpenSubset ∧
      IsCompact data.compactOpenSubset ∧
      data.isCompactOpen data.uniformizerScaledSubset ∧
      data.rawHaarMeasure data.ringOfIntegers = 1 ∧
      0 < data.rawHaarMeasure data.compactOpenSubset ∧
      data.rawHaarLogVolume data.uniformizerScaledSubset =
        data.rawHaarLogVolume data.compactOpenSubset -
          (data.finiteExtensionDegree : Real) *
            Real.log (data.residuePrime : Real) ∧
      data.normalizedHaarLogVolume data.ringOfIntegers = 0 ∧
      data.normalizedHaarLogVolume data.uniformizerScaledSubset =
        data.normalizedHaarLogVolume data.compactOpenSubset -
          Real.log (data.residuePrime : Real) ∧
      ((data.toCompactOpenTopologyHaarNormalizationSource)
        |>.toFiniteExtensionHaarCompactOpenLogVolumeSource
        |>.toNonarchimedeanLocalCompactOpenLogVolumeSource).compactOpenRegion =
        data.realizedRegion data.compactOpenSubset :=
  ⟨data.compactOpen_is_open data.ringOfIntegers_compactOpen,
    data.compactOpen_is_compact data.ringOfIntegers_compactOpen,
    data.compactOpen_is_open data.compactOpenSubset_compactOpen,
    data.compactOpen_is_compact data.compactOpenSubset_compactOpen,
    data.uniformizerScaledSubset_compactOpen,
    data.ringOfIntegers_measure_one,
    data.compactOpenSubset_measure_pos,
    data.uniformizerScaled_rawHaarLogVolume_eq,
    data.ringOfIntegers_normalizedHaarLogVolume_zero,
    data.uniformizerScaled_normalizedHaarLogVolume_eq,
    rfl⟩

end IUTStage1AdditiveHaarCompactOpenNormalizationSource

/--
Additive-Haar construction of a compact-open norm-square localized arithmetic
vector bundle.

This lowers the compact-open norm-square source by deriving each local tensor
factor from an additive Haar compact-open normalization source.  The
nonnegativity required to take square roots is no longer a standalone field on
the tensor factor: it follows from the concrete Haar lower bound
`1 <= μ(U).toReal`, since the normalized local log-volume is
`log(μ(U).toReal) / [K : Q_p]`.
-/
structure IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
    (α : Type u) (η : Type v) (K : Type w) (γ : Type x)
    [TopologicalSpace K] [MeasurableSpace K] [AddGroup K] [Fintype γ]
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  localRing : η
  additiveHaarFactor :
    γ -> IUTStage1AdditiveHaarCompactOpenNormalizationSource
      α η K hullSystem
  factor_localRing_eq :
    ∀ summand : γ, (additiveHaarFactor summand).localRing = localRing
  compactOpenMeasure_ge_one :
    ∀ summand : γ,
      1 <=
        ((additiveHaarFactor summand).haarMeasure
          (additiveHaarFactor summand).compactOpenSubset).toReal
  rank_gt_one : 1 < Fintype.card γ

namespace IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource

variable {α : Type u} {η : Type v} {K : Type w} {γ : Type x}
variable [TopologicalSpace K] [MeasurableSpace K] [AddGroup K] [Fintype γ]
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

noncomputable def compactOpenTensorFactor
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem)
    (summand : γ) :
    IUTStage1LocalCompactOpenTensorFactorSource α η hullSystem :=
  (data.additiveHaarFactor summand).toCompactOpenTopologyHaarNormalizationSource
    |>.toFiniteExtensionHaarCompactOpenLogVolumeSource
    |>.toNonarchimedeanLocalCompactOpenLogVolumeSource
    |>.toLocalCompactOpenTensorFactorSource

theorem compactOpenTensorFactor_normalizedLogVolume_nonneg
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem)
    (summand : γ) :
    0 <= (data.compactOpenTensorFactor summand).normalizedLogVolume := by
  dsimp [compactOpenTensorFactor,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.toCompactOpenTopologyHaarNormalizationSource,
    IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource.toFiniteExtensionHaarCompactOpenLogVolumeSource,
    IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource.toNonarchimedeanLocalCompactOpenLogVolumeSource,
    IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource.toLocalCompactOpenTensorFactorSource,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.normalizedHaarLogVolume,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.rawHaarLogVolume,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.rawHaarMeasure]
  exact div_nonneg
    (Real.log_nonneg (data.compactOpenMeasure_ge_one summand))
    (by
      exact_mod_cast
        Nat.zero_le
          (data.additiveHaarFactor summand).finiteExtensionDegree)

theorem additiveHaarFactor_normalizedHaarLogVolume_pos_of_measure_gt_one
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem)
    (summand : γ)
    (hmeasure :
      1 <
        ((data.additiveHaarFactor summand).haarMeasure
          (data.additiveHaarFactor summand).compactOpenSubset).toReal) :
    0 <
      (data.additiveHaarFactor summand).normalizedHaarLogVolume
        (data.additiveHaarFactor summand).compactOpenSubset := by
  dsimp [
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.normalizedHaarLogVolume,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.rawHaarLogVolume,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.rawHaarMeasure]
  exact div_pos
    (Real.log_pos hmeasure)
    (by
      exact_mod_cast
        (data.additiveHaarFactor summand).finite_extension_degree_pos)

theorem compactOpenTensorFactor_normalizedLogVolume_pos_of_measure_gt_one
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem)
    (summand : γ)
    (hmeasure :
      1 <
        ((data.additiveHaarFactor summand).haarMeasure
          (data.additiveHaarFactor summand).compactOpenSubset).toReal) :
    0 < (data.compactOpenTensorFactor summand).normalizedLogVolume := by
  dsimp [compactOpenTensorFactor,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.toCompactOpenTopologyHaarNormalizationSource,
    IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource.toFiniteExtensionHaarCompactOpenLogVolumeSource,
    IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource.toNonarchimedeanLocalCompactOpenLogVolumeSource,
    IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource.toLocalCompactOpenTensorFactorSource]
  exact data.additiveHaarFactor_normalizedHaarLogVolume_pos_of_measure_gt_one
    summand hmeasure

noncomputable def toCompactOpenNormSquareLocalizedVectorBundleSource
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem) :
    IUTStage1CompactOpenNormSquareLocalizedVectorBundleSource
      α η γ hullSystem :=
  { localRing := data.localRing,
    factor := data.compactOpenTensorFactor,
    factor_localRing_eq := by
      intro summand
      simpa [compactOpenTensorFactor,
        IUTStage1AdditiveHaarCompactOpenNormalizationSource.toCompactOpenTopologyHaarNormalizationSource,
        IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource.toFiniteExtensionHaarCompactOpenLogVolumeSource,
        IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource.toNonarchimedeanLocalCompactOpenLogVolumeSource,
        IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource.toLocalCompactOpenTensorFactorSource] using
        data.factor_localRing_eq summand,
    normalizedLogVolume_nonneg :=
      data.compactOpenTensorFactor_normalizedLogVolume_nonneg,
    rank_gt_one := data.rank_gt_one }

set_option linter.style.longLine false in
theorem projected_directSummandLogVolume_eq_additiveHaarNormalized
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem)
    (summand : γ) :
    data.toCompactOpenNormSquareLocalizedVectorBundleSource.toNormSquareLocalizedArithmeticVectorBundle.toLocalizedArithmeticVectorBundle.directSummandLogVolume
        summand =
      (data.additiveHaarFactor summand).normalizedHaarLogVolume
        (data.additiveHaarFactor summand).compactOpenSubset := by
  simpa [toCompactOpenNormSquareLocalizedVectorBundleSource,
    compactOpenTensorFactor,
    IUTStage1AdditiveHaarCompactOpenNormalizationSource.toCompactOpenTopologyHaarNormalizationSource,
    IUTStage1FiniteExtensionCompactOpenTopologyHaarNormalizationSource.toFiniteExtensionHaarCompactOpenLogVolumeSource,
    IUTStage1FiniteExtensionHaarCompactOpenLogVolumeSource.toNonarchimedeanLocalCompactOpenLogVolumeSource,
    IUTStage1NonarchimedeanLocalCompactOpenLogVolumeSource.toLocalCompactOpenTensorFactorSource] using
    data.toCompactOpenNormSquareLocalizedVectorBundleSource
      |>.projected_directSummandLogVolume_eq_normalizedLogVolume summand

set_option linter.style.longLine false in
theorem endpoint
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
        α η K γ hullSystem) :
    (∀ summand : γ,
      1 <=
        ((data.additiveHaarFactor summand).haarMeasure
          (data.additiveHaarFactor summand).compactOpenSubset).toReal) ∧
      (∀ summand : γ,
        0 <= (data.compactOpenTensorFactor summand).normalizedLogVolume) ∧
      (∀ summand : γ,
        data.toCompactOpenNormSquareLocalizedVectorBundleSource.toNormSquareLocalizedArithmeticVectorBundle.toLocalizedArithmeticVectorBundle.directSummandLogVolume
            summand =
          (data.additiveHaarFactor summand).normalizedHaarLogVolume
            (data.additiveHaarFactor summand).compactOpenSubset) ∧
      data.toCompactOpenNormSquareLocalizedVectorBundleSource.localRing =
        data.localRing :=
  ⟨data.compactOpenMeasure_ge_one,
    data.compactOpenTensorFactor_normalizedLogVolume_nonneg,
    data.projected_directSummandLogVolume_eq_additiveHaarNormalized,
    rfl⟩

end IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource

set_option linter.style.longLine false in
/--
Structure-sheaf-adjusted compact-open norm-square localized vector-bundle source
constructed from additive Haar compact-open factors.
-/
structure IUTStage1AdditiveHaarCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource
    (α : Type u) (η : Type v) (K : Type w) (γ : Type x)
    [TopologicalSpace K] [MeasurableSpace K] [AddGroup K] [Fintype γ]
    (hullSystem : IUTStage1Remark395HolomorphicHullSystem α) where
  bundle :
    IUTStage1AdditiveHaarCompactOpenNormSquareLocalizedVectorBundleSource
      α η K γ hullSystem
  structureSheafLogVolume : Real
  adjustedRawLogVolume : Real
  adjusted_raw_eq_additiveHaar :
    adjustedRawLogVolume =
      (Finset.univ.sum fun summand : γ =>
        (bundle.additiveHaarFactor summand).normalizedHaarLogVolume
          (bundle.additiveHaarFactor summand).compactOpenSubset) -
        structureSheafLogVolume
  weight : Nat
  weight_pos : 0 < weight

namespace IUTStage1AdditiveHaarCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource

variable {α : Type u} {η : Type v} {K : Type w} {γ : Type x}
variable [TopologicalSpace K] [MeasurableSpace K] [AddGroup K] [Fintype γ]
variable {hullSystem : IUTStage1Remark395HolomorphicHullSystem α}

noncomputable def toCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource
        α η K γ hullSystem) :
    IUTStage1CompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource
      α η γ hullSystem :=
  { bundle := data.bundle.toCompactOpenNormSquareLocalizedVectorBundleSource,
    structureSheafLogVolume := data.structureSheafLogVolume,
    adjustedRawLogVolume := data.adjustedRawLogVolume,
    adjusted_raw_eq_compactOpen := by
      calc
        data.adjustedRawLogVolume =
            (Finset.univ.sum fun summand : γ =>
              (data.bundle.additiveHaarFactor summand).normalizedHaarLogVolume
                (data.bundle.additiveHaarFactor summand).compactOpenSubset) -
              data.structureSheafLogVolume :=
          data.adjusted_raw_eq_additiveHaar
        _ =
            (Finset.univ.sum fun summand : γ =>
              ((data.bundle.toCompactOpenNormSquareLocalizedVectorBundleSource).factor
                  summand).normalizedLogVolume) -
              data.structureSheafLogVolume := by
          rfl,
    weight := data.weight,
    weight_pos := data.weight_pos }

set_option linter.style.longLine false in
theorem projected_adjustedRawLogVolume_eq_additiveHaar
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource
        α η K γ hullSystem) :
    data.toCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource.toNormSquareStructureSheafAdjustedLocalizedVectorBundleSource.toStructureSheafAdjustedLocalizedVectorBundleSource.adjustedRawLogVolume =
      (Finset.univ.sum fun summand : γ =>
        (data.bundle.additiveHaarFactor summand).normalizedHaarLogVolume
          (data.bundle.additiveHaarFactor summand).compactOpenSubset) -
        data.structureSheafLogVolume :=
  data.adjusted_raw_eq_additiveHaar

set_option linter.style.longLine false in
theorem endpoint
    (data :
      IUTStage1AdditiveHaarCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource
        α η K γ hullSystem) :
    (∀ summand : γ,
      0 <= (data.bundle.compactOpenTensorFactor summand).normalizedLogVolume) ∧
      data.toCompactOpenNormSquareStructureSheafAdjustedLocalizedVectorBundleSource.toNormSquareStructureSheafAdjustedLocalizedVectorBundleSource.toStructureSheafAdjustedLocalizedVectorBundleSource.adjustedRawLogVolume =
        (Finset.univ.sum fun summand : γ =>
          (data.bundle.additiveHaarFactor summand).normalizedHaarLogVolume
