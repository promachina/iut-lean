  basePrimeImageSubmodule_toAddSubgroup :
    letI := integerResidueModule
    basePrimeImageSubmodule.toAddSubgroup =
      (integerSource.integerAddSubgroup.map
        (IUTStage1PadicFiniteExtensionBasePrimeDilationAddMonoidHom p K)
