  realization : ℚ_[p] -> α
  realizedRegion : Set ℚ_[p] -> Set α
  realizedRegion_eq_image :
    ∀ subset : Set ℚ_[p], realizedRegion subset = realization '' subset
  compactOpenRadius : Real
  compactOpenRadius_pos : 0 < compactOpenRadius
