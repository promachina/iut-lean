omit [MeasurableSpace ℚ_[p]] [BorelSpace ℚ_[p]]
  [LocallyCompactSpace ℚ_[p]] [IsTopologicalAddGroup ℚ_[p]] in
theorem basePrime_real_inv_le_one :
