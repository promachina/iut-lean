    (data : IUTStage1Remark395Ob3Ob4AdjustedDeterminantSource β γ) :
    data.normalizedDeterminantLogVolume = data.determinantLogVolume :=
  data.toWeightedDeterminantSource.normalizedLogVolume_eq_determinantLogVolume

