theorem hullApproximantUpperRay_qPilot_le_theta
    {α : Type u}
    {hullData : IUTStage1HolomorphicHullLogVolumeShadow α}
    {region : Set α}
    (approximant : IUTStage1HullLogVolumeApproximant hullData region)
