theorem gaussianDegree_subordinate_sum_unitAction_eq
    (evaluation : GaussianMonoidDegreeEvaluation l)
    (a : (ZMod l.value)ˣ) :
    (@Finset.filter (IUTStage1ZModCuspFullLabel l)
