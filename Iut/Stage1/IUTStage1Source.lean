    tensor.tensorPowerLogVolume < finite.thetaRealLogVolume ∧
      tensor.tensorPowerUpperRay ⊆ finite.upperRayData.upperRay ∧
      finite.thetaRealLogVolume ∉ tensor.tensorPowerUpperRay := by
