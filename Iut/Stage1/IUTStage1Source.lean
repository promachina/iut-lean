    intro calibration
    exact ⟨rfl, rfl, rfl⟩

theorem ofZModLabelledProcessionEntryTargetAndThetaTarget_endpoint
    {l : PrimeGeFive}
    (labelledAverage :
      IUTStage1ZModLabelledCapsuleFamilyLogVolume
        l IUTStage1PlaceKind.nonarchimedean)
