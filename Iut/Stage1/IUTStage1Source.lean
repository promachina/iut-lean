      (Classical.decPred _) Finset.univ).sum evaluation.gaussianDegree =
      Finset.univ.sum fun label : Fin (absLabelProcessionTop l) =>
        evaluation.gaussianDegree (absNonzeroLabelFromIndex l label) := by
