theorem environmentDegree_eq_zero_of_normalizedActedLogVolume_eq_packetNormalized
    (action : LGPSplittingMonoidTensorPacketAction l)
    (hfixed :
      action.normalizedActedLogVolume =
        action.packet.normalizedLogVolume) :
