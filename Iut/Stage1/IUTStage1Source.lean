        rw [data.cK_half_eq_eta_bK]

theorem h_bound_before_epsilon_endpoint
    (data : IUTStage1IUTIVCorollary22HBoundBeforeEpsilonShadow) :
    data.h = data.logQAll ∧
      1 <= data.delta ∧
      0 <= data.sqrtH * data.logTwoDeltaH ∧
      data.cK = 40 * data.etaPrm + 2 * data.bK ∧
