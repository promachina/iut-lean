      IUTStage1HodgeSHEIPLHullRouteLogVolumeAlignment
        part audited record X C) :
    alignment.targetSynchronizedLogVolume =
      part.toThetaCuspClassContainerAudit.theta_source.compatible_average.cuspLogVolume
