    _ =
        (part.theta_source.compatible_average.cuspLogVolume audited).cuspClassLogVolume
          (zmodCanonicalSignLabelQuotient l) := by
      rw [zmodSignLabelFromCoordinate_one_eq_canonical]
    _ = (part.cuspClassLocalObject audited
