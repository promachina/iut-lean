namespace IUTStage1IUTIVFinalErrorAbsorptionShadow

theorem finalError_le_ten
    (data : IUTStage1IUTIVFinalErrorAbsorptionShadow) :
    2 * data.logL + 74 + (20 / 3 : Real) * data.primeProductLogTerm <=
      10 * data.eEta := by
  have hprimeScaled :
