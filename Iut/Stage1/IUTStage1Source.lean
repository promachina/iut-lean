        (20 / 3 : Real) * ((4 / 3 : Real) * data.eEta) := by
    exact mul_le_mul_of_nonneg_left data.primeProduct_bound (by norm_num)
  nlinarith [data.log_error_bound, hprimeScaled, data.eEta_nonneg]

