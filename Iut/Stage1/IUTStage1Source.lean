  constructor
  · intro hpres
    exact
      ⟨evaluation.zero_translation_of_unitAffine_pointwise_gaussian_preserving
          a henv hpres,
        evaluation.signSubgroup_of_unitAffine_pointwise_gaussian_preserving
          a henv hpres⟩
  · rintro ⟨ht, ha⟩ j
    subst t
