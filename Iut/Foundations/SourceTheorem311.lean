structure SourceTheorem311MultiradialAlgorithm
    {l : PrimeGeFive}
    {C : CategoryTheory.Cat.{u, u + 1}} {length : ℕ+}
    (procession : CategoryProcession C length)
    (presentation : SourceTheorem311MultiradialPresentation.{u} l) where
  functor : CategoryProcessionMemberObject C ⥤ Type u
  realizationEquiv :
    functor.obj procession.toMemberObject ≃ presentation.Realization

namespace SourceTheorem311MultiradialAlgorithm

variable
    {l : PrimeGeFive}
    {C : CategoryTheory.Cat.{u, u + 1}} {length : ℕ+}
    {procession : CategoryProcession C length}
    {presentation : SourceTheorem311MultiradialPresentation.{u} l}

/-- Ind1 is derived from the algorithm's functorial action on processions. -/
