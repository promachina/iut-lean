            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean)
    (distinguished : Fin (label.tensorIndex + 1))
    (place :
      (lattice.siteLocalPacket algorithm n m rationalPlace label
        siteTopology).place) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer ''
        ((lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
          siteTopology hkind).distinguishedLattice distinguished place : Set _) =
      ((lattice.nonarchimedeanShells algorithm n rationalPlace label
        commonTopology hkind).distinguishedLattice distinguished
          ((lattice.verticalPacketKummerIso algorithm n m rationalPlace label
            siteTopology commonTopology).placeEquiv place) : Set _) := by
  let kummer := lattice.verticalPacketKummerIso algorithm n m rationalPlace
    label siteTopology commonTopology
  have distinguished_image :
      kummer.packetKummer ''
          ((lattice.siteLocalPacket algorithm n m rationalPlace label
            siteTopology).distinguishedSubmodule distinguished place : Set _) =
        ((lattice.localPacket algorithm n rationalPlace label commonTopology
          ).distinguishedSubmodule distinguished
            (kummer.placeEquiv place) : Set _) := by
    ext targetValue
    constructor
    · rintro ⟨sourceValue, hsource, rfl⟩
      rw [← kummer.distinguishedSubmodule_map distinguished place]
      exact ⟨sourceValue, hsource, rfl⟩
    · intro htarget
      rw [← kummer.distinguishedSubmodule_map distinguished place] at htarget
      rcases htarget with ⟨sourceValue, hsource, heq⟩
      exact ⟨sourceValue, hsource, heq⟩
  change kummer.packetKummer ''
      (((lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
        siteTopology hkind).packetLattice : Set _) ∩
        ((lattice.siteLocalPacket algorithm n m rationalPlace label
          siteTopology).distinguishedSubmodule distinguished place : Set _)) =
    (((lattice.nonarchimedeanShells algorithm n rationalPlace label
      commonTopology hkind).packetLattice : Set _) ∩
      ((lattice.localPacket algorithm n rationalPlace label commonTopology
        ).distinguishedSubmodule distinguished
          (kummer.placeEquiv place) : Set _))
  rw [Set.image_inter kummer.packetKummer.injective,
    lattice.verticalPacketLattice_image algorithm n m rationalPlace label
      siteTopology commonTopology hkind,
    distinguished_image]

