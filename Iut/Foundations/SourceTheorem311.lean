    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (siteIntegral : SitePacketIntegralConstruction lattice algorithm n m
      rationalPlace label siteTopology)
    (commonIntegral : PacketIntegralConstruction lattice algorithm n
      rationalPlace label commonTopology)
    (hkind : rationalPlace.kind = .archimedean) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer ''
        (siteIntegral.construction.fullArchimedeanRegion hkind).carrier =
      (commonIntegral.construction.fullArchimedeanRegion hkind).carrier := by
  let kummer := lattice.verticalPacketKummerIso algorithm n m rationalPlace
    label siteTopology commonTopology
  change kummer.packetKummer ''
      (siteIntegral.construction.asArchimedean hkind).packetMetric.unitBall =
    (commonIntegral.construction.asArchimedean hkind).packetMetric.unitBall
  ext targetValue
  constructor
  · rintro ⟨sourceValue, hsource, rfl⟩
    rw [SourceArchimedeanIntegralStructure.unitBall,
      Seminorm.mem_closedBall_zero] at hsource ⊢
    rwa [lattice.verticalPacketSeminorm_compatible algorithm n m rationalPlace
      label siteTopology commonTopology siteIntegral commonIntegral hkind]
  · intro htarget
    let sourceValue := kummer.packetKummer.symm targetValue
    refine ⟨sourceValue, ?_, kummer.packetKummer.apply_symm_apply targetValue⟩
    rw [SourceArchimedeanIntegralStructure.unitBall,
      Seminorm.mem_closedBall_zero] at htarget ⊢
    have hseminorm := lattice.verticalPacketSeminorm_compatible algorithm n m
      rationalPlace label siteTopology commonTopology siteIntegral commonIntegral
        hkind sourceValue
    rw [show kummer.packetKummer sourceValue = targetValue by
      exact kummer.packetKummer.apply_symm_apply targetValue] at hseminorm
    rwa [← hseminorm]

/-- Every actual distinguished archimedean region is vertically isomorphic. -/
theorem verticalDistinguishedArchimedeanIntegral_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (siteIntegral : SitePacketIntegralConstruction lattice algorithm n m
      rationalPlace label siteTopology)
    (commonIntegral : PacketIntegralConstruction lattice algorithm n
      rationalPlace label commonTopology)
    (hkind : rationalPlace.kind = .archimedean)
    (distinguished : Fin (label.tensorIndex + 1))
    (place :
      (lattice.siteLocalPacket algorithm n m rationalPlace label
        siteTopology).place) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer ''
        (siteIntegral.construction.distinguishedArchimedeanRegion hkind
          distinguished place).carrier =
      (commonIntegral.construction.distinguishedArchimedeanRegion hkind
        distinguished
          ((lattice.verticalPacketKummerIso algorithm n m rationalPlace label
            siteTopology commonTopology).placeEquiv place)).carrier := by
  let kummer := lattice.verticalPacketKummerIso algorithm n m rationalPlace
    label siteTopology commonTopology
  change kummer.packetKummer ''
      (Subtype.val ''
        ((siteIntegral.construction.asArchimedean hkind).distinguishedMetric
          distinguished place).unitBall : Set _) =
    (Subtype.val ''
      ((commonIntegral.construction.asArchimedean hkind).distinguishedMetric
        distinguished (kummer.placeEquiv place)).unitBall : Set _)
  apply kummer.distinguishedUnitBall_image
    (siteIntegral.construction.asArchimedean hkind)
    (commonIntegral.construction.asArchimedean hkind)
  intro factor first second
  exact lattice.verticalFactorInner_compatible algorithm n m rationalPlace
    label siteTopology commonTopology siteIntegral commonIntegral hkind factor
      first second

/--
The full integral region is vertically isomorphic without exposing the
finite/infinite place split to downstream Theorem 3.11 constructions.
-/
theorem verticalFullIntegral_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (siteIntegral : SitePacketIntegralConstruction lattice algorithm n m
      rationalPlace label siteTopology)
    (commonIntegral : PacketIntegralConstruction lattice algorithm n
      rationalPlace label commonTopology) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer ''
        siteIntegral.construction.fullRegion.carrier =
      commonIntegral.construction.fullRegion.carrier := by
  cases rationalPlace with
  | finite place =>
      simpa only [SourcePacketIntegralConstruction.fullRegion] using
        lattice.verticalFullNonarchimedeanIntegral_image algorithm n m
          (.finite place) label siteTopology commonTopology siteIntegral
            commonIntegral rfl
  | infinite place =>
      simpa only [SourcePacketIntegralConstruction.fullRegion] using
        lattice.verticalFullArchimedeanIntegral_image algorithm n m
          (.infinite place) label siteTopology commonTopology siteIntegral
            commonIntegral rfl

/-- Every distinguished integral region is vertically isomorphic at any place. -/
theorem verticalDistinguishedIntegral_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (siteIntegral : SitePacketIntegralConstruction lattice algorithm n m
      rationalPlace label siteTopology)
    (commonIntegral : PacketIntegralConstruction lattice algorithm n
      rationalPlace label commonTopology)
    (distinguished : Fin (label.tensorIndex + 1))
    (place :
      (lattice.siteLocalPacket algorithm n m rationalPlace label
        siteTopology).place) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer ''
        (siteIntegral.construction.distinguishedRegion distinguished place).carrier =
      (commonIntegral.construction.distinguishedRegion distinguished
        ((lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          siteTopology commonTopology).placeEquiv place)).carrier := by
  cases rationalPlace with
  | finite rationalPlace =>
      simpa only [SourcePacketIntegralConstruction.distinguishedRegion,
        SourcePacketIntegralConstruction.asNonarchimedean] using
        lattice.verticalDistinguishedNonarchimedeanIntegral_image algorithm n m
          (.finite rationalPlace) label siteTopology commonTopology siteIntegral
            commonIntegral rfl distinguished place
  | infinite rationalPlace =>
      simpa only [SourcePacketIntegralConstruction.distinguishedRegion,
        SourcePacketIntegralConstruction.asArchimedean] using
        lattice.verticalDistinguishedArchimedeanIntegral_image algorithm n m
          (.infinite rationalPlace) label siteTopology commonTopology
            siteIntegral commonIntegral rfl distinguished place

/--
The integral constructions at every rational place and absolute label of one
non-coric lattice site `(n,m)`.
-/
structure SiteLocalConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) where
  topology :
    ∀ (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace)
  integral :
    ∀ (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      SitePacketIntegralConstruction lattice algorithm n m rationalPlace label
        (topology rationalPlace label)

namespace SiteLocalConstruction

/-- A concrete non-coric lattice site supplies the earlier local-data API. -/
noncomputable def toTheorem311LocalData
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n m : ℤ}
    (construction : SiteLocalConstruction lattice algorithm n m) :
    SourceTheorem311LocalData.{u} theta.l where
  placeAbove := fun rationalPlace =>
    SourceSelectedPlaceAbove theta rationalPlace
  packet rationalPlace label :=
    lattice.siteLocalPacket algorithm n m rationalPlace label
      (construction.topology rationalPlace label)
  packet_rationalPlace _ _ := rfl
  packetPlaceEquiv _ _ := Equiv.refl _
  integralConstruction rationalPlace label :=
    (construction.integral rationalPlace label).construction
  normalizedLogVolume rationalPlace label :=
    (construction.integral rationalPlace label).logVolumeDecomposition
      |>.toNormalizedLogVolume
  normalizedLogVolume_region _ _ := rfl

end SiteLocalConstruction

/--
One whole vertical comparison from the non-coric site `(n,m)` to the fixed
`(n,circle)` construction.  The radial product-measure square is required for
every rational place and every absolute label.
-/
structure VerticalLocalConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) where
  common : LocalConstruction lattice algorithm n
  site : SiteLocalConstruction lattice algorithm n m
  logVolumeCompatible :
    ∀ rationalPlace label,
      SourcePacketLogVolumeDecomposition.Compatible
        (site.integral rationalPlace label).logVolumeDecomposition
        (common.integral rationalPlace label).logVolumeDecomposition
        (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          (site.topology rationalPlace label)
          (common.topology rationalPlace label)).packetKummer
  logVolumeCompatible_placeEquiv :
    ∀ rationalPlace label,
      (logVolumeCompatible rationalPlace label).coordinatePlaceEquiv =
        (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          (site.topology rationalPlace label)
          (common.topology rationalPlace label)).placeEquiv

namespace VerticalLocalConstruction

/-- Extract the complete packetwise comparison at one place and label. -/
noncomputable def packetComparison
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n m : ℤ}
    (construction : VerticalLocalConstruction lattice algorithm n m)
    (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :
    VerticalPacketIntegralConstruction lattice algorithm n m rationalPlace
      label (construction.site.topology rationalPlace label)
        (construction.common.topology rationalPlace label) where
  siteIntegral := construction.site.integral rationalPlace label
  commonIntegral := construction.common.integral rationalPlace label
  logVolumeCompatible := construction.logVolumeCompatible rationalPlace label
  logVolumeCompatible_placeEquiv :=
    construction.logVolumeCompatible_placeEquiv rationalPlace label

/--
The concrete lattice, shell algorithm, integral regions, and radial measures
construct the abstract vertical local-Kummer interface of Theorem 3.11(ii)(a).
-/
noncomputable def toTheorem311VerticalLocalKummer
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n m : ℤ}
    (construction : VerticalLocalConstruction lattice algorithm n m) :
    SourceTheorem311VerticalLocalKummer
      construction.site.toTheorem311LocalData
      construction.common.toTheorem311LocalData where
  rationalPlaceEquiv := Equiv.refl _
  placeKind_compatible _ := rfl
  packetKummer rationalPlace label :=
    lattice.verticalPacketKummerIso algorithm n m rationalPlace label
      (construction.site.topology rationalPlace label)
      (construction.common.topology rationalPlace label)
  fullIntegral_image rationalPlace label := by
    change
      (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          (construction.site.topology rationalPlace label)
          (construction.common.topology rationalPlace label)).packetKummer ''
          ((construction.site.integral rationalPlace label).construction
            |>.fullRegion).carrier =
        ((construction.common.integral rationalPlace label).construction
          |>.fullRegion).carrier
    exact lattice.verticalFullIntegral_image algorithm n m rationalPlace label
      (construction.site.topology rationalPlace label)
      (construction.common.topology rationalPlace label)
      (construction.site.integral rationalPlace label)
      (construction.common.integral rationalPlace label)
  distinguishedIntegral_image rationalPlace label place := by
    change
      (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          (construction.site.topology rationalPlace label)
          (construction.common.topology rationalPlace label)).packetKummer ''
          ((construction.site.integral rationalPlace label).construction
            |>.distinguishedRegion label.distinguishedFactor place).carrier =
        ((construction.common.integral rationalPlace label).construction
          |>.distinguishedRegion label.distinguishedFactor
            ((lattice.verticalPacketKummerIso algorithm n m rationalPlace label
              (construction.site.topology rationalPlace label)
              (construction.common.topology rationalPlace label)).placeEquiv
                place)).carrier
    exact lattice.verticalDistinguishedIntegral_image algorithm n m
      rationalPlace label
      (construction.site.topology rationalPlace label)
      (construction.common.topology rationalPlace label)
      (construction.site.integral rationalPlace label)
      (construction.common.integral rationalPlace label)
      label.distinguishedFactor place
  logVolumeFunctional_compatible rationalPlace label :=
    (construction.logVolumeCompatible rationalPlace label)
      |>.toNormalizedLogVolume_compatible

end VerticalLocalConstruction

/--
All vertical local constructions in one fixed `n`-column, sharing one literal
`(n,circle)` target.  Only the product-decomposition compatibility remains as
input; packet Kummer maps and integral-region maps are derived from the lattice.
-/
structure VerticalFamilyConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) where
  common : LocalConstruction lattice algorithm n
  site : ∀ m : ℤ, SiteLocalConstruction lattice algorithm n m
  logVolumeCompatible :
    ∀ m rationalPlace label,
      SourcePacketLogVolumeDecomposition.Compatible
        ((site m).integral rationalPlace label).logVolumeDecomposition
        (common.integral rationalPlace label).logVolumeDecomposition
        (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          ((site m).topology rationalPlace label)
          (common.topology rationalPlace label)).packetKummer
  logVolumeCompatible_placeEquiv :
    ∀ m rationalPlace label,
      (logVolumeCompatible m rationalPlace label).coordinatePlaceEquiv =
        (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
          ((site m).topology rationalPlace label)
          (common.topology rationalPlace label)).placeEquiv

namespace VerticalFamilyConstruction

/-- One member of the vertical family as a complete local construction. -/
noncomputable def verticalAt
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n)
    (m : ℤ) : VerticalLocalConstruction lattice algorithm n m where
  common := family.common
  site := family.site m
  logVolumeCompatible := family.logVolumeCompatible m
  logVolumeCompatible_placeEquiv :=
    family.logVolumeCompatible_placeEquiv m

/-- The actual non-coric packet at one site of the family. -/
noncomputable abbrev sourcePacket
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n)
    (m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :=
  lattice.siteLocalPacket algorithm n m rationalPlace label
    ((family.site m).topology rationalPlace label)

/-- The actual site-to-circle tensor Kummer isomorphism. -/
noncomputable abbrev packetKummer
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n)
    (m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :=
  lattice.verticalPacketKummerIso algorithm n m rationalPlace label
    ((family.site m).topology rationalPlace label)
    (family.common.topology rationalPlace label)

/-- The common local data is independent of the vertical coordinate. -/
noncomputable def commonContainer
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n) :
    SourceTheorem311CoricContainer.{u} theta.l :=
  SourceTheorem311CoricContainer.ofLocalData
    family.common.toTheorem311LocalData

/-- Every vertical member has the concrete local-Kummer comparison. -/
noncomputable def verticalLocalKummer
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n)
    (m : ℤ) :
    SourceTheorem311VerticalLocalKummer
      (family.site m).toTheorem311LocalData
      family.common.toTheorem311LocalData :=
  (family.verticalAt m).toTheorem311VerticalLocalKummer

end VerticalFamilyConstruction

/--
The still irreducible Proposition 3.5(ii)(a)-(b) input for a concrete vertical
family.  These fields concern unit groups and domains of iterated log-links;
they are deliberately separated from the additive packet Kummer maps, integral
regions, and measures already constructed above.
-/
structure VerticalUpperSemiData
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n) where
  unitInvariants :
    ∀ m rationalPlace label,
      AddSubgroup (family.sourcePacket m rationalPlace label).carrier
  radiusPiRegion :
    ∀ m rationalPlace label,
      Set (family.sourcePacket m rationalPlace label).carrier
  radiusPiRegion_is_piBall :
    ∀ m rationalPlace label,
      rationalPlace.kind = .archimedean ->
        ∃ metric : SourceArchimedeanIntegralStructure
            (family.sourcePacket m rationalPlace label).carrier,
          radiusPiRegion m rationalPlace label = metric.piBall
  nonarchLogDomain :
    ∀ (m : ℤ) (steps : ℕ+) (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      Set (family.sourcePacket (m - (steps.1 : ℤ)) rationalPlace label).carrier
  nonarchLogDomain_mem_units :
    ∀ m steps rationalPlace label value,
      value ∈ nonarchLogDomain m steps rationalPlace label ->
        value ∈ unitInvariants (m - (steps.1 : ℤ)) rationalPlace label
  nonarchLogIterate :
    ∀ m steps rationalPlace label,
      {value // value ∈ nonarchLogDomain m steps rationalPlace label} ->
        (family.sourcePacket m rationalPlace label).carrier
  nonarch_direct_contained :
    ∀ m rationalPlace label,
      rationalPlace.kind = .nonarchimedean ->
        Set.MapsTo
          (family.packetKummer m rationalPlace label).packetKummer
          (unitInvariants m rationalPlace label : Set _)
          (((family.common.integral rationalPlace label).construction
            |>.fullRegion).carrier)
  nonarch_logKummer_contained :
    ∀ m steps rationalPlace label,
      rationalPlace.kind = .nonarchimedean ->
        ∀ value,
          (family.packetKummer m rationalPlace label).packetKummer
              (nonarchLogIterate m steps rationalPlace label value) ∈
            ((family.common.integral rationalPlace label).construction
              |>.fullRegion).carrier
  arch_direct_units_contained :
    ∀ m rationalPlace label,
      rationalPlace.kind = .archimedean ->
        Set.MapsTo
          (family.packetKummer m rationalPlace label).packetKummer
          (unitInvariants m rationalPlace label : Set _)
          ((family.common.integral rationalPlace label).construction
            |>.fullRegion).carrier
  arch_direct_piBall_contained :
    ∀ m rationalPlace label,
      rationalPlace.kind = .archimedean ->
        Set.MapsTo
          (family.packetKummer m rationalPlace label).packetKummer
          (radiusPiRegion m rationalPlace label)
          ((family.common.integral rationalPlace label).construction
            |>.fullRegion).carrier
  archLogDomain :
    ∀ (m : ℤ) (steps : ℕ+) (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      Set (family.sourcePacket (m - (steps.1 : ℤ)) rationalPlace label).carrier
  archLogDomain_mem_units :
    ∀ m steps rationalPlace label value,
      value ∈ archLogDomain m steps rationalPlace label ->
        value ∈ unitInvariants (m - (steps.1 : ℤ)) rationalPlace label
  archLogPreimage :
    ∀ (m : ℤ) (steps : ℕ+) (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      Set (family.sourcePacket m rationalPlace label).carrier
  archLogPreimage_mem_piBall :
    ∀ m steps rationalPlace label,
      rationalPlace.kind = .archimedean ->
        archLogPreimage m steps rationalPlace label ⊆
          radiusPiRegion m rationalPlace label
  archLogIterate :
    ∀ m steps rationalPlace label,
      {value // value ∈ archLogPreimage m steps rationalPlace label} ->
        {value // value ∈ archLogDomain m steps rationalPlace label}
  archLogIterate_surjective :
    ∀ m steps rationalPlace label,
      rationalPlace.kind = .archimedean ->
        Function.Surjective (archLogIterate m steps rationalPlace label)

namespace VerticalFamilyConstruction

/--
Construct the Ind3 system from the lattice family and exactly the remaining
unit/log-link obligations.  Direct Kummer maps, integral images, and normalized
log-volume compatibility are not fields of `VerticalUpperSemiData`.
-/
noncomputable def toTheorem311Ind3System
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (family : VerticalFamilyConstruction lattice algorithm n)
    (upperSemi : VerticalUpperSemiData family) :
    SourceTheorem311Ind3System.{u} theta.l where
  common := family.commonContainer
  packet := family.sourcePacket
  packet_rationalPlace _ _ _ := rfl
  integralConstruction m rationalPlace label :=
    ((family.site m).integral rationalPlace label).construction
  directKummer := family.packetKummer
  directKummerIntegral_image m rationalPlace label := by
    exact lattice.verticalFullIntegral_image algorithm n m rationalPlace label
      ((family.site m).topology rationalPlace label)
      (family.common.topology rationalPlace label)
      ((family.site m).integral rationalPlace label)
      (family.common.integral rationalPlace label)
  unitInvariants := upperSemi.unitInvariants
  radiusPiRegion := upperSemi.radiusPiRegion
  radiusPiRegion_is_piBall := upperSemi.radiusPiRegion_is_piBall
  nonarchLogDomain := upperSemi.nonarchLogDomain
  nonarchLogDomain_mem_units := upperSemi.nonarchLogDomain_mem_units
  nonarchLogIterate := upperSemi.nonarchLogIterate
  nonarch_direct_contained := upperSemi.nonarch_direct_contained
  nonarch_logKummer_contained := upperSemi.nonarch_logKummer_contained
  arch_direct_units_contained := upperSemi.arch_direct_units_contained
  arch_direct_piBall_contained := upperSemi.arch_direct_piBall_contained
  archLogDomain := upperSemi.archLogDomain
  archLogDomain_mem_units := upperSemi.archLogDomain_mem_units
  archLogPreimage := upperSemi.archLogPreimage
  archLogPreimage_mem_piBall := upperSemi.archLogPreimage_mem_piBall
  archLogIterate := upperSemi.archLogIterate
  archLogIterate_surjective := upperSemi.archLogIterate_surjective
  sourceNormalizedLogVolume m rationalPlace label :=
    ((family.site m).integral rationalPlace label).logVolumeDecomposition
      |>.toNormalizedLogVolume
  sourceNormalizedLogVolume_region _ _ _ := rfl
  logVolumeFunctional_compatible m rationalPlace label :=
    (family.logVolumeCompatible m rationalPlace label)
      |>.toNormalizedLogVolume_compatible

end VerticalFamilyConstruction

/--
The exact Ind2 summand actions on one procession packet, constructed from the
source log-shell symmetries at every selected place above `v_Q`.
-/
noncomputable def localInd2Action
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) :
    SourceTheorem311Ind2Action rationalPlace.kind
      (lattice.localPacket algorithm n rationalPlace label topology) where
  symmetry factor place :=
    algorithm.ind2SymmetryAbove
      ((lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor))
      rationalPlace place
  summandAction factor place :=
    algorithm.ind2ActionAbove
      ((lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor))
      rationalPlace place
  summandAction_one factor place value :=
    algorithm.ind2ActionAbove_one
      ((lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor))
      rationalPlace place value
  summandAction_mul factor place first second value :=
    algorithm.ind2ActionAbove_mul
      ((lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor))
      rationalPlace place first second value
  archimedean_order_two hkind factor place choice :=
    algorithm.ind2SymmetryAbove_square_of_archimedean
      ((lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor))
      rationalPlace place hkind choice

