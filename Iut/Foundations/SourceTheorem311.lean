        commonTopology hkind).pureIntegralTensors := by
  let kummer := lattice.verticalPacketKummerIso algorithm n m rationalPlace
    label siteTopology commonTopology
  let siteShells := lattice.siteNonarchimedeanShells algorithm n m rationalPlace
    label siteTopology hkind
  let commonShells := lattice.nonarchimedeanShells algorithm n rationalPlace
    label commonTopology hkind
  ext tensor
  constructor
  · rintro ⟨sourceTensor, ⟨components, hintegral, rfl⟩, rfl⟩
    refine ⟨fun factor => kummer.factorKummer factor (components factor), ?_, ?_⟩
    · intro factor
      have himage : kummer.factorKummer factor (components factor) ∈
          kummer.factorKummer factor ''
            (siteShells.factorLattice factor : Set _) :=
        ⟨components factor, hintegral factor, rfl⟩
      simpa only [kummer, siteShells, commonShells,
        lattice.verticalFactorLattice_image algorithm n m rationalPlace label
          siteTopology commonTopology hkind factor] using himage
    · apply commonTopology.toPacket.tensorIso.toLinearEquiv.injective
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ components))) =
        commonTopology.toPacket.tensorIso.toLinearEquiv
          (commonTopology.toPacket.tensorIso.inv
            (PiTensorProduct.tprod ℚ
              (fun factor => kummer.factorKummer factor (components factor))))
      have htransport := kummer.packetKummer_on_tensor
        (siteTopology.toPacket.tensorIso.inv
          (PiTensorProduct.tprod ℚ components))
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ components))) =
        PiTensorProduct.congr
          (fun factor => (kummer.factorKummer factor).toLinearEquiv)
          (siteTopology.toPacket.tensorIso.toLinearEquiv
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ components))) at htransport
      calc
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (siteTopology.toPacket.tensorIso.toLinearEquiv
                (siteTopology.toPacket.tensorIso.inv
                  (PiTensorProduct.tprod ℚ components))) := htransport
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (PiTensorProduct.tprod ℚ components) := by
          exact congrArg
            (PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv))
            (siteTopology.toPacket.tensorIso.inv_hom_id_apply _)
        _ = PiTensorProduct.tprod ℚ
              (fun factor => kummer.factorKummer factor (components factor)) :=
          PiTensorProduct.congr_tprod _ components
        _ = _ := by
          exact (commonTopology.toPacket.tensorIso.inv_hom_id_apply _).symm
  · rintro ⟨components, hintegral, rfl⟩
    let sourceComponents :
        ∀ factor,
          (siteTopology.toPacket.factor factor).carrier :=
      fun factor => (kummer.factorKummer factor).symm (components factor)
    refine ⟨siteTopology.toPacket.tensorIso.inv
        (PiTensorProduct.tprod ℚ sourceComponents), ?_, ?_⟩
    · refine ⟨sourceComponents, ?_, rfl⟩
      intro factor
      have himage : components factor ∈
          kummer.factorKummer factor ''
            (siteShells.factorLattice factor : Set _) := by
        simpa only [kummer, siteShells, commonShells,
          lattice.verticalFactorLattice_image algorithm n m rationalPlace label
            siteTopology commonTopology hkind factor] using hintegral factor
      rcases himage with ⟨preimage, hpreimage, heq⟩
      have hsource : sourceComponents factor = preimage := by
        change (kummer.factorKummer factor).symm (components factor) = preimage
        rw [← heq, ContinuousLinearEquiv.symm_apply_apply]
      rwa [hsource]
    · apply commonTopology.toPacket.tensorIso.toLinearEquiv.injective
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ sourceComponents))) =
        commonTopology.toPacket.tensorIso.toLinearEquiv
          (commonTopology.toPacket.tensorIso.inv
            (PiTensorProduct.tprod ℚ components))
      have htransport := kummer.packetKummer_on_tensor
        (siteTopology.toPacket.tensorIso.inv
          (PiTensorProduct.tprod ℚ sourceComponents))
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ sourceComponents))) =
        PiTensorProduct.congr
          (fun factor => (kummer.factorKummer factor).toLinearEquiv)
          (siteTopology.toPacket.tensorIso.toLinearEquiv
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ sourceComponents))) at htransport
      calc
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (siteTopology.toPacket.tensorIso.toLinearEquiv
                (siteTopology.toPacket.tensorIso.inv
                  (PiTensorProduct.tprod ℚ sourceComponents))) := htransport
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (PiTensorProduct.tprod ℚ sourceComponents) := by
          exact congrArg
            (PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv))
            (siteTopology.toPacket.tensorIso.inv_hom_id_apply _)
        _ = PiTensorProduct.tprod ℚ
              (fun factor => kummer.factorKummer factor
                (sourceComponents factor)) :=
          PiTensorProduct.congr_tprod _ sourceComponents
        _ = PiTensorProduct.tprod ℚ components := by
          congr 1
          funext factor
          exact (kummer.factorKummer factor).apply_symm_apply
            (components factor)
        _ = _ := by
          exact (commonTopology.toPacket.tensorIso.inv_hom_id_apply _).symm

