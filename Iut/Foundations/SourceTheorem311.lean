/-!
# Source objects for IUT III, Theorem 3.11

This module starts the source-faithful formalization of the local objects and
indeterminacies in IUT III, Proposition 3.2 and Theorem 3.11(i).  A local
packet is an actual finite indexed tensor product of actual place-indexed
direct sums.  Its topology and its algebraic rational-module structure are
retained separately: at a finite place, the usual real topology on `ℚ` does
not make scalar multiplication on a `p`-adic module continuous.

The quotient below is generated by the two actions in the paper: procession
automorphisms (Ind1) and independent direct-summand actions (Ind2).  It is not
a finite translation or degree quotient.
-/

open CategoryTheory
open scoped DirectSum TensorProduct Pointwise
open scoped NumberField.LiesOver WithZero

namespace Iut

universe u v w

/-- The two kinds of rational places distinguished in Proposition 3.2(ii). -/
inductive SourceRationalPlaceKind
  | nonarchimedean
  | archimedean
  deriving DecidableEq

/-- The literal set `V_Q = V(ℚ)` of finite and archimedean rational places. -/
abbrev SourceRationalPlace := ThetaPlace ℚ

namespace SourceRationalPlace

/-- The completed local field `ℚ_(v_Q)` attached to a rational place. -/
abbrev Completion : SourceRationalPlace -> Type
  | .finite place => ThetaFinitePlace.Completion place
  | .infinite place => ThetaInfinitePlace.Completion place

noncomputable instance completionNormedField :
    (place : SourceRationalPlace) -> NormedField place.Completion
  | .finite _ => inferInstance
  | .infinite _ => inferInstance

noncomputable instance completionCompleteSpace :
    (place : SourceRationalPlace) -> CompleteSpace place.Completion
  | .finite _ => inferInstance
  | .infinite _ => inferInstance

noncomputable instance completionAlgebra :
    (place : SourceRationalPlace) -> Algebra ℚ place.Completion
  | .finite _ => inferInstance
  | .infinite _ => inferInstance

/-- The finite/archimedean dichotomy is derived from the rational place. -/
def kind : SourceRationalPlace -> SourceRationalPlaceKind
  | .finite _ => .nonarchimedean
  | .infinite _ => .archimedean

/-- The rational residue prime determined by a nonarchimedean rational place. -/
noncomputable def residuePrime
    (place : SourceRationalPlace)
    (hkind : place.kind = .nonarchimedean) : ℕ :=
  match place with
  | .finite finitePlace =>
      Rat.HeightOneSpectrum.natGenerator
        (ThetaFinitePlace.underlyingPrime finitePlace)
  | .infinite _ => nomatch hkind

theorem residuePrime_prime
    (place : SourceRationalPlace)
    (hkind : place.kind = .nonarchimedean) :
    Nat.Prime (place.residuePrime hkind) := by
  cases place with
  | finite finitePlace =>
      exact Rat.HeightOneSpectrum.prime_natGenerator
        (ThetaFinitePlace.underlyingPrime finitePlace)
  | infinite _ => exact nomatch hkind

end SourceRationalPlace

namespace ThetaPlace

/-- Restriction of a number-field place to its rational place. -/
noncomputable def toRational
    {K : Type u} [Field K] [NumberField K]
    (place : ThetaPlace K) : SourceRationalPlace :=
  match place with
  | .finite finitePlace =>
      .finite (ThetaFinitePlace.comap finitePlace)
  | .infinite infinitePlace =>
      .infinite (infinitePlace.comap (algebraMap ℚ K))

end ThetaPlace

/-- The literal selected set `V ⊆ V(K)` supplied by initial theta data. -/
def SourceSelectedPlace
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) :=
  {place : ThetaPlace K | place ∈ theta.valuations.selectedPlaces}

/-- The actual finite fiber `{v ∈ V | v | v_Q}` of selected places. -/
def SourceSelectedPlaceAbove
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K)
    (rationalPlace : SourceRationalPlace) :=
  {place : SourceSelectedPlace theta |
    place.1.toRational = rationalPlace}

/-- The literal bad-place subset `Vbad` of the selected finite places. -/
def SourceSelectedBadPlace
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) :=
  {place : NumberField.FinitePlace K | place ∈ theta.valuations.bad}

/-- Arithmetic finiteness of the set of bad reduction places. -/
class SourceSelectedBadPlaceFiniteness
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) where
  [badPlaceFintype : Fintype (SourceSelectedBadPlace theta)]

attribute [implicit_reducible, instance]
  SourceSelectedBadPlaceFiniteness.badPlaceFintype

namespace SourceSelectedBadPlace

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}

/-- A bad place is canonically one of the selected places `V`. -/
def toSelected (place : SourceSelectedBadPlace theta) :
    SourceSelectedPlace theta :=
  ⟨ThetaPlace.finite place.1,
    (theta.valuations.finite_mem_selectedPlaces_iff place.1).mpr place.2.1⟩

/-- Its rational place is the restriction of that selected place to `Q`. -/
noncomputable def rationalPlace (place : SourceSelectedBadPlace theta) :
    SourceRationalPlace :=
  (toSelected place).1.toRational

/-- The canonical proof that the bad place lies above its rational place. -/
noncomputable def toAbove (place : SourceSelectedBadPlace theta) :
    SourceSelectedPlaceAbove theta (rationalPlace place) :=
  ⟨toSelected place, rfl⟩

end SourceSelectedBadPlace

