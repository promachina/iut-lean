/-!
# Source objects for IUT III, Theorem 3.11

This module starts the source-faithful formalization of the local objects and
indeterminacies in IUT III, Proposition 3.2 and Theorem 3.11(i).  A local
packet is an actual finite indexed tensor product of actual place-indexed
direct sums.  Its topology and its algebraic rational-module structure are
retained separately: at a finite place, the usual real topology on `ℚ` does
not make scalar multiplication on a `p`-adic module continuous.

The quotient below is generated by the two actions in the paper: procession
automorphisms (Ind1) and independent direct-summand actions (Ind2).  It is not
a finite translation or degree quotient.
-/

open CategoryTheory
open scoped DirectSum TensorProduct
open scoped NumberField.LiesOver

namespace Iut

universe u v w

/-- The two kinds of rational places distinguished in Proposition 3.2(ii). -/
inductive SourceRationalPlaceKind
  | nonarchimedean
  | archimedean
  deriving DecidableEq

/-- The literal set `V_Q = V(ℚ)` of finite and archimedean rational places. -/
abbrev SourceRationalPlace := ThetaPlace ℚ

namespace SourceRationalPlace

/-- The completed local field `ℚ_(v_Q)` attached to a rational place. -/
abbrev Completion : SourceRationalPlace -> Type
  | .finite place => ThetaFinitePlace.Completion place
  | .infinite place => ThetaInfinitePlace.Completion place

noncomputable instance completionNormedField :
    (place : SourceRationalPlace) -> NormedField place.Completion
  | .finite _ => inferInstance
  | .infinite _ => inferInstance

noncomputable instance completionCompleteSpace :
    (place : SourceRationalPlace) -> CompleteSpace place.Completion
  | .finite _ => inferInstance
  | .infinite _ => inferInstance

noncomputable instance completionAlgebra :
    (place : SourceRationalPlace) -> Algebra ℚ place.Completion
  | .finite _ => inferInstance
  | .infinite _ => inferInstance

/-- The finite/archimedean dichotomy is derived from the rational place. -/
def kind : SourceRationalPlace -> SourceRationalPlaceKind
  | .finite _ => .nonarchimedean
  | .infinite _ => .archimedean

end SourceRationalPlace

namespace ThetaPlace

/-- Restriction of a number-field place to its rational place. -/
noncomputable def toRational
    {K : Type u} [Field K] [NumberField K]
    (place : ThetaPlace K) : SourceRationalPlace :=
  match place with
  | .finite finitePlace =>
      .finite (ThetaFinitePlace.comap finitePlace)
  | .infinite infinitePlace =>
      .infinite (infinitePlace.comap (algebraMap ℚ K))

end ThetaPlace

/-- The literal selected set `V ⊆ V(K)` supplied by initial theta data. -/
def SourceSelectedPlace
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) :=
  {place : ThetaPlace K | place ∈ theta.valuations.selectedPlaces}

/-- The actual finite fiber `{v ∈ V | v | v_Q}` of selected places. -/
def SourceSelectedPlaceAbove
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K)
    (rationalPlace : SourceRationalPlace) :=
  {place : SourceSelectedPlace theta |
    place.1.toRational = rationalPlace}

/-- The literal bad-place subset `Vbad` of the selected finite places. -/
def SourceSelectedBadPlace
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) :=
  {place : NumberField.FinitePlace K | place ∈ theta.valuations.bad}

/-- Arithmetic finiteness of the set of bad reduction places. -/
class SourceSelectedBadPlaceFiniteness
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) where
  [badPlaceFintype : Fintype (SourceSelectedBadPlace theta)]

attribute [implicit_reducible, instance]
  SourceSelectedBadPlaceFiniteness.badPlaceFintype

namespace SourceSelectedBadPlace

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}

/-- A bad place is canonically one of the selected places `V`. -/
def toSelected (place : SourceSelectedBadPlace theta) :
    SourceSelectedPlace theta :=
  ⟨ThetaPlace.finite place.1,
    (theta.valuations.finite_mem_selectedPlaces_iff place.1).mpr place.2.1⟩

/-- Its rational place is the restriction of that selected place to `Q`. -/
noncomputable def rationalPlace (place : SourceSelectedBadPlace theta) :
    SourceRationalPlace :=
  (toSelected place).1.toRational

/-- The canonical proof that the bad place lies above its rational place. -/
noncomputable def toAbove (place : SourceSelectedBadPlace theta) :
    SourceSelectedPlaceAbove theta (rationalPlace place) :=
  ⟨toSelected place, rfl⟩

end SourceSelectedBadPlace

/--
The arithmetic finiteness theorem for the fibers of `V -> V(ℚ)`.

The fiber type itself is derived above; only its finiteness proof remains an
upstream number-field obligation.
-/
class SourceSelectedPlaceFiberFiniteness
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    (theta : SourceInitialThetaCore Fmod F K) where
  [fiberFintype :
    ∀ rationalPlace,
      Fintype (SourceSelectedPlaceAbove theta rationalPlace)]

attribute [implicit_reducible, instance]
  SourceSelectedPlaceFiberFiniteness.fiberFintype

noncomputable instance sourceSelectedPlaceAboveDecidableEq
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    (rationalPlace : SourceRationalPlace) :
    DecidableEq (SourceSelectedPlaceAbove theta rationalPlace) :=
  Classical.decEq _

namespace SourceSelectedPlace

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}

/--
The source local degree `[K_v : (F_mod)_v]`.  At a finite place this is
the ramification index times the residue-field degree of the contracted prime;
at an infinite place it is the degree of the corresponding extension of
completions.
-/
noncomputable def moduliLocalDegree
    (place : SourceSelectedPlace theta) : ℕ+ :=
  match place.1 with
  | .finite finitePlace =>
      let P := finitePlace.maximalIdeal
      let p := P.asIdeal.under (NumberField.RingOfIntegers Fmod)
      ⟨p.ramificationIdx P.asIdeal * p.inertiaDeg P.asIdeal, by
        apply Nat.mul_pos
        · apply Nat.pos_iff_ne_zero.mpr
          apply Ideal.IsDedekindDomain.ramificationIdx_ne_zero_of_liesOver
          change P.asIdeal.comap
              (algebraMap (NumberField.RingOfIntegers Fmod)
                (NumberField.RingOfIntegers K)) ≠ ⊥
          exact Ideal.IsIntegral.comap_ne_bot
            (NumberField.RingOfIntegers Fmod) P.ne_bot
        · exact Ideal.inertiaDeg_pos' p P.asIdeal⟩
  | .infinite infinitePlace =>
      let basePlace :=
        infinitePlace.comap (algebraMap Fmod K)
      letI : AbsoluteValue.LiesOver infinitePlace.1 basePlace.1 := ⟨rfl⟩
      ⟨basePlace.inertiaDeg infinitePlace, by
        by_cases hunramified : infinitePlace.IsUnramified Fmod
        · rw [NumberField.InfinitePlace.inertiaDeg_eq_one
            (show infinitePlace ∈
              NumberField.InfinitePlace.unramifiedPlacesOver K basePlace from
                ⟨inferInstance, hunramified⟩)]
          exact Nat.zero_lt_one
        · rw [NumberField.InfinitePlace.inertiaDeg_eq_two
            (show infinitePlace ∈
              NumberField.InfinitePlace.ramifiedPlacesOver K basePlace from
                ⟨inferInstance, hunramified⟩)]
          exact Nat.zero_lt_succ 1⟩

/--
The second local degree in Remark 3.1.1(ii),
`[(F_mod)_v : ℚ_(v_ℚ)]`, obtained by contracting the selected `K`-place
first to `F_mod` and then to `ℚ`.
-/
noncomputable def moduliRationalLocalDegree
    (place : SourceSelectedPlace theta) : ℕ+ :=
  match place.1 with
  | .finite finitePlace =>
      let P := finitePlace.maximalIdeal
      let moduliPrime :=
        P.asIdeal.under (NumberField.RingOfIntegers Fmod)
      let rationalPrime :=
        moduliPrime.under (NumberField.RingOfIntegers ℚ)
      ⟨rationalPrime.ramificationIdx moduliPrime *
          rationalPrime.inertiaDeg moduliPrime, by
        apply Nat.mul_pos
        · apply Nat.pos_iff_ne_zero.mpr
          apply Ideal.IsDedekindDomain.ramificationIdx_ne_zero_of_liesOver
          change moduliPrime.comap
              (algebraMap (NumberField.RingOfIntegers ℚ)
                (NumberField.RingOfIntegers Fmod)) ≠ ⊥
          apply Ideal.IsIntegral.comap_ne_bot
            (NumberField.RingOfIntegers ℚ)
          change P.asIdeal.comap
              (algebraMap (NumberField.RingOfIntegers Fmod)
                (NumberField.RingOfIntegers K)) ≠ ⊥
          exact Ideal.IsIntegral.comap_ne_bot
            (NumberField.RingOfIntegers Fmod) P.ne_bot
        · exact Ideal.inertiaDeg_pos' rationalPrime moduliPrime⟩
  | .infinite infinitePlace =>
      let moduliPlace :=
        infinitePlace.comap (algebraMap Fmod K)
      let rationalPlace :=
        moduliPlace.comap (algebraMap ℚ Fmod)
      letI : AbsoluteValue.LiesOver moduliPlace.1 rationalPlace.1 := ⟨rfl⟩
      ⟨rationalPlace.inertiaDeg moduliPlace, by
        by_cases hunramified : moduliPlace.IsUnramified ℚ
        · rw [NumberField.InfinitePlace.inertiaDeg_eq_one
            (show moduliPlace ∈
              NumberField.InfinitePlace.unramifiedPlacesOver Fmod rationalPlace from
                ⟨inferInstance, hunramified⟩)]
          exact Nat.zero_lt_one
        · rw [NumberField.InfinitePlace.inertiaDeg_eq_two
            (show moduliPlace ∈
              NumberField.InfinitePlace.ramifiedPlacesOver Fmod rationalPlace from
                ⟨inferInstance, hunramified⟩)]
          exact Nat.zero_lt_succ 1⟩

end SourceSelectedPlace

/--
A topological additive group with an algebraic `ℚ`-module structure.

Unlike `TopModuleCat ℚ`, this does not assert continuity of scalar
multiplication for the usual archimedean topology on `ℚ`; that assertion is
false for finite-place logarithmic modules.
-/
structure SourceTopologicalQModule extends ModuleCat.{u} ℚ where
  [topologicalSpace : TopologicalSpace carrier]
  [isTopologicalAddGroup : IsTopologicalAddGroup carrier]

namespace SourceTopologicalQModule

noncomputable instance : CoeSort SourceTopologicalQModule (Type u) :=
  ⟨fun module => module.toModuleCat⟩

attribute [instance]
  SourceTopologicalQModule.topologicalSpace
  SourceTopologicalQModule.isTopologicalAddGroup

/-- Log-volume measures use the canonical Borel sigma-algebra of the topology. -/
noncomputable instance measurableSpace
    (module : SourceTopologicalQModule.{u}) : MeasurableSpace module :=
  borel module

noncomputable instance borelSpace
    (module : SourceTopologicalQModule.{u}) : BorelSpace module :=
  ⟨rfl⟩

/-- Package a topological additive group with an algebraic rational action. -/
abbrev of (M : Type u) [AddCommGroup M] [Module ℚ M]
    [TopologicalSpace M] [IsTopologicalAddGroup M] :
    SourceTopologicalQModule.{u} :=
  ⟨ModuleCat.of ℚ M⟩

/-- A rational submodule with its subspace topology. -/
abbrev submodule
    (M : SourceTopologicalQModule.{u}) (target : Submodule ℚ M) :
    SourceTopologicalQModule.{u} :=
  SourceTopologicalQModule.of target

end SourceTopologicalQModule

/--
An ind-topological local module presented exactly as a filtered colimit of
finite-dimensional modules over `Q_(v_Q)`.
-/
structure SourceIndTopologicalLocalModule
    (rationalPlace : SourceRationalPlace) where
  stageIndex : Type u
  [stageCategory : SmallCategory stageIndex]
  [stageFiltered : IsFiltered stageIndex]
  stageDiagram :
    CategoryTheory.Cat.of stageIndex ⥤
      TopModuleCat.{u} rationalPlace.Completion
  stage_finiteDimensional :
    ∀ stage,
      FiniteDimensional rationalPlace.Completion (stageDiagram.obj stage)
  colimitCocone : Limits.Cocone stageDiagram
  colimitIsColimit : Limits.IsColimit colimitCocone

attribute [instance]
  SourceIndTopologicalLocalModule.stageCategory
  SourceIndTopologicalLocalModule.stageFiltered
  SourceIndTopologicalLocalModule.stage_finiteDimensional

namespace SourceIndTopologicalLocalModule

variable {rationalPlace : SourceRationalPlace}

/-- The actual topological local-field module underlying the filtered colimit. -/
noncomputable abbrev carrier
    (module : SourceIndTopologicalLocalModule.{u} rationalPlace) :=
  module.colimitCocone.pt

/-- Restriction of scalars gives the rational module used in tensor packets. -/
noncomputable def rationalCarrier
    (module : SourceIndTopologicalLocalModule.{u} rationalPlace) :
    SourceTopologicalQModule.{u} :=
  letI : Module ℚ module.carrier :=
    Module.compHom module.carrier
      (algebraMap ℚ rationalPlace.Completion)
  SourceTopologicalQModule.of module.carrier

end SourceIndTopologicalLocalModule

/--
A finite local field occurring at one stage of the ind-topological log field.

The scalar field is the actual completion `Q_(v_Q)`.  The rational algebra and
scalar-tower data are retained explicitly because packet tensor products are
subsequently regarded as rational modules.  Local compactness and second
countability are source requirements for the measures of Remark 3.1.1(iii),
not consequences assumed from an arbitrary field structure.
-/
structure SourceTopologicalLocalField
    (rationalPlace : SourceRationalPlace) where
  carrier : Type u
  [normedField : NormedField carrier]
  [localAlgebra : Algebra rationalPlace.Completion carrier]
  [rationalAlgebra : Algebra ℚ carrier]
  [scalarTower : IsScalarTower ℚ rationalPlace.Completion carrier]
  [normedSpace : NormedSpace rationalPlace.Completion carrier]
  [finiteDimensional :
    FiniteDimensional rationalPlace.Completion carrier]
  [completeSpace : CompleteSpace carrier]
  [locallyCompactSpace : LocallyCompactSpace carrier]
  [secondCountableTopology : SecondCountableTopology carrier]

attribute [instance]
  SourceTopologicalLocalField.normedField
  SourceTopologicalLocalField.localAlgebra
  SourceTopologicalLocalField.rationalAlgebra
  SourceTopologicalLocalField.scalarTower
  SourceTopologicalLocalField.normedSpace
  SourceTopologicalLocalField.finiteDimensional
  SourceTopologicalLocalField.completeSpace
  SourceTopologicalLocalField.locallyCompactSpace
  SourceTopologicalLocalField.secondCountableTopology

namespace SourceTopologicalLocalField

/-- The Borel sigma-algebra on a finite local-field stage. -/
noncomputable instance measurableSpace
    {rationalPlace : SourceRationalPlace}
    (field : SourceTopologicalLocalField.{u} rationalPlace) :
    MeasurableSpace field.carrier :=
  borel field.carrier

noncomputable instance borelSpace
    {rationalPlace : SourceRationalPlace}
    (field : SourceTopologicalLocalField.{u} rationalPlace) :
    BorelSpace field.carrier :=
  ⟨rfl⟩

/-- Restriction of scalars to the rational module used by packet coordinates. -/
noncomputable def rationalModule
    {rationalPlace : SourceRationalPlace}
    (field : SourceTopologicalLocalField.{u} rationalPlace) :
    SourceTopologicalQModule.{u} :=
  SourceTopologicalQModule.of field.carrier

end SourceTopologicalLocalField

/--
One finite local-field realization of a specified stage in a logarithmic
field's filtered system.
-/
structure SourceLocalFieldStage
    {rationalPlace : SourceRationalPlace}
    (module : SourceIndTopologicalLocalModule.{u} rationalPlace)
    (stage : module.stageIndex) where
  field : SourceTopologicalLocalField.{u} rationalPlace
  stageIso :
    module.stageDiagram.obj stage ≃L[rationalPlace.Completion] field.carrier

/--
The field-valued presentation asserted for `log(alpha F_v)` in Proposition
3.1(i).  It strengthens a bare filtered diagram of modules by exhibiting every
stage as a finite local field and every transition as a continuous field
embedding compatible with the underlying topological-module diagram.
-/
structure SourceIndTopologicalLocalFieldPresentation
    {rationalPlace : SourceRationalPlace}
    (module : SourceIndTopologicalLocalModule.{u} rationalPlace) where
  fieldStage :
    ∀ stage : module.stageIndex, SourceLocalFieldStage module stage
  transition :
    ∀ {source target : module.stageIndex} (map : source ⟶ target),
      (fieldStage source).field.carrier →ₐ[rationalPlace.Completion]
        (fieldStage target).field.carrier
  transition_continuous :
    ∀ {source target : module.stageIndex} (map : source ⟶ target),
      Continuous (transition map)
  transition_commutes :
    ∀ {source target : module.stageIndex} (map : source ⟶ target)
      (value : (fieldStage source).field.carrier),
      (fieldStage target).stageIso
          ((module.stageDiagram.map map).hom
            ((fieldStage source).stageIso.symm value)) =
        transition map value

namespace SourceIndTopologicalLocalFieldPresentation

variable {rationalPlace : SourceRationalPlace}
variable {module : SourceIndTopologicalLocalModule.{u} rationalPlace}

/-- Transition embeddings preserve identities because the module diagram does. -/
theorem transition_id
    (presentation : SourceIndTopologicalLocalFieldPresentation module)
    (stage : module.stageIndex)
    (value : (presentation.fieldStage stage).field.carrier) :
    presentation.transition (CategoryStruct.id stage) value = value := by
  rw [← presentation.transition_commutes (CategoryStruct.id stage) value]
  have hmap :
      module.stageDiagram.map (CategoryStruct.id stage) =
        CategoryStruct.id (module.stageDiagram.obj stage) :=
    module.stageDiagram.map_id stage
  rw [hmap]
  exact (presentation.fieldStage stage).stageIso.apply_symm_apply value

/-- Transition embeddings compose because the module diagram does. -/
theorem transition_comp
    (presentation : SourceIndTopologicalLocalFieldPresentation module)
    {first second third : module.stageIndex}
    (left : first ⟶ second) (right : second ⟶ third)
    (value : (presentation.fieldStage first).field.carrier) :
    presentation.transition (left ≫ right) value =
      presentation.transition right (presentation.transition left value) := by
  rw [← presentation.transition_commutes (left ≫ right) value]
  let sourceValue :=
    (presentation.fieldStage first).stageIso.symm value
  have hmap :
      (module.stageDiagram.map (left ≫ right)).hom sourceValue =
        (module.stageDiagram.map right).hom
          ((module.stageDiagram.map left).hom sourceValue) := by
    have hfun := congrArg TopModuleCat.Hom.hom
      (module.stageDiagram.map_comp left right)
    exact DFunLike.congr_fun hfun sourceValue
  change
    (presentation.fieldStage third).stageIso
        ((module.stageDiagram.map (left ≫ right)).hom sourceValue) = _
  rw [hmap]
  rw [← presentation.transition_commutes right
    (presentation.transition left value),
    ← presentation.transition_commutes left value]
  simp [sourceValue]

end SourceIndTopologicalLocalFieldPresentation

/--
One factor of a local tensor packet.

The type `place` is exactly the finite fiber of places `v | v_Q`; hence its
cardinality is definitionally the number of direct summands in the factor.
-/
structure SourceLocalLogDirectSum
    (rationalPlace : SourceRationalPlace)
    (place : Type u) [Fintype place] [DecidableEq place] where
  logarithmicShell :
    place -> SourceIndTopologicalLocalModule.{u} rationalPlace
  carrier : SourceTopologicalQModule.{u}
  directSumIso :
    carrier.toModuleCat ≅
      ModuleCat.of ℚ
        (⨁ placeIndex, (logarithmicShell placeIndex).rationalCarrier)

namespace SourceLocalLogDirectSum

variable {rationalPlace : SourceRationalPlace}
variable {place : Type u} [Fintype place] [DecidableEq place]

/-- Each rational tensor summand is derived from its local-field log shell. -/
noncomputable def summand
    (factor : SourceLocalLogDirectSum.{u} rationalPlace place)
    (placeIndex : place) : SourceTopologicalQModule.{u} :=
  (factor.logarithmicShell placeIndex).rationalCarrier

/--
The finite direct sum over `v | v_Q`, with its product topology, derived from
the individual logarithmic-shell modules.
-/
noncomputable def ofLogarithmicShells
    (logarithmicShell :
      place -> SourceIndTopologicalLocalModule.{u} rationalPlace) :
    SourceLocalLogDirectSum.{u} rationalPlace place where
  logarithmicShell := logarithmicShell
  carrier :=
    SourceTopologicalQModule.of
      (∀ placeIndex, (logarithmicShell placeIndex).rationalCarrier)
  directSumIso :=
    (DirectSum.linearEquivFunOnFintype ℚ place
      (fun placeIndex =>
        (logarithmicShell placeIndex).rationalCarrier)).symm.toModuleIso

@[simp]
theorem ofLogarithmicShells_summand
    (logarithmicShell :
      place -> SourceIndTopologicalLocalModule.{u} rationalPlace)
    (placeIndex : place) :
    (ofLogarithmicShells logarithmicShell).summand placeIndex =
      (logarithmicShell placeIndex).rationalCarrier :=
  rfl

@[simp]
theorem ofLogarithmicShells_directSumIso_hom_apply
    (logarithmicShell :
      place -> SourceIndTopologicalLocalModule.{u} rationalPlace)
    (value : (ofLogarithmicShells logarithmicShell).carrier)
    (placeIndex : place) :
    (ofLogarithmicShells logarithmicShell).directSumIso.hom value placeIndex =
      value placeIndex := by
  change
    ((DirectSum.linearEquivFunOnFintype ℚ place
      (fun index =>
        (logarithmicShell index).rationalCarrier)).symm value) placeIndex =
      value placeIndex
  exact congrFun
    ((DirectSum.linearEquivFunOnFintype ℚ place
      (fun index =>
        (logarithmicShell index).rationalCarrier)).apply_symm_apply value)
    placeIndex

end SourceLocalLogDirectSum

/--
The local `(j+1)`-tensor packet of IUT III, Proposition 3.2.

Each factor is a place-indexed direct sum, and `tensorIso` identifies the
underlying module with Mathlib's genuine dependent tensor product.
-/
structure SourceMonoAnalyticTensorPacket (j : ℕ) where
  rationalPlace : SourceRationalPlace
  place : Type u
  [placeFintype : Fintype place]
  [placeDecidableEq : DecidableEq place]
  factor :
    Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place
  carrier : SourceTopologicalQModule.{u}
  tensorIso :
    carrier.toModuleCat ≅
      ModuleCat.of ℚ
        (PiTensorProduct ℚ (fun a => (factor a).carrier))

attribute [instance]
  SourceMonoAnalyticTensorPacket.placeFintype
  SourceMonoAnalyticTensorPacket.placeDecidableEq

namespace SourceMonoAnalyticTensorPacket

variable {j : ℕ}

/-- The tensor packet has exactly `j+1` factors, as in Proposition 3.2. -/
@[simp]
theorem factor_count :
    Fintype.card (Fin (j + 1)) = j + 1 := by
  simp

/-- The full index of independent direct-summand choices in Ind2. -/
abbrev Ind2CoordinateIndex
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :=
  Fin (j + 1) × packet.place

/--
There is one Ind2 coordinate for every place summand in every tensor factor.
-/
theorem ind2CoordinateIndex_card
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :
    Fintype.card packet.Ind2CoordinateIndex =
      (j + 1) * Fintype.card packet.place := by
  simp [Ind2CoordinateIndex]

/--
One place-tuple tensor block in the displayed expansion of Proposition 3.1 is
selected by choosing a place above `v_Q` independently in every tensor factor.
The resulting block is a tensor product; it is not yet one of the field
summands in the subsequent ind-topological ring decomposition.
-/
abbrev PlaceTupleIndex
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :=
  ∀ _factor : Fin (j + 1), packet.place

/-- The displayed expansion has `#(v | v_Q)^(j+1)` place-tuple blocks. -/
theorem placeTupleIndex_card
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :
    Fintype.card packet.PlaceTupleIndex =
      Fintype.card packet.place ^ (j + 1) := by
  simp [PlaceTupleIndex, Fintype.card_pi]

/-- A place reindexing acts independently in every tensor factor. -/
def placeTupleIndexEquivOf
    (source target : SourceMonoAnalyticTensorPacket.{u} j)
    (placeEquiv : source.place ≃ target.place) :
    source.PlaceTupleIndex ≃ target.PlaceTupleIndex :=
  Equiv.piCongrRight fun _ => placeEquiv

@[simp]
theorem placeTupleIndexEquivOf_apply
    (source target : SourceMonoAnalyticTensorPacket.{u} j)
    (placeEquiv : source.place ≃ target.place)
    (index : source.PlaceTupleIndex)
    (factor : Fin (j + 1)) :
    placeTupleIndexEquivOf source target placeEquiv index factor =
      placeEquiv (index factor) :=
  rfl

/--
Compatibility alias for declarations written before the place-tuple/field
summand distinction was formalized. New source-facing declarations must use
`PlaceTupleIndex`.
-/
@[deprecated PlaceTupleIndex (since := "2026-07-21")]
abbrev DirectSummandIndex
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :=
  packet.PlaceTupleIndex

@[deprecated placeTupleIndex_card (since := "2026-07-21")]
theorem directSummandIndex_card
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :
    Fintype.card packet.PlaceTupleIndex =
      Fintype.card packet.place ^ (j + 1) :=
  packet.placeTupleIndex_card

@[deprecated placeTupleIndexEquivOf (since := "2026-07-21")]
def directSummandIndexEquivOf
    (source target : SourceMonoAnalyticTensorPacket.{u} j)
    (placeEquiv : source.place ≃ target.place) :
    source.PlaceTupleIndex ≃ target.PlaceTupleIndex :=
  placeTupleIndexEquivOf source target placeEquiv

@[deprecated placeTupleIndexEquivOf_apply (since := "2026-07-21")]
theorem directSummandIndexEquivOf_apply
    (source target : SourceMonoAnalyticTensorPacket.{u} j)
    (placeEquiv : source.place ≃ target.place)
    (index : source.PlaceTupleIndex)
    (factor : Fin (j + 1)) :
    placeTupleIndexEquivOf source target placeEquiv index factor =
      placeEquiv (index factor) :=
  rfl

/--
Pure tensors whose distinguished factor belongs to the summand indexed by
`place`, as in `log(A,alpha D_v)` of Proposition 3.2.
-/
def distinguishedPureTensors
    (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (distinguished : Fin (j + 1))
    (place : packet.place) :
    Set (PiTensorProduct ℚ
      (fun a => (packet.factor a).carrier)) :=
  { tensor |
      ∃ (components : ∀ a, (packet.factor a).carrier)
        (value : (packet.factor distinguished).summand place),
        components distinguished =
          (packet.factor distinguished).directSumIso.inv
            (DirectSum.of
              (fun placeIndex =>
                (packet.factor distinguished).summand placeIndex)
              place value) ∧
        tensor = PiTensorProduct.tprod ℚ components }

/--
The actual distinguished submodule `I_Q(S_{j+1,j};v)` generated by those
pure tensors, transported back into the topological packet.
-/
def distinguishedSubmodule
    (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (distinguished : Fin (j + 1))
    (place : packet.place) :
    Submodule ℚ packet.carrier :=
  (Submodule.span ℚ
      (packet.distinguishedPureTensors distinguished place)).comap
    packet.tensorIso.hom.hom

theorem inverse_tprod_mem_distinguishedSubmodule
    (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (distinguished : Fin (j + 1))
    (place : packet.place)
    (components : ∀ a, (packet.factor a).carrier)
    (value : (packet.factor distinguished).summand place)
    (hcomponent :
      components distinguished =
        (packet.factor distinguished).directSumIso.inv
          (DirectSum.of
            (fun placeIndex =>
              (packet.factor distinguished).summand placeIndex)
            place value)) :
    packet.tensorIso.inv (PiTensorProduct.tprod ℚ components) ∈
      packet.distinguishedSubmodule distinguished place := by
  change
    packet.tensorIso.hom
        (packet.tensorIso.inv
          (PiTensorProduct.tprod ℚ components)) ∈
      Submodule.span ℚ
        (packet.distinguishedPureTensors distinguished place)
  rw [Iso.inv_hom_id_apply]
  exact Submodule.subset_span
    ⟨components, value, hcomponent, rfl⟩

end SourceMonoAnalyticTensorPacket

/--
The Proposition 3.1(i) field-valued presentations of all logarithmic-shell
factors in a tensor packet.
-/
structure SourceMonoAnalyticTensorPacketFieldPresentation
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j) where
  factorPresentation :
    ∀ (factor : Fin (j + 1)) (place : packet.place),
      SourceIndTopologicalLocalFieldPresentation
        ((packet.factor factor).logarithmicShell place)

/--
A finite stage of one place-tuple tensor block, together with its actual
decomposition as a finite product of local fields.

Proposition 3.1 does not identify the entire ind-topological tensor block with
this finite product.  Accordingly `blockEmbedding` is an injective map from
the chosen stage into the block.  `fieldIndex` indexes the genuine field
summands on which Proposition 3.9 defines component volumes.
-/
structure SourcePacketFiniteFieldStage
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (presentation :
      SourceMonoAnalyticTensorPacketFieldPresentation packet)
    (placeTuple : packet.PlaceTupleIndex) where
  factorStage :
    ∀ factor : Fin (j + 1),
      ((packet.factor factor).logarithmicShell
        (placeTuple factor)).stageIndex
  factorEmbedding :
    ∀ factor : Fin (j + 1),
      ((presentation.factorPresentation factor
          (placeTuple factor)).fieldStage
            (factorStage factor)).field.rationalModule ≃L[ℚ]
        (packet.factor factor).summand (placeTuple factor)
  factorEmbedding_agreesWithCocone :
    ∀ (factor : Fin (j + 1))
      (value :
        ((presentation.factorPresentation factor
          (placeTuple factor)).fieldStage
            (factorStage factor)).field.carrier),
      factorEmbedding factor value =
        (((packet.factor factor).logarithmicShell
            (placeTuple factor)).colimitCocone.ι.app
              (factorStage factor)).hom
          (((presentation.factorPresentation factor
              (placeTuple factor)).fieldStage
                (factorStage factor)).stageIso.symm value)
  fieldIndex : Type u
  [fieldIndexFintype : Fintype fieldIndex]
  [fieldIndexDecidableEq : DecidableEq fieldIndex]
  [fieldIndexNonempty : Nonempty fieldIndex]
  field : fieldIndex → SourceTopologicalLocalField.{u} packet.rationalPlace
  tensorAlgebra : Type u
  [tensorAlgebraCommRing : CommRing tensorAlgebra]
  [tensorAlgebraRationalAlgebra : Algebra ℚ tensorAlgebra]
  [tensorAlgebraTopologicalSpace : TopologicalSpace tensorAlgebra]
  [tensorAlgebraIsTopologicalRing : IsTopologicalRing tensorAlgebra]
  stageTensorIso :
    (SourceTopologicalQModule.of tensorAlgebra).toModuleCat ≅
      ModuleCat.of ℚ
        (PiTensorProduct ℚ (fun factor ↦
          ((presentation.factorPresentation factor
              (placeTuple factor)).fieldStage
                (factorStage factor)).field.rationalModule))
  fieldDecomposition :
    tensorAlgebra ≃ₐ[ℚ] (∀ index, (field index).carrier)
  fieldDecomposition_continuous : Continuous fieldDecomposition
  fieldDecomposition_symm_continuous : Continuous fieldDecomposition.symm
  blockEmbedding :
    SourceTopologicalQModule.of tensorAlgebra →ₗ[ℚ]
      PiTensorProduct ℚ
        (fun factor ↦
          (packet.factor factor).summand (placeTuple factor))
  blockEmbedding_injective : Function.Injective blockEmbedding
  blockEmbedding_tprod :
    ∀ components : ∀ factor,
      ((presentation.factorPresentation factor
          (placeTuple factor)).fieldStage
            (factorStage factor)).field.carrier,
      blockEmbedding
          (stageTensorIso.inv
            (PiTensorProduct.tprod ℚ components)) =
        PiTensorProduct.tprod ℚ
          (fun factor ↦ factorEmbedding factor (components factor))

attribute [instance]
  SourcePacketFiniteFieldStage.fieldIndexFintype
  SourcePacketFiniteFieldStage.fieldIndexDecidableEq
  SourcePacketFiniteFieldStage.fieldIndexNonempty
  SourcePacketFiniteFieldStage.tensorAlgebraCommRing
  SourcePacketFiniteFieldStage.tensorAlgebraRationalAlgebra
  SourcePacketFiniteFieldStage.tensorAlgebraTopologicalSpace
  SourcePacketFiniteFieldStage.tensorAlgebraIsTopologicalRing

namespace SourcePacketFiniteFieldStage

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
variable {presentation :
  SourceMonoAnalyticTensorPacketFieldPresentation packet}
variable {placeTuple : packet.PlaceTupleIndex}

/-- The rational topological module underlying the chosen finite tensor stage. -/
noncomputable def module
    (stage : SourcePacketFiniteFieldStage packet presentation placeTuple) :
    SourceTopologicalQModule.{u} :=
  SourceTopologicalQModule.of stage.tensorAlgebra

/-- The field decomposition as a homeomorphism of the underlying spaces. -/
noncomputable def fieldDecompositionHomeomorph
    (stage : SourcePacketFiniteFieldStage packet presentation placeTuple) :
    stage.tensorAlgebra ≃ₜ (∀ index, (stage.field index).carrier) where
  toEquiv := stage.fieldDecomposition.toEquiv
  continuous_toFun := stage.fieldDecomposition_continuous
  continuous_invFun := stage.fieldDecomposition_symm_continuous

end SourcePacketFiniteFieldStage

/--
One simultaneous finite-stage field decomposition for every place-tuple block
of a packet.  This is the finite set `V` used in Remark 3.1.1(iii)-(iv), after
flattening the field indices below.
-/
structure SourcePacketFiniteFieldDecomposition
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (presentation :
      SourceMonoAnalyticTensorPacketFieldPresentation packet) where
  blockStage :
    ∀ placeTuple : packet.PlaceTupleIndex,
      SourcePacketFiniteFieldStage packet presentation placeTuple

namespace SourcePacketFiniteFieldDecomposition

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
variable {presentation :
  SourceMonoAnalyticTensorPacketFieldPresentation packet}

/-- A genuine field summand is a field inside a chosen place-tuple stage. -/
abbrev FieldSummandIndex
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :=
  Σ placeTuple : packet.PlaceTupleIndex,
    (decomposition.blockStage placeTuple).fieldIndex

/-- The local field selected by a flattened field-summand index. -/
def field
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation)
    (index : decomposition.FieldSummandIndex) :
    SourceTopologicalLocalField.{u} packet.rationalPlace :=
  (decomposition.blockStage index.1).field index.2

/--
The number of actual fields is the sum of the stagewise field counts.  It is
not generally `#places^(j+1)`, which counts only the outer tensor blocks.
-/
theorem fieldSummandIndex_card
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :
    Fintype.card decomposition.FieldSummandIndex =
      ∑ placeTuple : packet.PlaceTupleIndex,
        Fintype.card (decomposition.blockStage placeTuple).fieldIndex := by
  letI (placeTuple : packet.PlaceTupleIndex) :
      Fintype (decomposition.blockStage placeTuple).fieldIndex :=
    (decomposition.blockStage placeTuple).fieldIndexFintype
  change
    Fintype.card
        (Σ placeTuple : packet.PlaceTupleIndex,
          (decomposition.blockStage placeTuple).fieldIndex) = _
  exact Fintype.card_sigma
    (ι := packet.PlaceTupleIndex)
    (α := fun placeTuple ↦
      (decomposition.blockStage placeTuple).fieldIndex)

/-- The product of the place-tuple tensor blocks in Proposition 3.1. -/
abbrev PlaceTupleBlockCoordinates
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :=
  ∀ placeTuple : packet.PlaceTupleIndex,
    PiTensorProduct ℚ fun factor =>
      (packet.factor factor).summand (placeTuple factor)

/--
The canonical expansion
`tensor_product (direct_sum_v M_v) = direct_sum_(v_t) tensor_product M_(v_t)`,
followed by the finite direct-sum/function equivalence.
-/
noncomputable def placeTupleDecomposition
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :
    packet.carrier ≃ₗ[ℚ] PlaceTupleBlockCoordinates packet :=
  packet.tensorIso.toLinearEquiv |>.trans
    (PiTensorProduct.congr
      (fun factor => (packet.factor factor).directSumIso.toLinearEquiv)) |>.trans
    PiTensorProduct.ofDirectSumEquiv |>.trans
    (DirectSum.linearEquivFunOnFintype ℚ packet.PlaceTupleIndex
      (fun placeTuple => PiTensorProduct ℚ
        (fun factor =>
          (packet.factor factor).summand (placeTuple factor))))

/-- The dependent product of all simultaneously chosen finite tensor stages. -/
abbrev StageCoordinates
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :=
  ∀ placeTuple : packet.PlaceTupleIndex,
    (decomposition.blockStage placeTuple).tensorAlgebra

/-- The rational topological module underlying the chosen finite packet stage. -/
noncomputable def stageModule
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :
    SourceTopologicalQModule.{u} :=
  SourceTopologicalQModule.of decomposition.StageCoordinates

/-- Apply the selected finite-stage embedding in every place-tuple block. -/
noncomputable def stageBlockEmbedding
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :
    decomposition.stageModule →ₗ[ℚ] PlaceTupleBlockCoordinates packet where
  toFun := fun value placeTuple =>
    (decomposition.blockStage placeTuple).blockEmbedding (value placeTuple)
  map_add' := by
    intro first second
    funext placeTuple
    exact map_add (decomposition.blockStage placeTuple).blockEmbedding
      (first placeTuple) (second placeTuple)
  map_smul' := by
    intro scalar value
    funext placeTuple
    exact map_smul (decomposition.blockStage placeTuple).blockEmbedding
      scalar (value placeTuple)

/-- The chosen finite packet stage maps into, rather than equals, the ind-packet. -/
noncomputable def stageEmbedding
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :
    decomposition.stageModule →ₗ[ℚ] packet.carrier :=
  (placeTupleDecomposition packet).symm.toLinearMap.comp
    decomposition.stageBlockEmbedding

/-- The simultaneous finite-stage map into the ind-packet is injective. -/
theorem stageEmbedding_injective
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) :
    Function.Injective decomposition.stageEmbedding := by
  intro first second heq
  have hblocks :
      decomposition.stageBlockEmbedding first =
        decomposition.stageBlockEmbedding second :=
    (placeTupleDecomposition packet).symm.injective heq
  funext placeTuple
  exact (decomposition.blockStage placeTuple).blockEmbedding_injective
    (congrFun hblocks placeTuple)

end SourcePacketFiniteFieldDecomposition

namespace IUTIIAbsoluteThetaLabel

variable {l : PrimeGeFive}

/--
The integer `j` represented by an absolute theta label `|j|`: zero represents
`0`, while a nonzero sign class uses its unique representative in
`{1,...,l*}`.
-/
noncomputable def tensorIndex
    (label : IUTIIAbsoluteThetaLabel.{u} l) : ℕ :=
  match label with
  | none => 0
  | some lifted =>
      IUTIPositiveLabel.representative
        ((IUTIPositiveLabel.signLabelEquiv.symm lifted.down) :
          IUTIPositiveLabel.{0} l)

@[simp]
theorem tensorIndex_zero :
    tensorIndex (zero : IUTIIAbsoluteThetaLabel.{u} l) = 0 :=
  rfl

theorem tensorIndex_nonzero_pos
    (label :
      EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    0 < tensorIndex (nonzero label : IUTIIAbsoluteThetaLabel.{u} l) := by
  exact
    IUTIPositiveLabel.representative_pos
      ((IUTIPositiveLabel.signLabelEquiv.symm label) :
        IUTIPositiveLabel.{0} l)

theorem tensorIndex_lt_l
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    tensorIndex label < l.value := by
  cases label with
  | none =>
      have hpositive : 0 < l.value := by
        have := l.ge_five
        omega
      simpa [tensorIndex] using hpositive
  | some lifted =>
      exact
        IUTIPositiveLabel.representative_lt_l
          ((IUTIPositiveLabel.signLabelEquiv.symm lifted.down) :
            IUTIPositiveLabel.{0} l)

end IUTIIAbsoluteThetaLabel

/-- The cardinal `l± = l* + 1 = (l+1)/2` of the absolute-label set. -/
def PrimeGeFive.lPlusMinus (l : PrimeGeFive) : ℕ :=
  l.lStar + 1

theorem PrimeGeFive.lPlusMinus_pos (l : PrimeGeFive) :
    0 < l.lPlusMinus := by
  simp [PrimeGeFive.lPlusMinus]

/-- `l±` packaged as the positive length of the Proposition 6.9 procession. -/
def PrimeGeFive.lPlusMinusPositive (l : PrimeGeFive) : ℕ+ :=
  ⟨l.lPlusMinus, l.lPlusMinus_pos⟩

@[simp]
theorem PrimeGeFive.lPlusMinusPositive_val (l : PrimeGeFive) :
    l.lPlusMinusPositive.1 = l.lPlusMinus :=
  rfl

namespace IUTIIAbsoluteThetaLabel

variable {l : PrimeGeFive}

/-- The absolute labels `|F_l|` are ordered as `0,1,...,l*`. -/
noncomputable def orderedIndexEquiv :
    IUTIIAbsoluteThetaLabel.{u} l ≃
      CategoryCapsule.FiniteIndex.{u} l.lPlusMinus :=
  let nonzeroToFin :
      ULift.{u}
          (EtaleTheta.SignLabel
            (EtaleTheta.LTorsionLabel l.value)) ≃
        Fin l.lStar :=
    Equiv.ulift.trans <|
      (IUTIPositiveLabel.signLabelEquiv.{0} (l := l)).symm.trans
        Equiv.ulift
  (Equiv.optionCongr nonzeroToFin).trans <|
    (_root_.finSuccEquiv l.lStar).symm.trans Equiv.ulift.symm

/-- The absolute labels inherit their finite enumeration from `0,1,...,l*`. -/
noncomputable instance fintype : Fintype (IUTIIAbsoluteThetaLabel.{u} l) :=
  Fintype.ofEquiv (CategoryCapsule.FiniteIndex.{u} l.lPlusMinus)
    orderedIndexEquiv.symm

/-- The full absolute-label set has cardinality `l±`. -/
theorem card_eq_lPlusMinus :
    Fintype.card (IUTIIAbsoluteThetaLabel.{u} l) = l.lPlusMinus := by
  rw [Fintype.card_congr orderedIndexEquiv]
  rw [Fintype.card_congr
    (Equiv.ulift : ULift.{u} (Fin l.lPlusMinus) ≃ Fin l.lPlusMinus)]
  exact Fintype.card_fin l.lPlusMinus

@[simp]
theorem orderedIndexEquiv_zero :
    (orderedIndexEquiv
      (l := l) (zero : IUTIIAbsoluteThetaLabel.{u} l)).down.1 = 0 := by
  change (((_root_.finSuccEquiv l.lStar).symm none).1 = 0)
  simp

theorem orderedIndexEquiv_val
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (orderedIndexEquiv label).down.1 = tensorIndex label := by
  cases label with
  | none =>
      change (((_root_.finSuccEquiv l.lStar).symm none).1 = 0)
      simp
  | some lifted =>
      let positive : IUTIPositiveLabel.{0} l :=
        IUTIPositiveLabel.signLabelEquiv.symm lifted.down
      change
        (((_root_.finSuccEquiv l.lStar).symm
          (some positive.down)).1 = positive.down.1 + 1)
      simp

/-- The Proposition 6.9 procession position associated to an absolute label. -/
noncomputable def processionPosition
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    Fin l.lPlusMinus :=
  (orderedIndexEquiv label).down

@[simp]
theorem processionPosition_val
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (processionPosition label).1 = tensorIndex label :=
  orderedIndexEquiv_val label

/-- The factor labeled `j` in the packet `S_{j+1}`. -/
noncomputable def distinguishedFactor
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    Fin (tensorIndex label + 1) :=
  Fin.last (tensorIndex label)

end IUTIIAbsoluteThetaLabel

/--
The `D-Θ±` bridge core of IUT I, Definition 6.4(i), indexed by the full
absolute-label set `|F_l|` rather than only its nonzero part.
-/
structure SourceDAbsoluteThetaBridgeCore
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    (models : IUTIThetaHodgeTheaterModels theta) where
  capsule :
    CategoryCapsule
      (CategoryTheory.Cat.of (SourceDPrimeStrip models))
  target : SourceDPrimeStrip models
  polyMorphism : ∀ index, Set (capsule.object index ⟶ target)
  polyMorphism_nonempty : ∀ index, (polyMorphism index).Nonempty
  evaluationLabel :
    capsule.index -> IUTIIAbsoluteThetaLabel.{u} theta.l
  evaluationLabel_injective : Function.Injective evaluationLabel
  evaluationLabel_surjective : Function.Surjective evaluationLabel

namespace SourceDAbsoluteThetaBridgeCore

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/-- The absolute evaluation labels give the Definition 6.4 capsule ordering. -/
noncomputable def orderedIndexEquiv
    (bridge : SourceDAbsoluteThetaBridgeCore models) :
    bridge.capsule.index ≃
      CategoryCapsule.FiniteIndex theta.l.lPlusMinus :=
  (Equiv.ofBijective bridge.evaluationLabel
    ⟨bridge.evaluationLabel_injective,
      bridge.evaluationLabel_surjective⟩).trans
    IUTIIAbsoluteThetaLabel.orderedIndexEquiv

/-- The `l±`-procession of IUT I, Proposition 6.9(i). -/
noncomputable def procession
    (bridge : SourceDAbsoluteThetaBridgeCore models) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDPrimeStrip models))
      theta.l.lPlusMinusPositive :=
  CategoryCapsule.nestedProcession.{u, u + 1, u}
    bridge.capsule bridge.orderedIndexEquiv

theorem procession_capsule_card
    (bridge : SourceDAbsoluteThetaBridgeCore models)
    (position : Fin theta.l.lPlusMinusPositive.1) :
    Fintype.card (bridge.procession.capsule position).index =
      position.1 + 1 :=
  bridge.procession.capsule_card position

/-- Mono-analyticization of the full absolute-label procession. -/
noncomputable def monoAnalyticProcession
    (bridge : SourceDAbsoluteThetaBridgeCore models)
    (mono : SourceDMonoAnalyticization models) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models))
      theta.l.lPlusMinusPositive :=
  bridge.procession.map mono.functor

theorem monoAnalyticProcession_capsule_card
    (bridge : SourceDAbsoluteThetaBridgeCore models)
    (mono : SourceDMonoAnalyticization models)
    (position : Fin theta.l.lPlusMinusPositive.1) :
    Fintype.card
        ((bridge.monoAnalyticProcession mono).capsule position).index =
      position.1 + 1 :=
  (bridge.monoAnalyticProcession mono).capsule_card position

/-- One compatible member of a full poly-isomorphism of `D-Θ±` bridges. -/
structure IsomorphismMember
    (source target : SourceDAbsoluteThetaBridgeCore models) where
  indexEquiv : source.capsule.index ≃ target.capsule.index
  componentIso :
    ∀ index,
      source.capsule.object index ≅
        target.capsule.object (indexEquiv index)
  targetIso : source.target ≅ target.target
  evaluationLabel_compatible :
    ∀ index,
      target.evaluationLabel (indexEquiv index) =
        source.evaluationLabel index
  polyMorphism_compatible :
    ∀ index arrow,
      arrow ∈ source.polyMorphism index ↔
        (componentIso index).inv ≫ arrow ≫ targetIso.hom ∈
          target.polyMorphism (indexEquiv index)

theorem IsomorphismMember.orderedIndex_compatible
    {source target : SourceDAbsoluteThetaBridgeCore models}
    (iso : IsomorphismMember source target)
    (index : source.capsule.index) :
    target.orderedIndexEquiv (iso.indexEquiv index) =
      source.orderedIndexEquiv index := by
  simp only [orderedIndexEquiv, Equiv.trans_apply,
    Equiv.ofBijective_apply]
  rw [iso.evaluationLabel_compatible]

/-- A bridge isomorphism induces a morphism of absolute-label processions. -/
noncomputable def IsomorphismMember.processionHom
    {source target : SourceDAbsoluteThetaBridgeCore models}
    (_iso : IsomorphismMember source target) :
    CategoryProcession.Hom source.procession target.procession where
  positionEmbedding :=
    Function.Embedding.refl (Fin theta.l.lPlusMinusPositive.1)
  positionStrictMono := strictMono_id
  component _ :=
    { indexEmbedding := Function.Embedding.refl _ }

/-- Every component of the induced procession map has an actual iso member. -/
noncomputable def IsomorphismMember.processionHomMember
    {source target : SourceDAbsoluteThetaBridgeCore models}
    (iso : IsomorphismMember source target) :
    ∀ position, (iso.processionHom.component position).Members := by
  intro position index
  let ordered : CategoryCapsule.FiniteIndex.{u} theta.l.lPlusMinus :=
    ULift.up
      ⟨index.down.1,
        lt_of_lt_of_le index.down.2
          (Nat.succ_le_iff.mpr position.2)⟩
  let sourceIndex := source.orderedIndexEquiv.symm ordered
  have hindex :
      iso.indexEquiv sourceIndex =
        target.orderedIndexEquiv.symm ordered := by
    apply target.orderedIndexEquiv.injective
    rw [iso.orderedIndex_compatible]
    dsimp [sourceIndex]
    exact
      (source.orderedIndexEquiv.apply_symm_apply ordered).trans
        (target.orderedIndexEquiv.apply_symm_apply ordered).symm
  change
    source.capsule.object sourceIndex ≅
      target.capsule.object
        (target.orderedIndexEquiv.symm ordered)
  exact
    (iso.componentIso sourceIndex).trans
      (eqToIso (congrArg target.capsule.object hindex))

/-- The same compatible members after mono-analyticization. -/
noncomputable def IsomorphismMember.monoAnalyticProcessionHomMember
    {source target : SourceDAbsoluteThetaBridgeCore models}
    (iso : IsomorphismMember source target)
    (mono : SourceDMonoAnalyticization models) :
    ∀ position,
      ((iso.processionHom.component position).map mono.functor).Members :=
  fun position => (iso.processionHomMember position).map mono.functor

end SourceDAbsoluteThetaBridgeCore

/--
The F-prime-strip lift of a Definition 6.4 `D-Θ±` bridge.  Its capsule is
indexed by all absolute labels, including zero.
-/
structure SourceFAbsoluteThetaBridge
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    (models : IUTIThetaHodgeTheaterModels theta) where
  capsule : SourceFPrimeStripCapsule models
  theater : SourceThetaHodgeTheater models
  polyMorphism :
    ∀ index, Set (capsule.object index ⟶ theater.associatedF)
  polyMorphism_nonempty :
    ∀ index, (polyMorphism index).Nonempty
  associatedD_injective :
    ∀ index (first second :
      capsule.object index ⟶ theater.associatedF),
      first ∈ polyMorphism index ->
      second ∈ polyMorphism index ->
      first.associatedD = second.associatedD -> first = second
  evaluationLabel :
    capsule.index -> IUTIIAbsoluteThetaLabel.{u} theta.l
  evaluationLabel_injective : Function.Injective evaluationLabel
  evaluationLabel_surjective : Function.Surjective evaluationLabel

namespace SourceFAbsoluteThetaBridge

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/-- Mono-analytic `D-Θ±` bridge obtained from the lifted F-prime strips. -/
def associatedD (bridge : SourceFAbsoluteThetaBridge models) :
    SourceDAbsoluteThetaBridgeCore models where
  capsule := CategoryCapsule.map sourceFPrimeStripToD bridge.capsule
  target := bridge.theater.associatedF.associatedD
  polyMorphism index :=
    { arrow |
      ∃ lift : bridge.capsule.object index ⟶
          bridge.theater.associatedF,
        lift ∈ bridge.polyMorphism index ∧
          lift.associatedD = arrow }
  polyMorphism_nonempty index := by
    rcases bridge.polyMorphism_nonempty index with ⟨lift, hlift⟩
    exact ⟨lift.associatedD, lift, hlift, rfl⟩
  evaluationLabel := bridge.evaluationLabel
  evaluationLabel_injective := bridge.evaluationLabel_injective
  evaluationLabel_surjective := bridge.evaluationLabel_surjective

end SourceFAbsoluteThetaBridge

/--
The nonarchimedean integral structure in Proposition 3.2(ii): a closed
additive lattice whose rational span is the whole packet.
-/
structure SourceNonarchimedeanIntegralStructure
    (M : SourceTopologicalQModule.{u}) where
  lattice : AddSubgroup M
  isClosed_lattice : IsClosed (lattice : Set M)
  rationalSpan_eq_top :
    Submodule.span ℚ (lattice : Set M) = ⊤

/--
The archimedean integral structure in Proposition 3.2(ii): the closed unit
ball of a continuous, definite seminorm induced by the Hermitian metric.
-/
structure SourceArchimedeanIntegralStructure
    (M : SourceTopologicalQModule.{u}) where
  seminorm : Seminorm ℚ M
  continuous_seminorm : Continuous seminorm
  definite : ∀ x : M, seminorm x = 0 -> x = 0
  inner : M →ₗ[ℚ] M →ₗ[ℚ] ℝ
  inner_symmetric : ∀ x y, inner x y = inner y x
  seminorm_sq : ∀ x, seminorm x ^ 2 = inner x x

namespace SourceArchimedeanIntegralStructure

variable {M : SourceTopologicalQModule.{u}}

/-- The closed unit ball that the paper regards as the integral structure. -/
def unitBall (integral : SourceArchimedeanIntegralStructure M) : Set M :=
  integral.seminorm.closedBall 0 1

/-- The closed radius-`pi` ball used in Proposition 3.5(ii)(b). -/
def piBall (integral : SourceArchimedeanIntegralStructure M) : Set M :=
  integral.seminorm.closedBall 0 Real.pi

theorem zero_mem_unitBall
    (integral : SourceArchimedeanIntegralStructure M) :
    (0 : M) ∈ integral.unitBall := by
  simp [unitBall]

theorem isClosed_unitBall
    (integral : SourceArchimedeanIntegralStructure M) :
    IsClosed integral.unitBall := by
  rw [unitBall, Seminorm.closedBall_zero_eq]
  exact isClosed_Iic.preimage integral.continuous_seminorm

theorem zero_mem_piBall
    (integral : SourceArchimedeanIntegralStructure M) :
    (0 : M) ∈ integral.piBall := by
  simp [piBall, Real.pi_pos.le]

theorem isClosed_piBall
    (integral : SourceArchimedeanIntegralStructure M) :
    IsClosed integral.piBall := by
  rw [piBall, Seminorm.closedBall_zero_eq]
  exact isClosed_Iic.preimage integral.continuous_seminorm

/-- Restrict an archimedean integral metric to a rational submodule. -/
def restrict
    (integral : SourceArchimedeanIntegralStructure M)
    (target : Submodule ℚ M) :
    SourceArchimedeanIntegralStructure
      (SourceTopologicalQModule.submodule M target) where
  seminorm := integral.seminorm.comp target.subtype
  continuous_seminorm :=
    integral.continuous_seminorm.comp continuous_subtype_val
  definite value hvalue :=
    Subtype.ext (integral.definite value.1 hvalue)
  inner :=
    { toFun := fun first => (integral.inner first.1).domRestrict target
      map_add' := by
        intro first second
        ext value
        simp
      map_smul' := by
        intro scalar value
        ext argument
        simp }
  inner_symmetric first second := integral.inner_symmetric first.1 second.1
  seminorm_sq value := integral.seminorm_sq value.1

/-- Restriction to the full submodule has the original unit ball as its image. -/
theorem image_unitBall_restrict_top
    (integral : SourceArchimedeanIntegralStructure M) :
    (Subtype.val '' (integral.restrict (⊤ : Submodule ℚ M)).unitBall : Set M) =
      integral.unitBall := by
  ext value
  simp [unitBall, restrict]

end SourceArchimedeanIntegralStructure

/--
An integral region whose rational span is a specified submodule.

The final two fields retain the source distinction: at a nonarchimedean place
the region is a closed additive lattice, while at an archimedean place it is
the closed unit ball of a continuous definite seminorm.
-/
structure SourceIntegralRegionOn
    (kind : SourceRationalPlaceKind)
    (M : SourceTopologicalQModule.{u})
    (target : Submodule ℚ M) where
  carrier : Set M
  isClosed_carrier : IsClosed carrier
  zero_mem : (0 : M) ∈ carrier
  rationalSpan_eq : Submodule.span ℚ carrier = target
  nonarchimedean_lattice :
    kind = .nonarchimedean ->
      ∃ lattice : AddSubgroup M, carrier = (lattice : Set M)
  archimedean_unitBall :
    kind = .archimedean ->
      ∃ metric :
          SourceArchimedeanIntegralStructure
            (SourceTopologicalQModule.submodule M target),
        carrier = Subtype.val '' metric.unitBall

namespace SourceIntegralRegionOn

variable
    {kind targetKind : SourceRationalPlaceKind}
    {M : SourceTopologicalQModule.{u}}
    {target : Submodule ℚ M}

/-- Reindex only the place-kind witness, leaving the actual region unchanged. -/
def rekind
    (region : SourceIntegralRegionOn kind M target)
    (hkind : kind = targetKind) :
    SourceIntegralRegionOn targetKind M target where
  carrier := region.carrier
  isClosed_carrier := region.isClosed_carrier
  zero_mem := region.zero_mem
  rationalSpan_eq := region.rationalSpan_eq
  nonarchimedean_lattice htarget :=
    region.nonarchimedean_lattice (hkind.trans htarget)
  archimedean_unitBall htarget :=
    region.archimedean_unitBall (hkind.trans htarget)

@[simp]
theorem rekind_carrier
    (region : SourceIntegralRegionOn kind M target)
    (hkind : kind = targetKind) :
    (region.rekind hkind).carrier = region.carrier :=
  rfl

end SourceIntegralRegionOn

/-- The placewise nonarchimedean log-shells used to form a packet lattice. -/
structure SourceNonarchimedeanPacketShells
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j) where
  summandIntegral :
    ∀ (factor : Fin (j + 1)) (place : packet.place),
      SourceNonarchimedeanIntegralStructure
        ((packet.factor factor).summand place)

namespace SourceNonarchimedeanPacketShells

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}

/-- The finite direct sum of the placewise nonarchimedean lattices. -/
def factorLattice
    (shells : SourceNonarchimedeanPacketShells packet)
    (factor : Fin (j + 1)) :
    AddSubgroup (packet.factor factor).carrier where
  carrier :=
    { value |
      ∀ place,
        (packet.factor factor).directSumIso.hom value place ∈
          (shells.summandIntegral factor place).lattice }
  zero_mem' place := by
    simpa only [map_zero, Pi.zero_apply] using
      (shells.summandIntegral factor place).lattice.zero_mem
  add_mem' {first second} hfirst hsecond place := by
    simpa using
      (shells.summandIntegral factor place).lattice.add_mem
        (hfirst place) (hsecond place)
  neg_mem' {value} hvalue place := by
    simpa only [map_neg, Pi.neg_apply] using
      (shells.summandIntegral factor place).lattice.neg_mem
        (hvalue place)

/-- Pure tensors all of whose factors lie in the direct-sum log-shells. -/
def pureIntegralTensors
    (shells : SourceNonarchimedeanPacketShells packet) :
    Set packet.carrier :=
  { tensor |
    ∃ components : ∀ factor, (packet.factor factor).carrier,
      (∀ factor, components factor ∈ shells.factorLattice factor) ∧
      tensor = packet.tensorIso.inv (PiTensorProduct.tprod ℚ components) }

/--
The nonarchimedean packet lattice: the closed additive subgroup generated by
the pure tensors of local log-shell lattices.
-/
def packetLattice
    (shells : SourceNonarchimedeanPacketShells packet) :
    AddSubgroup packet.carrier :=
  (AddSubgroup.closure shells.pureIntegralTensors).topologicalClosure

/--
A continuous linear equivalence that preserves pure integral tensors also
preserves the closed packet lattice generated by them.
-/
theorem packetLattice_image
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    (sourceShells : SourceNonarchimedeanPacketShells packet)
    (targetShells : SourceNonarchimedeanPacketShells targetPacket)
    (equiv : packet.carrier ≃L[ℚ] targetPacket.carrier)
    (pure_image :
      equiv '' sourceShells.pureIntegralTensors =
        targetShells.pureIntegralTensors) :
    equiv '' (sourceShells.packetLattice : Set packet.carrier) =
      (targetShells.packetLattice : Set targetPacket.carrier) := by
  let addMap := equiv.toLinearEquiv.toAddEquiv.toAddMonoidHom
  change equiv '' closure
      (AddSubgroup.closure sourceShells.pureIntegralTensors :
        Set packet.carrier) =
    closure
      (AddSubgroup.closure targetShells.pureIntegralTensors :
        Set targetPacket.carrier)
  calc
    _ = closure
        (equiv ''
          (AddSubgroup.closure sourceShells.pureIntegralTensors :
            Set packet.carrier)) :=
      equiv.toHomeomorph.image_closure _
    _ = closure
        (AddSubgroup.closure targetShells.pureIntegralTensors :
          Set targetPacket.carrier) := by
      congr 1
      calc
        equiv ''
            (AddSubgroup.closure sourceShells.pureIntegralTensors :
              Set packet.carrier) =
          (AddSubgroup.map addMap
            (AddSubgroup.closure sourceShells.pureIntegralTensors) :
              Set targetPacket.carrier) := by
            symm
            exact AddSubgroup.coe_map addMap _
        _ = (AddSubgroup.closure
              (equiv '' sourceShells.pureIntegralTensors) :
                Set targetPacket.carrier) := by
          exact congrArg (fun subgroup : AddSubgroup targetPacket.carrier =>
            (subgroup : Set targetPacket.carrier))
              (AddMonoidHom.map_closure addMap sourceShells.pureIntegralTensors)
        _ = (AddSubgroup.closure targetShells.pureIntegralTensors :
              Set targetPacket.carrier) := by rw [pure_image]

/-- The induced lattice on `log(A,alpha D_v)`. -/
def distinguishedLattice
    (shells : SourceNonarchimedeanPacketShells packet)
    (distinguished : Fin (j + 1)) (place : packet.place) :
    AddSubgroup packet.carrier :=
  shells.packetLattice ⊓
    (packet.distinguishedSubmodule distinguished place).toAddSubgroup

end SourceNonarchimedeanPacketShells

/--
Span certificates for the fixed nonarchimedean packet and distinguished
lattices.  Their carriers are definitions, not supplied fields.
-/
structure SourceNonarchimedeanPacketIntegralConstruction
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j) where
  shells : SourceNonarchimedeanPacketShells packet
  packet_rationalSpan_eq_top :
    Submodule.span ℚ (shells.packetLattice : Set packet.carrier) = ⊤
  distinguishedSubmodule_isClosed :
    ∀ distinguished place,
      IsClosed
        (packet.distinguishedSubmodule distinguished place :
          Set packet.carrier)
  distinguished_rationalSpan :
    ∀ distinguished place,
      Submodule.span ℚ
          (shells.distinguishedLattice distinguished place :
            Set packet.carrier) =
        packet.distinguishedSubmodule distinguished place

namespace SourceNonarchimedeanPacketIntegralConstruction

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}

/-- The full packet integral region derived from the closed tensor lattice. -/
def fullRegion
    (construction :
      SourceNonarchimedeanPacketIntegralConstruction packet) :
    SourceIntegralRegionOn .nonarchimedean packet.carrier ⊤ where
  carrier := construction.shells.packetLattice
  isClosed_carrier := by
    simpa [SourceNonarchimedeanPacketShells.packetLattice] using
      (AddSubgroup.isClosed_topologicalClosure
        (AddSubgroup.closure construction.shells.pureIntegralTensors))
  zero_mem := construction.shells.packetLattice.zero_mem
  rationalSpan_eq := construction.packet_rationalSpan_eq_top
  nonarchimedean_lattice _ :=
    ⟨construction.shells.packetLattice, rfl⟩
  archimedean_unitBall h := nomatch h

/-- The distinguished integral region derived by intersection with its summand. -/
def distinguishedRegion
    (construction :
      SourceNonarchimedeanPacketIntegralConstruction packet)
    (distinguished : Fin (j + 1)) (place : packet.place) :
    SourceIntegralRegionOn .nonarchimedean packet.carrier
      (packet.distinguishedSubmodule distinguished place) where
  carrier := construction.shells.distinguishedLattice distinguished place
  isClosed_carrier :=
    ((by
        simpa [SourceNonarchimedeanPacketShells.packetLattice] using
          (AddSubgroup.isClosed_topologicalClosure
            (AddSubgroup.closure
              construction.shells.pureIntegralTensors))) :
      IsClosed (construction.shells.packetLattice : Set packet.carrier)).inter
      (construction.distinguishedSubmodule_isClosed distinguished place)
  zero_mem :=
    (construction.shells.distinguishedLattice
      distinguished place).zero_mem
  rationalSpan_eq :=
    construction.distinguished_rationalSpan distinguished place
  nonarchimedean_lattice _ :=
    ⟨construction.shells.distinguishedLattice distinguished place, rfl⟩
  archimedean_unitBall h := nomatch h

end SourceNonarchimedeanPacketIntegralConstruction

/--
The Hermitian direct-sum and tensor-product construction at an archimedean
rational place.  The displayed equations are the metric constructions of
Proposition 3.2(ii), not unconstrained packet seminorms.
-/
structure SourceArchimedeanPacketIntegralConstruction
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j) where
  summandMetric :
    ∀ (factor : Fin (j + 1)) (place : packet.place),
      SourceArchimedeanIntegralStructure
        ((packet.factor factor).summand place)
  factorMetric :
    ∀ factor : Fin (j + 1),
      SourceArchimedeanIntegralStructure (packet.factor factor).carrier
  factorMetric_sq :
    ∀ factor value,
      (factorMetric factor).seminorm value ^ 2 =
        ∑ place,
          (summandMetric factor place).seminorm
            ((packet.factor factor).directSumIso.hom value place) ^ 2
  factorMetric_inner :
    ∀ factor first second,
      (factorMetric factor).inner first second =
        ∑ place,
          (summandMetric factor place).inner
            ((packet.factor factor).directSumIso.hom first place)
            ((packet.factor factor).directSumIso.hom second place)
  packetMetric : SourceArchimedeanIntegralStructure packet.carrier
  packetMetric_tprod :
    ∀ components : ∀ factor, (packet.factor factor).carrier,
      packetMetric.seminorm
          (packet.tensorIso.inv (PiTensorProduct.tprod ℚ components)) =
        ∏ factor, (factorMetric factor).seminorm (components factor)
  packetMetric_inner_tprod :
    ∀ (first second : ∀ factor, (packet.factor factor).carrier),
      packetMetric.inner
          (packet.tensorIso.inv (PiTensorProduct.tprod ℚ first))
          (packet.tensorIso.inv (PiTensorProduct.tprod ℚ second)) =
        ∏ factor,
          (factorMetric factor).inner (first factor) (second factor)
  packet_rationalSpan_eq_top :
    Submodule.span ℚ packetMetric.unitBall = ⊤
  distinguishedMetric :
    ∀ distinguished place,
      SourceArchimedeanIntegralStructure
        (SourceTopologicalQModule.submodule packet.carrier
          (packet.distinguishedSubmodule distinguished place))
  distinguishedMetric_induced :
    ∀ distinguished place value,
      (distinguishedMetric distinguished place).seminorm value =
        packetMetric.seminorm value.1
  distinguishedMetric_inner_induced :
    ∀ distinguished place first second,
      (distinguishedMetric distinguished place).inner first second =
        packetMetric.inner first.1 second.1
  distinguishedCarrier_isClosed :
    ∀ distinguished place,
      IsClosed
        (Subtype.val ''
          (distinguishedMetric distinguished place).unitBall :
            Set packet.carrier)
  distinguished_rationalSpan :
    ∀ distinguished place,
      Submodule.span ℚ
          (Subtype.val ''
            (distinguishedMetric distinguished place).unitBall :
              Set packet.carrier) =
        packet.distinguishedSubmodule distinguished place

namespace SourceArchimedeanPacketIntegralConstruction

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}

/-- The full archimedean unit ball as an integral region. -/
def fullRegion
    (construction :
      SourceArchimedeanPacketIntegralConstruction packet) :
    SourceIntegralRegionOn .archimedean packet.carrier ⊤ where
  carrier := construction.packetMetric.unitBall
  isClosed_carrier := construction.packetMetric.isClosed_unitBall
  zero_mem := construction.packetMetric.zero_mem_unitBall
  rationalSpan_eq := construction.packet_rationalSpan_eq_top
  nonarchimedean_lattice h := nomatch h
  archimedean_unitBall _ :=
    ⟨construction.packetMetric.restrict ⊤,
      construction.packetMetric.image_unitBall_restrict_top.symm⟩

/-- The unit ball of the induced metric on a distinguished submodule. -/
def distinguishedRegion
    (construction :
      SourceArchimedeanPacketIntegralConstruction packet)
    (distinguished : Fin (j + 1)) (place : packet.place) :
    SourceIntegralRegionOn .archimedean packet.carrier
      (packet.distinguishedSubmodule distinguished place) where
  carrier :=
    Subtype.val ''
      (construction.distinguishedMetric distinguished place).unitBall
  isClosed_carrier :=
    construction.distinguishedCarrier_isClosed distinguished place
  zero_mem :=
    ⟨0,
      (construction.distinguishedMetric
        distinguished place).zero_mem_unitBall,
      rfl⟩
  rationalSpan_eq :=
    construction.distinguished_rationalSpan distinguished place
  nonarchimedean_lattice h := nomatch h
  archimedean_unitBall _ :=
    ⟨construction.distinguishedMetric distinguished place, rfl⟩

end SourceArchimedeanPacketIntegralConstruction

/--
The Proposition 3.2(ii) packet construction selected by the packet's actual
rational place.  This prevents an independently chosen place kind from being
paired with the packet.
-/
def SourcePacketIntegralConstruction
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j) : Type u :=
  match packet.rationalPlace.kind with
  | .nonarchimedean => SourceNonarchimedeanPacketIntegralConstruction packet
  | .archimedean => SourceArchimedeanPacketIntegralConstruction packet

namespace SourcePacketIntegralConstruction

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}

/-- Extract the finite-place construction after proving the packet place finite. -/
def asNonarchimedean
    (construction : SourcePacketIntegralConstruction packet)
    (hkind : packet.rationalPlace.kind = .nonarchimedean) :
    SourceNonarchimedeanPacketIntegralConstruction packet := by
  rw [SourcePacketIntegralConstruction, hkind] at construction
  exact construction

/-- Extract the infinite-place construction after proving the packet place infinite. -/
def asArchimedean
    (construction : SourcePacketIntegralConstruction packet)
    (hkind : packet.rationalPlace.kind = .archimedean) :
    SourceArchimedeanPacketIntegralConstruction packet := by
  rw [SourcePacketIntegralConstruction, hkind] at construction
  exact construction

/-- The full packet region is derived by the rational-place case split. -/
def fullRegion
    (construction : SourcePacketIntegralConstruction packet) :
    SourceIntegralRegionOn packet.rationalPlace.kind packet.carrier ⊤ := by
  cases hkind : packet.rationalPlace.kind with
  | nonarchimedean =>
      rw [SourcePacketIntegralConstruction, hkind] at construction
      simpa only [hkind] using construction.fullRegion
  | archimedean =>
      rw [SourcePacketIntegralConstruction, hkind] at construction
      simpa only [hkind] using construction.fullRegion

/-- Every distinguished region is derived from the same packet construction. -/
def distinguishedRegion
    (construction : SourcePacketIntegralConstruction packet)
    (distinguished : Fin (j + 1)) (place : packet.place) :
    SourceIntegralRegionOn packet.rationalPlace.kind packet.carrier
      (packet.distinguishedSubmodule distinguished place) := by
  cases hkind : packet.rationalPlace.kind with
  | nonarchimedean =>
      rw [SourcePacketIntegralConstruction, hkind] at construction
      simpa only [hkind] using
        construction.distinguishedRegion distinguished place
  | archimedean =>
      rw [SourcePacketIntegralConstruction, hkind] at construction
      simpa only [hkind] using
        construction.distinguishedRegion distinguished place

/-- The full finite-place region without a dependent place-kind recast. -/
def fullNonarchimedeanRegion
    (construction : SourcePacketIntegralConstruction packet)
    (hkind : packet.rationalPlace.kind = .nonarchimedean) :
    SourceIntegralRegionOn .nonarchimedean packet.carrier ⊤ :=
  (construction.asNonarchimedean hkind).fullRegion

/-- A distinguished finite-place region without a dependent recast. -/
def distinguishedNonarchimedeanRegion
    (construction : SourcePacketIntegralConstruction packet)
    (hkind : packet.rationalPlace.kind = .nonarchimedean)
    (distinguished : Fin (j + 1)) (place : packet.place) :
    SourceIntegralRegionOn .nonarchimedean packet.carrier
      (packet.distinguishedSubmodule distinguished place) :=
  (construction.asNonarchimedean hkind).distinguishedRegion
    distinguished place

/-- The full infinite-place region without a dependent place-kind recast. -/
def fullArchimedeanRegion
    (construction : SourcePacketIntegralConstruction packet)
    (hkind : packet.rationalPlace.kind = .archimedean) :
    SourceIntegralRegionOn .archimedean packet.carrier ⊤ :=
  (construction.asArchimedean hkind).fullRegion

/-- A distinguished infinite-place region without a dependent recast. -/
def distinguishedArchimedeanRegion
    (construction : SourcePacketIntegralConstruction packet)
    (hkind : packet.rationalPlace.kind = .archimedean)
    (distinguished : Fin (j + 1)) (place : packet.place) :
    SourceIntegralRegionOn .archimedean packet.carrier
      (packet.distinguishedSubmodule distinguished place) :=
  (construction.asArchimedean hkind).distinguishedRegion
    distinguished place

end SourcePacketIntegralConstruction

/-- The place-dependent integral structure used in Theorem 3.11(i)(a). -/
def SourceMonoAnalyticIntegralStructure
    (kind : SourceRationalPlaceKind)
    (M : SourceTopologicalQModule.{u}) : Type u :=
  match kind with
  | .nonarchimedean => SourceNonarchimedeanIntegralStructure M
  | .archimedean => SourceArchimedeanIntegralStructure M

namespace SourceMonoAnalyticIntegralStructure

variable {kind : SourceRationalPlaceKind}
variable {M : SourceTopologicalQModule.{u}}

/-- The log-shell subset represented by a place-dependent integral structure. -/
def carrier
    (integral : SourceMonoAnalyticIntegralStructure kind M) : Set M :=
  match kind, integral with
  | .nonarchimedean, integral => (integral.lattice : Set M)
  | .archimedean, integral => integral.unitBall

theorem zero_mem
    (integral : SourceMonoAnalyticIntegralStructure kind M) :
    (0 : M) ∈ integral.carrier := by
  cases kind with
  | nonarchimedean => exact integral.lattice.zero_mem
  | archimedean => exact integral.zero_mem_unitBall

theorem isClosed
    (integral : SourceMonoAnalyticIntegralStructure kind M) :
    IsClosed integral.carrier := by
  cases kind with
  | nonarchimedean => exact integral.isClosed_lattice
  | archimedean => exact integral.isClosed_unitBall

/-- Extract the finite-place lattice after identifying the place kind. -/
def asNonarchimedean
    (integral : SourceMonoAnalyticIntegralStructure kind M)
    (hkind : kind = .nonarchimedean) :
    SourceNonarchimedeanIntegralStructure M := by
  subst kind
  exact integral

@[simp]
theorem asNonarchimedean_lattice
    (integral : SourceMonoAnalyticIntegralStructure kind M)
    (hkind : kind = .nonarchimedean) :
    ((integral.asNonarchimedean hkind).lattice : Set M) = integral.carrier := by
  subst kind
  rfl

/-- Extract the infinite-place metric after identifying the place kind. -/
def asArchimedean
    (integral : SourceMonoAnalyticIntegralStructure kind M)
    (hkind : kind = .archimedean) :
    SourceArchimedeanIntegralStructure M := by
  subst kind
  exact integral

@[simp]
theorem asArchimedean_unitBall
    (integral : SourceMonoAnalyticIntegralStructure kind M)
    (hkind : kind = .archimedean) :
    (integral.asArchimedean hkind).unitBall = integral.carrier := by
  subst kind
  rfl

end SourceMonoAnalyticIntegralStructure

/-- An open subgroup of a topological group. -/
def SourceOpenSubgroup (G : Type u) [Group G] [TopologicalSpace G] :=
  {subgroup : Subgroup G | IsOpen (subgroup : Set G)}

/-- A chosen compact topological-group structure on an algebraic group. -/
structure SourceCompactTopologicalGroupStructure
    (G : Type u) [Group G] where
  topology : TopologicalSpace G
  isTopologicalGroup :
    let _ : TopologicalSpace G := topology
    IsTopologicalGroup G
  compactSpace :
    let _ : TopologicalSpace G := topology
    CompactSpace G

/--
The data used in IUT II, Example 1.8(iv), to define `Ism(G)`: a continuous
profinite Galois action and the lattice attached to every open subgroup.
-/
structure SourceNonarchimedeanLogShellSymmetryCore
    (M : SourceTopologicalQModule.{u})
    (integral : SourceNonarchimedeanIntegralStructure M) where
  galois : ProfiniteGrp.{u}
  action : galois -> M ≃L[ℚ] M
  action_one : ∀ value, action 1 value = value
  action_mul :
    ∀ first second value,
      action (first * second) value = action first (action second value)
  continuous_action :
    Continuous (fun value : galois × M => action value.1 value.2)
  invariantLattice : SourceOpenSubgroup galois -> AddSubgroup M
  invariantLattice_le_shell :
    ∀ subgroup, invariantLattice subgroup ≤ integral.lattice

namespace SourceNonarchimedeanLogShellSymmetryCore

variable
    {M : SourceTopologicalQModule.{u}}
    {integral : SourceNonarchimedeanIntegralStructure M}

/-- A continuous linear automorphism is a `G`-isometry exactly as in Example 1.8(iv). -/
def IsGaloisIsometry
    (core : SourceNonarchimedeanLogShellSymmetryCore M integral)
    (automorphism : M ≃L[ℚ] M) : Prop :=
  (∀ g value,
      automorphism (core.action g value) =
        core.action g (automorphism value)) ∧
    ∀ subgroup,
      automorphism '' (core.invariantLattice subgroup : Set M) =
        (core.invariantLattice subgroup : Set M)

/-- The actual algebraic group `Ism(G)` of all lattice-preserving G-isometries. -/
def IsmSubgroup
    (core : SourceNonarchimedeanLogShellSymmetryCore M integral) :
    Subgroup (M ≃L[ℚ] M) where
  carrier := core.IsGaloisIsometry
  one_mem' := by
    constructor
    · intro g value
      rfl
    · intro subgroup
      ext value
      change
        (∃ source ∈ core.invariantLattice subgroup, source = value) ↔
          value ∈ core.invariantLattice subgroup
      simp
  mul_mem' := by
    intro first second hfirst hsecond
    constructor
    · intro g value
      change first (second (core.action g value)) =
        core.action g (first (second value))
      rw [hsecond.1, hfirst.1]
    · intro subgroup
      ext value
      constructor
      · rintro ⟨source, hsource, hvalue⟩
        change first (second source) = value at hvalue
        have hsecondSource :
            second source ∈ core.invariantLattice subgroup := by
          have : second source ∈
              second '' (core.invariantLattice subgroup : Set M) :=
            ⟨source, hsource, rfl⟩
          simpa only [hsecond.2 subgroup] using this
        have hfirstSource :
            first (second source) ∈ core.invariantLattice subgroup := by
          have : first (second source) ∈
              first '' (core.invariantLattice subgroup : Set M) :=
            ⟨second source, hsecondSource, rfl⟩
          simpa only [hfirst.2 subgroup] using this
        rwa [hvalue] at hfirstSource
      · intro hvalue
        have hfirstImage : value ∈
            first '' (core.invariantLattice subgroup : Set M) := by
          simpa only [hfirst.2 subgroup] using hvalue
        rcases hfirstImage with ⟨middle, hmiddle, rfl⟩
        have hsecondImage : middle ∈
            second '' (core.invariantLattice subgroup : Set M) := by
          simpa only [hsecond.2 subgroup] using hmiddle
        rcases hsecondImage with ⟨source, hsource, rfl⟩
        exact ⟨source, hsource, rfl⟩
  inv_mem' := by
    intro automorphism hautomorphism
    constructor
    · intro g value
      apply automorphism.injective
      change
        automorphism (automorphism.symm (core.action g value)) =
          automorphism (core.action g (automorphism.symm value))
      rw [automorphism.apply_symm_apply]
      rw [hautomorphism.1 g (automorphism.symm value)]
      rw [automorphism.apply_symm_apply]
    · intro subgroup
      ext value
      constructor
      · rintro ⟨source, hsource, rfl⟩
        change automorphism.symm source ∈ core.invariantLattice subgroup
        have himage : source ∈
            automorphism '' (core.invariantLattice subgroup : Set M) := by
          simpa only [hautomorphism.2 subgroup] using hsource
        rcases himage with ⟨preimage, hpreimage, heq⟩
        have hinverse : automorphism.symm source = preimage := by
          rw [← heq, automorphism.symm_apply_apply]
        rw [hinverse]
        exact hpreimage
      · intro hvalue
        refine ⟨automorphism value, ?_, ?_⟩
        have : automorphism value ∈
            automorphism '' (core.invariantLattice subgroup : Set M) :=
          ⟨value, hvalue, rfl⟩
        simpa only [hautomorphism.2 subgroup] using this
        exact automorphism.symm_apply_apply value

/-- The carrier of the source's compact isometry group. -/
abbrev Ism
    (core : SourceNonarchimedeanLogShellSymmetryCore M integral) :=
  core.IsmSubgroup

/-- Every member of `Ism` acts on the logarithmic module. -/
def ismAction
    (core : SourceNonarchimedeanLogShellSymmetryCore M integral)
    (isometry : core.Ism) : M ≃L[ℚ] M :=
  isometry.1

end SourceNonarchimedeanLogShellSymmetryCore

/-- The full finite-place `Ism`, including its cited compact topology. -/
structure SourceNonarchimedeanLogShellSymmetry
    (M : SourceTopologicalQModule.{u})
    (integral : SourceNonarchimedeanIntegralStructure M) where
  core : SourceNonarchimedeanLogShellSymmetryCore M integral
  compactTopology : SourceCompactTopologicalGroupStructure core.Ism

/--
The archimedean independent sign actions from Proposition 1.2(vii).  A choice
is one copy of `Z/2Z` for every direct factor used by the reconstruction.
-/
structure SourceArchimedeanLogShellSymmetry
    (M : SourceTopologicalQModule.{u})
    (integral : SourceArchimedeanIntegralStructure M) where
  factorIndex : Type u
  [factorFintype : Fintype factorIndex]
  action : (factorIndex -> Multiplicative (ZMod 2)) -> M ≃L[ℚ] M
  action_one : ∀ value, action 1 value = value
  action_mul :
    ∀ first second value,
      action (first * second) value = action first (action second value)
  unitBall_image :
    ∀ choice, action choice '' integral.unitBall = integral.unitBall

attribute [instance]
  SourceArchimedeanLogShellSymmetry.factorFintype

namespace SourceArchimedeanLogShellSymmetry

variable
    {M : SourceTopologicalQModule.{u}}
    {integral : SourceArchimedeanIntegralStructure M}

/-- Every independent archimedean sign choice has order dividing two. -/
theorem choice_square
    (symmetry : SourceArchimedeanLogShellSymmetry M integral)
    (choice : symmetry.factorIndex -> Multiplicative (ZMod 2)) :
    choice * choice = 1 := by
  funext factor
  apply Multiplicative.toAdd.injective
  exact ZModModule.add_self (choice factor).toAdd

end SourceArchimedeanLogShellSymmetry

/-- The source-prescribed Ind2 symmetry, indexed by the actual place kind. -/
inductive SourceMonoAnalyticLogShellSymmetryData
    (M : SourceTopologicalQModule.{u}) :
    ∀ kind : SourceRationalPlaceKind,
      SourceMonoAnalyticIntegralStructure kind M -> Type (u + 1)
  | nonarchimedean
      (integral : SourceNonarchimedeanIntegralStructure M)
      (symmetry : SourceNonarchimedeanLogShellSymmetry M integral) :
      SourceMonoAnalyticLogShellSymmetryData M .nonarchimedean integral
  | archimedean
      (integral : SourceArchimedeanIntegralStructure M)
      (symmetry : SourceArchimedeanLogShellSymmetry M integral) :
      SourceMonoAnalyticLogShellSymmetryData M .archimedean integral

namespace SourceMonoAnalyticLogShellSymmetryData

variable {M : SourceTopologicalQModule.{u}}
variable {kind : SourceRationalPlaceKind}
variable {integral : SourceMonoAnalyticIntegralStructure kind M}

/-- The actual group underlying the indexed source symmetry. -/
def GroupType
    (data : SourceMonoAnalyticLogShellSymmetryData M kind integral) : Type u :=
  match data with
  | .nonarchimedean _ symmetry => symmetry.core.Ism
  | .archimedean _ symmetry =>
      symmetry.factorIndex -> Multiplicative (ZMod 2)

noncomputable instance groupTypeGroup
    (data : SourceMonoAnalyticLogShellSymmetryData M kind integral) :
    Group data.GroupType := by
  cases data <;> simp only [GroupType] <;> infer_instance

/-- The corresponding continuous source automorphism, regarded linearly. -/
noncomputable def action
    (data : SourceMonoAnalyticLogShellSymmetryData M kind integral)
    (choice : data.GroupType) : M ≃ₗ[ℚ] M :=
  match data with
  | .nonarchimedean _ symmetry =>
      (symmetry.core.ismAction choice).toLinearEquiv
  | .archimedean _ symmetry =>
      (symmetry.action choice).toLinearEquiv

theorem action_one
    (data : SourceMonoAnalyticLogShellSymmetryData M kind integral)
    (value : M) : data.action 1 value = value := by
  cases data with
  | nonarchimedean => rfl
  | archimedean _ symmetry => exact symmetry.action_one value

theorem action_mul
    (data : SourceMonoAnalyticLogShellSymmetryData M kind integral)
    (first second : data.GroupType) (value : M) :
    data.action (first * second) value =
      data.action first (data.action second value) := by
  cases data with
  | nonarchimedean => rfl
  | archimedean _ symmetry => exact symmetry.action_mul first second value

/-- The infinite-place constructor has exponent two. -/
theorem square_of_archimedean
    (data : SourceMonoAnalyticLogShellSymmetryData M kind integral)
    (hkind : kind = .archimedean)
    (choice : data.GroupType) : choice * choice = 1 := by
  cases data with
  | nonarchimedean => contradiction
  | archimedean _ symmetry => exact symmetry.choice_square choice

end SourceMonoAnalyticLogShellSymmetryData

/--
A normalized log-volume functional on its source-prescribed class `M(-)` of
admissible regions.  Remark 3.1.1(iii)-(iv) explicitly warns that weighted
packet log-volumes need not be logarithms of ordinary measures, so the
functional is not falsely bundled as a `Measure`.  Actual measures remain in
the direct-summand realization below.
-/
structure SourceNormalizedLogVolume
    (M : SourceTopologicalQModule.{u}) where
  admissible : Set M -> Prop
  rawLogVolume : ∀ region, admissible region -> ℝ
  integralRegion : Set M
  integralRegion_admissible : admissible integralRegion
  normalizationOffset : ℝ

namespace SourceNormalizedLogVolume

variable {M : SourceTopologicalQModule.{u}}

/-- One region in the source-prescribed domain `M(-)` of the functional. -/
structure AdmissibleRegion (volume : SourceNormalizedLogVolume M) where
  carrier : Set M
  isAdmissible : volume.admissible carrier

/-- The distinguished integral region as an admissible region. -/
def integralAdmissibleRegion
    (volume : SourceNormalizedLogVolume M) : volume.AdmissibleRegion where
  carrier := volume.integralRegion
  isAdmissible := volume.integralRegion_admissible

/-- The normalized log-volume functional on an admissible region. -/
noncomputable def valueOn
    (volume : SourceNormalizedLogVolume M)
    (region : volume.AdmissibleRegion) : ℝ :=
  volume.rawLogVolume region.carrier region.isAdmissible -
      volume.normalizationOffset

/-- The normalized log-volume of the distinguished integral region. -/
noncomputable def value (volume : SourceNormalizedLogVolume M) : ℝ :=
  volume.valueOn volume.integralAdmissibleRegion

/--
Compatibility transports the complete admissible-region domain and raw
log-volume functional, not merely the distinguished integral value.
-/
structure Compatible
    {N : SourceTopologicalQModule.{u}}
    (source : SourceNormalizedLogVolume M)
    (target : SourceNormalizedLogVolume N)
    (equiv : M ≃L[ℚ] N) : Prop where
  admissible_image :
    ∀ region : source.AdmissibleRegion,
      target.admissible (equiv '' region.carrier)
  rawLogVolume_image :
    ∀ region : source.AdmissibleRegion,
      target.rawLogVolume (equiv '' region.carrier)
          (admissible_image region) =
        source.rawLogVolume region.carrier region.isAdmissible
  normalizationOffset_eq :
    target.normalizationOffset = source.normalizationOffset

namespace Compatible

variable
    {N : SourceTopologicalQModule.{u}}
    {source : SourceNormalizedLogVolume M}
    {target : SourceNormalizedLogVolume N}
    {equiv : M ≃L[ℚ] N}

/-- Transport an admissible region through a compatible packet map. -/
def mapRegion
    (compatible : Compatible source target equiv)
    (region : source.AdmissibleRegion) : target.AdmissibleRegion where
  carrier := equiv '' region.carrier
  isAdmissible := compatible.admissible_image region

/-- Compatible packet maps preserve the full normalized log-volume functional. -/
theorem valueOn_mapRegion
    (compatible : Compatible source target equiv)
    (region : source.AdmissibleRegion) :
    target.valueOn (compatible.mapRegion region) = source.valueOn region := by
  rw [valueOn, valueOn]
  change
    target.rawLogVolume (equiv '' region.carrier)
          (compatible.admissible_image region) - target.normalizationOffset =
      source.rawLogVolume region.carrier region.isAdmissible -
        source.normalizationOffset
  rw [compatible.rawLogVolume_image region,
    compatible.normalizationOffset_eq]

/--
If the packet map carries the distinguished integral region to the target
integral region, compatibility of the full functional gives equality of the
distinguished normalized values.
-/
theorem value_eq
    (compatible : Compatible source target equiv)
    (integralRegion_image :
      equiv '' source.integralRegion = target.integralRegion) :
    source.value = target.value := by
  rw [value, value]
  symm
  simpa only [integralAdmissibleRegion, mapRegion, integralRegion_image] using
    compatible.valueOn_mapRegion source.integralAdmissibleRegion

end Compatible

/--
The additive shift required by the packet normalization of Proposition 3.9(i):
`-log(p)` at a finite rational place and `log(e) = 1` at infinity.
-/
noncomputable def packetLogVolumeShift :
    SourceRationalPlace -> ℝ
  | .finite place =>
      -Real.log (ThetaFinitePlace.residueCharacteristic place : ℝ)
  | .infinite _ => 1

/-- A functional realization of the source packet-normalization dilation. -/
structure PacketNormalization
    (rationalPlace : SourceRationalPlace)
    (volume : SourceNormalizedLogVolume M) where
  dilation : M ≃ M
  admissible_image :
    ∀ region : volume.AdmissibleRegion,
      volume.admissible (dilation '' region.carrier)
  rawLogVolume_dilation :
    ∀ region : volume.AdmissibleRegion,
      volume.rawLogVolume (dilation '' region.carrier)
          (admissible_image region) =
        volume.rawLogVolume region.carrier region.isAdmissible +
          packetLogVolumeShift rationalPlace

namespace PacketNormalization

variable {rationalPlace : SourceRationalPlace}
variable {volume : SourceNormalizedLogVolume M}

/-- Dilation carries an admissible region to another admissible region. -/
def dilateRegion
    (normalization : PacketNormalization rationalPlace volume)
    (region : volume.AdmissibleRegion) : volume.AdmissibleRegion where
  carrier := normalization.dilation '' region.carrier
  isAdmissible := normalization.admissible_image region

/-- The packet-normalized log-volume has exactly the source-prescribed shift. -/
theorem valueOn_dilateRegion
    (normalization : PacketNormalization rationalPlace volume)
    (region : volume.AdmissibleRegion) :
    volume.valueOn (normalization.dilateRegion region) =
      volume.valueOn region + packetLogVolumeShift rationalPlace := by
  rw [valueOn, valueOn]
  change
    volume.rawLogVolume (normalization.dilation '' region.carrier)
          (normalization.admissible_image region) -
        volume.normalizationOffset =
      (volume.rawLogVolume region.carrier region.isAdmissible -
        volume.normalizationOffset) +
          packetLogVolumeShift rationalPlace
  rw [normalization.rawLogVolume_dilation region]
  ring

end PacketNormalization

end SourceNormalizedLogVolume

/--
One genuine finite-stage field summand, together with the measure space on
which Proposition 3.9 computes its component log-volume.

At a finite place the radial carrier is identified with the additive local
field itself. At an infinite place it is identified with `R_{≥0}`, and the
radialization map is the complex norm after a chosen complex-field model. This
records the two cases of Absolute Anabelian Geometry III, Proposition 5.7,
without identifying radial length with planar Haar measure.
-/
structure SourcePacketMeasuredField
    (rationalPlace : SourceRationalPlace)
    (field : SourceTopologicalLocalField.{u} rationalPlace) where
  radialCarrier : Type u
  [radialTopologicalSpace : TopologicalSpace radialCarrier]
  [radialT2Space : T2Space radialCarrier]
  [radialLocallyCompactSpace : LocallyCompactSpace radialCarrier]
  [radialSecondCountableTopology : SecondCountableTopology radialCarrier]
  [radialMeasurableSpace : MeasurableSpace radialCarrier]
  [radialBorelSpace : BorelSpace radialCarrier]
  radialization : field.carrier → radialCarrier
  radialization_measurable : Measurable radialization
  nonarchimedeanRadialEquiv :
    rationalPlace.kind = .nonarchimedean →
      radialCarrier ≃ₜ field.carrier
  nonarchimedean_radialization :
    ∀ (hkind : rationalPlace.kind = .nonarchimedean) value,
      nonarchimedeanRadialEquiv hkind (radialization value) = value
  archimedeanComplexEquiv :
    rationalPlace.kind = .archimedean → field.carrier ≃ₜ ℂ
  archimedeanRadialEquiv :
    rationalPlace.kind = .archimedean → radialCarrier ≃ₜ NNReal
  archimedean_radialization :
    ∀ (hkind : rationalPlace.kind = .archimedean) value,
      archimedeanRadialEquiv hkind (radialization value) =
        nnnorm (archimedeanComplexEquiv hkind value)
  volume : SourceNormalizedLogVolume field.rationalModule
  measure : MeasureTheory.Measure radialCarrier
  measureSigmaFinite : MeasureTheory.SigmaFinite measure
  measureComplete : MeasureTheory.Measure.IsComplete measure
  admissible_radialImage_measurable :
    ∀ region : volume.AdmissibleRegion,
      MeasurableSet (radialization '' region.carrier)
  admissible_measure_ne_zero :
    ∀ region : volume.AdmissibleRegion,
      measure (radialization '' region.carrier) ≠ 0
  admissible_measure_ne_top :
    ∀ region : volume.AdmissibleRegion,
      measure (radialization '' region.carrier) ≠ ⊤
  integral_measure_eq_one :
    measure (radialization '' volume.integralRegion) = 1
  normalizationOffset_eq_zero : volume.normalizationOffset = 0
  rawLogVolume_eq_measure :
    ∀ region : volume.AdmissibleRegion,
      volume.rawLogVolume region.carrier region.isAdmissible =
        Real.log (measure (radialization '' region.carrier)).toReal

attribute [instance]
  SourcePacketMeasuredField.radialTopologicalSpace
  SourcePacketMeasuredField.radialT2Space
  SourcePacketMeasuredField.radialLocallyCompactSpace
  SourcePacketMeasuredField.radialSecondCountableTopology
  SourcePacketMeasuredField.radialMeasurableSpace
  SourcePacketMeasuredField.radialBorelSpace

namespace SourcePacketMeasuredField

instance sigmaFinite
    {rationalPlace : SourceRationalPlace}
    {field : SourceTopologicalLocalField.{u} rationalPlace}
    (measured : SourcePacketMeasuredField rationalPlace field) :
    MeasureTheory.SigmaFinite measured.measure :=
  measured.measureSigmaFinite

instance complete
    {rationalPlace : SourceRationalPlace}
    {field : SourceTopologicalLocalField.{u} rationalPlace}
    (measured : SourcePacketMeasuredField rationalPlace field) :
    MeasureTheory.Measure.IsComplete measured.measure :=
  measured.measureComplete

end SourcePacketMeasuredField

/--
A simultaneous finite-stage decomposition equipped with component volume data
on every genuine field summand.
-/
structure SourcePacketFiniteMeasuredFieldDecomposition
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    {presentation :
      SourceMonoAnalyticTensorPacketFieldPresentation packet}
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation) where
  measuredField :
    ∀ index : decomposition.FieldSummandIndex,
      SourcePacketMeasuredField packet.rationalPlace
        (decomposition.field index)

namespace SourcePacketFiniteMeasuredFieldDecomposition

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
variable {presentation :
  SourceMonoAnalyticTensorPacketFieldPresentation packet}
variable {decomposition :
  SourcePacketFiniteFieldDecomposition packet presentation}

/-- The measured local field at one internal coordinate of a place-tuple block. -/
abbrev blockMeasuredField
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex)
    (index : (decomposition.blockStage placeTuple).fieldIndex) :=
  measured.measuredField ⟨placeTuple, index⟩

/-- The genuine local-field coordinates of one chosen finite tensor stage. -/
abbrev BlockFieldCoordinates
    (placeTuple : packet.PlaceTupleIndex) :=
  ∀ index : (decomposition.blockStage placeTuple).fieldIndex,
    ((decomposition.blockStage placeTuple).field index).carrier

/--
The radial part `M_v` of Remark 3.1.1(iii): one radial coordinate for every
genuine field in the finite-stage decomposition of the place-tuple block.
-/
abbrev BlockRadialCoordinates
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :=
  ∀ index : (decomposition.blockStage placeTuple).fieldIndex,
    (measured.blockMeasuredField placeTuple index).radialCarrier

/-- The finite-stage field decomposition as a homeomorphism. -/
noncomputable def blockFieldDecomposition
    (placeTuple : packet.PlaceTupleIndex) :
    (decomposition.blockStage placeTuple).module ≃ₜ
      BlockFieldCoordinates (decomposition := decomposition) placeTuple :=
  (decomposition.blockStage placeTuple).fieldDecompositionHomeomorph

/-- Apply the source-prescribed finite/radial map in every genuine field. -/
def blockRadializeCoordinates
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex)
    (value : BlockFieldCoordinates
      (decomposition := decomposition) placeTuple) :
    measured.BlockRadialCoordinates placeTuple :=
  fun index =>
    (measured.blockMeasuredField placeTuple index).radialization (value index)

/-- The product of the fieldwise distinguished integral regions. -/
def blockFieldIntegralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    Set (BlockFieldCoordinates (decomposition := decomposition) placeTuple) :=
  Set.pi Set.univ fun index =>
    (measured.blockMeasuredField placeTuple index).volume.integralRegion

/-- The distinguished integral region in the finite tensor-stage algebra. -/
noncomputable def blockIntegralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    Set (decomposition.blockStage placeTuple).module :=
  (blockFieldDecomposition
      (decomposition := decomposition) placeTuple).symm ''
    measured.blockFieldIntegralRegion placeTuple

/-- The radial image of a region in one finite place-tuple stage. -/
def blockRadializedRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex)
    (region : Set (decomposition.blockStage placeTuple).module) :
    Set (measured.BlockRadialCoordinates placeTuple) :=
  measured.blockRadializeCoordinates placeTuple ''
    (blockFieldDecomposition
      (decomposition := decomposition) placeTuple '' region)

/-- The ordinary finite product measure on the radial part `M_v`. -/
noncomputable def blockProductMeasure
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    MeasureTheory.Measure (measured.BlockRadialCoordinates placeTuple) :=
  MeasureTheory.Measure.pi fun index =>
    (measured.blockMeasuredField placeTuple index).measure

noncomputable instance blockProductMeasureSigmaFinite
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    MeasureTheory.SigmaFinite (measured.blockProductMeasure placeTuple) := by
  unfold blockProductMeasure
  infer_instance

/-- The field decomposition carries the integral block to the fieldwise product. -/
theorem blockFieldDecomposition_image_integralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    blockFieldDecomposition (decomposition := decomposition) placeTuple ''
        measured.blockIntegralRegion placeTuple =
      measured.blockFieldIntegralRegion placeTuple := by
  ext value
  constructor
  · rintro ⟨sourceValue, ⟨fieldValue, hfieldValue, rfl⟩, rfl⟩
    simpa using hfieldValue
  · intro hvalue
    refine ⟨(blockFieldDecomposition
      (decomposition := decomposition) placeTuple).symm value, ?_, ?_⟩
    · exact ⟨value, hvalue, rfl⟩
    · exact (blockFieldDecomposition
        (decomposition := decomposition) placeTuple).apply_symm_apply value

/-- Membership in the integral block is detected in genuine field coordinates. -/
theorem blockIntegralRegion_iff
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex)
    (value : (decomposition.blockStage placeTuple).module) :
    value ∈ measured.blockIntegralRegion placeTuple ↔
      blockFieldDecomposition (decomposition := decomposition) placeTuple value ∈
        measured.blockFieldIntegralRegion placeTuple := by
  constructor
  · intro hvalue
    rw [← measured.blockFieldDecomposition_image_integralRegion placeTuple]
    exact ⟨value, hvalue, rfl⟩
  · intro hvalue
    rw [← measured.blockFieldDecomposition_image_integralRegion placeTuple] at hvalue
    obtain ⟨sourceValue, hsourceValue, heq⟩ := hvalue
    exact (blockFieldDecomposition
      (decomposition := decomposition) placeTuple).injective heq ▸ hsourceValue

/--
The radial image of the integral block is exactly the product of the genuine
fieldwise radial integral regions.
-/
theorem blockRadializedRegion_integralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    measured.blockRadializedRegion placeTuple
        (measured.blockIntegralRegion placeTuple) =
      Set.pi Set.univ fun index =>
        (measured.blockMeasuredField placeTuple index).radialization ''
          (measured.blockMeasuredField placeTuple index).volume.integralRegion := by
  classical
  rw [blockRadializedRegion,
    measured.blockFieldDecomposition_image_integralRegion placeTuple]
  ext value
  constructor
  · rintro ⟨sourceValue, hsourceValue, rfl⟩ index _
    exact ⟨sourceValue index,
      hsourceValue index (Set.mem_univ _), rfl⟩
  · intro hvalue
    choose sourceValue hsourceValue hradial using
      fun index => hvalue index (Set.mem_univ index)
    refine ⟨sourceValue, ?_, ?_⟩
    · intro index _
      exact hsourceValue index
    · funext index
      exact hradial index

/-- The distinguished radial block is Borel measurable. -/
theorem blockRadializedRegion_integralRegion_measurable
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    MeasurableSet
      (measured.blockRadializedRegion placeTuple
        (measured.blockIntegralRegion placeTuple)) := by
  rw [measured.blockRadializedRegion_integralRegion placeTuple]
  exact MeasurableSet.univ_pi fun index =>
    (measured.blockMeasuredField placeTuple index).admissible_radialImage_measurable
      (measured.blockMeasuredField placeTuple index).volume.integralAdmissibleRegion

/-- Every fieldwise integral normalization multiplies to measure one on `M_v`. -/
theorem blockProductMeasure_integralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    measured.blockProductMeasure placeTuple
        (measured.blockRadializedRegion placeTuple
          (measured.blockIntegralRegion placeTuple)) = 1 := by
  rw [blockProductMeasure,
    measured.blockRadializedRegion_integralRegion placeTuple,
    MeasureTheory.Measure.pi_pi]
  simp only [SourcePacketMeasuredField.integral_measure_eq_one,
    Finset.prod_const_one]

/-- The distinguished radial block has positive measure. -/
theorem blockProductMeasure_integralRegion_ne_zero
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    measured.blockProductMeasure placeTuple
        (measured.blockRadializedRegion placeTuple
          (measured.blockIntegralRegion placeTuple)) ≠ 0 := by
  rw [measured.blockProductMeasure_integralRegion placeTuple]
  exact one_ne_zero

/-- The distinguished radial block has finite measure. -/
theorem blockProductMeasure_integralRegion_ne_top
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    measured.blockProductMeasure placeTuple
        (measured.blockRadializedRegion placeTuple
          (measured.blockIntegralRegion placeTuple)) ≠ ⊤ := by
  rw [measured.blockProductMeasure_integralRegion placeTuple]
  exact ENNReal.one_ne_top

/--
The normalized log-volume of one finite place-tuple stage, constructed from
the genuine field measures rather than supplied as an arbitrary block field.
-/
noncomputable def blockVolume
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    SourceNormalizedLogVolume
      (decomposition.blockStage placeTuple).module where
  admissible := fun region =>
    MeasurableSet (measured.blockRadializedRegion placeTuple region) ∧
      measured.blockProductMeasure placeTuple
          (measured.blockRadializedRegion placeTuple region) ≠ 0 ∧
      measured.blockProductMeasure placeTuple
          (measured.blockRadializedRegion placeTuple region) ≠ ⊤
  rawLogVolume := fun region _ =>
    Real.log
      (measured.blockProductMeasure placeTuple
        (measured.blockRadializedRegion placeTuple region)).toReal
  integralRegion := measured.blockIntegralRegion placeTuple
  integralRegion_admissible :=
    ⟨measured.blockRadializedRegion_integralRegion_measurable placeTuple,
      measured.blockProductMeasure_integralRegion_ne_zero placeTuple,
      measured.blockProductMeasure_integralRegion_ne_top placeTuple⟩
  normalizationOffset :=
    ∑ index,
      (measured.blockMeasuredField placeTuple index).volume.normalizationOffset

/-- The block normalization offset is derived to be zero field by field. -/
theorem blockVolume_normalizationOffset_eq_zero
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    (measured.blockVolume placeTuple).normalizationOffset = 0 := by
  change
    (∑ index,
      (measured.blockMeasuredField placeTuple index).volume.normalizationOffset) = 0
  exact Finset.sum_eq_zero fun index _ =>
    (measured.blockMeasuredField placeTuple index).normalizationOffset_eq_zero

/-- The block raw log-volume is literally the log of its radial product measure. -/
theorem blockVolume_rawLogVolume_eq_measure
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex)
    (region : (measured.blockVolume placeTuple).AdmissibleRegion) :
    (measured.blockVolume placeTuple).rawLogVolume
        region.carrier region.isAdmissible =
      Real.log
        (measured.blockProductMeasure placeTuple
          (measured.blockRadializedRegion placeTuple region.carrier)).toReal :=
  rfl

/-- The distinguished integral block has normalized log-volume zero. -/
theorem blockVolume_value_eq_zero
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (placeTuple : packet.PlaceTupleIndex) :
    (measured.blockVolume placeTuple).value = 0 := by
  rw [SourceNormalizedLogVolume.value,
    SourceNormalizedLogVolume.valueOn]
  change
    Real.log
        (measured.blockProductMeasure placeTuple
          (measured.blockRadializedRegion placeTuple
            (measured.blockIntegralRegion placeTuple))).toReal -
      (measured.blockVolume placeTuple).normalizationOffset = 0
  rw [measured.blockProductMeasure_integralRegion placeTuple,
    measured.blockVolume_normalizationOffset_eq_zero placeTuple]
  norm_num

/-- The outer product `M_V` of the radial place-tuple blocks. -/
abbrev PacketRadialCoordinates
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition) :=
  ∀ placeTuple : packet.PlaceTupleIndex,
    measured.BlockRadialCoordinates placeTuple

/-- Radialize every field in every place-tuple block of the finite packet stage. -/
noncomputable def packetRadializeCoordinates
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (value : decomposition.stageModule) :
    measured.PacketRadialCoordinates :=
  fun placeTuple =>
    measured.blockRadializeCoordinates placeTuple
      (blockFieldDecomposition
        (decomposition := decomposition) placeTuple (value placeTuple))

/-- A direct product region in the selected finite packet stage. -/
def packetProductRegion
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      Set (decomposition.blockStage placeTuple).module) :
    Set decomposition.stageModule :=
  Set.pi Set.univ regions

/-- The radial image of a finite packet-stage region in `M_V`. -/
def packetRadializedRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (region : Set decomposition.stageModule) :
    Set measured.PacketRadialCoordinates :=
  measured.packetRadializeCoordinates '' region

/--
Radialization carries a direct product of place-tuple stage regions to the
direct product of their derived radial images.
-/
theorem packetRadializedRegion_productRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      Set (decomposition.blockStage placeTuple).module) :
    measured.packetRadializedRegion
        (packetProductRegion (decomposition := decomposition) regions) =
      Set.pi Set.univ fun placeTuple =>
        measured.blockRadializedRegion placeTuple (regions placeTuple) := by
  classical
  ext value
  constructor
  · rintro ⟨sourceValue, hsourceValue, rfl⟩ placeTuple _
    refine ⟨blockFieldDecomposition
      (decomposition := decomposition) placeTuple (sourceValue placeTuple), ?_, rfl⟩
    exact ⟨sourceValue placeTuple,
      hsourceValue placeTuple (Set.mem_univ _), rfl⟩
  · intro hvalue
    choose fieldValue hfieldValue hradial using
      fun placeTuple => hvalue placeTuple (Set.mem_univ placeTuple)
    choose sourceValue hsourceValue hfield using hfieldValue
    refine ⟨sourceValue, ?_, ?_⟩
    · intro placeTuple _
      exact hsourceValue placeTuple
    · funext placeTuple
      change
        measured.blockRadializeCoordinates placeTuple
            (blockFieldDecomposition
              (decomposition := decomposition) placeTuple
                (sourceValue placeTuple)) = value placeTuple
      rw [hfield placeTuple]
      exact hradial placeTuple

/-- The product of all fieldwise integral structures in the finite packet stage. -/
def packetIntegralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition) :
    Set decomposition.stageModule :=
  packetProductRegion (decomposition := decomposition) fun placeTuple =>
    measured.blockIntegralRegion placeTuple

/-- The distinguished finite packet-stage region inside the actual ind-packet. -/
noncomputable def embeddedPacketIntegralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition) :
    Set packet.carrier :=
  decomposition.stageEmbedding '' measured.packetIntegralRegion

/-- Injectivity identifies the preimage of the embedded integral region exactly. -/
theorem stageEmbedding_preimage_embeddedPacketIntegralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition) :
    decomposition.stageEmbedding ⁻¹'
        measured.embeddedPacketIntegralRegion =
      measured.packetIntegralRegion := by
  ext value
  constructor
  · rintro ⟨sourceValue, hsourceValue, heq⟩
    exact (decomposition.stageEmbedding_injective heq).symm ▸ hsourceValue
  · intro hvalue
    exact ⟨value, hvalue, rfl⟩

/-- The integral packet stage radializes to the exact product of field regions. -/
theorem packetRadializedRegion_integralRegion
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition) :
    measured.packetRadializedRegion measured.packetIntegralRegion =
      Set.pi Set.univ fun placeTuple =>
        Set.pi Set.univ fun index =>
          (measured.blockMeasuredField placeTuple index).radialization ''
            (measured.blockMeasuredField placeTuple index).volume.integralRegion := by
  rw [packetIntegralRegion,
    measured.packetRadializedRegion_productRegion]
  congr 1
  funext placeTuple
  exact measured.blockRadializedRegion_integralRegion placeTuple

end SourcePacketFiniteMeasuredFieldDecomposition

/--
The source-faithful finite-stage E/W log-volume data of Remark 3.1.1(ii)-(iv).

Only the two families of local degrees remain as arithmetic inputs. The packet
stage, every `M_v`, every component measure, and every component integral
region are derived from the genuine finite-stage field decomposition.
-/
structure SourcePacketFiniteStageLogVolume
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    {presentation :
      SourceMonoAnalyticTensorPacketFieldPresentation packet}
    (decomposition :
      SourcePacketFiniteFieldDecomposition packet presentation)
    (measured :
      SourcePacketFiniteMeasuredFieldDecomposition packet decomposition) where
  place_nonempty : Nonempty packet.place
  placeMultiplicity : packet.place → ℕ+
  placeNormalizationDegree : packet.place → ℕ+

namespace SourcePacketFiniteStageLogVolume

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
variable {presentation :
  SourceMonoAnalyticTensorPacketFieldPresentation packet}
variable {decomposition :
  SourcePacketFiniteFieldDecomposition packet presentation}
variable {measured :
  SourcePacketFiniteMeasuredFieldDecomposition packet decomposition}

/-- The cardinality `N_v`, obtained as the product of selected local degrees. -/
noncomputable def multiplicity
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (placeTuple : packet.PlaceTupleIndex) : ℕ+ :=
  ∏ factor, data.placeMultiplicity (placeTuple factor)

@[simp]
theorem multiplicity_val
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (placeTuple : packet.PlaceTupleIndex) :
    (data.multiplicity placeTuple).1 =
      ∏ factor, (data.placeMultiplicity (placeTuple factor)).1 := by
  change PNat.coeMonoidHom
    (∏ factor, data.placeMultiplicity (placeTuple factor)) = _
  rw [map_prod]
  rfl

/-- The denominator in the normalized weights of Remark 3.1.1(ii). -/
noncomputable def normalizationDenominator
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) : ℕ :=
  ∑ placeTuple : packet.PlaceTupleIndex,
    ∏ factor,
      (data.placeNormalizationDegree (placeTuple factor)).1

/-- The source weight denominator is strictly positive. -/
theorem normalizationDenominator_pos
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    0 < data.normalizationDenominator := by
  classical
  obtain ⟨place⟩ := data.place_nonempty
  let placeTuple : packet.PlaceTupleIndex := fun _ => place
  refine Finset.sum_pos' (fun _ _ => Nat.zero_le _)
    ⟨placeTuple, Finset.mem_univ _, ?_⟩
  exact Finset.prod_pos fun factor _ =>
    (data.placeNormalizationDegree (placeTuple factor)).2

/-- The reciprocal source weight normalization. -/
noncomputable def normalizationScale
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) : ℝ :=
  (data.normalizationDenominator : ℝ)⁻¹

theorem normalizationScale_pos
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    0 < data.normalizationScale := by
  rw [normalizationScale, inv_pos]
  exact_mod_cast data.normalizationDenominator_pos

/-- The product `E = ∏_v E_v`, with `#E_v = N_v`. -/
abbrev WeightChoice
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :=
  ∀ placeTuple, Fin (data.multiplicity placeTuple).1

/-- The product `E_{≠v}` of all weight coordinates away from `v`. -/
abbrev ReplicaFiber
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (placeTuple : packet.PlaceTupleIndex) :=
  ∀ other : {other : packet.PlaceTupleIndex // other ≠ placeTuple},
    Fin (data.multiplicity other.1).1

/-- The paper's replica index `W = ⨆_v E_{≠v}`. -/
abbrev ReplicaIndex
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :=
  Σ placeTuple : packet.PlaceTupleIndex,
    data.ReplicaFiber placeTuple

/-- The product `M_W` of replicated, derived radial place-tuple blocks. -/
abbrev ReplicaSpace
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :=
  ∀ replica : data.ReplicaIndex,
    measured.BlockRadialCoordinates replica.1

/-- Splitting off the `v`-coordinate identifies `E` with `E_v × E_{≠v}`. -/
noncomputable def weightChoiceEquiv
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (placeTuple : packet.PlaceTupleIndex) :
    data.WeightChoice ≃
      Fin (data.multiplicity placeTuple).1 × data.ReplicaFiber placeTuple where
  toFun := fun choice =>
    ⟨choice placeTuple, fun other => choice other.1⟩
  invFun := fun split other =>
    if hother : other = placeTuple then
      Fin.cast
        (congrArg (fun index => (data.multiplicity index).1) hother.symm)
        split.1
    else
      split.2 ⟨other, hother⟩
  left_inv := by
    intro choice
    funext other
    by_cases hother : other = placeTuple
    · subst other
      simp
    · simp [hother]
  right_inv := by
    rintro ⟨selected, away⟩
    apply Prod.ext
    · simp
    · funext other
      simp [other.2]

/-- The source identity `#E = N_v · #E_{≠v}`. -/
theorem weightChoice_card_factor
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (placeTuple : packet.PlaceTupleIndex) :
    Fintype.card data.WeightChoice =
      (data.multiplicity placeTuple).1 *
        Fintype.card (data.ReplicaFiber placeTuple) := by
  rw [Fintype.card_congr (data.weightChoiceEquiv placeTuple)]
  simp

/-- Grouping a sum over `W = ⨆_v E_{≠v}` by its image in `V`. -/
theorem sum_replica_fst
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (value : packet.PlaceTupleIndex → ℝ) :
    (∑ replica : data.ReplicaIndex, value replica.1) =
      ∑ placeTuple : packet.PlaceTupleIndex,
        (Fintype.card (data.ReplicaFiber placeTuple) : ℝ) *
          value placeTuple := by
  calc
    (∑ replica : data.ReplicaIndex, value replica.1) =
        ∑ placeTuple : packet.PlaceTupleIndex,
          ∑ _away : data.ReplicaFiber placeTuple, value placeTuple :=
      Fintype.sum_sigma fun replica : data.ReplicaIndex => value replica.1
    _ = _ := by
      apply Finset.sum_congr rfl
      intro placeTuple _
      simp

/--
The combinatorial identity in the final display of Remark 3.1.1(iv): dividing
the replicated sum by `#E` gives the sum of the reciprocal-`N_v` weights.
-/
theorem normalizedReplicaSum_eq_inverseMultiplicitySum
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (value : packet.PlaceTupleIndex → ℝ) :
    (∑ replica : data.ReplicaIndex, value replica.1) /
        Fintype.card data.WeightChoice =
      ∑ placeTuple : packet.PlaceTupleIndex,
        value placeTuple / (data.multiplicity placeTuple).1 := by
  rw [data.sum_replica_fst value, Finset.sum_div]
  apply Finset.sum_congr rfl
  intro placeTuple _
  rw [data.weightChoice_card_factor placeTuple, Nat.cast_mul]
  have hmultiplicity :
      (data.multiplicity placeTuple).1 ≠ 0 :=
    Nat.ne_of_gt (data.multiplicity placeTuple).pos
  have hfiber :
      Fintype.card (data.ReplicaFiber placeTuple) ≠ 0 := by
    exact Nat.ne_of_gt (Fintype.card_pos_iff.mpr
      ⟨fun other => ⟨0, (data.multiplicity other.1).pos⟩⟩)
  field_simp

/-- Read from `M_W` the `M_V` tuple associated to one `e ∈ E`. -/
def slice
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (value : data.ReplicaSpace) (choice : data.WeightChoice) :
    measured.PacketRadialCoordinates :=
  fun placeTuple =>
    value ⟨placeTuple, fun other => choice other.1⟩

/-- The exact subset `S_E ⊆ M_W` in Remark 3.1.1(iv). -/
def weightedLift
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (region : Set decomposition.stageModule) :
    Set data.ReplicaSpace :=
  {value | ∀ choice,
    data.slice value choice ∈ measured.packetRadializedRegion region}

/-- The ordinary product measure on the replicated radial space `M_W`. -/
noncomputable def replicaProductMeasure
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    MeasureTheory.Measure data.ReplicaSpace :=
  MeasureTheory.Measure.pi fun replica =>
    measured.blockProductMeasure replica.1

/-- Mochizuki's `E`-weighted content, which is not a measure in `region`. -/
noncomputable def weightedContent
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (region : Set decomposition.stageModule) : ENNReal :=
  data.replicaProductMeasure (data.weightedLift region)

/--
For every direct product region, the weighted lift is exactly the product of
the replicated derived block radial regions.
-/
theorem weightedLift_productRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      Set (decomposition.blockStage placeTuple).module) :
    data.weightedLift
        (SourcePacketFiniteMeasuredFieldDecomposition.packetProductRegion
          (decomposition := decomposition) regions) =
      Set.pi Set.univ fun replica : data.ReplicaIndex =>
        measured.blockRadializedRegion replica.1 (regions replica.1) := by
  classical
  have himage := measured.packetRadializedRegion_productRegion regions
  ext value
  constructor
  · intro hvalue replica _
    let choice : data.WeightChoice := fun placeTuple =>
      if hindex : placeTuple = replica.1 then
        ⟨0, (data.multiplicity placeTuple).pos⟩
      else
        replica.2 ⟨placeTuple, hindex⟩
    have hslice := hvalue choice
    rw [himage] at hslice
    have hcomponent := hslice replica.1 (Set.mem_univ _)
    change value replica ∈
      measured.blockRadializedRegion replica.1 (regions replica.1)
    convert hcomponent using 1
    congr 1
    apply Sigma.ext
    · rfl
    · exact heq_of_eq (by
        funext other
        simp only [choice, dif_neg other.2])
  · intro hvalue choice
    rw [himage]
    intro placeTuple _
    exact hvalue
      ⟨placeTuple, fun other => choice other.1⟩ (Set.mem_univ _)

/-- The weighted content of a direct product is the replicated product measure. -/
theorem weightedContent_productRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      Set (decomposition.blockStage placeTuple).module) :
    data.weightedContent
        (SourcePacketFiniteMeasuredFieldDecomposition.packetProductRegion
          (decomposition := decomposition) regions) =
      ∏ replica : data.ReplicaIndex,
        measured.blockProductMeasure replica.1
          (measured.blockRadializedRegion replica.1 (regions replica.1)) := by
  rw [weightedContent, data.weightedLift_productRegion regions]
  exact MeasureTheory.Measure.pi_pi
    (fun replica : data.ReplicaIndex =>
      measured.blockProductMeasure replica.1)
    (fun replica : data.ReplicaIndex =>
      measured.blockRadializedRegion replica.1 (regions replica.1))

/-- Measurable block radial regions give a measurable weighted lift. -/
theorem weightedLift_productRegion_measurable
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      Set (decomposition.blockStage placeTuple).module)
    (hmeasurable : ∀ placeTuple,
      MeasurableSet
        (measured.blockRadializedRegion placeTuple (regions placeTuple))) :
    MeasurableSet
      (data.weightedLift
        (SourcePacketFiniteMeasuredFieldDecomposition.packetProductRegion
          (decomposition := decomposition) regions)) := by
  rw [data.weightedLift_productRegion regions]
  exact MeasurableSet.univ_pi fun replica => hmeasurable replica.1

/-- The distinguished integral weighted lift is an exact replicated product. -/
theorem weightedLift_integralRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.weightedLift measured.packetIntegralRegion =
      Set.pi Set.univ fun replica : data.ReplicaIndex =>
        measured.blockRadializedRegion replica.1
          (measured.blockIntegralRegion replica.1) := by
  simpa only [SourcePacketFiniteMeasuredFieldDecomposition.packetIntegralRegion]
    using data.weightedLift_productRegion
      (fun placeTuple => measured.blockIntegralRegion placeTuple)

/-- The distinguished integral weighted lift is Borel measurable. -/
theorem weightedLift_integralRegion_measurable
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    MeasurableSet (data.weightedLift measured.packetIntegralRegion) := by
  simpa only [SourcePacketFiniteMeasuredFieldDecomposition.packetIntegralRegion]
    using data.weightedLift_productRegion_measurable
      (fun placeTuple => measured.blockIntegralRegion placeTuple)
      (fun placeTuple =>
        measured.blockRadializedRegion_integralRegion_measurable placeTuple)

/-- The integral weighted content is the product of the derived block measures. -/
theorem weightedContent_integralRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.weightedContent measured.packetIntegralRegion =
      ∏ replica : data.ReplicaIndex,
        measured.blockProductMeasure replica.1
          (measured.blockRadializedRegion replica.1
            (measured.blockIntegralRegion replica.1)) := by
  simpa only [SourcePacketFiniteMeasuredFieldDecomposition.packetIntegralRegion]
    using data.weightedContent_productRegion
      (fun placeTuple => measured.blockIntegralRegion placeTuple)

/-- Every normalized integral block has measure one, hence so does `μ_E`. -/
theorem weightedContent_integralRegion_eq_one
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.weightedContent measured.packetIntegralRegion = 1 := by
  rw [data.weightedContent_integralRegion]
  simp only [measured.blockProductMeasure_integralRegion,
    Finset.prod_const_one]

/-- The integral weighted content is positive. -/
theorem weightedContent_integralRegion_ne_zero
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.weightedContent measured.packetIntegralRegion ≠ 0 := by
  rw [data.weightedContent_integralRegion_eq_one]
  exact one_ne_zero

/-- The integral weighted content is finite. -/
theorem weightedContent_integralRegion_ne_top
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.weightedContent measured.packetIntegralRegion ≠ ⊤ := by
  rw [data.weightedContent_integralRegion_eq_one]
  exact ENNReal.one_ne_top

/--
The finite-stage packet functional obtained from the exact E/W construction.
The factor `1 / #E` and the normalized local-degree scale are both retained.
-/
noncomputable def toNormalizedLogVolume
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    SourceNormalizedLogVolume decomposition.stageModule where
  admissible := fun region =>
    MeasurableSet (data.weightedLift region) ∧
      data.weightedContent region ≠ 0 ∧
      data.weightedContent region ≠ ⊤
  rawLogVolume := fun region _ =>
    data.normalizationScale *
      (Real.log (data.weightedContent region).toReal /
        Fintype.card data.WeightChoice)
  integralRegion := measured.packetIntegralRegion
  integralRegion_admissible :=
    ⟨data.weightedLift_integralRegion_measurable,
      data.weightedContent_integralRegion_ne_zero,
      data.weightedContent_integralRegion_ne_top⟩
  normalizationOffset :=
    data.normalizationScale *
      ((∑ replica : data.ReplicaIndex,
        (measured.blockVolume replica.1).normalizationOffset) /
          Fintype.card data.WeightChoice)

/-- The complete finite-stage weighted normalization offset is zero. -/
theorem toNormalizedLogVolume_normalizationOffset_eq_zero
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.toNormalizedLogVolume.normalizationOffset = 0 := by
  change
    data.normalizationScale *
      ((∑ replica : data.ReplicaIndex,
        (measured.blockVolume replica.1).normalizationOffset) /
          Fintype.card data.WeightChoice) = 0
  simp only [measured.blockVolume_normalizationOffset_eq_zero,
    Finset.sum_const_zero,
    zero_div, mul_zero]

/-- The integral finite packet stage has normalized weighted log-volume zero. -/
theorem toNormalizedLogVolume_value_eq_zero
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured) :
    data.toNormalizedLogVolume.value = 0 := by
  rw [SourceNormalizedLogVolume.value,
    SourceNormalizedLogVolume.valueOn]
  change
    data.normalizationScale *
        (Real.log
          (data.weightedContent measured.packetIntegralRegion).toReal /
            Fintype.card data.WeightChoice) -
      data.toNormalizedLogVolume.normalizationOffset = 0
  rw [data.weightedContent_integralRegion_eq_one,
    data.toNormalizedLogVolume_normalizationOffset_eq_zero]
  norm_num

/-- A direct product of admissible derived blocks is an admissible packet region. -/
noncomputable def admissibleProductRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      (measured.blockVolume placeTuple).AdmissibleRegion) :
    data.toNormalizedLogVolume.AdmissibleRegion where
  carrier :=
    SourcePacketFiniteMeasuredFieldDecomposition.packetProductRegion
      (decomposition := decomposition) fun placeTuple =>
        (regions placeTuple).carrier
  isAdmissible := by
    refine ⟨data.weightedLift_productRegion_measurable
      (fun placeTuple => (regions placeTuple).carrier)
      (fun placeTuple => (regions placeTuple).isAdmissible.1), ?_, ?_⟩
    · rw [data.weightedContent_productRegion]
      exact Finset.prod_ne_zero_iff.mpr fun replica _ =>
        (regions replica.1).isAdmissible.2.1
    · rw [data.weightedContent_productRegion]
      exact ENNReal.prod_ne_top fun replica _ =>
        (regions replica.1).isAdmissible.2.2

/--
For a direct product region, the E/W value is the normalized replicated sum
of the genuine finite-stage block log-volumes.
-/
theorem toNormalizedLogVolume_valueOn_admissibleProductRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      (measured.blockVolume placeTuple).AdmissibleRegion) :
    data.toNormalizedLogVolume.valueOn
        (data.admissibleProductRegion regions) =
      data.normalizationScale *
        ((∑ replica : data.ReplicaIndex,
          (measured.blockVolume replica.1).valueOn (regions replica.1)) /
            Fintype.card data.WeightChoice) := by
  change
    data.normalizationScale *
          (Real.log
            (data.weightedContent
              (SourcePacketFiniteMeasuredFieldDecomposition.packetProductRegion
                (decomposition := decomposition) fun placeTuple =>
                  (regions placeTuple).carrier)).toReal /
            Fintype.card data.WeightChoice) -
        data.normalizationScale *
          ((∑ replica : data.ReplicaIndex,
            (measured.blockVolume replica.1).normalizationOffset) /
              Fintype.card data.WeightChoice) =
      data.normalizationScale *
        ((∑ replica : data.ReplicaIndex,
          (measured.blockVolume replica.1).valueOn (regions replica.1)) /
            Fintype.card data.WeightChoice)
  have hblock : ∀ replica : data.ReplicaIndex,
      (measured.blockVolume replica.1).valueOn (regions replica.1) =
        Real.log
            (measured.blockProductMeasure replica.1
              (measured.blockRadializedRegion replica.1
                (regions replica.1).carrier)).toReal -
          (measured.blockVolume replica.1).normalizationOffset := by
    intro replica
    rw [SourceNormalizedLogVolume.valueOn]
    rw [measured.blockVolume_rawLogVolume_eq_measure]
  have hpositive : ∀ replica : data.ReplicaIndex,
      0 < (measured.blockProductMeasure replica.1
        (measured.blockRadializedRegion replica.1
          (regions replica.1).carrier)).toReal := by
    intro replica
    apply ENNReal.toReal_pos
    · exact (regions replica.1).isAdmissible.2.1
    · exact (regions replica.1).isAdmissible.2.2
  simp_rw [hblock]
  rw [data.weightedContent_productRegion,
    ENNReal.toReal_prod,
    Real.log_prod (fun replica _ => (hpositive replica).ne'),
    Finset.sum_sub_distrib]
  ring

/--
The exact final formula of Remark 3.1.1(iv) for direct product regions:
`(#E)⁻¹ log μ_E(S) = ∑_v (N_v)⁻¹ log μ_v(S_v)`.
-/
theorem normalized_log_weightedContent_productRegion
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      (measured.blockVolume placeTuple).AdmissibleRegion) :
    Real.log
          (data.weightedContent
            (SourcePacketFiniteMeasuredFieldDecomposition.packetProductRegion
              (decomposition := decomposition) fun placeTuple =>
                (regions placeTuple).carrier)).toReal /
        Fintype.card data.WeightChoice =
      ∑ placeTuple : packet.PlaceTupleIndex,
        Real.log
            (measured.blockProductMeasure placeTuple
              (measured.blockRadializedRegion placeTuple
                (regions placeTuple).carrier)).toReal /
          (data.multiplicity placeTuple).1 := by
  have hpositive : ∀ replica : data.ReplicaIndex,
      0 < (measured.blockProductMeasure replica.1
        (measured.blockRadializedRegion replica.1
          (regions replica.1).carrier)).toReal := by
    intro replica
    apply ENNReal.toReal_pos
    · exact (regions replica.1).isAdmissible.2.1
    · exact (regions replica.1).isAdmissible.2.2
  rw [data.weightedContent_productRegion,
    ENNReal.toReal_prod,
    Real.log_prod (fun replica _ => (hpositive replica).ne')]
  exact data.normalizedReplicaSum_eq_inverseMultiplicitySum fun placeTuple =>
    Real.log
      (measured.blockProductMeasure placeTuple
        (measured.blockRadializedRegion placeTuple
          (regions placeTuple).carrier)).toReal

/-- The packet value is the reciprocal-`N_v` weighted sum of block values. -/
theorem toNormalizedLogVolume_valueOn_admissibleProductRegion_eq_weightedSum
    (data :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (regions : ∀ placeTuple : packet.PlaceTupleIndex,
      (measured.blockVolume placeTuple).AdmissibleRegion) :
    data.toNormalizedLogVolume.valueOn
        (data.admissibleProductRegion regions) =
      data.normalizationScale *
        ∑ placeTuple : packet.PlaceTupleIndex,
          (measured.blockVolume placeTuple).valueOn (regions placeTuple) /
            (data.multiplicity placeTuple).1 := by
  rw [data.toNormalizedLogVolume_valueOn_admissibleProductRegion]
  rw [data.normalizedReplicaSum_eq_inverseMultiplicitySum fun placeTuple =>
    (measured.blockVolume placeTuple).valueOn (regions placeTuple)]

/-!
## Finite-stage mono-analytic/holomorphic compatibility

Proposition 3.2(i) transports the actual finite local fields in the tensor
packet, while Proposition 3.9(ii) asserts compatibility of the resulting
packet-normalized log-volumes.  The structure below records only the geometric
transport.  Compatibility of the complete E/W functional is derived below.
-/

/--
A source-faithful finite-stage realization of the poly-isomorphisms of
Proposition 3.2(i), tied to the tensor-packet Kummer isomorphism.
-/
structure Compatible
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    {targetPresentation :
      SourceMonoAnalyticTensorPacketFieldPresentation targetPacket}
    {targetDecomposition :
      SourcePacketFiniteFieldDecomposition targetPacket targetPresentation}
    {targetMeasured :
      SourcePacketFiniteMeasuredFieldDecomposition targetPacket
        targetDecomposition}
    (source :
      SourcePacketFiniteStageLogVolume packet decomposition measured)
    (target :
      SourcePacketFiniteStageLogVolume targetPacket targetDecomposition
        targetMeasured)
    (packetKummer : packet.carrier ≃L[ℚ] targetPacket.carrier) where
  placeEquiv : packet.place ≃ targetPacket.place
  fieldIndexEquiv :
    ∀ placeTuple : packet.PlaceTupleIndex,
      (decomposition.blockStage placeTuple).fieldIndex ≃
        (targetDecomposition.blockStage
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)).fieldIndex
  fieldKummer :
    ∀ (placeTuple : packet.PlaceTupleIndex)
      (index : (decomposition.blockStage placeTuple).fieldIndex),
      ((decomposition.blockStage placeTuple).field index).rationalModule ≃L[ℚ]
        ((targetDecomposition.blockStage
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)).field
              (fieldIndexEquiv placeTuple index)).rationalModule
  radialKummer :
    ∀ (placeTuple : packet.PlaceTupleIndex)
      (index : (decomposition.blockStage placeTuple).fieldIndex),
      (measured.blockMeasuredField placeTuple index).radialCarrier ≃ᵐ
        (targetMeasured.blockMeasuredField
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)
          (fieldIndexEquiv placeTuple index)).radialCarrier
  radial_measurePreserving :
    ∀ (placeTuple : packet.PlaceTupleIndex)
      (index : (decomposition.blockStage placeTuple).fieldIndex),
      MeasureTheory.MeasurePreserving (radialKummer placeTuple index)
        (measured.blockMeasuredField placeTuple index).measure
        (targetMeasured.blockMeasuredField
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)
          (fieldIndexEquiv placeTuple index)).measure
  radialization_commutes :
    ∀ (placeTuple : packet.PlaceTupleIndex)
      (index : (decomposition.blockStage placeTuple).fieldIndex) value,
      radialKummer placeTuple index
          ((measured.blockMeasuredField placeTuple index).radialization value) =
        (targetMeasured.blockMeasuredField
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)
          (fieldIndexEquiv placeTuple index)).radialization
            (fieldKummer placeTuple index value)
  fieldIntegralRegion_image :
    ∀ (placeTuple : packet.PlaceTupleIndex)
      (index : (decomposition.blockStage placeTuple).fieldIndex),
      fieldKummer placeTuple index ''
          (measured.blockMeasuredField placeTuple index).volume.integralRegion =
        (targetMeasured.blockMeasuredField
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)
          (fieldIndexEquiv placeTuple index)).volume.integralRegion
  placeMultiplicity_eq :
    ∀ place,
      target.placeMultiplicity (placeEquiv place) =
        source.placeMultiplicity place
  placeNormalizationDegree_eq :
    ∀ place,
      target.placeNormalizationDegree (placeEquiv place) =
        source.placeNormalizationDegree place
  stageKummer :
    decomposition.stageModule ≃L[ℚ] targetDecomposition.stageModule
  stageKummer_fieldCoordinates :
    ∀ value (placeTuple : packet.PlaceTupleIndex)
      (index : (decomposition.blockStage placeTuple).fieldIndex),
      SourcePacketFiniteMeasuredFieldDecomposition.blockFieldDecomposition
          (decomposition := targetDecomposition)
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket placeEquiv placeTuple)
          (stageKummer value
            (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
              packet targetPacket placeEquiv placeTuple))
          (fieldIndexEquiv placeTuple index) =
        fieldKummer placeTuple index
          (SourcePacketFiniteMeasuredFieldDecomposition.blockFieldDecomposition
            (decomposition := decomposition) placeTuple (value placeTuple) index)
  packetKummer_stageEmbedding :
    ∀ value,
      packetKummer (decomposition.stageEmbedding value) =
        targetDecomposition.stageEmbedding (stageKummer value)

namespace Compatible

variable
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    {targetPresentation :
      SourceMonoAnalyticTensorPacketFieldPresentation targetPacket}
    {targetDecomposition :
      SourcePacketFiniteFieldDecomposition targetPacket targetPresentation}
    {targetMeasured :
      SourcePacketFiniteMeasuredFieldDecomposition targetPacket
        targetDecomposition}
    {source :
      SourcePacketFiniteStageLogVolume packet decomposition measured}
    {target :
      SourcePacketFiniteStageLogVolume targetPacket targetDecomposition
        targetMeasured}
    {packetKummer : packet.carrier ≃L[ℚ] targetPacket.carrier}

/-- The factorwise place transport on outer place-tuple blocks. -/
def placeTupleEquiv
    (compatible : Compatible source target packetKummer) :
    packet.PlaceTupleIndex ≃ targetPacket.PlaceTupleIndex :=
  SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
    packet targetPacket compatible.placeEquiv

@[simp]
theorem placeTupleEquiv_apply
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    compatible.placeTupleEquiv placeTuple =
      SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
        packet targetPacket compatible.placeEquiv placeTuple :=
  rfl

/-- Named form of the stored field-coordinate compatibility. -/
theorem stageKummer_fieldCoordinates_apply
    (compatible : Compatible source target packetKummer)
    (value : decomposition.stageModule)
    (placeTuple : packet.PlaceTupleIndex)
    (index : (decomposition.blockStage placeTuple).fieldIndex) :
    SourcePacketFiniteMeasuredFieldDecomposition.blockFieldDecomposition
        (decomposition := targetDecomposition)
        (compatible.placeTupleEquiv placeTuple)
        (compatible.stageKummer value
          (compatible.placeTupleEquiv placeTuple))
        (compatible.fieldIndexEquiv placeTuple index) =
      compatible.fieldKummer placeTuple index
        (SourcePacketFiniteMeasuredFieldDecomposition.blockFieldDecomposition
          (decomposition := decomposition) placeTuple (value placeTuple) index) := by
  simpa only [placeTupleEquiv] using
    compatible.stageKummer_fieldCoordinates value placeTuple index

/-- Named form of fieldwise preservation of the integral region. -/
theorem fieldIntegralRegion_image_apply
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex)
    (index : (decomposition.blockStage placeTuple).fieldIndex) :
    compatible.fieldKummer placeTuple index ''
        (measured.blockMeasuredField placeTuple index).volume.integralRegion =
      (targetMeasured.blockMeasuredField
        (compatible.placeTupleEquiv placeTuple)
        (compatible.fieldIndexEquiv placeTuple index)).volume.integralRegion := by
  simpa only [placeTupleEquiv] using
    compatible.fieldIntegralRegion_image placeTuple index

/-- Product multiplicities are preserved by the selected-place transport. -/
theorem multiplicity_eq
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    target.multiplicity (compatible.placeTupleEquiv placeTuple) =
      source.multiplicity placeTuple := by
  apply Subtype.ext
  simp only [multiplicity_val]
  apply Finset.prod_congr rfl
  intro factor _
  exact congrArg (·.1)
    (compatible.placeMultiplicity_eq (placeTuple factor))

/-- The normalized degree denominator is invariant under the place transport. -/
theorem normalizationDenominator_eq
    (compatible : Compatible source target packetKummer) :
    target.normalizationDenominator = source.normalizationDenominator := by
  classical
  calc
    target.normalizationDenominator =
        ∑ placeTuple : packet.PlaceTupleIndex,
          ∏ factor,
            (target.placeNormalizationDegree
              (compatible.placeTupleEquiv placeTuple factor)).1 := by
      exact (compatible.placeTupleEquiv.sum_comp
        (fun targetTuple : targetPacket.PlaceTupleIndex =>
          ∏ factor,
            (target.placeNormalizationDegree (targetTuple factor)).1)).symm
    _ = source.normalizationDenominator := by
      apply Finset.sum_congr rfl
      intro placeTuple _
      apply Finset.prod_congr rfl
      intro factor _
      exact congrArg (·.1)
        (compatible.placeNormalizationDegree_eq (placeTuple factor))

/-- The real reciprocal normalization scale is consequently preserved. -/
theorem normalizationScale_eq
    (compatible : Compatible source target packetKummer) :
    target.normalizationScale = source.normalizationScale := by
  rw [normalizationScale, normalizationScale,
    compatible.normalizationDenominator_eq]

/-- Transport one field coordinate inside a fixed outer tensor block. -/
noncomputable def blockRadialEquiv
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    measured.BlockRadialCoordinates placeTuple ≃ᵐ
      targetMeasured.BlockRadialCoordinates
        (compatible.placeTupleEquiv placeTuple) :=
  (MeasurableEquiv.piCongrRight
    (compatible.radialKummer placeTuple)).trans
      (MeasurableEquiv.piCongrLeft
        (fun index =>
          (targetMeasured.blockMeasuredField
            (compatible.placeTupleEquiv placeTuple) index).radialCarrier)
        (compatible.fieldIndexEquiv placeTuple))

@[simp]
theorem blockRadialEquiv_apply
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex)
    (value : measured.BlockRadialCoordinates placeTuple)
    (index : (decomposition.blockStage placeTuple).fieldIndex) :
    compatible.blockRadialEquiv placeTuple value
        (compatible.fieldIndexEquiv placeTuple index) =
      compatible.radialKummer placeTuple index (value index) := by
  change
    (MeasurableEquiv.piCongrLeft
      (fun targetIndex =>
        (targetMeasured.blockMeasuredField
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket compatible.placeEquiv placeTuple)
          targetIndex).radialCarrier)
      (compatible.fieldIndexEquiv placeTuple)
      ((MeasurableEquiv.piCongrRight
        (compatible.radialKummer placeTuple)) value))
          (compatible.fieldIndexEquiv placeTuple index) = _
  rw [MeasurableEquiv.piCongrLeft_apply_apply]
  rfl

/-- Fieldwise measure preservation gives preservation of the block product. -/
theorem blockRadial_measurePreserving
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    MeasureTheory.MeasurePreserving
      (compatible.blockRadialEquiv placeTuple)
      (measured.blockProductMeasure placeTuple)
      (targetMeasured.blockProductMeasure
        (compatible.placeTupleEquiv placeTuple)) := by
  have hfactor : MeasureTheory.MeasurePreserving
      (fun value index =>
        compatible.radialKummer placeTuple index (value index))
      (measured.blockProductMeasure placeTuple)
      (MeasureTheory.Measure.pi fun index =>
        (targetMeasured.blockMeasuredField
          (compatible.placeTupleEquiv placeTuple)
          (compatible.fieldIndexEquiv placeTuple index)).measure) :=
    MeasureTheory.measurePreserving_pi
      (fun index =>
        (measured.blockMeasuredField placeTuple index).measure)
      (fun index =>
        (targetMeasured.blockMeasuredField
          (compatible.placeTupleEquiv placeTuple)
          (compatible.fieldIndexEquiv placeTuple index)).measure)
      (compatible.radial_measurePreserving placeTuple)
  have hreindex := MeasureTheory.measurePreserving_piCongrLeft
    (fun index =>
      (targetMeasured.blockMeasuredField
        (compatible.placeTupleEquiv placeTuple) index).measure)
    (compatible.fieldIndexEquiv placeTuple)
  exact hreindex.comp hfactor

/-- Transport all radial blocks of the selected finite packet stage. -/
noncomputable def packetRadialEquiv
    (compatible : Compatible source target packetKummer) :
    measured.PacketRadialCoordinates ≃ᵐ
      targetMeasured.PacketRadialCoordinates :=
  (MeasurableEquiv.piCongrRight compatible.blockRadialEquiv).trans
    (MeasurableEquiv.piCongrLeft
      (fun placeTuple =>
        targetMeasured.BlockRadialCoordinates placeTuple)
      compatible.placeTupleEquiv)

@[simp]
theorem packetRadialEquiv_apply
    (compatible : Compatible source target packetKummer)
    (value : measured.PacketRadialCoordinates)
    (placeTuple : packet.PlaceTupleIndex) :
    compatible.packetRadialEquiv value
        (compatible.placeTupleEquiv placeTuple) =
      compatible.blockRadialEquiv placeTuple (value placeTuple) := by
  change
    (MeasurableEquiv.piCongrLeft
      (fun targetTuple =>
        targetMeasured.BlockRadialCoordinates targetTuple)
      compatible.placeTupleEquiv
      (MeasurableEquiv.piCongrRight
        compatible.blockRadialEquiv value))
          (compatible.placeTupleEquiv placeTuple) = _
  rw [MeasurableEquiv.piCongrLeft_apply_apply]
  rfl

/-- Radialization commutes with the genuine finite-stage Kummer map. -/
theorem packetRadializeCoordinates_stageKummer
    (compatible : Compatible source target packetKummer)
    (value : decomposition.stageModule) :
    targetMeasured.packetRadializeCoordinates
        (compatible.stageKummer value) =
      compatible.packetRadialEquiv
        (measured.packetRadializeCoordinates value) := by
  funext targetTuple
  obtain ⟨placeTuple, rfl⟩ :=
    compatible.placeTupleEquiv.surjective targetTuple
  apply funext
  intro targetIndex
  obtain ⟨index, rfl⟩ :=
    (compatible.fieldIndexEquiv placeTuple).surjective targetIndex
  change
    (targetMeasured.blockMeasuredField
      (compatible.placeTupleEquiv placeTuple)
      (compatible.fieldIndexEquiv placeTuple index)).radialization
        (SourcePacketFiniteMeasuredFieldDecomposition.blockFieldDecomposition
          (decomposition := targetDecomposition)
          (compatible.placeTupleEquiv placeTuple)
          (compatible.stageKummer value
            (compatible.placeTupleEquiv placeTuple))
          (compatible.fieldIndexEquiv placeTuple index)) = _
  rw [compatible.packetRadialEquiv_apply,
    compatible.blockRadialEquiv_apply]
  rw [compatible.stageKummer_fieldCoordinates_apply value placeTuple index]
  exact (compatible.radialization_commutes placeTuple index _).symm

/-- A transported field value belongs to the target integral region exactly. -/
theorem fieldKummer_mem_integralRegion_iff
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex)
    (index : (decomposition.blockStage placeTuple).fieldIndex)
    (value : (decomposition.blockStage placeTuple).field index |>.carrier) :
    compatible.fieldKummer placeTuple index value ∈
        (targetMeasured.blockMeasuredField
          (compatible.placeTupleEquiv placeTuple)
          (compatible.fieldIndexEquiv placeTuple index)).volume.integralRegion ↔
      value ∈
        (measured.blockMeasuredField placeTuple index).volume.integralRegion := by
  rw [← compatible.fieldIntegralRegion_image_apply placeTuple index]
  constructor
  · rintro ⟨sourceValue, hsourceValue, heq⟩
    exact (compatible.fieldKummer placeTuple index).injective heq ▸ hsourceValue
  · intro hvalue
    exact ⟨value, hvalue, rfl⟩

/-- The finite-stage Kummer map preserves the complete product integral region. -/
theorem stageKummer_mem_packetIntegralRegion_iff
    (compatible : Compatible source target packetKummer)
    (value : decomposition.stageModule) :
    compatible.stageKummer value ∈ targetMeasured.packetIntegralRegion ↔
      value ∈ measured.packetIntegralRegion := by
  classical
  constructor
  · intro htarget
    change
      compatible.stageKummer value ∈ Set.pi Set.univ
        (fun targetTuple =>
          targetMeasured.blockIntegralRegion targetTuple) at htarget
    change
      value ∈ Set.pi Set.univ
        (fun placeTuple => measured.blockIntegralRegion placeTuple)
    intro placeTuple _
    apply (measured.blockIntegralRegion_iff placeTuple _).mpr
    intro index _
    have htargetBlock := htarget
      (compatible.placeTupleEquiv placeTuple) (Set.mem_univ _)
    have htargetFields :=
      (targetMeasured.blockIntegralRegion_iff
        (compatible.placeTupleEquiv placeTuple) _).mp htargetBlock
    have htargetField := htargetFields
      (compatible.fieldIndexEquiv placeTuple index) (Set.mem_univ _)
    rw [compatible.stageKummer_fieldCoordinates_apply value placeTuple index]
      at htargetField
    exact (compatible.fieldKummer_mem_integralRegion_iff
      placeTuple index _).mp htargetField
  · intro hsource
    change
      value ∈ Set.pi Set.univ
        (fun placeTuple => measured.blockIntegralRegion placeTuple) at hsource
    change
      compatible.stageKummer value ∈ Set.pi Set.univ
        (fun targetTuple =>
          targetMeasured.blockIntegralRegion targetTuple)
    intro targetTuple _
    obtain ⟨placeTuple, rfl⟩ :=
      compatible.placeTupleEquiv.surjective targetTuple
    apply (targetMeasured.blockIntegralRegion_iff
      (compatible.placeTupleEquiv placeTuple) _).mpr
    intro targetIndex _
    obtain ⟨index, rfl⟩ :=
      (compatible.fieldIndexEquiv placeTuple).surjective targetIndex
    rw [compatible.stageKummer_fieldCoordinates_apply value placeTuple index]
    apply (compatible.fieldKummer_mem_integralRegion_iff
      placeTuple index _).mpr
    exact (measured.blockIntegralRegion_iff placeTuple _).mp
      (hsource placeTuple (Set.mem_univ _)) index (Set.mem_univ _)

/-- The distinguished finite packet stage maps exactly onto its target. -/
theorem stageKummer_image_packetIntegralRegion
    (compatible : Compatible source target packetKummer) :
    compatible.stageKummer '' measured.packetIntegralRegion =
      targetMeasured.packetIntegralRegion := by
  ext targetValue
  constructor
  · rintro ⟨sourceValue, hsourceValue, rfl⟩
    exact (compatible.stageKummer_mem_packetIntegralRegion_iff sourceValue).mpr
      hsourceValue
  · intro htargetValue
    refine ⟨compatible.stageKummer.symm targetValue, ?_,
      compatible.stageKummer.apply_symm_apply targetValue⟩
    apply (compatible.stageKummer_mem_packetIntegralRegion_iff
      (compatible.stageKummer.symm targetValue)).mp
    simpa only [compatible.stageKummer.apply_symm_apply] using htargetValue

/-- Radialized finite-stage regions transport exactly under Kummer. -/
theorem packetRadialEquiv_image_radializedRegion
    (compatible : Compatible source target packetKummer)
    (region : Set decomposition.stageModule) :
    compatible.packetRadialEquiv ''
        measured.packetRadializedRegion region =
      targetMeasured.packetRadializedRegion
        (compatible.stageKummer '' region) := by
  ext targetValue
  constructor
  · rintro ⟨sourceValue, ⟨stageValue, hstageValue, rfl⟩, rfl⟩
    exact ⟨compatible.stageKummer stageValue,
      ⟨stageValue, hstageValue, rfl⟩,
      compatible.packetRadializeCoordinates_stageKummer stageValue⟩
  · rintro ⟨targetStageValue,
      ⟨sourceStageValue, hsourceStageValue, rfl⟩, hradial⟩
    refine ⟨measured.packetRadializeCoordinates sourceStageValue,
      ⟨sourceStageValue, hsourceStageValue, rfl⟩, ?_⟩
    exact (compatible.packetRadializeCoordinates_stageKummer
      sourceStageValue).symm.trans hradial

/-- Multiplicity preservation identifies one finite `E_v` coordinate. -/
noncomputable def weightCoordinateEquiv
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    Fin (source.multiplicity placeTuple).1 ≃
      Fin (target.multiplicity
        (compatible.placeTupleEquiv placeTuple)).1 :=
  finCongr (congrArg (·.1) (compatible.multiplicity_eq placeTuple).symm)

/-- Reindexing place tuples and their finite coordinates identifies `E`. -/
noncomputable def weightChoiceEquiv
    (compatible : Compatible source target packetKummer) :
    source.WeightChoice ≃ target.WeightChoice :=
  (Equiv.piCongrRight fun placeTuple =>
    compatible.weightCoordinateEquiv placeTuple).trans
      (Equiv.piCongrLeft
        (fun targetTuple =>
          Fin (target.multiplicity targetTuple).1)
        compatible.placeTupleEquiv)

@[simp]
theorem weightChoiceEquiv_apply
    (compatible : Compatible source target packetKummer)
    (choice : source.WeightChoice)
    (placeTuple : packet.PlaceTupleIndex) :
    compatible.weightChoiceEquiv choice
        (compatible.placeTupleEquiv placeTuple) =
      compatible.weightCoordinateEquiv placeTuple (choice placeTuple) := by
  change
    (Equiv.piCongrLeft
      (fun targetTuple => Fin (target.multiplicity targetTuple).1)
      compatible.placeTupleEquiv
      ((Equiv.piCongrRight fun sourceTuple =>
        compatible.weightCoordinateEquiv sourceTuple) choice))
          (compatible.placeTupleEquiv placeTuple) = _
  rw [Equiv.piCongrLeft_apply_apply]
  rfl

/-- Place tuples away from one selected tuple reindex equivariantly. -/
def otherPlaceTupleEquiv
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    {other : packet.PlaceTupleIndex // other ≠ placeTuple} ≃
      {other : targetPacket.PlaceTupleIndex //
        other ≠ compatible.placeTupleEquiv placeTuple} :=
  compatible.placeTupleEquiv.subtypeEquiv fun other => by
    constructor
    · intro hne heq
      exact hne (compatible.placeTupleEquiv.injective heq)
    · intro hne heq
      exact hne (congrArg compatible.placeTupleEquiv heq)

/-- The choices in `E_{≠v}` transport coordinatewise. -/
noncomputable def replicaFiberEquiv
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex) :
    source.ReplicaFiber placeTuple ≃
      target.ReplicaFiber (compatible.placeTupleEquiv placeTuple) :=
  (Equiv.piCongrRight fun other :
      {other : packet.PlaceTupleIndex // other ≠ placeTuple} =>
    compatible.weightCoordinateEquiv other.1).trans
      (Equiv.piCongrLeft
        (fun other : {other : targetPacket.PlaceTupleIndex //
          other ≠ compatible.placeTupleEquiv placeTuple} =>
            Fin (target.multiplicity other.1).1)
        (compatible.otherPlaceTupleEquiv placeTuple))

@[simp]
theorem replicaFiberEquiv_apply
    (compatible : Compatible source target packetKummer)
    (placeTuple : packet.PlaceTupleIndex)
    (choice : source.ReplicaFiber placeTuple)
    (other : {other : packet.PlaceTupleIndex // other ≠ placeTuple}) :
    compatible.replicaFiberEquiv placeTuple choice
        (compatible.otherPlaceTupleEquiv placeTuple other) =
      compatible.weightCoordinateEquiv other.1 (choice other) := by
  change
    (Equiv.piCongrLeft
      (fun targetOther : {other : targetPacket.PlaceTupleIndex //
        other ≠ compatible.placeTupleEquiv placeTuple} =>
          Fin (target.multiplicity targetOther.1).1)
      (compatible.otherPlaceTupleEquiv placeTuple)
      ((Equiv.piCongrRight fun sourceOther :
        {other : packet.PlaceTupleIndex // other ≠ placeTuple} =>
          compatible.weightCoordinateEquiv sourceOther.1) choice))
            (compatible.otherPlaceTupleEquiv placeTuple other) = _
  rw [Equiv.piCongrLeft_apply_apply]
  rfl

/-- The source data canonically identifies the replicated index `W`. -/
noncomputable def replicaIndexEquiv
    (compatible : Compatible source target packetKummer) :
    source.ReplicaIndex ≃ target.ReplicaIndex :=
  Equiv.sigmaCongr compatible.placeTupleEquiv
    compatible.replicaFiberEquiv

/-- Slice indices commute with the induced equivalences of `E` and `W`. -/
theorem replicaIndexEquiv_sliceIndex
    (compatible : Compatible source target packetKummer)
    (choice : source.WeightChoice)
    (placeTuple : packet.PlaceTupleIndex) :
    compatible.replicaIndexEquiv
        ⟨placeTuple, fun other => choice other.1⟩ =
      ⟨compatible.placeTupleEquiv placeTuple,
        fun other =>
          compatible.weightChoiceEquiv choice other.1⟩ := by
  apply Sigma.ext
  · rfl
  · exact heq_of_eq (by
      funext targetOther
      obtain ⟨sourceOther, rfl⟩ :=
        (compatible.otherPlaceTupleEquiv placeTuple).surjective targetOther
      change
        compatible.replicaFiberEquiv placeTuple
            (fun other => choice other.1)
            (compatible.otherPlaceTupleEquiv placeTuple sourceOther) =
          compatible.weightChoiceEquiv choice
            (compatible.placeTupleEquiv sourceOther.1)
      rw [compatible.replicaFiberEquiv_apply,
        compatible.weightChoiceEquiv_apply])

/-- A replicated radial block is transported by its derived block map. -/
noncomputable def replicaBlockEquiv
    (compatible : Compatible source target packetKummer)
    (replica : source.ReplicaIndex) :
    measured.BlockRadialCoordinates replica.1 ≃ᵐ
      targetMeasured.BlockRadialCoordinates
        (compatible.replicaIndexEquiv replica).1 := by
  change
    measured.BlockRadialCoordinates replica.1 ≃ᵐ
      targetMeasured.BlockRadialCoordinates
        (compatible.placeTupleEquiv replica.1)
  exact compatible.blockRadialEquiv replica.1

/-- The induced Borel equivalence of the replicated radial spaces `M_W`. -/
noncomputable def replicaEquiv
    (compatible : Compatible source target packetKummer) :
    source.ReplicaSpace ≃ᵐ target.ReplicaSpace :=
  (MeasurableEquiv.piCongrRight compatible.replicaBlockEquiv).trans
    (MeasurableEquiv.piCongrLeft
      (fun replica : target.ReplicaIndex =>
        targetMeasured.BlockRadialCoordinates replica.1)
      compatible.replicaIndexEquiv)

@[simp]
theorem replicaEquiv_apply
    (compatible : Compatible source target packetKummer)
    (value : source.ReplicaSpace)
    (replica : source.ReplicaIndex) :
    compatible.replicaEquiv value
        (compatible.replicaIndexEquiv replica) =
      compatible.replicaBlockEquiv replica (value replica) := by
  change
    (MeasurableEquiv.piCongrLeft
      (fun targetReplica : target.ReplicaIndex =>
        targetMeasured.BlockRadialCoordinates targetReplica.1)
      compatible.replicaIndexEquiv
      (MeasurableEquiv.piCongrRight
        compatible.replicaBlockEquiv value))
          (compatible.replicaIndexEquiv replica) = _
  rw [MeasurableEquiv.piCongrLeft_apply_apply]
  rfl

/-- Slicing `M_W` commutes with the finite-stage radial transport. -/
theorem slice_replicaEquiv_weightChoiceEquiv
    (compatible : Compatible source target packetKummer)
    (value : source.ReplicaSpace)
    (choice : source.WeightChoice) :
    target.slice (compatible.replicaEquiv value)
        (compatible.weightChoiceEquiv choice) =
      compatible.packetRadialEquiv (source.slice value choice) := by
  funext targetTuple
  obtain ⟨placeTuple, rfl⟩ :=
    compatible.placeTupleEquiv.surjective targetTuple
  change
    compatible.replicaEquiv value
        ⟨compatible.placeTupleEquiv placeTuple,
          fun other => compatible.weightChoiceEquiv choice other.1⟩ =
      compatible.packetRadialEquiv (source.slice value choice)
        (compatible.placeTupleEquiv placeTuple)
  rw [compatible.packetRadialEquiv_apply]
  let sourceReplica : source.ReplicaIndex :=
    ⟨placeTuple, fun other => choice other.1⟩
  let targetReplica : target.ReplicaIndex :=
    ⟨compatible.placeTupleEquiv placeTuple,
      fun other => compatible.weightChoiceEquiv choice other.1⟩
  have hindex :
      compatible.replicaIndexEquiv sourceReplica = targetReplica :=
    compatible.replicaIndexEquiv_sliceIndex choice placeTuple
  have htransport :
      compatible.replicaEquiv value
          (compatible.replicaIndexEquiv sourceReplica) =
        compatible.replicaEquiv value targetReplica :=
    eq_of_heq (congr_arg_heq (compatible.replicaEquiv value) hindex)
  have happly := compatible.replicaEquiv_apply value sourceReplica
  change
    compatible.replicaEquiv value
        (compatible.replicaIndexEquiv sourceReplica) =
      compatible.blockRadialEquiv placeTuple (value sourceReplica) at happly
  exact htransport.symm.trans happly

/-- Every replicated block map preserves its genuine product measure. -/
theorem replicaBlock_measurePreserving
    (compatible : Compatible source target packetKummer)
    (replica : source.ReplicaIndex) :
    MeasureTheory.MeasurePreserving
      (compatible.replicaBlockEquiv replica)
      (measured.blockProductMeasure replica.1)
      (targetMeasured.blockProductMeasure
        (compatible.replicaIndexEquiv replica).1) := by
  change MeasureTheory.MeasurePreserving
    (compatible.blockRadialEquiv replica.1)
    (measured.blockProductMeasure replica.1)
    (targetMeasured.blockProductMeasure
      (compatible.placeTupleEquiv replica.1))
  exact compatible.blockRadial_measurePreserving replica.1

/-- Product measure on `M_W` is preserved by the induced replica transport. -/
theorem replica_measurePreserving
    (compatible : Compatible source target packetKummer) :
    MeasureTheory.MeasurePreserving compatible.replicaEquiv
      source.replicaProductMeasure target.replicaProductMeasure := by
  have hfactor : MeasureTheory.MeasurePreserving
      (fun value replica =>
        compatible.replicaBlockEquiv replica (value replica))
      source.replicaProductMeasure
      (MeasureTheory.Measure.pi fun replica : source.ReplicaIndex =>
        targetMeasured.blockProductMeasure
          (compatible.replicaIndexEquiv replica).1) :=
    MeasureTheory.measurePreserving_pi
      (fun replica : source.ReplicaIndex =>
        measured.blockProductMeasure replica.1)
      (fun replica : source.ReplicaIndex =>
        targetMeasured.blockProductMeasure
          (compatible.replicaIndexEquiv replica).1)
      compatible.replicaBlock_measurePreserving
  have hreindex := MeasureTheory.measurePreserving_piCongrLeft
    (fun replica : target.ReplicaIndex =>
      targetMeasured.blockProductMeasure replica.1)
    compatible.replicaIndexEquiv
  exact hreindex.comp hfactor

/-- Membership in a radialized region is reflected by radial transport. -/
theorem packetRadialEquiv_mem_radializedRegion_iff
    (compatible : Compatible source target packetKummer)
    (region : Set decomposition.stageModule)
    (value : measured.PacketRadialCoordinates) :
    compatible.packetRadialEquiv value ∈
        targetMeasured.packetRadializedRegion
          (compatible.stageKummer '' region) ↔
      value ∈ measured.packetRadializedRegion region := by
  rw [← compatible.packetRadialEquiv_image_radializedRegion region]
  constructor
  · rintro ⟨sourceValue, hsourceValue, heq⟩
    exact compatible.packetRadialEquiv.injective heq ▸ hsourceValue
  · intro hvalue
    exact ⟨value, hvalue, rfl⟩

/-- Weighted-lift membership is reflected by the map on `M_W`. -/
theorem replicaEquiv_mem_weightedLift_iff
    (compatible : Compatible source target packetKummer)
    (region : Set decomposition.stageModule)
    (value : source.ReplicaSpace) :
    compatible.replicaEquiv value ∈
        target.weightedLift (compatible.stageKummer '' region) ↔
      value ∈ source.weightedLift region := by
  constructor
  · intro htarget sourceChoice
    have hslice := htarget (compatible.weightChoiceEquiv sourceChoice)
    rw [compatible.slice_replicaEquiv_weightChoiceEquiv] at hslice
    exact (compatible.packetRadialEquiv_mem_radializedRegion_iff
      region (source.slice value sourceChoice)).mp hslice
  · intro hsource targetChoice
    let sourceChoice := compatible.weightChoiceEquiv.symm targetChoice
    have hslice := hsource sourceChoice
    have htarget :=
      (compatible.packetRadialEquiv_mem_radializedRegion_iff
        region (source.slice value sourceChoice)).mpr hslice
    rw [← compatible.slice_replicaEquiv_weightChoiceEquiv] at htarget
    simpa only [sourceChoice, Equiv.apply_symm_apply] using htarget

/-- The induced replica map carries `S_E` exactly onto its target. -/
theorem replicaEquiv_image_weightedLift
    (compatible : Compatible source target packetKummer)
    (region : Set decomposition.stageModule) :
    compatible.replicaEquiv '' source.weightedLift region =
      target.weightedLift (compatible.stageKummer '' region) := by
  ext targetValue
  constructor
  · rintro ⟨sourceValue, hsourceValue, rfl⟩
    exact (compatible.replicaEquiv_mem_weightedLift_iff
      region sourceValue).mpr hsourceValue
  · intro htargetValue
    refine ⟨compatible.replicaEquiv.symm targetValue, ?_,
      compatible.replicaEquiv.apply_symm_apply targetValue⟩
    apply (compatible.replicaEquiv_mem_weightedLift_iff region
      (compatible.replicaEquiv.symm targetValue)).mp
    simpa only [compatible.replicaEquiv.apply_symm_apply] using htargetValue

/-- The derived `E`-weighted content is invariant under finite-stage Kummer. -/
theorem weightedContent_image
    (compatible : Compatible source target packetKummer)
    (region : Set decomposition.stageModule) :
    target.weightedContent (compatible.stageKummer '' region) =
      source.weightedContent region := by
  rw [weightedContent, weightedContent,
    ← compatible.replicaEquiv_image_weightedLift region]
  rw [← compatible.replica_measurePreserving.map_eq]
  exact (compatible.replicaEquiv.map_apply
      (compatible.replicaEquiv '' source.weightedLift region)).trans
    (congrArg source.replicaProductMeasure
      (compatible.replicaEquiv.injective.preimage_image
        (source.weightedLift region)))

/-- Measurability of `S_E` transports through the replica equivalence. -/
theorem weightedLift_image_measurable
    (compatible : Compatible source target packetKummer)
    (region : Set decomposition.stageModule)
    (hmeasurable : MeasurableSet (source.weightedLift region)) :
    MeasurableSet
      (target.weightedLift (compatible.stageKummer '' region)) := by
  rw [← compatible.replicaEquiv_image_weightedLift region]
  exact compatible.replicaEquiv.measurableEmbedding.measurableSet_image.mpr
    hmeasurable

/-- The induced equivalence of weight choices preserves `#E`. -/
theorem weightChoice_card_eq
    (compatible : Compatible source target packetKummer) :
    Fintype.card target.WeightChoice = Fintype.card source.WeightChoice :=
  (Fintype.card_congr compatible.weightChoiceEquiv).symm

/-- The complete finite-stage E/W functionals are Kummer compatible. -/
theorem toNormalizedLogVolume_compatible
    (compatible : Compatible source target packetKummer) :
    SourceNormalizedLogVolume.Compatible
      source.toNormalizedLogVolume target.toNormalizedLogVolume
        compatible.stageKummer := by
  refine
    { admissible_image := ?_
      rawLogVolume_image := ?_
      normalizationOffset_eq := ?_ }
  · intro region
    rcases region.isAdmissible with ⟨hmeasurable, hneZero, hneTop⟩
    refine ⟨compatible.weightedLift_image_measurable
      region.carrier hmeasurable, ?_, ?_⟩
    · rwa [compatible.weightedContent_image]
    · rwa [compatible.weightedContent_image]
  · intro region
    change
      target.normalizationScale *
          (Real.log
              (target.weightedContent
                (compatible.stageKummer '' region.carrier)).toReal /
            Fintype.card target.WeightChoice) =
        source.normalizationScale *
          (Real.log
              (source.weightedContent region.carrier).toReal /
            Fintype.card source.WeightChoice)
    rw [compatible.weightedContent_image,
      compatible.normalizationScale_eq,
      compatible.weightChoice_card_eq]
  · rw [target.toNormalizedLogVolume_normalizationOffset_eq_zero,
      source.toNormalizedLogVolume_normalizationOffset_eq_zero]

/-- Exact finite-stage compatibility implies equality of normalized values. -/
theorem normalizedLogVolume_value_eq
    (compatible : Compatible source target packetKummer) :
    source.toNormalizedLogVolume.value =
      target.toNormalizedLogVolume.value :=
  (compatible.toNormalizedLogVolume_compatible).value_eq
    compatible.stageKummer_image_packetIntegralRegion

/--
The selected finite stage commutes with the actual packet Kummer isomorphism,
including its full product integral structure.
-/
theorem packetKummer_image_embeddedPacketIntegralRegion
    (compatible : Compatible source target packetKummer) :
    packetKummer '' measured.embeddedPacketIntegralRegion =
      targetMeasured.embeddedPacketIntegralRegion := by
  ext targetValue
  constructor
  · rintro ⟨sourcePacketValue,
      ⟨sourceStageValue, hsourceStageValue, rfl⟩, rfl⟩
    rw [compatible.packetKummer_stageEmbedding]
    exact ⟨compatible.stageKummer sourceStageValue,
      (compatible.stageKummer_mem_packetIntegralRegion_iff
        sourceStageValue).mpr hsourceStageValue, rfl⟩
  · rintro ⟨targetStageValue, htargetStageValue, rfl⟩
    let sourceStageValue := compatible.stageKummer.symm targetStageValue
    refine ⟨decomposition.stageEmbedding sourceStageValue, ?_, ?_⟩
    · exact ⟨sourceStageValue,
        (compatible.stageKummer_mem_packetIntegralRegion_iff
          sourceStageValue).mp (by
            simpa only [sourceStageValue,
              compatible.stageKummer.apply_symm_apply] using htargetStageValue),
        rfl⟩
    · rw [compatible.packetKummer_stageEmbedding]
      exact congrArg targetDecomposition.stageEmbedding
        (compatible.stageKummer.apply_symm_apply targetStageValue)

end Compatible

end SourcePacketFiniteStageLogVolume

/--
Legacy whole-place-tuple realization retained while the existing weighted
volume corridor is migrated to `SourcePacketFiniteMeasuredFieldDecomposition`.
It is a tensor block, not a field summand, and must not discharge Proposition
3.1(i), Proposition 3.9, or Theorem 3.11.
-/
structure SourcePacketMeasuredSummand
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (index : packet.PlaceTupleIndex) where
  module : SourceTopologicalQModule.{u}
  tensorIso :
    module.toModuleCat ≅
      ModuleCat.of ℚ
        (PiTensorProduct ℚ
          (fun factor => (packet.factor factor).summand (index factor)))
  radialCarrier : Type u
  [radialTopologicalSpace : TopologicalSpace radialCarrier]
  [radialT2Space : T2Space radialCarrier]
  [radialLocallyCompactSpace : LocallyCompactSpace radialCarrier]
  [radialSecondCountableTopology : SecondCountableTopology radialCarrier]
  [radialMeasurableSpace : MeasurableSpace radialCarrier]
  [radialBorelSpace : BorelSpace radialCarrier]
  radialization : module -> radialCarrier
  radialization_measurable : Measurable radialization
  volume : SourceNormalizedLogVolume module
  measure : MeasureTheory.Measure radialCarrier
  measureSigmaFinite : MeasureTheory.SigmaFinite measure
  measureComplete : MeasureTheory.Measure.IsComplete measure
  admissible_radialImage_measurable :
    ∀ region : volume.AdmissibleRegion,
      MeasurableSet (radialization '' region.carrier)
  admissible_measure_ne_zero :
    ∀ region : volume.AdmissibleRegion,
      measure (radialization '' region.carrier) ≠ 0
  admissible_measure_ne_top :
    ∀ region : volume.AdmissibleRegion,
      measure (radialization '' region.carrier) ≠ ⊤
  rawLogVolume_eq_measure :
    ∀ region : volume.AdmissibleRegion,
      volume.rawLogVolume region.carrier region.isAdmissible =
        Real.log (measure (radialization '' region.carrier)).toReal

attribute [instance]
  SourcePacketMeasuredSummand.radialTopologicalSpace
  SourcePacketMeasuredSummand.radialT2Space
  SourcePacketMeasuredSummand.radialLocallyCompactSpace
  SourcePacketMeasuredSummand.radialSecondCountableTopology
  SourcePacketMeasuredSummand.radialMeasurableSpace
  SourcePacketMeasuredSummand.radialBorelSpace

namespace SourcePacketMeasuredSummand

instance sigmaFinite
    {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
    {index : packet.PlaceTupleIndex}
    (summand : SourcePacketMeasuredSummand packet index) :
    MeasureTheory.SigmaFinite summand.measure :=
  summand.measureSigmaFinite

instance complete
    {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
    {index : packet.PlaceTupleIndex}
    (summand : SourcePacketMeasuredSummand packet index) :
    MeasureTheory.Measure.IsComplete summand.measure :=
  summand.measureComplete

end SourcePacketMeasuredSummand

namespace SourcePacketLogVolumeDecomposition

/--
The canonical algebraic expansion
`tensor_product (direct_sum_v M_v) = direct_sum_(v_t) tensor_product M_(v_t)`,
followed by the finite direct-sum/function identification and the measured
summands' specified tensor identifications.
-/
noncomputable def algebraicDecomposition
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (summand : ∀ index : packet.PlaceTupleIndex,
      SourcePacketMeasuredSummand packet index) :
    packet.carrier ≃ₗ[ℚ] (∀ index, (summand index).module) :=
  packet.tensorIso.toLinearEquiv |>.trans
    (PiTensorProduct.congr
      (fun factor => (packet.factor factor).directSumIso.toLinearEquiv)) |>.trans
    PiTensorProduct.ofDirectSumEquiv |>.trans
    (DirectSum.linearEquivFunOnFintype ℚ packet.PlaceTupleIndex
      (fun index => PiTensorProduct ℚ
        (fun factor => (packet.factor factor).summand (index factor)))) |>.trans
    (LinearEquiv.piCongrRight
      (fun index => (summand index).tensorIso.symm.toLinearEquiv))

end SourcePacketLogVolumeDecomposition

/--
The Proposition 3.1 direct-summand decomposition underlying the volume of one
tensor packet.  Its integral region is identified with the product of the
component integral regions, while the component radialization maps determine
the corresponding region in `M_V`.  No ordinary measure is asserted on the
tensor packet itself.
-/
structure SourcePacketLogVolumeDecomposition
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (integralRegion : Set packet.carrier) where
  place_nonempty : Nonempty packet.place
  summand :
    ∀ index : packet.PlaceTupleIndex,
      SourcePacketMeasuredSummand packet index
  placeMultiplicity : packet.place -> ℕ+
  placeNormalizationDegree : packet.place -> ℕ+
  integralRegion_measurable : MeasurableSet integralRegion
  algebraicDecomposition_measurable :
    Measurable
      (SourcePacketLogVolumeDecomposition.algebraicDecomposition packet summand)
  algebraicDecomposition_symm_measurable :
    Measurable
      (SourcePacketLogVolumeDecomposition.algebraicDecomposition packet summand).symm
  integralRegion_image :
    SourcePacketLogVolumeDecomposition.algebraicDecomposition packet summand ''
        integralRegion =
      Set.pi Set.univ
        (fun index => (summand index).volume.integralRegion)

namespace SourcePacketLogVolumeDecomposition

variable {j : ℕ} {packet : SourceMonoAnalyticTensorPacket.{u} j}
variable {integralRegion : Set packet.carrier}

/--
The cardinality `N_v` of Remark 3.1.1(iii)-(iv): the product of the local
degrees selected independently in every tensor factor.
-/
noncomputable def multiplicity
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (index : packet.PlaceTupleIndex) : ℕ+ :=
  ∏ factor, data.placeMultiplicity (index factor)

@[simp]
theorem multiplicity_val
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (index : packet.PlaceTupleIndex) :
    (data.multiplicity index).1 =
      ∏ factor, (data.placeMultiplicity (index factor)).1 := by
  change PNat.coeMonoidHom
      (∏ factor, data.placeMultiplicity (index factor)) = _
  rw [map_prod]
  rfl

/-- The normalized packet-weight denominator in Remark 3.1.1(ii). -/
noncomputable def normalizationDenominator
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) : ℕ :=
  ∑ index : packet.PlaceTupleIndex,
    ∏ factor,
      (data.placeNormalizationDegree (index factor)).1

/-- The normalized packet-weight denominator is nonzero. -/
theorem normalizationDenominator_pos
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    0 < data.normalizationDenominator := by
  classical
  obtain ⟨place⟩ := data.place_nonempty
  let index : packet.PlaceTupleIndex := fun _ => place
  refine Finset.sum_pos' (fun _ _ => Nat.zero_le _) ⟨index, Finset.mem_univ _, ?_⟩
  exact Finset.prod_pos fun factor _ =>
    (data.placeNormalizationDegree (index factor)).2

/-- The source normalization scale is the reciprocal of the derived denominator. -/
noncomputable def normalizationScale
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) : ℝ :=
  (data.normalizationDenominator : ℝ)⁻¹

theorem normalizationScale_pos
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    0 < data.normalizationScale := by
  rw [normalizationScale, inv_pos]
  exact_mod_cast data.normalizationDenominator_pos

/-- The canonical algebraic decomposition with its certified Borel structure. -/
noncomputable def decomposition
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    packet.carrier ≃ᵐ (∀ index, (data.summand index).module) where
  toEquiv := algebraicDecomposition packet data.summand
  measurable_toFun := data.algebraicDecomposition_measurable
  measurable_invFun := data.algebraicDecomposition_symm_measurable

/-- The product `E = ∏_v E_v` of Remark 3.1.1(iv), with `#E_v = N_v`. -/
abbrev WeightChoice
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :=
  ∀ index, Fin (data.multiplicity index).1

/--
The paper's index set `W = ⨆_v E_{≠v}`.  A copy of the summand at `v`
occurs once for every choice of weight coordinates away from `v`.
-/
abbrev ReplicaIndex
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :=
  Σ index : packet.PlaceTupleIndex,
    ∀ other : {other : packet.PlaceTupleIndex // other ≠ index},
      Fin (data.multiplicity other.1).1

/-- The product `M_V` of the source measure carriers. -/
abbrev VolumeCoordinates
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :=
  ∀ index, (data.summand index).radialCarrier

/-- The product `M_W` carrying the ordinary product measure. -/
abbrev ReplicaSpace
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :=
  ∀ replica : data.ReplicaIndex,
    (data.summand replica.1).radialCarrier

noncomputable instance weightChoiceFintype
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    Fintype data.WeightChoice :=
  Fintype.ofFinite _

noncomputable instance replicaIndexFintype
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    Fintype data.ReplicaIndex :=
  Fintype.ofFinite _

/-- Apply the finite/archimedean radialization in every direct summand. -/
def radializeCoordinates
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (value : ∀ index, (data.summand index).module) :
    data.VolumeCoordinates :=
  fun index => (data.summand index).radialization (value index)

/-- The radial image of a packet region inside the paper's `M_V`. -/
def radializedRegion
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (region : Set packet.carrier) : Set data.VolumeCoordinates :=
  data.radializeCoordinates '' (data.decomposition '' region)

/-- Read from `M_W` the `M_V` tuple associated to one `e ∈ E`. -/
def slice
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (value : data.ReplicaSpace) (choice : data.WeightChoice) :
    data.VolumeCoordinates :=
  fun index => value ⟨index, fun other => choice other.1⟩

/--
The subset `S_E ⊆ M_W`: every `E`-indexed tuple read from a replicated
point belongs to the image of `S` in the canonical direct-summand product.
-/
def weightedLift
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (region : Set packet.carrier) : Set data.ReplicaSpace :=
  {value | ∀ choice, data.slice value choice ∈ data.radializedRegion region}

/-- The ordinary product measure on `M_W`. -/
noncomputable def replicaProductMeasure
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    MeasureTheory.Measure data.ReplicaSpace :=
  MeasureTheory.Measure.pi
    (fun replica => (data.summand replica.1).measure)

/-- Mochizuki's `E`-weighted content `μ_E(S)`, not generally a measure in `S`. -/
noncomputable def weightedContent
    (data : SourcePacketLogVolumeDecomposition packet integralRegion)
    (region : Set packet.carrier) : ENNReal :=
  data.replicaProductMeasure (data.weightedLift region)

/--
The distinguished packet region radializes to the direct product of the
component radial regions.  This is where the finite-place identity and the
archimedean quotient map are kept distinct.
-/
theorem radializedRegion_integralRegion
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    data.radializedRegion integralRegion =
      Set.pi Set.univ
        (fun index =>
          (data.summand index).radialization ''
            (data.summand index).volume.integralRegion) := by
  classical
  have himage : data.decomposition '' integralRegion =
      Set.pi Set.univ
        (fun index => (data.summand index).volume.integralRegion) := by
    change algebraicDecomposition packet data.summand '' integralRegion = _
    exact data.integralRegion_image
  rw [radializedRegion, himage]
  ext value
  constructor
  · rintro ⟨sourceValue, hsourceValue, rfl⟩ index _
    exact ⟨sourceValue index,
      hsourceValue index (Set.mem_univ _), rfl⟩
  · intro hvalue
    choose sourceValue hsourceValue hradial using
      fun index => hvalue index (Set.mem_univ index)
    refine ⟨sourceValue, ?_, ?_⟩
    · intro index _
      exact hsourceValue index
    · funext index
      exact hradial index

/--
For the distinguished direct-product region, `S_E` is exactly the product of
the component regions over `W`.  This is the set-theoretic calculation in the
final display of Remark 3.1.1(iv).
-/
theorem weightedLift_integralRegion
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    data.weightedLift integralRegion =
      Set.pi Set.univ
        (fun replica : data.ReplicaIndex =>
          (data.summand replica.1).radialization ''
            (data.summand replica.1).volume.integralRegion) := by
  classical
  have himage := data.radializedRegion_integralRegion
  ext value
  constructor
  · intro hvalue replica _
    let choice : data.WeightChoice := fun index =>
      if hindex : index = replica.1 then
        ⟨0, (data.multiplicity index).pos⟩
      else
        replica.2 ⟨index, hindex⟩
    have hslice := hvalue choice
    rw [himage] at hslice
    have hcomponent := hslice replica.1 (Set.mem_univ _)
    change value replica ∈
      (data.summand replica.1).radialization ''
        (data.summand replica.1).volume.integralRegion
    convert hcomponent using 1
    congr 1
    apply Sigma.ext
    · rfl
    · exact heq_of_eq (by
        funext other
        simp only [choice, dif_neg other.2])
  · intro hvalue choice
    rw [himage]
    intro index _
    exact hvalue
      ⟨index, fun other => choice other.1⟩ (Set.mem_univ _)

/-- The distinguished weighted lift is Borel measurable. -/
theorem weightedLift_integralRegion_measurable
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    MeasurableSet (data.weightedLift integralRegion) := by
  rw [data.weightedLift_integralRegion]
  exact MeasurableSet.univ_pi fun replica =>
    (data.summand replica.1).admissible_radialImage_measurable
      (data.summand replica.1).volume.integralAdmissibleRegion

/-- The `E`-weighted content of a direct-product region is the replicated product. -/
theorem weightedContent_integralRegion
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    data.weightedContent integralRegion =
      ∏ replica : data.ReplicaIndex,
        (data.summand replica.1).measure
          ((data.summand replica.1).radialization ''
            (data.summand replica.1).volume.integralRegion) := by
  rw [weightedContent, data.weightedLift_integralRegion]
  exact MeasureTheory.Measure.pi_pi
    (fun replica : data.ReplicaIndex =>
      (data.summand replica.1).measure)
    (fun replica : data.ReplicaIndex =>
      (data.summand replica.1).radialization ''
        (data.summand replica.1).volume.integralRegion)

/-- The distinguished weighted content is positive. -/
theorem weightedContent_integralRegion_ne_zero
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    data.weightedContent integralRegion ≠ 0 := by
  rw [data.weightedContent_integralRegion]
  exact Finset.prod_ne_zero_iff.mpr fun replica _ =>
    (data.summand replica.1).admissible_measure_ne_zero
      (data.summand replica.1).volume.integralAdmissibleRegion

/-- The distinguished weighted content is finite. -/
theorem weightedContent_integralRegion_ne_top
    (data : SourcePacketLogVolumeDecomposition packet integralRegion) :
    data.weightedContent integralRegion ≠ ⊤ := by
  rw [data.weightedContent_integralRegion]
  exact ENNReal.prod_ne_top fun replica _ =>
    (data.summand replica.1).admissible_measure_ne_top
      (data.summand replica.1).volume.integralAdmissibleRegion

/-- The finite product measure on the source radial coordinate space `M_V`. -/
noncomputable def productMeasure
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    MeasureTheory.Measure
      decomposition.VolumeCoordinates :=
  MeasureTheory.Measure.pi
    (fun index => (decomposition.summand index).measure)

/-- The integral packet is measurable because it is a product region. -/
theorem measurable_integralRegion
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    MeasurableSet integralRegion :=
  decomposition.integralRegion_measurable

/-- The radialized integral region has the product of the component volumes. -/
theorem productMeasure_radializedIntegralRegion
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    decomposition.productMeasure
        (decomposition.radializedRegion integralRegion) =
      ∏ index,
        (decomposition.summand index).measure
          ((decomposition.summand index).radialization ''
            (decomposition.summand index).volume.integralRegion) := by
  rw [decomposition.radializedRegion_integralRegion]
  exact MeasureTheory.Measure.pi_pi
    (fun index => (decomposition.summand index).measure)
    (fun index =>
      (decomposition.summand index).radialization ''
        (decomposition.summand index).volume.integralRegion)

/-- The radialized integral region has positive product measure. -/
theorem productMeasure_radializedIntegralRegion_ne_zero
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    decomposition.productMeasure
        (decomposition.radializedRegion integralRegion) ≠ 0 := by
  rw [decomposition.productMeasure_radializedIntegralRegion]
  exact Finset.prod_ne_zero_iff.mpr (fun index _ =>
    (decomposition.summand index).admissible_measure_ne_zero
      (decomposition.summand index).volume.integralAdmissibleRegion)

/-- The radialized integral region has finite product measure. -/
theorem productMeasure_radializedIntegralRegion_ne_top
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    decomposition.productMeasure
        (decomposition.radializedRegion integralRegion) ≠ ⊤ := by
  rw [decomposition.productMeasure_radializedIntegralRegion]
  exact ENNReal.prod_ne_top (fun index _ =>
    (decomposition.summand index).admissible_measure_ne_top
      (decomposition.summand index).volume.integralAdmissibleRegion)

/--
The packet functional obtained from Mochizuki's `E`-weighted content.  The
factor `1 / #E` is the normalization in Remark 3.1.1(iv); the remaining
source weight normalization is the derived `normalizationScale`.
-/
noncomputable def toNormalizedLogVolume
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    SourceNormalizedLogVolume packet.carrier where
  admissible := fun region =>
    MeasurableSet (decomposition.weightedLift region) ∧
      decomposition.weightedContent region ≠ 0 ∧
      decomposition.weightedContent region ≠ ⊤
  rawLogVolume := fun region _ =>
    decomposition.normalizationScale *
      (Real.log (decomposition.weightedContent region).toReal /
        Fintype.card decomposition.WeightChoice)
  integralRegion := integralRegion
  integralRegion_admissible :=
    ⟨decomposition.weightedLift_integralRegion_measurable,
      decomposition.weightedContent_integralRegion_ne_zero,
      decomposition.weightedContent_integralRegion_ne_top⟩
  normalizationOffset :=
    decomposition.normalizationScale *
      ((∑ replica : decomposition.ReplicaIndex,
        (decomposition.summand replica.1).volume.normalizationOffset) /
          Fintype.card decomposition.WeightChoice)

/-- The weighted packet value is the normalized replicated sum of component values. -/
theorem toNormalizedLogVolume_value
    (decomposition :
      SourcePacketLogVolumeDecomposition packet integralRegion) :
    decomposition.toNormalizedLogVolume.value =
      decomposition.normalizationScale *
        ((∑ replica : decomposition.ReplicaIndex,
          (decomposition.summand replica.1).volume.value) /
            Fintype.card decomposition.WeightChoice) := by
  change
    decomposition.normalizationScale *
          (Real.log (decomposition.weightedContent integralRegion).toReal /
            Fintype.card decomposition.WeightChoice) -
        decomposition.normalizationScale *
          ((∑ replica : decomposition.ReplicaIndex,
            (decomposition.summand replica.1).volume.normalizationOffset) /
              Fintype.card decomposition.WeightChoice) =
      decomposition.normalizationScale *
        ((∑ replica : decomposition.ReplicaIndex,
          (decomposition.summand replica.1).volume.value) /
            Fintype.card decomposition.WeightChoice)
  have hsummand : ∀ replica : decomposition.ReplicaIndex,
      (decomposition.summand replica.1).volume.value =
        Real.log
            ((decomposition.summand replica.1).measure
              ((decomposition.summand replica.1).radialization ''
                (decomposition.summand replica.1).volume.integralRegion)).toReal -
          (decomposition.summand replica.1).volume.normalizationOffset := by
    intro replica
    rw [SourceNormalizedLogVolume.value,
      SourceNormalizedLogVolume.valueOn]
    rw [(decomposition.summand replica.1).rawLogVolume_eq_measure
      (decomposition.summand replica.1).volume.integralAdmissibleRegion]
    rfl
  have hpositive : ∀ replica : decomposition.ReplicaIndex,
      0 < ((decomposition.summand replica.1).measure
        ((decomposition.summand replica.1).radialization ''
          (decomposition.summand replica.1).volume.integralRegion)).toReal := by
    intro replica
    apply ENNReal.toReal_pos
    · exact (decomposition.summand replica.1).admissible_measure_ne_zero
        (decomposition.summand replica.1).volume.integralAdmissibleRegion
    · exact (decomposition.summand replica.1).admissible_measure_ne_top
        (decomposition.summand replica.1).volume.integralAdmissibleRegion
  simp_rw [hsummand]
  rw [decomposition.weightedContent_integralRegion,
    ENNReal.toReal_prod,
    Real.log_prod (fun replica _ => (hpositive replica).ne'),
    Finset.sum_sub_distrib]
  ring

/--
Compatibility of packet log-volume decompositions under a continuous Kummer
isomorphism.  The measurable packet map is required to be exactly the composite
of decomposition, measure-preserving coordinate transport, and reassembly.
-/
noncomputable def coordinateEquivOf
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    {targetIntegralRegion : Set targetPacket.carrier}
    (source : SourcePacketLogVolumeDecomposition packet integralRegion)
    (target :
      SourcePacketLogVolumeDecomposition targetPacket targetIntegralRegion)
    (indexEquiv : packet.PlaceTupleIndex ≃ targetPacket.PlaceTupleIndex)
    (summandEquiv : ∀ index,
      (source.summand index).module ≃ᵐ
        (target.summand (indexEquiv index)).module) :
    (∀ index, (source.summand index).module) ≃ᵐ
      (∀ index, (target.summand index).module) :=
  (MeasurableEquiv.piCongrRight summandEquiv).trans
    (MeasurableEquiv.piCongrLeft
      (fun index => (target.summand index).module) indexEquiv)

/-- A continuous packet Kummer isomorphism is canonically a Borel equivalence. -/
noncomputable def packetMeasurableEquivOf
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    (packetKummer : packet.carrier ≃L[ℚ] targetPacket.carrier) :
    packet.carrier ≃ᵐ targetPacket.carrier where
  toEquiv := packetKummer.toLinearEquiv.toEquiv
  measurable_toFun := packetKummer.continuous.measurable
  measurable_invFun := packetKummer.symm.continuous.measurable

structure Compatible
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    {targetIntegralRegion : Set targetPacket.carrier}
    (source : SourcePacketLogVolumeDecomposition packet integralRegion)
    (target :
      SourcePacketLogVolumeDecomposition targetPacket targetIntegralRegion)
    (packetKummer : packet.carrier ≃L[ℚ] targetPacket.carrier) where
  coordinatePlaceEquiv : packet.place ≃ targetPacket.place
  coordinateSummandEquiv :
    ∀ index,
      (source.summand index).module ≃ᵐ
        (target.summand
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket coordinatePlaceEquiv index)).module
  coordinateRadialEquiv :
    ∀ index,
      (source.summand index).radialCarrier ≃ᵐ
        (target.summand
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket coordinatePlaceEquiv index)).radialCarrier
  coordinateRadial_measurePreserving :
    ∀ index,
      MeasureTheory.MeasurePreserving (coordinateRadialEquiv index)
        (source.summand index).measure
        (target.summand
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket coordinatePlaceEquiv index)).measure
  coordinateRadialization_commutes :
    ∀ index value,
      coordinateRadialEquiv index
          ((source.summand index).radialization value) =
        (target.summand
          (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
            packet targetPacket coordinatePlaceEquiv index)).radialization
              (coordinateSummandEquiv index value)
  placeMultiplicity_eq :
    ∀ place,
      target.placeMultiplicity (coordinatePlaceEquiv place) =
        source.placeMultiplicity place
  placeNormalizationDegree_eq :
    ∀ place,
      target.placeNormalizationDegree (coordinatePlaceEquiv place) =
        source.placeNormalizationDegree place
  summandNormalizationOffset_eq :
    ∀ index,
      (target.summand
        (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
          packet targetPacket coordinatePlaceEquiv index)).volume.normalizationOffset =
        (source.summand index).volume.normalizationOffset
  packetKummer_apply_composite :
    ∀ value,
      packetKummer value =
        target.decomposition.toEquiv.symm
          ((coordinateEquivOf source target
            (SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
              packet targetPacket coordinatePlaceEquiv)
            coordinateSummandEquiv).toEquiv
              (source.decomposition.toEquiv value))

namespace Compatible

variable
    {targetPacket : SourceMonoAnalyticTensorPacket.{u} j}
    {targetIntegralRegion : Set targetPacket.carrier}
    {source : SourcePacketLogVolumeDecomposition packet integralRegion}
    {target :
      SourcePacketLogVolumeDecomposition targetPacket targetIntegralRegion}
    {packetKummer : packet.carrier ≃L[ℚ] targetPacket.carrier}

/-- The direct-summand reindexing is the factorwise product of the place map. -/
def coordinateIndexEquiv
    (compatible : Compatible source target packetKummer) :
    packet.PlaceTupleIndex ≃ targetPacket.PlaceTupleIndex :=
  SourceMonoAnalyticTensorPacket.placeTupleIndexEquivOf
    packet targetPacket compatible.coordinatePlaceEquiv

/-- Product weights are preserved because every selected local degree is preserved. -/
theorem multiplicity_eq
    (compatible : Compatible source target packetKummer)
    (index : packet.PlaceTupleIndex) :
    target.multiplicity (compatible.coordinateIndexEquiv index) =
      source.multiplicity index := by
  apply Subtype.ext
  simp only [multiplicity_val]
  apply Finset.prod_congr rfl
  intro factor _
  change
    (target.placeMultiplicity
      (compatible.coordinatePlaceEquiv (index factor))).1 =
      (source.placeMultiplicity (index factor)).1
  exact congrArg (·.1)
    (compatible.placeMultiplicity_eq (index factor))

/-- Factorwise preservation of moduli-to-rational degrees preserves the denominator. -/
theorem normalizationDenominator_eq
    (compatible : Compatible source target packetKummer) :
    target.normalizationDenominator = source.normalizationDenominator := by
  classical
  calc
    target.normalizationDenominator =
        ∑ index : packet.PlaceTupleIndex,
          ∏ factor,
            (target.placeNormalizationDegree
              (compatible.coordinateIndexEquiv index factor)).1 := by
      exact (compatible.coordinateIndexEquiv.sum_comp
        (fun index : targetPacket.PlaceTupleIndex =>
          ∏ factor,
            (target.placeNormalizationDegree (index factor)).1)).symm
    _ = source.normalizationDenominator := by
      apply Finset.sum_congr rfl
      intro index _
      apply Finset.prod_congr rfl
      intro factor _
      change
        (target.placeNormalizationDegree
          (compatible.coordinatePlaceEquiv (index factor))).1 =
          (source.placeNormalizationDegree (index factor)).1
      exact congrArg (·.1)
        (compatible.placeNormalizationDegree_eq (index factor))

/-- The real normalization scale is therefore preserved, rather than supplied. -/
theorem normalizationScale_eq
    (compatible : Compatible source target packetKummer) :
    target.normalizationScale = source.normalizationScale := by
  rw [normalizationScale, normalizationScale,
    compatible.normalizationDenominator_eq]

/-- Coordinate transport is induced by reindexing and the summand maps. -/
noncomputable def coordinateEquiv
    (compatible : Compatible source target packetKummer) :
    (∀ index, (source.summand index).module) ≃ᵐ
      (∀ index, (target.summand index).module) :=
  coordinateEquivOf source target compatible.coordinateIndexEquiv
    compatible.coordinateSummandEquiv

/-- Coordinate transport on the source measure carriers `M_V`. -/
noncomputable def coordinateVolumeEquiv
    (compatible : Compatible source target packetKummer) :
    source.VolumeCoordinates ≃ᵐ target.VolumeCoordinates :=
  (MeasurableEquiv.piCongrRight compatible.coordinateRadialEquiv).trans
    (MeasurableEquiv.piCongrLeft
      (fun index => (target.summand index).radialCarrier)
      compatible.coordinateIndexEquiv)

/-- Multiplicity preservation identifies the finite weight coordinate at one summand. -/
noncomputable def weightCoordinateEquiv
    (compatible : Compatible source target packetKummer)
    (index : packet.PlaceTupleIndex) :
    Fin (source.multiplicity index).1 ≃
      Fin (target.multiplicity
        (compatible.coordinateIndexEquiv index)).1 :=
  finCongr (congrArg (·.1) (compatible.multiplicity_eq index).symm)

/-- Reindexing the summands and their finite coordinates identifies `E`. -/
noncomputable def weightChoiceEquiv
    (compatible : Compatible source target packetKummer) :
    source.WeightChoice ≃ target.WeightChoice :=
  (Equiv.piCongrRight fun index =>
    compatible.weightCoordinateEquiv index).trans
      (Equiv.piCongrLeft
        (fun index => Fin (target.multiplicity index).1)
        compatible.coordinateIndexEquiv)

/-- Evaluation of the induced `E`-equivalence at a transported summand. -/
@[simp]
theorem weightChoiceEquiv_apply
    (compatible : Compatible source target packetKummer)
    (choice : source.WeightChoice)
    (index : packet.PlaceTupleIndex) :
    compatible.weightChoiceEquiv choice
        (compatible.coordinateIndexEquiv index) =
      compatible.weightCoordinateEquiv index (choice index) := by
  change
    (Equiv.piCongrLeft
      (fun index => Fin (target.multiplicity index).1)
      compatible.coordinateIndexEquiv
      ((Equiv.piCongrRight fun index =>
        compatible.weightCoordinateEquiv index) choice))
        (compatible.coordinateIndexEquiv index) = _
  rw [Equiv.piCongrLeft_apply_apply]
  rfl

/-- The indices away from one summand are transported by the summand reindexing. -/
def otherIndexEquiv
    (compatible : Compatible source target packetKummer)
    (index : packet.PlaceTupleIndex) :
    {other : packet.PlaceTupleIndex // other ≠ index} ≃
      {other : targetPacket.PlaceTupleIndex //
        other ≠ compatible.coordinateIndexEquiv index} :=
  compatible.coordinateIndexEquiv.subtypeEquiv fun other => by
    constructor
    · intro hne heq
      exact hne (compatible.coordinateIndexEquiv.injective heq)
    · intro hne heq
      exact hne (congrArg compatible.coordinateIndexEquiv heq)

/-- The choices away from one summand are transported factor by factor. -/
noncomputable def otherChoiceEquiv
    (compatible : Compatible source target packetKummer)
    (index : packet.PlaceTupleIndex) :
    (∀ other : {other : packet.PlaceTupleIndex // other ≠ index},
      Fin (source.multiplicity other.1).1) ≃
    (∀ other : {other : targetPacket.PlaceTupleIndex //
        other ≠ compatible.coordinateIndexEquiv index},
      Fin (target.multiplicity other.1).1) :=
  (Equiv.piCongrRight fun other :
      {other : packet.PlaceTupleIndex // other ≠ index} =>
    compatible.weightCoordinateEquiv other.1).trans
      (Equiv.piCongrLeft
        (fun other : {other : targetPacket.PlaceTupleIndex //
          other ≠ compatible.coordinateIndexEquiv index} =>
            Fin (target.multiplicity other.1).1)
        (compatible.otherIndexEquiv index))

/-- Evaluation of an away-from-one-summand choice after reindexing. -/
@[simp]
theorem otherChoiceEquiv_apply
    (compatible : Compatible source target packetKummer)
    (index : packet.PlaceTupleIndex)
    (choice : ∀ other :
      {other : packet.PlaceTupleIndex // other ≠ index},
        Fin (source.multiplicity other.1).1)
    (other : {other : packet.PlaceTupleIndex // other ≠ index}) :
    compatible.otherChoiceEquiv index choice
        (compatible.otherIndexEquiv index other) =
      compatible.weightCoordinateEquiv other.1 (choice other) := by
  change
    (Equiv.piCongrLeft
      (fun other : {other : targetPacket.PlaceTupleIndex //
        other ≠ compatible.coordinateIndexEquiv index} =>
          Fin (target.multiplicity other.1).1)
      (compatible.otherIndexEquiv index)
      ((Equiv.piCongrRight fun other :
        {other : packet.PlaceTupleIndex // other ≠ index} =>
          compatible.weightCoordinateEquiv other.1) choice))
        (compatible.otherIndexEquiv index other) = _
  rw [Equiv.piCongrLeft_apply_apply]
  rfl

/-- The source-prescribed reindexing and multiplicities canonically identify `W`. -/
noncomputable def replicaIndexEquiv
    (compatible : Compatible source target packetKummer) :
    source.ReplicaIndex ≃ target.ReplicaIndex :=
  Equiv.sigmaCongr compatible.coordinateIndexEquiv
    compatible.otherChoiceEquiv

/-- The replica selected by a slice is carried to the replica selected after transport. -/
theorem replicaIndexEquiv_sliceIndex
    (compatible : Compatible source target packetKummer)
    (choice : source.WeightChoice)
    (index : packet.PlaceTupleIndex) :
    compatible.replicaIndexEquiv
        ⟨index, fun other => choice other.1⟩ =
      ⟨compatible.coordinateIndexEquiv index,
        fun other =>
          (compatible.weightChoiceEquiv choice) other.1⟩ := by
  apply Sigma.ext
  · rfl
  · exact heq_of_eq (by
      funext targetOther
      obtain ⟨sourceOther, rfl⟩ :=
        (compatible.otherIndexEquiv index).surjective targetOther
      change
        compatible.otherChoiceEquiv index
            (fun other => choice other.1)
            (compatible.otherIndexEquiv index sourceOther) =
          compatible.weightChoiceEquiv choice
            (compatible.coordinateIndexEquiv sourceOther.1)
      rw [compatible.otherChoiceEquiv_apply,
        compatible.weightChoiceEquiv_apply])

/-- A replicated radial carrier is transported by its source measure-space map. -/
noncomputable def replicaSummandEquiv
    (compatible : Compatible source target packetKummer)
    (replica : source.ReplicaIndex) :
    (source.summand replica.1).radialCarrier ≃ᵐ
      (target.summand
        (compatible.replicaIndexEquiv replica).1).radialCarrier := by
  change (source.summand replica.1).radialCarrier ≃ᵐ
    (target.summand
      (compatible.coordinateIndexEquiv replica.1)).radialCarrier
  exact compatible.coordinateRadialEquiv replica.1

/-- The induced Borel equivalence of the replicated product spaces `M_W`. -/
noncomputable def replicaEquiv
    (compatible : Compatible source target packetKummer) :
    source.ReplicaSpace ≃ᵐ target.ReplicaSpace :=
  (MeasurableEquiv.piCongrRight compatible.replicaSummandEquiv).trans
    (MeasurableEquiv.piCongrLeft
      (fun replica : target.ReplicaIndex =>
        (target.summand replica.1).radialCarrier)
      compatible.replicaIndexEquiv)

/-- Evaluation of coordinate transport at a reindexed direct summand. -/
@[simp]
theorem coordinateEquiv_apply
    (compatible : Compatible source target packetKummer)
    (value : ∀ index, (source.summand index).module)
    (index : packet.PlaceTupleIndex) :
    compatible.coordinateEquiv value
        (compatible.coordinateIndexEquiv index) =
      compatible.coordinateSummandEquiv index (value index) := by
  change
    (MeasurableEquiv.piCongrLeft
      (fun index => (target.summand index).module)
      compatible.coordinateIndexEquiv
      (MeasurableEquiv.piCongrRight
        compatible.coordinateSummandEquiv value))
        (compatible.coordinateIndexEquiv index) = _
  rw [MeasurableEquiv.piCongrLeft_apply_apply]
  rfl

/-- Evaluation of radial coordinate transport at a reindexed summand. -/
@[simp]
theorem coordinateVolumeEquiv_apply
    (compatible : Compatible source target packetKummer)
    (value : source.VolumeCoordinates)
    (index : packet.PlaceTupleIndex) :
    compatible.coordinateVolumeEquiv value
        (compatible.coordinateIndexEquiv index) =
      compatible.coordinateRadialEquiv index (value index) := by
  change
    (MeasurableEquiv.piCongrLeft
      (fun index => (target.summand index).radialCarrier)
      compatible.coordinateIndexEquiv
      (MeasurableEquiv.piCongrRight
        compatible.coordinateRadialEquiv value))
        (compatible.coordinateIndexEquiv index) = _
  rw [MeasurableEquiv.piCongrLeft_apply_apply]
  rfl

/-- Radialization commutes with the factorwise Kummer coordinate maps. -/
theorem radializeCoordinates_coordinateEquiv
    (compatible : Compatible source target packetKummer)
    (value : ∀ index, (source.summand index).module) :
    target.radializeCoordinates (compatible.coordinateEquiv value) =
      compatible.coordinateVolumeEquiv (source.radializeCoordinates value) := by
  funext targetIndex
  obtain ⟨index, rfl⟩ :=
    compatible.coordinateIndexEquiv.surjective targetIndex
  change
    (target.summand (compatible.coordinateIndexEquiv index)).radialization
        (compatible.coordinateEquiv value
          (compatible.coordinateIndexEquiv index)) =
      compatible.coordinateVolumeEquiv
          (source.radializeCoordinates value)
          (compatible.coordinateIndexEquiv index)
  rw [compatible.coordinateEquiv_apply,
    compatible.coordinateVolumeEquiv_apply]
  change
    (target.summand (compatible.coordinateIndexEquiv index)).radialization
        (compatible.coordinateSummandEquiv index (value index)) =
      compatible.coordinateRadialEquiv index
        ((source.summand index).radialization (value index))
  exact (compatible.coordinateRadialization_commutes index (value index)).symm

/-- Evaluation of replicated transport at a reindexed replica. -/
@[simp]
theorem replicaEquiv_apply
    (compatible : Compatible source target packetKummer)
    (value : source.ReplicaSpace)
    (replica : source.ReplicaIndex) :
    compatible.replicaEquiv value
        (compatible.replicaIndexEquiv replica) =
      compatible.replicaSummandEquiv replica (value replica) := by
  change
    (MeasurableEquiv.piCongrLeft
      (fun replica : target.ReplicaIndex =>
        (target.summand replica.1).radialCarrier)
      compatible.replicaIndexEquiv
      (MeasurableEquiv.piCongrRight
        compatible.replicaSummandEquiv value))
        (compatible.replicaIndexEquiv replica) = _
  rw [MeasurableEquiv.piCongrLeft_apply_apply]
  rfl

/-- Slicing the transported `M_W` point commutes with coordinate transport. -/
theorem slice_replicaEquiv_weightChoiceEquiv
    (compatible : Compatible source target packetKummer)
    (value : source.ReplicaSpace)
    (choice : source.WeightChoice) :
    target.slice (compatible.replicaEquiv value)
        (compatible.weightChoiceEquiv choice) =
      compatible.coordinateVolumeEquiv (source.slice value choice) := by
  funext targetIndex
  obtain ⟨index, rfl⟩ :=
    compatible.coordinateIndexEquiv.surjective targetIndex
  change
    compatible.replicaEquiv value
        ⟨compatible.coordinateIndexEquiv index,
          fun other => compatible.weightChoiceEquiv choice other.1⟩ =
      compatible.coordinateVolumeEquiv (source.slice value choice)
        (compatible.coordinateIndexEquiv index)
  rw [compatible.coordinateVolumeEquiv_apply]
  change
    compatible.replicaEquiv value
        ⟨compatible.coordinateIndexEquiv index,
          fun other => compatible.weightChoiceEquiv choice other.1⟩ =
      compatible.coordinateRadialEquiv index
        (value ⟨index, fun other => choice other.1⟩)
  let sourceReplica : source.ReplicaIndex :=
    ⟨index, fun other => choice other.1⟩
  let targetReplica : target.ReplicaIndex :=
    ⟨compatible.coordinateIndexEquiv index,
      fun other => compatible.weightChoiceEquiv choice other.1⟩
  have hindex : compatible.replicaIndexEquiv sourceReplica = targetReplica :=
    compatible.replicaIndexEquiv_sliceIndex choice index
  have htransport :
      compatible.replicaEquiv value
          (compatible.replicaIndexEquiv sourceReplica) =
        compatible.replicaEquiv value targetReplica :=
    eq_of_heq (congr_arg_heq (compatible.replicaEquiv value) hindex)
  have happly := compatible.replicaEquiv_apply value sourceReplica
  change
    compatible.replicaEquiv value
        (compatible.replicaIndexEquiv sourceReplica) =
      compatible.coordinateRadialEquiv index (value sourceReplica) at happly
  exact htransport.symm.trans happly

/-- Every replicated factor map preserves its component measure. -/
theorem replicaSummand_measurePreserving
    (compatible : Compatible source target packetKummer)
    (replica : source.ReplicaIndex) :
    MeasureTheory.MeasurePreserving (compatible.replicaSummandEquiv replica)
      (source.summand replica.1).measure
      (target.summand (compatible.replicaIndexEquiv replica).1).measure := by
  change MeasureTheory.MeasurePreserving
    (compatible.coordinateRadialEquiv replica.1)
    (source.summand replica.1).measure
    (target.summand
      (compatible.coordinateIndexEquiv replica.1)).measure
  exact compatible.coordinateRadial_measurePreserving replica.1

/-- Factorwise measure preservation constructs measure preservation on `M_W`. -/
theorem replica_measurePreserving
    (compatible : Compatible source target packetKummer) :
    MeasureTheory.MeasurePreserving compatible.replicaEquiv
      source.replicaProductMeasure target.replicaProductMeasure := by
  have hfactor :
      MeasureTheory.MeasurePreserving
        (fun value replica =>
          compatible.replicaSummandEquiv replica (value replica))
        source.replicaProductMeasure
        (MeasureTheory.Measure.pi fun replica : source.ReplicaIndex =>
          (target.summand
            (compatible.replicaIndexEquiv replica).1).measure) :=
    MeasureTheory.measurePreserving_pi
      (fun replica : source.ReplicaIndex =>
        (source.summand replica.1).measure)
      (fun replica : source.ReplicaIndex =>
        (target.summand
          (compatible.replicaIndexEquiv replica).1).measure)
      compatible.replicaSummand_measurePreserving
  have hreindex :=
    MeasureTheory.measurePreserving_piCongrLeft
      (fun replica : target.ReplicaIndex =>
        (target.summand replica.1).measure)
      compatible.replicaIndexEquiv
  exact hreindex.comp hfactor

/-- Factorwise measure preservation constructs product-measure preservation. -/
theorem coordinate_measurePreserving
    (compatible : Compatible source target packetKummer) :
    MeasureTheory.MeasurePreserving compatible.coordinateVolumeEquiv
      source.productMeasure target.productMeasure := by
  have hfactor :
      MeasureTheory.MeasurePreserving
        (fun value index =>
          compatible.coordinateRadialEquiv index (value index))
        source.productMeasure
        (MeasureTheory.Measure.pi fun index =>
          (target.summand
            (compatible.coordinateIndexEquiv index)).measure) :=
    MeasureTheory.measurePreserving_pi
      (fun index => (source.summand index).measure)
      (fun index =>
        (target.summand
          (compatible.coordinateIndexEquiv index)).measure)
      compatible.coordinateRadial_measurePreserving
  have hreindex :=
    MeasureTheory.measurePreserving_piCongrLeft
      (fun index => (target.summand index).measure)
      compatible.coordinateIndexEquiv
  exact hreindex.comp hfactor

/-- The packet Kummer map commutes with the canonical direct-summand decompositions. -/
theorem decomposition_packetKummer_apply
    (compatible : Compatible source target packetKummer)
    (value : packet.carrier) :
    target.decomposition (packetKummer value) =
      compatible.coordinateEquiv (source.decomposition value) := by
  rw [compatible.packetKummer_apply_composite]
  exact target.decomposition.apply_symm_apply _

/-- Membership in a decomposed packet region is reflected by coordinate transport. -/
theorem coordinateEquiv_mem_decomposition_image_iff
    (compatible : Compatible source target packetKummer)
    (region : Set packet.carrier)
    (value : ∀ index, (source.summand index).module) :
    compatible.coordinateEquiv value ∈
        target.decomposition '' (packetKummer '' region) ↔
      value ∈ source.decomposition '' region := by
  constructor
  · rintro ⟨_, ⟨sourceValue, hsourceValue, rfl⟩, heq⟩
    refine ⟨sourceValue, hsourceValue, ?_⟩
    apply compatible.coordinateEquiv.injective
    exact (compatible.decomposition_packetKummer_apply sourceValue).symm.trans
      heq
  · rintro ⟨sourceValue, hsourceValue, rfl⟩
    exact ⟨packetKummer sourceValue, ⟨sourceValue, hsourceValue, rfl⟩,
      compatible.decomposition_packetKummer_apply sourceValue⟩

/-- Membership in the radial image is reflected by radial coordinate transport. -/
theorem coordinateVolumeEquiv_mem_radializedRegion_iff
    (compatible : Compatible source target packetKummer)
    (region : Set packet.carrier)
    (value : source.VolumeCoordinates) :
    compatible.coordinateVolumeEquiv value ∈
        target.radializedRegion (packetKummer '' region) ↔
      value ∈ source.radializedRegion region := by
  constructor
  · rintro ⟨targetValue, htargetValue, hradial⟩
    let sourceValue := compatible.coordinateEquiv.symm targetValue
    have htargetValue' :
        compatible.coordinateEquiv sourceValue ∈
          target.decomposition '' (packetKummer '' region) := by
      simpa only [sourceValue, compatible.coordinateEquiv.apply_symm_apply] using
        htargetValue
    have hsourceValue :=
      (compatible.coordinateEquiv_mem_decomposition_image_iff
        region sourceValue).mp htargetValue'
    refine ⟨sourceValue, hsourceValue, ?_⟩
    apply compatible.coordinateVolumeEquiv.injective
    calc
      compatible.coordinateVolumeEquiv
          (source.radializeCoordinates sourceValue) =
          target.radializeCoordinates
            (compatible.coordinateEquiv sourceValue) :=
        (compatible.radializeCoordinates_coordinateEquiv sourceValue).symm
      _ = target.radializeCoordinates targetValue := by
        congr 1
        exact compatible.coordinateEquiv.apply_symm_apply targetValue
      _ = compatible.coordinateVolumeEquiv value := hradial
  · rintro ⟨sourceValue, hsourceValue, rfl⟩
    refine ⟨compatible.coordinateEquiv sourceValue, ?_, ?_⟩
    · exact (compatible.coordinateEquiv_mem_decomposition_image_iff
        region sourceValue).mpr hsourceValue
    · exact compatible.radializeCoordinates_coordinateEquiv sourceValue

/-- Weighted-lift membership is reflected by the induced map on `M_W`. -/
theorem replicaEquiv_mem_weightedLift_iff
    (compatible : Compatible source target packetKummer)
    (region : Set packet.carrier)
    (value : source.ReplicaSpace) :
    compatible.replicaEquiv value ∈
        target.weightedLift (packetKummer '' region) ↔
      value ∈ source.weightedLift region := by
  constructor
  · intro htarget sourceChoice
    have hslice := htarget (compatible.weightChoiceEquiv sourceChoice)
    rw [compatible.slice_replicaEquiv_weightChoiceEquiv] at hslice
    exact (compatible.coordinateVolumeEquiv_mem_radializedRegion_iff
      region (source.slice value sourceChoice)).mp hslice
  · intro hsource targetChoice
    let sourceChoice := compatible.weightChoiceEquiv.symm targetChoice
    have hslice := hsource sourceChoice
    have htarget :=
      (compatible.coordinateVolumeEquiv_mem_radializedRegion_iff
        region (source.slice value sourceChoice)).mpr hslice
    rw [← compatible.slice_replicaEquiv_weightChoiceEquiv] at htarget
    simpa only [sourceChoice, Equiv.apply_symm_apply] using htarget

/-- The induced map on `M_W` carries the complete weighted lift onto its target. -/
theorem replicaEquiv_image_weightedLift
    (compatible : Compatible source target packetKummer)
    (region : Set packet.carrier) :
    compatible.replicaEquiv '' source.weightedLift region =
      target.weightedLift (packetKummer '' region) := by
  ext targetValue
  constructor
  · rintro ⟨sourceValue, hsourceValue, rfl⟩
    exact (compatible.replicaEquiv_mem_weightedLift_iff
      region sourceValue).mpr hsourceValue
  · intro htargetValue
    refine ⟨compatible.replicaEquiv.symm targetValue, ?_,
      compatible.replicaEquiv.apply_symm_apply targetValue⟩
    apply (compatible.replicaEquiv_mem_weightedLift_iff region
      (compatible.replicaEquiv.symm targetValue)).mp
    simpa only [compatible.replicaEquiv.apply_symm_apply] using htargetValue

/-- Kummer coordinate transport preserves Mochizuki's `E`-weighted content. -/
theorem weightedContent_image
    (compatible : Compatible source target packetKummer)
    (region : Set packet.carrier) :
    target.weightedContent (packetKummer '' region) =
      source.weightedContent region := by
  rw [weightedContent, weightedContent,
    ← compatible.replicaEquiv_image_weightedLift region]
  rw [← compatible.replica_measurePreserving.map_eq]
  exact (compatible.replicaEquiv.map_apply
      (compatible.replicaEquiv '' source.weightedLift region)).trans
    (congrArg source.replicaProductMeasure
      (compatible.replicaEquiv.injective.preimage_image
        (source.weightedLift region)))

/-- Measurability of a weighted lift transports through the replica equivalence. -/
theorem weightedLift_image_measurable
    (compatible : Compatible source target packetKummer)
    (region : Set packet.carrier)
    (hmeasurable : MeasurableSet (source.weightedLift region)) :
    MeasurableSet (target.weightedLift (packetKummer '' region)) := by
  rw [← compatible.replicaEquiv_image_weightedLift region]
  exact compatible.replicaEquiv.measurableEmbedding.measurableSet_image.mpr
    hmeasurable

/-- The induced equivalence of `E` preserves its normalization cardinality. -/
theorem weightChoice_card_eq
    (compatible : Compatible source target packetKummer) :
    Fintype.card target.WeightChoice = Fintype.card source.WeightChoice :=
  (Fintype.card_congr compatible.weightChoiceEquiv).symm

/-- Reindexing `W` and preserving each summand offset preserves the replica sum. -/
theorem replicaNormalizationOffset_sum_eq
    (compatible : Compatible source target packetKummer) :
    (∑ replica : target.ReplicaIndex,
        (target.summand replica.1).volume.normalizationOffset) =
      ∑ replica : source.ReplicaIndex,
        (source.summand replica.1).volume.normalizationOffset := by
  calc
    (∑ replica : target.ReplicaIndex,
        (target.summand replica.1).volume.normalizationOffset) =
        ∑ replica : source.ReplicaIndex,
          (target.summand
            (compatible.replicaIndexEquiv replica).1).volume.normalizationOffset :=
      (compatible.replicaIndexEquiv.sum_comp
        (fun replica : target.ReplicaIndex =>
          (target.summand replica.1).volume.normalizationOffset)).symm
    _ = ∑ replica : source.ReplicaIndex,
          (source.summand replica.1).volume.normalizationOffset := by
      apply Finset.sum_congr rfl
      intro replica _
      change
        (target.summand
          (compatible.coordinateIndexEquiv replica.1)).volume.normalizationOffset =
        (source.summand replica.1).volume.normalizationOffset
      exact compatible.summandNormalizationOffset_eq replica.1

/-- The complete weighted normalization offset is derived from coordinate data. -/
theorem normalizationOffset_eq
    (compatible : Compatible source target packetKummer) :
    target.toNormalizedLogVolume.normalizationOffset =
      source.toNormalizedLogVolume.normalizationOffset := by
  change
    target.normalizationScale *
        ((∑ replica : target.ReplicaIndex,
          (target.summand replica.1).volume.normalizationOffset) /
            Fintype.card target.WeightChoice) =
      source.normalizationScale *
        ((∑ replica : source.ReplicaIndex,
          (source.summand replica.1).volume.normalizationOffset) /
            Fintype.card source.WeightChoice)
  rw [compatible.normalizationScale_eq,
    compatible.replicaNormalizationOffset_sum_eq,
    compatible.weightChoice_card_eq]

/-- The derived normalized packet functionals are Kummer compatible. -/
theorem toNormalizedLogVolume_compatible
    (compatible : Compatible source target packetKummer) :
    SourceNormalizedLogVolume.Compatible
      source.toNormalizedLogVolume target.toNormalizedLogVolume packetKummer := by
  refine
    { admissible_image := ?_
      rawLogVolume_image := ?_
      normalizationOffset_eq := compatible.normalizationOffset_eq }
  · intro region
    rcases region.isAdmissible with ⟨hmeasurable, hneZero, hneTop⟩
    refine ⟨compatible.weightedLift_image_measurable
      region.carrier hmeasurable, ?_, ?_⟩
    · rwa [compatible.weightedContent_image]
    · rwa [compatible.weightedContent_image]
  · intro region
    change
      target.normalizationScale *
          (Real.log
              (target.weightedContent
                (packetKummer '' region.carrier)).toReal /
            Fintype.card target.WeightChoice) =
        source.normalizationScale *
          (Real.log
              (source.weightedContent region.carrier).toReal /
            Fintype.card source.WeightChoice)
    rw [compatible.weightedContent_image,
      compatible.normalizationScale_eq,
      compatible.weightChoice_card_eq]

end Compatible

end SourcePacketLogVolumeDecomposition

/--
One Proposition 1.2(vi)-(vii) mono-analytic log-shell, attached to an actual
mono-analytic prime strip and an actual selected place.
-/
structure SourceMonoAnalyticLogShell
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}
    (_strip : SourceDMonoAnalyticPrimeStrip models)
    (place : SourceSelectedPlace theta) where
  module :
    SourceIndTopologicalLocalModule.{u} place.1.toRational
  integral :
    SourceMonoAnalyticIntegralStructure
      place.1.toRational.kind module.rationalCarrier
  symmetryData :
    SourceMonoAnalyticLogShellSymmetryData module.rationalCarrier
      place.1.toRational.kind integral
  normalizedLogVolume :
    SourceNormalizedLogVolume module.rationalCarrier
  normalizedLogVolume_region :
    normalizedLogVolume.integralRegion = integral.carrier
  packetNormalization :
    SourceNormalizedLogVolume.PacketNormalization place.1.toRational
      normalizedLogVolume

namespace SourceMonoAnalyticLogShell

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}
    {strip : SourceDMonoAnalyticPrimeStrip models}
    {place : SourceSelectedPlace theta}

/-- The exact source symmetry group attached to one mono-analytic summand. -/
noncomputable def ind2Symmetry
    (shell : SourceMonoAnalyticLogShell strip place) : Type u :=
  shell.symmetryData.GroupType

noncomputable instance ind2SymmetryGroup
    (shell : SourceMonoAnalyticLogShell strip place) :
    Group shell.ind2Symmetry := by
  unfold ind2Symmetry
  infer_instance

/-- The source symmetry acts by rational-linear automorphisms of the log module. -/
noncomputable def ind2Action
    (shell : SourceMonoAnalyticLogShell strip place)
    (symmetry : shell.ind2Symmetry) :
    shell.module.rationalCarrier ≃ₗ[ℚ]
      shell.module.rationalCarrier :=
  shell.symmetryData.action symmetry

theorem ind2Action_one
    (shell : SourceMonoAnalyticLogShell strip place)
    (value : shell.module.rationalCarrier) :
    shell.ind2Action 1 value = value := by
  exact shell.symmetryData.action_one value

theorem ind2Action_mul
    (shell : SourceMonoAnalyticLogShell strip place)
    (first second : shell.ind2Symmetry)
    (value : shell.module.rationalCarrier) :
    shell.ind2Action (first * second) value =
      shell.ind2Action first (shell.ind2Action second value) := by
  exact shell.symmetryData.action_mul first second value

/-- At an infinite place every source Ind2 symmetry has order dividing two. -/
theorem ind2Symmetry_square_of_archimedean
    (shell : SourceMonoAnalyticLogShell strip place)
    (hkind : place.1.toRational.kind = .archimedean)
    (symmetry : shell.ind2Symmetry) :
    symmetry * symmetry = 1 := by
  exact shell.symmetryData.square_of_archimedean hkind symmetry

end SourceMonoAnalyticLogShell

/--
The functorial log-shell algorithm of Proposition 1.2(vi)-(viii).

The transport maps act on the actual colimit modules, preserve the actual
shell subsets, preserve the measured regions, and satisfy the category laws.
-/
structure SourceMonoAnalyticLogShellAlgorithm
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    (models : IUTIThetaHodgeTheaterModels theta) where
  shell :
    (strip : SourceDMonoAnalyticPrimeStrip models) ->
      (place : SourceSelectedPlace theta) ->
      SourceMonoAnalyticLogShell strip place
  transport :
    ∀ {source target : SourceDMonoAnalyticPrimeStrip models}
      (map : source ⟶ target) (place : SourceSelectedPlace theta),
      (shell source place).module.rationalCarrier ≃L[ℚ]
        (shell target place).module.rationalCarrier
  transport_integral :
    ∀ {source target} (map : source ⟶ target) place,
      transport map place '' (shell source place).integral.carrier =
        (shell target place).integral.carrier
  transport_archimedean_seminorm :
    ∀ {source target} (map : source ⟶ target) place
      (hkind : place.1.toRational.kind = .archimedean) value,
      ((shell target place).integral.asArchimedean hkind).seminorm
          (transport map place value) =
        ((shell source place).integral.asArchimedean hkind).seminorm value
  transport_archimedean_inner :
    ∀ {source target} (map : source ⟶ target) place
      (hkind : place.1.toRational.kind = .archimedean) first second,
      ((shell target place).integral.asArchimedean hkind).inner
          (transport map place first) (transport map place second) =
        ((shell source place).integral.asArchimedean hkind).inner first second
  transport_logVolumeFunctional :
    ∀ {source target} (map : source ⟶ target) place,
      SourceNormalizedLogVolume.Compatible
        (shell source place).normalizedLogVolume
        (shell target place).normalizedLogVolume
        (transport map place)
  transport_packetDilation :
    ∀ {source target} (map : source ⟶ target) place value,
      transport map place
          ((shell source place).packetNormalization.dilation value) =
        (shell target place).packetNormalization.dilation
          (transport map place value)
  transport_id :
    ∀ (strip : SourceDMonoAnalyticPrimeStrip models) place,
      transport (𝟙 strip) place =
        ContinuousLinearEquiv.refl ℚ
          (shell strip place).module.rationalCarrier
  transport_comp :
    ∀ {source middle target : SourceDMonoAnalyticPrimeStrip models}
      (first : source ⟶ middle) (second : middle ⟶ target) place,
      transport (first ≫ second) place =
        (transport first place).trans (transport second place)

namespace SourceMonoAnalyticLogShellAlgorithm

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/-- Measured integral regions are transported by the actual log-shell map. -/
theorem transport_measuredRegion
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target) (place : SourceSelectedPlace theta) :
    algorithm.transport map place ''
        (algorithm.shell source place).normalizedLogVolume.integralRegion =
      (algorithm.shell target place).normalizedLogVolume.integralRegion := by
  rw [(algorithm.shell source place).normalizedLogVolume_region,
    algorithm.transport_integral map place,
    (algorithm.shell target place).normalizedLogVolume_region]

/--
Functorial log-shell transport preserves the normalized value because it
preserves the full measured-region functional and the actual integral shell.
-/
theorem transport_logVolume
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target) (place : SourceSelectedPlace theta) :
    (algorithm.shell source place).normalizedLogVolume.value =
      (algorithm.shell target place).normalizedLogVolume.value :=
  (algorithm.transport_logVolumeFunctional map place).value_eq
    (algorithm.transport_measuredRegion map place)

/-- Transport a shell module along the defining equation `v | v_Q`. -/
noncomputable def moduleAbove
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    SourceIndTopologicalLocalModule.{u} rationalPlace := by
  rw [← place.2]
  exact (algorithm.shell strip place.1).module

/-- Transport between summands above a fixed rational place. -/
noncomputable def transportAbove
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    (algorithm.moduleAbove source rationalPlace place).rationalCarrier ≃L[ℚ]
      (algorithm.moduleAbove target rationalPlace place).rationalCarrier := by
  rcases place with ⟨place, rfl⟩
  exact algorithm.transport map place

@[simp]
theorem transportAbove_id
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    algorithm.transportAbove (𝟙 strip) rationalPlace place =
      ContinuousLinearEquiv.refl ℚ
        (algorithm.moduleAbove strip rationalPlace place).rationalCarrier := by
  rcases place with ⟨place, rfl⟩
  exact algorithm.transport_id strip place

theorem transportAbove_comp
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source middle target : SourceDMonoAnalyticPrimeStrip models}
    (first : source ⟶ middle) (second : middle ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    algorithm.transportAbove (first ≫ second) rationalPlace place =
      (algorithm.transportAbove first rationalPlace place).trans
        (algorithm.transportAbove second rationalPlace place) := by
  rcases place with ⟨place, rfl⟩
  exact algorithm.transport_comp first second place

/-- The integral structure on a summand above the fixed rational place. -/
noncomputable def integralAbove
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    SourceMonoAnalyticIntegralStructure rationalPlace.kind
      (algorithm.moduleAbove strip rationalPlace place).rationalCarrier := by
  rcases place with ⟨place, hplace⟩
  subst rationalPlace
  exact (algorithm.shell strip place).integral

/-- Vertical transport carries the selected-place integral shell exactly. -/
theorem transportAbove_integral
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    algorithm.transportAbove map rationalPlace place ''
        (algorithm.integralAbove source rationalPlace place).carrier =
      (algorithm.integralAbove target rationalPlace place).carrier := by
  rcases place with ⟨place, hplace⟩
  subst rationalPlace
  exact algorithm.transport_integral map place

/-- At an infinite place, vertical transport is an isometry of shell metrics. -/
theorem transportAbove_archimedean_seminorm
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (hkind : rationalPlace.kind = .archimedean)
    (value : (algorithm.moduleAbove source rationalPlace place).rationalCarrier) :
    ((algorithm.integralAbove target rationalPlace place).asArchimedean hkind
      ).seminorm (algorithm.transportAbove map rationalPlace place value) =
      ((algorithm.integralAbove source rationalPlace place).asArchimedean hkind
        ).seminorm value := by
  rcases place with ⟨place, hplace⟩
  subst rationalPlace
  exact algorithm.transport_archimedean_seminorm map place hkind value

/-- At an infinite place, vertical transport preserves the Hermitian form. -/
theorem transportAbove_archimedean_inner
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (hkind : rationalPlace.kind = .archimedean)
    (first second :
      (algorithm.moduleAbove source rationalPlace place).rationalCarrier) :
    ((algorithm.integralAbove target rationalPlace place).asArchimedean hkind
      ).inner
        (algorithm.transportAbove map rationalPlace place first)
        (algorithm.transportAbove map rationalPlace place second) =
      ((algorithm.integralAbove source rationalPlace place).asArchimedean hkind
        ).inner first second := by
  rcases place with ⟨place, hplace⟩
  subst rationalPlace
  exact algorithm.transport_archimedean_inner map place hkind first second

/-- The measured log-volume attached to the same transported summand. -/
noncomputable def normalizedLogVolumeAbove
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    SourceNormalizedLogVolume
      (algorithm.moduleAbove strip rationalPlace place).rationalCarrier := by
  rcases place with ⟨place, hplace⟩
  subst rationalPlace
  exact (algorithm.shell strip place).normalizedLogVolume

/-- The measured region is exactly the transported summand integral shell. -/
theorem normalizedLogVolumeAbove_region
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    (algorithm.normalizedLogVolumeAbove strip rationalPlace place).integralRegion =
      (algorithm.integralAbove strip rationalPlace place).carrier := by
  rcases place with ⟨place, hplace⟩
  subst rationalPlace
  exact (algorithm.shell strip place).normalizedLogVolume_region

/-- The exact Ind2 symmetry group on a summand above `v_Q`. -/
noncomputable def ind2SymmetryAbove
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) : Type u :=
  (algorithm.shell strip place.1).ind2Symmetry

noncomputable instance ind2SymmetryAboveGroup
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace) :
    Group (algorithm.ind2SymmetryAbove strip rationalPlace place) :=
  SourceMonoAnalyticLogShell.ind2SymmetryGroup
    (algorithm.shell strip place.1)

/-- The transported source symmetry on the actual summand above `v_Q`. -/
noncomputable def ind2ActionAbove
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (choice : algorithm.ind2SymmetryAbove strip rationalPlace place) :
    (algorithm.moduleAbove strip rationalPlace place).rationalCarrier ≃ₗ[ℚ]
      (algorithm.moduleAbove strip rationalPlace place).rationalCarrier := by
  rcases place with ⟨place, rfl⟩
  exact (algorithm.shell strip place).ind2Action choice

theorem ind2ActionAbove_one
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (value :
      (algorithm.moduleAbove strip rationalPlace place).rationalCarrier) :
    algorithm.ind2ActionAbove strip rationalPlace place 1 value = value := by
  rcases place with ⟨place, rfl⟩
  exact (algorithm.shell strip place).ind2Action_one value

theorem ind2ActionAbove_mul
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (first second :
      algorithm.ind2SymmetryAbove strip rationalPlace place)
    (value :
      (algorithm.moduleAbove strip rationalPlace place).rationalCarrier) :
    algorithm.ind2ActionAbove strip rationalPlace place (first * second) value =
      algorithm.ind2ActionAbove strip rationalPlace place first
        (algorithm.ind2ActionAbove strip rationalPlace place second value) := by
  rcases place with ⟨place, rfl⟩
  exact (algorithm.shell strip place).ind2Action_mul first second value

theorem ind2SymmetryAbove_square_of_archimedean
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (hkind : rationalPlace.kind = .archimedean)
    (choice : algorithm.ind2SymmetryAbove strip rationalPlace place) :
    choice * choice = 1 := by
  rcases place with ⟨place, rfl⟩
  exact
    (algorithm.shell strip place).ind2Symmetry_square_of_archimedean
      hkind choice

/-- The Proposition 3.2 one-factor direct sum computed from local log-shells. -/
noncomputable def factor
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace) :
    SourceLocalLogDirectSum.{u} rationalPlace
      (SourceSelectedPlaceAbove theta rationalPlace) :=
  SourceLocalLogDirectSum.ofLogarithmicShells
    (algorithm.moduleAbove strip rationalPlace)

/-- The finite direct-sum lattice formed from all finite-place log shells. -/
noncomputable def factorIntegralLattice
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace)
    (hkind : rationalPlace.kind = .nonarchimedean) :
    AddSubgroup (algorithm.factor strip rationalPlace).carrier where
  carrier :=
    { value |
      ∀ place,
        value place ∈
          ((algorithm.integralAbove strip rationalPlace place).asNonarchimedean
            hkind).lattice }
  zero_mem' place :=
    ((algorithm.integralAbove strip rationalPlace place).asNonarchimedean
      hkind).lattice.zero_mem
  add_mem' {first second} hfirst hsecond place :=
    ((algorithm.integralAbove strip rationalPlace place).asNonarchimedean
      hkind).lattice.add_mem (hfirst place) (hsecond place)
  neg_mem' {value} hvalue place :=
    ((algorithm.integralAbove strip rationalPlace place).asNonarchimedean
      hkind).lattice.neg_mem (hvalue place)

/-- The finite direct-sum transport induced by every placewise shell transport. -/
noncomputable def factorTransport
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace) :
    (algorithm.factor source rationalPlace).carrier ≃L[ℚ]
      (algorithm.factor target rationalPlace).carrier :=
  ContinuousLinearEquiv.piCongrRight
    (fun place => algorithm.transportAbove map rationalPlace place)

@[simp]
theorem factorTransport_id
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (strip : SourceDMonoAnalyticPrimeStrip models)
    (rationalPlace : SourceRationalPlace) :
    algorithm.factorTransport (𝟙 strip) rationalPlace =
      ContinuousLinearEquiv.refl ℚ
        (algorithm.factor strip rationalPlace).carrier := by
  apply ContinuousLinearEquiv.ext
  funext value
  funext place
  change algorithm.transportAbove (𝟙 strip) rationalPlace place
      (value place) = value place
  rw [algorithm.transportAbove_id]
  rfl

theorem factorTransport_comp
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source middle target : SourceDMonoAnalyticPrimeStrip models}
    (first : source ⟶ middle) (second : middle ⟶ target)
    (rationalPlace : SourceRationalPlace) :
    algorithm.factorTransport (first ≫ second) rationalPlace =
      (algorithm.factorTransport first rationalPlace).trans
        (algorithm.factorTransport second rationalPlace) := by
  apply ContinuousLinearEquiv.ext
  funext value
  funext place
  change algorithm.transportAbove (first ≫ second) rationalPlace place
      (value place) =
    algorithm.transportAbove second rationalPlace place
      (algorithm.transportAbove first rationalPlace place (value place))
  rw [algorithm.transportAbove_comp]
  rfl

/-- The direct-sum Kummer transport preserves the lattice at every place. -/
theorem factorTransport_integralLattice_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (hkind : rationalPlace.kind = .nonarchimedean) :
    algorithm.factorTransport map rationalPlace ''
        (algorithm.factorIntegralLattice source rationalPlace hkind : Set _) =
      (algorithm.factorIntegralLattice target rationalPlace hkind : Set _) := by
  ext targetValue
  constructor
  · rintro ⟨sourceValue, hsource, rfl⟩
    intro place
    change algorithm.transportAbove map rationalPlace place
        (sourceValue place) ∈
      ((algorithm.integralAbove target rationalPlace place).asNonarchimedean
        hkind).lattice
    have hplace := algorithm.transportAbove_integral map rationalPlace place
    rw [← SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice
          (algorithm.integralAbove source rationalPlace place) hkind,
        ← SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice
          (algorithm.integralAbove target rationalPlace place) hkind] at hplace
    have himage :
        algorithm.transportAbove map rationalPlace place (sourceValue place) ∈
          algorithm.transportAbove map rationalPlace place ''
            (((algorithm.integralAbove source rationalPlace place).asNonarchimedean
              hkind).lattice : Set _) :=
      ⟨sourceValue place, hsource place, rfl⟩
    simpa only [hplace] using himage
  · intro htarget
    let sourceValue : (algorithm.factor source rationalPlace).carrier :=
      fun place =>
        (algorithm.transportAbove map rationalPlace place).symm
          (targetValue place)
    refine ⟨sourceValue, ?_, ?_⟩
    · intro place
      have hplace := algorithm.transportAbove_integral map rationalPlace place
      rw [← SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice
            (algorithm.integralAbove source rationalPlace place) hkind,
          ← SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice
            (algorithm.integralAbove target rationalPlace place) hkind] at hplace
      have himage : targetValue place ∈
          algorithm.transportAbove map rationalPlace place ''
            (((algorithm.integralAbove source rationalPlace place).asNonarchimedean
              hkind).lattice : Set _) := by
        rw [hplace]
        exact htarget place
      rcases himage with ⟨preimage, hpreimage, heq⟩
      have hsourceValue : sourceValue place = preimage := by
        change (algorithm.transportAbove map rationalPlace place).symm
            (targetValue place) = preimage
        rw [← heq, ContinuousLinearEquiv.symm_apply_apply]
      rwa [hsourceValue]
    · funext place
      exact (algorithm.transportAbove map rationalPlace place).apply_symm_apply
        (targetValue place)

/-- The direct-sum transport restricts to the prescribed placewise transport. -/
theorem factorTransport_on_summand
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {source target : SourceDMonoAnalyticPrimeStrip models}
    (map : source ⟶ target)
    (rationalPlace : SourceRationalPlace)
    (place : SourceSelectedPlaceAbove theta rationalPlace)
    (value : (algorithm.factor source rationalPlace).summand place) :
    (algorithm.factor target rationalPlace).directSumIso.toLinearEquiv
        (algorithm.factorTransport map rationalPlace
          ((algorithm.factor source rationalPlace).directSumIso.inv
            (DirectSum.of
              (fun placeIndex =>
                (algorithm.factor source rationalPlace).summand placeIndex)
              place value))) =
      DirectSum.of
        (fun placeIndex =>
          (algorithm.factor target rationalPlace).summand placeIndex)
        place (algorithm.transportAbove map rationalPlace place value) := by
  simp only [factorTransport, factor,
    SourceLocalLogDirectSum.ofLogarithmicShells,
    SourceLocalLogDirectSum.summand]
  change
    (DirectSum.linearEquivFunOnFintype ℚ
      (SourceSelectedPlaceAbove theta rationalPlace)
      (fun placeIndex =>
        (algorithm.moduleAbove target rationalPlace
          placeIndex).rationalCarrier)).symm
        ((ContinuousLinearEquiv.piCongrRight
          (fun place => algorithm.transportAbove map rationalPlace place))
          ((DirectSum.linearEquivFunOnFintype ℚ
            (SourceSelectedPlaceAbove theta rationalPlace)
            (fun placeIndex =>
              (algorithm.moduleAbove source rationalPlace
                placeIndex).rationalCarrier))
            ((DirectSum.lof ℚ
              (SourceSelectedPlaceAbove theta rationalPlace)
              (fun placeIndex =>
                (algorithm.moduleAbove source rationalPlace
                  placeIndex).rationalCarrier)
              place) value))) =
      (DirectSum.lof ℚ
        (SourceSelectedPlaceAbove theta rationalPlace)
        (fun placeIndex =>
          (algorithm.moduleAbove target rationalPlace
            placeIndex).rationalCarrier)
        place) (algorithm.transportAbove map rationalPlace place value)
  rw [DirectSum.linearEquivFunOnFintype_lof]
  have coordinateEq :
      (ContinuousLinearEquiv.piCongrRight
          (fun place => algorithm.transportAbove map rationalPlace place))
          (Pi.single place value) =
        Pi.single place
          (algorithm.transportAbove map rationalPlace place value) := by
    funext other
    by_cases h : other = place
    · subst other
      simp
    · simp [Pi.single, h]
  rw [coordinateEq, DirectSum.linearEquivFunOnFintype_symm_single]

/--
The ind-topological tensor product topology used in Propositions 3.1-3.2.

The final clause is its universal property: a rational-linear map out of the
tensor product is continuous exactly when its composite with the pure-tensor
map is continuous.
-/
structure TensorTopology
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    (factor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place) where
  topologicalSpace :
    TopologicalSpace
      (PiTensorProduct ℚ (fun index => (factor index).carrier))
  isTopologicalAddGroup :
    let _ :
        TopologicalSpace
          (PiTensorProduct ℚ (fun index => (factor index).carrier)) :=
      topologicalSpace
    IsTopologicalAddGroup
      (PiTensorProduct ℚ (fun index => (factor index).carrier))
  tprod_continuous :
    @Continuous
      (∀ index, (factor index).carrier)
      (PiTensorProduct ℚ (fun index => (factor index).carrier))
      inferInstance topologicalSpace
      (PiTensorProduct.tprod ℚ)
  continuous_linear_iff :
    ∀ (target : SourceTopologicalQModule.{u})
      (linear :
        PiTensorProduct ℚ (fun index => (factor index).carrier) →ₗ[ℚ]
          target),
      @Continuous _ _ topologicalSpace inferInstance linear ↔
        Continuous
          (fun components =>
            linear (PiTensorProduct.tprod ℚ components))

namespace TensorTopology

/-- The tensor topology produces a packet whose carrier is the literal tensor product. -/
noncomputable def toPacket
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {factor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (topology : TensorTopology factor) :
    SourceMonoAnalyticTensorPacket.{u} j := by
  letI :
      TopologicalSpace
        (PiTensorProduct ℚ (fun index => (factor index).carrier)) :=
    topology.topologicalSpace
  letI :
      IsTopologicalAddGroup
        (PiTensorProduct ℚ (fun index => (factor index).carrier)) :=
    topology.isTopologicalAddGroup
  exact
    { rationalPlace := rationalPlace
      place := place
      factor := factor
      carrier :=
        SourceTopologicalQModule.of
          (PiTensorProduct ℚ (fun index => (factor index).carrier))
      tensorIso := Iso.refl _ }

/--
Transport a packet topology along continuous equivalences of all tensor
factors.  Continuity in both directions is derived from the two tensor
universal properties.
-/
noncomputable def congr
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (sourceTopology : TensorTopology sourceFactor)
    (targetTopology : TensorTopology targetFactor)
    (factorEquiv : ∀ index, sourceFactor index |>.carrier ≃L[ℚ]
      targetFactor index |>.carrier) :
    sourceTopology.toPacket.carrier ≃L[ℚ]
      targetTopology.toPacket.carrier where
  __ := PiTensorProduct.congr
    (fun index => (factorEquiv index).toLinearEquiv)
  continuous_toFun := by
    letI : TopologicalSpace
        (PiTensorProduct ℚ (fun index => (targetFactor index).carrier)) :=
      targetTopology.topologicalSpace
    change @Continuous
      (PiTensorProduct ℚ (fun index => (sourceFactor index).carrier))
      (PiTensorProduct ℚ (fun index => (targetFactor index).carrier))
      sourceTopology.topologicalSpace targetTopology.topologicalSpace
      (PiTensorProduct.congr
        (fun index => (factorEquiv index).toLinearEquiv))
    apply (sourceTopology.continuous_linear_iff
      targetTopology.toPacket.carrier
      (PiTensorProduct.congr
        (fun index => (factorEquiv index).toLinearEquiv)).toLinearMap).2
    convert targetTopology.tprod_continuous.comp
      (continuous_pi fun index =>
        (factorEquiv index).continuous.comp (continuous_apply index)) using 1
    funext components
    exact PiTensorProduct.congr_tprod _ components
  continuous_invFun := by
    letI : TopologicalSpace
        (PiTensorProduct ℚ (fun index => (sourceFactor index).carrier)) :=
      sourceTopology.topologicalSpace
    change @Continuous
      (PiTensorProduct ℚ (fun index => (targetFactor index).carrier))
      (PiTensorProduct ℚ (fun index => (sourceFactor index).carrier))
      targetTopology.topologicalSpace sourceTopology.topologicalSpace
      (PiTensorProduct.congr
        (fun index => (factorEquiv index).toLinearEquiv)).symm
    apply (targetTopology.continuous_linear_iff
      sourceTopology.toPacket.carrier
      (PiTensorProduct.congr
        (fun index => (factorEquiv index).toLinearEquiv)).symm.toLinearMap).2
    convert sourceTopology.tprod_continuous.comp
      (continuous_pi fun index =>
        (factorEquiv index).symm.continuous.comp (continuous_apply index)) using 1
    funext components
    exact PiTensorProduct.congr_symm_tprod _ components

/-- Reindex the product of tensor factors and then transport each factor. -/
noncomputable def componentReindexEquiv
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (indexEquiv : Fin (j + 1) ≃ Fin (j + 1))
    (factorEquiv : ∀ targetIndex,
      (sourceFactor (indexEquiv.symm targetIndex)).carrier ≃L[ℚ]
        (targetFactor targetIndex).carrier) :
    (∀ sourceIndex, (sourceFactor sourceIndex).carrier) ≃L[ℚ]
      (∀ targetIndex, (targetFactor targetIndex).carrier) :=
  (ContinuousLinearEquiv.piCongrLeft ℚ
      (fun sourceIndex => (sourceFactor sourceIndex).carrier)
      indexEquiv.symm).symm |>.trans <|
    ContinuousLinearEquiv.piCongrRight factorEquiv

@[simp]
theorem componentReindexEquiv_apply
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (indexEquiv : Fin (j + 1) ≃ Fin (j + 1))
    (factorEquiv : ∀ targetIndex,
      (sourceFactor (indexEquiv.symm targetIndex)).carrier ≃L[ℚ]
        (targetFactor targetIndex).carrier)
    (components : ∀ index, (sourceFactor index).carrier)
    (targetIndex : Fin (j + 1)) :
    componentReindexEquiv indexEquiv factorEquiv components targetIndex =
      factorEquiv targetIndex (components (indexEquiv.symm targetIndex)) :=
  rfl

/-- The algebraic tensor equivalence underlying a factor permutation. -/
noncomputable def reindexLinearEquiv
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (indexEquiv : Fin (j + 1) ≃ Fin (j + 1))
    (factorEquiv : ∀ targetIndex,
      (sourceFactor (indexEquiv.symm targetIndex)).carrier ≃L[ℚ]
        (targetFactor targetIndex).carrier) :
    PiTensorProduct ℚ (fun index => (sourceFactor index).carrier) ≃ₗ[ℚ]
      PiTensorProduct ℚ (fun index => (targetFactor index).carrier) :=
  (PiTensorProduct.reindex ℚ
      (fun index => (sourceFactor index).carrier) indexEquiv).trans
    (PiTensorProduct.congr
      (fun index => (factorEquiv index).toLinearEquiv))

theorem reindexLinearEquiv_tprod
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (indexEquiv : Fin (j + 1) ≃ Fin (j + 1))
    (factorEquiv : ∀ targetIndex,
      (sourceFactor (indexEquiv.symm targetIndex)).carrier ≃L[ℚ]
        (targetFactor targetIndex).carrier)
    (components : ∀ index, (sourceFactor index).carrier) :
    reindexLinearEquiv indexEquiv factorEquiv
        (PiTensorProduct.tprod ℚ components) =
      PiTensorProduct.tprod ℚ
        (componentReindexEquiv indexEquiv factorEquiv components) := by
  rw [show reindexLinearEquiv indexEquiv factorEquiv
      (PiTensorProduct.tprod ℚ components) =
        PiTensorProduct.tprod ℚ
          (fun targetIndex =>
            factorEquiv targetIndex
              (components (indexEquiv.symm targetIndex))) by
    simp [reindexLinearEquiv]]
  congr 1

/-- Reindexed tensor transports compose when their factor maps compose. -/
theorem reindexLinearEquiv_trans
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor middleFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (firstPermutation secondPermutation : Fin (j + 1) ≃ Fin (j + 1))
    (firstFactor : ∀ middleIndex,
      (sourceFactor (firstPermutation.symm middleIndex)).carrier ≃L[ℚ]
        (middleFactor middleIndex).carrier)
    (secondFactor : ∀ targetIndex,
      (middleFactor (secondPermutation.symm targetIndex)).carrier ≃L[ℚ]
        (targetFactor targetIndex).carrier)
    (combinedFactor : ∀ targetIndex,
      (sourceFactor
        ((firstPermutation.trans secondPermutation).symm targetIndex)).carrier
          ≃L[ℚ] (targetFactor targetIndex).carrier)
    (combinedFactor_apply : ∀ targetIndex value,
      combinedFactor targetIndex value =
        secondFactor targetIndex
          (firstFactor (secondPermutation.symm targetIndex) value)) :
    reindexLinearEquiv (firstPermutation.trans secondPermutation)
        combinedFactor =
      (reindexLinearEquiv firstPermutation firstFactor).trans
        (reindexLinearEquiv secondPermutation secondFactor) := by
  apply LinearEquiv.ext
  intro tensor
  induction tensor using PiTensorProduct.induction_on with
  | smul_tprod scalar components =>
      rw [map_smul, map_smul]
      congr 1
      simp only [LinearEquiv.trans_apply, reindexLinearEquiv_tprod]
      congr 1
      funext targetIndex
      simp only [componentReindexEquiv_apply]
      exact combinedFactor_apply targetIndex
        (components
          ((firstPermutation.trans secondPermutation).symm targetIndex))
  | add first second first_ih second_ih =>
      rw [map_add, map_add, first_ih, second_ih]

/--
The continuous tensor equivalence induced by a permutation of tensor factors
and continuous equivalences on the permuted factors.
-/
noncomputable def reindexCongr
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (sourceTopology : TensorTopology sourceFactor)
    (targetTopology : TensorTopology targetFactor)
    (indexEquiv : Fin (j + 1) ≃ Fin (j + 1))
    (factorEquiv : ∀ targetIndex,
      (sourceFactor (indexEquiv.symm targetIndex)).carrier ≃L[ℚ]
        (targetFactor targetIndex).carrier) :
    sourceTopology.toPacket.carrier ≃L[ℚ]
      targetTopology.toPacket.carrier where
  __ := reindexLinearEquiv indexEquiv factorEquiv
  continuous_toFun := by
    letI : TopologicalSpace
        (PiTensorProduct ℚ (fun index => (targetFactor index).carrier)) :=
      targetTopology.topologicalSpace
    change @Continuous
      (PiTensorProduct ℚ (fun index => (sourceFactor index).carrier))
      (PiTensorProduct ℚ (fun index => (targetFactor index).carrier))
      sourceTopology.topologicalSpace targetTopology.topologicalSpace
      (reindexLinearEquiv indexEquiv factorEquiv)
    apply (sourceTopology.continuous_linear_iff
      targetTopology.toPacket.carrier
      (reindexLinearEquiv indexEquiv factorEquiv).toLinearMap).2
    convert targetTopology.tprod_continuous.comp
      (componentReindexEquiv indexEquiv factorEquiv).continuous using 1
    funext components
    exact reindexLinearEquiv_tprod indexEquiv factorEquiv components
  continuous_invFun := by
    letI : TopologicalSpace
        (PiTensorProduct ℚ (fun index => (sourceFactor index).carrier)) :=
      sourceTopology.topologicalSpace
    change @Continuous
      (PiTensorProduct ℚ (fun index => (targetFactor index).carrier))
      (PiTensorProduct ℚ (fun index => (sourceFactor index).carrier))
      targetTopology.topologicalSpace sourceTopology.topologicalSpace
      (reindexLinearEquiv indexEquiv factorEquiv).symm
    apply (targetTopology.continuous_linear_iff
      sourceTopology.toPacket.carrier
      (reindexLinearEquiv indexEquiv factorEquiv).symm.toLinearMap).2
    convert sourceTopology.tprod_continuous.comp
      (componentReindexEquiv indexEquiv factorEquiv).symm.continuous using 1
    funext components
    apply (reindexLinearEquiv indexEquiv factorEquiv).injective
    calc
      reindexLinearEquiv indexEquiv factorEquiv
          ((reindexLinearEquiv indexEquiv factorEquiv).symm
            (PiTensorProduct.tprod ℚ components)) =
          PiTensorProduct.tprod ℚ components :=
        (reindexLinearEquiv indexEquiv factorEquiv).apply_symm_apply _
      _ = reindexLinearEquiv indexEquiv factorEquiv
            (PiTensorProduct.tprod ℚ
              ((componentReindexEquiv indexEquiv factorEquiv).symm
                components)) := by
        rw [reindexLinearEquiv_tprod,
          ContinuousLinearEquiv.apply_symm_apply]

/-- The tensor transport maps the distinguished pure generators exactly. -/
theorem congr_image_distinguishedPureTensors
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (sourceTopology : TensorTopology sourceFactor)
    (targetTopology : TensorTopology targetFactor)
    (factorEquiv : ∀ index, sourceFactor index |>.carrier ≃L[ℚ]
      targetFactor index |>.carrier)
    (summandEquiv : ∀ index placeIndex,
      (sourceFactor index).summand placeIndex ≃ₗ[ℚ]
        (targetFactor index).summand placeIndex)
    (factorEquiv_on_summand :
      ∀ index placeIndex value,
        (targetFactor index).directSumIso.toLinearEquiv
            (factorEquiv index
              ((sourceFactor index).directSumIso.inv
                (DirectSum.of
                  (fun p => (sourceFactor index).summand p)
                  placeIndex value))) =
          DirectSum.of
            (fun p => (targetFactor index).summand p)
            placeIndex (summandEquiv index placeIndex value))
    (distinguished : Fin (j + 1)) (placeIndex : place) :
    (sourceTopology.congr targetTopology factorEquiv).toLinearEquiv ''
        (sourceTopology.toPacket.distinguishedPureTensors
          distinguished placeIndex) =
      targetTopology.toPacket.distinguishedPureTensors
        distinguished placeIndex := by
  ext tensor
  constructor
  · rintro ⟨_, ⟨components, value, hcomponent, rfl⟩, rfl⟩
    change components distinguished =
      (sourceFactor distinguished).directSumIso.inv
        (DirectSum.of
          (fun p => (sourceFactor distinguished).summand p)
          placeIndex value) at hcomponent
    refine ⟨fun index => factorEquiv index (components index),
      summandEquiv distinguished placeIndex value, ?_, ?_⟩
    · change factorEquiv distinguished (components distinguished) =
        (targetFactor distinguished).directSumIso.inv
          (DirectSum.of
            (fun p => (targetFactor distinguished).summand p)
            placeIndex (summandEquiv distinguished placeIndex value))
      rw [hcomponent]
      apply (targetFactor distinguished).directSumIso.toLinearEquiv.injective
      rw [factorEquiv_on_summand]
      exact ((targetFactor distinguished).directSumIso.toLinearEquiv
        |>.apply_symm_apply _).symm
    · exact PiTensorProduct.congr_tprod _ components
  · rintro ⟨components, value, hcomponent, rfl⟩
    change components distinguished =
      (targetFactor distinguished).directSumIso.inv
        (DirectSum.of
          (fun p => (targetFactor distinguished).summand p)
          placeIndex value) at hcomponent
    let sourceComponents :
        ∀ index, (sourceFactor index).carrier :=
      fun index => (factorEquiv index).symm (components index)
    let sourceValue :=
      (summandEquiv distinguished placeIndex).symm value
    have sourceComponent :
        sourceComponents distinguished =
          (sourceFactor distinguished).directSumIso.inv
            (DirectSum.of
              (fun p => (sourceFactor distinguished).summand p)
              placeIndex sourceValue) := by
      apply (factorEquiv distinguished).injective
      rw [ContinuousLinearEquiv.apply_symm_apply]
      rw [hcomponent]
      apply (targetFactor distinguished).directSumIso.toLinearEquiv.injective
      rw [factorEquiv_on_summand]
      exact ((targetFactor distinguished).directSumIso.toLinearEquiv
        |>.apply_symm_apply _).trans (by simp [sourceValue])
    refine ⟨PiTensorProduct.tprod ℚ sourceComponents,
      ⟨sourceComponents, sourceValue, sourceComponent, rfl⟩, ?_⟩
    change
      PiTensorProduct.congr
          (fun index => (factorEquiv index).toLinearEquiv)
          (PiTensorProduct.tprod ℚ sourceComponents) =
        PiTensorProduct.tprod ℚ components
    rw [PiTensorProduct.congr_tprod]
    congr 1
    funext index
    simp [sourceComponents]

/-- Distinguished tensor submodules are preserved exactly by transport. -/
theorem congr_distinguishedSubmodule
    {j : ℕ} {rationalPlace : SourceRationalPlace}
    {place : Type u} [Fintype place] [DecidableEq place]
    {sourceFactor targetFactor :
      Fin (j + 1) -> SourceLocalLogDirectSum.{u} rationalPlace place}
    (sourceTopology : TensorTopology sourceFactor)
    (targetTopology : TensorTopology targetFactor)
    (factorEquiv : ∀ index, sourceFactor index |>.carrier ≃L[ℚ]
      targetFactor index |>.carrier)
    (summandEquiv : ∀ index placeIndex,
      (sourceFactor index).summand placeIndex ≃ₗ[ℚ]
        (targetFactor index).summand placeIndex)
    (factorEquiv_on_summand :
      ∀ index placeIndex value,
        (targetFactor index).directSumIso.toLinearEquiv
            (factorEquiv index
              ((sourceFactor index).directSumIso.inv
                (DirectSum.of
                  (fun p => (sourceFactor index).summand p)
                  placeIndex value))) =
          DirectSum.of
            (fun p => (targetFactor index).summand p)
            placeIndex (summandEquiv index placeIndex value))
    (distinguished : Fin (j + 1)) (placeIndex : place) :
    Submodule.map
        (sourceTopology.congr targetTopology factorEquiv).toLinearEquiv.toLinearMap
        (sourceTopology.toPacket.distinguishedSubmodule
          distinguished placeIndex) =
      targetTopology.toPacket.distinguishedSubmodule
        distinguished placeIndex := by
  change
    Submodule.map
        (sourceTopology.congr targetTopology factorEquiv).toLinearEquiv.toLinearMap
        (Submodule.span ℚ
          (sourceTopology.toPacket.distinguishedPureTensors
            distinguished placeIndex)) =
      Submodule.span ℚ
        (targetTopology.toPacket.distinguishedPureTensors
          distinguished placeIndex)
  rw [Submodule.map_span]
  congr 1
  simpa using
    sourceTopology.congr_image_distinguishedPureTensors targetTopology
      factorEquiv summandEquiv factorEquiv_on_summand
      distinguished placeIndex

end TensorTopology

/--
Construct the local tensor packet of an actual mono-analytic capsule from the
functorial log-shell algorithm and the ind-topological tensor topology.
-/
noncomputable def packetOfCapsule
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor
            (capsule.object (indexEquiv index)) rationalPlace)) :
    SourceMonoAnalyticTensorPacket.{u} j :=
  topology.toPacket

/-- The permutation of ordered tensor factors induced by a capsule member. -/
noncomputable def capsuleFactorPermutation
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (member : CategoryCapsule.FullMemberMorphism capsule capsule) :
    Fin (j + 1) ≃ Fin (j + 1) :=
  indexEquiv.trans member.indexEquivSelf |>.trans indexEquiv.symm

@[simp]
theorem capsuleFactorPermutation_id
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index) :
    capsuleFactorPermutation capsule j indexEquiv
        (CategoryCapsule.FullMemberMorphism.id capsule) =
      Equiv.refl (Fin (j + 1)) := by
  ext index
  simp [capsuleFactorPermutation]

@[simp]
theorem capsuleFactorPermutation_id_symm_apply
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (index : Fin (j + 1)) :
    (capsuleFactorPermutation capsule j indexEquiv
      (CategoryCapsule.FullMemberMorphism.id capsule)).symm index = index := by
  rw [capsuleFactorPermutation_id]
  rfl

/-- Compatibility witness for the explicit identity factor permutation. -/
def capsuleFactorPermutationIdCompatible
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index) :
    ∀ targetIndex,
      (CategoryCapsule.FullMemberMorphism.id capsule).indexEmbedding
          (indexEquiv ((Equiv.refl (Fin (j + 1))).symm targetIndex)) =
        indexEquiv targetIndex :=
  fun _ => rfl

theorem capsuleFactorPermutation_comp
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (first second : CategoryCapsule.FullMemberMorphism capsule capsule) :
    capsuleFactorPermutation capsule j indexEquiv (first.comp second) =
      (capsuleFactorPermutation capsule j indexEquiv first).trans
        (capsuleFactorPermutation capsule j indexEquiv second) := by
  ext index
  simp [capsuleFactorPermutation,
    CategoryCapsule.FullMemberMorphism.indexEquivSelf_comp]

/-- The factor permutation sends the source capsule index to its member image. -/
theorem capsuleFactorPermutation_target
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (member : CategoryCapsule.FullMemberMorphism capsule capsule)
    (targetIndex : Fin (j + 1)) :
    member.indexEmbedding
        (indexEquiv
          ((capsuleFactorPermutation capsule j indexEquiv member).symm
            targetIndex)) =
      indexEquiv targetIndex := by
  have sourceIndex :
      indexEquiv
          ((capsuleFactorPermutation capsule j indexEquiv member).symm
            targetIndex) =
        member.indexEquivSelf.symm (indexEquiv targetIndex) := by
    simp [capsuleFactorPermutation]
  rw [sourceIndex]
  change member.indexEquivSelf
      (member.indexEquivSelf.symm (indexEquiv targetIndex)) =
    indexEquiv targetIndex
  exact member.indexEquivSelf.apply_symm_apply (indexEquiv targetIndex)

/-- A component member adjusted to a prescribed equal target capsule index. -/
def capsuleAdjustedComponentHom
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (member : CategoryCapsule.FullMemberMorphism capsule capsule)
    (sourceIndex targetIndex : capsule.index)
    (compatible : member.indexEmbedding sourceIndex = targetIndex) :
    capsule.object sourceIndex ⟶ capsule.object targetIndex :=
  (member.componentIso sourceIndex).hom ≫
    eqToHom (congrArg capsule.object compatible)

/-- Adjusted component members preserve composition. -/
theorem capsuleAdjustedComponentHom_comp
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (first second : CategoryCapsule.FullMemberMorphism capsule capsule)
    (sourceIndex middleIndex targetIndex : capsule.index)
    (firstCompatible : first.indexEmbedding sourceIndex = middleIndex)
    (secondCompatible : second.indexEmbedding middleIndex = targetIndex)
    (combinedCompatible :
      (first.comp second).indexEmbedding sourceIndex = targetIndex) :
    capsuleAdjustedComponentHom capsule (first.comp second)
        sourceIndex targetIndex combinedCompatible =
      capsuleAdjustedComponentHom capsule first sourceIndex middleIndex
          firstCompatible ≫
        capsuleAdjustedComponentHom capsule second middleIndex targetIndex
          secondCompatible := by
  subst middleIndex
  subst targetIndex
  simp only [capsuleAdjustedComponentHom,
    CategoryCapsule.FullMemberMorphism.comp, Iso.trans_hom, eqToHom_refl,
    Category.comp_id]
  let component :=
    (first.componentIso sourceIndex).hom ≫
      (second.componentIso (first.indexEmbedding sourceIndex)).hom
  let compatibilityProof :
      capsule.object
          (second.indexEmbedding (first.indexEmbedding sourceIndex)) =
        capsule.object
          (second.indexEmbedding (first.indexEmbedding sourceIndex)) :=
    congrArg capsule.object secondCompatible
  change component = component ≫ eqToHom compatibilityProof
  have compatibilityProofIdentity : compatibilityProof = rfl :=
    Subsingleton.elim _ _
  rw [compatibilityProofIdentity, eqToHom_refl, Category.comp_id]

/-- Compatibility of the composite member with the composite permutation. -/
def capsuleFactorPermutationCompatibleComp
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (first second : CategoryCapsule.FullMemberMorphism capsule capsule)
    (firstPermutation secondPermutation : Fin (j + 1) ≃ Fin (j + 1))
    (firstCompatible : ∀ middleIndex,
      first.indexEmbedding
          (indexEquiv (firstPermutation.symm middleIndex)) =
        indexEquiv middleIndex)
    (secondCompatible : ∀ targetIndex,
      second.indexEmbedding
          (indexEquiv (secondPermutation.symm targetIndex)) =
        indexEquiv targetIndex) :
    ∀ targetIndex,
      (first.comp second).indexEmbedding
          (indexEquiv
            ((firstPermutation.trans secondPermutation).symm targetIndex)) =
        indexEquiv targetIndex := by
  intro targetIndex
  change second.indexEmbedding
      (first.indexEmbedding
        (indexEquiv
          (firstPermutation.symm (secondPermutation.symm targetIndex)))) =
    indexEquiv targetIndex
  rw [firstCompatible, secondCompatible]

/--
The direct-sum factor transport for an explicit compatible factor
permutation.  Keeping the permutation explicit makes its laws usable through
dependent factor types.
-/
noncomputable def capsuleFactorTransportOf
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (member : CategoryCapsule.FullMemberMorphism capsule capsule)
    (permutation : Fin (j + 1) ≃ Fin (j + 1))
    (compatible : ∀ targetIndex,
      member.indexEmbedding
          (indexEquiv (permutation.symm targetIndex)) =
        indexEquiv targetIndex)
    (targetIndex : Fin (j + 1)) :
    (algorithm.factor
        (capsule.object
          (indexEquiv (permutation.symm targetIndex))) rationalPlace).carrier ≃L[ℚ]
      (algorithm.factor
        (capsule.object (indexEquiv targetIndex)) rationalPlace).carrier := by
  exact algorithm.factorTransport
    (capsuleAdjustedComponentHom capsule member
      (indexEquiv (permutation.symm targetIndex)) (indexEquiv targetIndex)
      (compatible targetIndex)) rationalPlace

/-- The adjusted direct-sum factor transports preserve composition. -/
theorem capsuleFactorTransportOf_comp_apply
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (first second : CategoryCapsule.FullMemberMorphism capsule capsule)
    (firstPermutation secondPermutation : Fin (j + 1) ≃ Fin (j + 1))
    (firstCompatible : ∀ middleIndex,
      first.indexEmbedding
          (indexEquiv (firstPermutation.symm middleIndex)) =
        indexEquiv middleIndex)
    (secondCompatible : ∀ targetIndex,
      second.indexEmbedding
          (indexEquiv (secondPermutation.symm targetIndex)) =
        indexEquiv targetIndex)
    (targetIndex : Fin (j + 1))
    (value :
      (algorithm.factor
        (capsule.object
          (indexEquiv
            ((firstPermutation.trans secondPermutation).symm targetIndex)))
        rationalPlace).carrier) :
    capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
        (first.comp second) (firstPermutation.trans secondPermutation)
        (capsuleFactorPermutationCompatibleComp capsule j indexEquiv
          first second firstPermutation secondPermutation
          firstCompatible secondCompatible) targetIndex value =
      capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
          second secondPermutation secondCompatible targetIndex
        (capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
          first firstPermutation firstCompatible
          (secondPermutation.symm targetIndex) value) := by
  unfold capsuleFactorTransportOf
  change
    (algorithm.factorTransport
      (capsuleAdjustedComponentHom capsule (first.comp second)
        (indexEquiv
          (firstPermutation.symm (secondPermutation.symm targetIndex)))
        (indexEquiv targetIndex) _)
      rationalPlace) value = _
  rw [capsuleAdjustedComponentHom_comp capsule first second
    (indexEquiv
      (firstPermutation.symm (secondPermutation.symm targetIndex)))
    (indexEquiv (secondPermutation.symm targetIndex))
    (indexEquiv targetIndex)
    (firstCompatible (secondPermutation.symm targetIndex))
    (secondCompatible targetIndex)]
  exact congrArg (fun transport => transport value)
    (algorithm.factorTransport_comp
      (capsuleAdjustedComponentHom capsule first
        (indexEquiv
          (firstPermutation.symm (secondPermutation.symm targetIndex)))
        (indexEquiv (secondPermutation.symm targetIndex))
        (firstCompatible (secondPermutation.symm targetIndex)))
      (capsuleAdjustedComponentHom capsule second
        (indexEquiv (secondPermutation.symm targetIndex))
        (indexEquiv targetIndex) (secondCompatible targetIndex))
      rationalPlace)

/-- The canonical factor transport attached to one capsule member. -/
noncomputable def capsuleFactorTransport
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (member : CategoryCapsule.FullMemberMorphism capsule capsule) :=
  capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace member
    (capsuleFactorPermutation capsule j indexEquiv member)
    (capsuleFactorPermutation_target capsule j indexEquiv member)

/-- The packet transport for an explicit compatible factor permutation. -/
noncomputable def packetMemberTransportOf
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace))
    (member : CategoryCapsule.FullMemberMorphism capsule capsule)
    (permutation : Fin (j + 1) ≃ Fin (j + 1))
    (compatible : ∀ targetIndex,
      member.indexEmbedding
          (indexEquiv (permutation.symm targetIndex)) =
        indexEquiv targetIndex) :
    topology.toPacket.carrier ≃L[ℚ] topology.toPacket.carrier :=
  topology.reindexCongr topology permutation
    (capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
      member permutation compatible)

/--
An actual capsule member acts continuously on the literal tensor packet by
permuting factors and applying its componentwise log-shell transports.
-/
noncomputable def packetMemberTransport
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace))
    (member : CategoryCapsule.FullMemberMorphism capsule capsule) :
    topology.toPacket.carrier ≃L[ℚ] topology.toPacket.carrier :=
  packetMemberTransportOf algorithm capsule j indexEquiv rationalPlace topology
    member
    (capsuleFactorPermutation capsule j indexEquiv member)
    (capsuleFactorPermutation_target capsule j indexEquiv member)

/-- The capsule-member transport has the prescribed action on pure tensors. -/
theorem packetMemberTransport_tprod
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace))
    (member : CategoryCapsule.FullMemberMorphism capsule capsule)
    (components : ∀ index,
      (algorithm.factor
        (capsule.object (indexEquiv index)) rationalPlace).carrier) :
    packetMemberTransport algorithm capsule j indexEquiv rationalPlace
        topology member (PiTensorProduct.tprod ℚ components) =
      PiTensorProduct.tprod ℚ
        (TensorTopology.componentReindexEquiv
          (capsuleFactorPermutation capsule j indexEquiv member)
          (capsuleFactorTransport algorithm capsule j indexEquiv
            rationalPlace member) components) := by
  change TensorTopology.reindexLinearEquiv
      (capsuleFactorPermutation capsule j indexEquiv member)
      (capsuleFactorTransport algorithm capsule j indexEquiv rationalPlace member)
      (PiTensorProduct.tprod ℚ components) = _
  apply TensorTopology.reindexLinearEquiv_tprod
    (capsuleFactorPermutation capsule j indexEquiv member)
    (capsuleFactorTransport algorithm capsule j indexEquiv rationalPlace member)
    components

/-- An explicitly identity factor permutation induces identity transport. -/
theorem packetMemberTransportOf_id
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace))
    (permutation : Fin (j + 1) ≃ Fin (j + 1))
    (compatible : ∀ targetIndex,
      (CategoryCapsule.FullMemberMorphism.id capsule).indexEmbedding
          (indexEquiv (permutation.symm targetIndex)) =
        indexEquiv targetIndex)
    (permutationIdentity : permutation = Equiv.refl (Fin (j + 1))) :
    packetMemberTransportOf algorithm capsule j indexEquiv rationalPlace topology
        (CategoryCapsule.FullMemberMorphism.id capsule) permutation compatible =
      ContinuousLinearEquiv.refl ℚ topology.toPacket.carrier := by
  subst permutation
  have compatibleIdentity : compatible =
      capsuleFactorPermutationIdCompatible capsule j indexEquiv :=
    Subsingleton.elim _ _
  subst compatible
  apply ContinuousLinearEquiv.ext
  funext value
  change TensorTopology.reindexLinearEquiv
      (Equiv.refl (Fin (j + 1)))
      (capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
        (CategoryCapsule.FullMemberMorphism.id capsule)
        (Equiv.refl (Fin (j + 1)))
        (capsuleFactorPermutationIdCompatible capsule j indexEquiv)) value = value
  induction value using PiTensorProduct.induction_on with
  | smul_tprod scalar components =>
      rw [map_smul]
      congr 1
      rw [TensorTopology.reindexLinearEquiv_tprod]
      congr 1
      funext targetIndex
      simp only [TensorTopology.componentReindexEquiv_apply]
      let stripMap :
          capsule.object (indexEquiv targetIndex) ⟶
            capsule.object (indexEquiv targetIndex) :=
        ((CategoryCapsule.FullMemberMorphism.id capsule).componentIso
            (indexEquiv targetIndex)).hom ≫
          eqToHom (congrArg capsule.object
            (capsuleFactorPermutationIdCompatible capsule j indexEquiv
              targetIndex))
      change algorithm.factorTransport stripMap rationalPlace
          (components targetIndex) = components targetIndex
      have stripMapIdentity :
          stripMap = 𝟙 (capsule.object (indexEquiv targetIndex)) := by
        simp [stripMap, CategoryCapsule.FullMemberMorphism.id]
        exact Category.comp_id _
      rw [stripMapIdentity]
      exact congrArg
        (fun transport => transport (components targetIndex))
        (algorithm.factorTransport_id
          (capsule.object (indexEquiv targetIndex)) rationalPlace)
  | add first second first_ih second_ih =>
      rw [map_add, first_ih, second_ih]

/-- The identity capsule member induces the identity packet transport. -/
@[simp]
theorem packetMemberTransport_id
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace)) :
    packetMemberTransport algorithm capsule j indexEquiv rationalPlace topology
        (CategoryCapsule.FullMemberMorphism.id capsule) =
      ContinuousLinearEquiv.refl ℚ topology.toPacket.carrier :=
  packetMemberTransportOf_id algorithm capsule j indexEquiv rationalPlace
    topology
    (capsuleFactorPermutation capsule j indexEquiv
      (CategoryCapsule.FullMemberMorphism.id capsule))
    (capsuleFactorPermutation_target capsule j indexEquiv
      (CategoryCapsule.FullMemberMorphism.id capsule))
    (capsuleFactorPermutation_id capsule j indexEquiv)

/-- Equal compatible factor permutations define the same packet transport. -/
theorem packetMemberTransportOf_congr
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace))
    (member : CategoryCapsule.FullMemberMorphism capsule capsule)
    (firstPermutation secondPermutation : Fin (j + 1) ≃ Fin (j + 1))
    (firstCompatible : ∀ targetIndex,
      member.indexEmbedding
          (indexEquiv (firstPermutation.symm targetIndex)) =
        indexEquiv targetIndex)
    (secondCompatible : ∀ targetIndex,
      member.indexEmbedding
          (indexEquiv (secondPermutation.symm targetIndex)) =
        indexEquiv targetIndex)
    (permutation_eq : firstPermutation = secondPermutation) :
    packetMemberTransportOf algorithm capsule j indexEquiv rationalPlace topology
        member firstPermutation firstCompatible =
      packetMemberTransportOf algorithm capsule j indexEquiv rationalPlace topology
        member secondPermutation secondCompatible := by
  subst secondPermutation
  have compatibleIdentity : secondCompatible = firstCompatible :=
    Subsingleton.elim _ _
  subst secondCompatible
  rfl

/-- The canonical capsule-member packet transports preserve composition. -/
theorem packetMemberTransport_comp
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (capsule :
      CategoryCapsule
        (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)))
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ capsule.index)
    (rationalPlace : SourceRationalPlace)
    (topology :
      TensorTopology
        (fun index =>
          algorithm.factor (capsule.object (indexEquiv index)) rationalPlace))
    (first second : CategoryCapsule.FullMemberMorphism capsule capsule) :
    packetMemberTransport algorithm capsule j indexEquiv rationalPlace topology
        (first.comp second) =
      (packetMemberTransport algorithm capsule j indexEquiv rationalPlace
        topology first).trans
      (packetMemberTransport algorithm capsule j indexEquiv rationalPlace
        topology second) := by
  let firstPermutation := capsuleFactorPermutation capsule j indexEquiv first
  let secondPermutation := capsuleFactorPermutation capsule j indexEquiv second
  let firstCompatible :=
    capsuleFactorPermutation_target capsule j indexEquiv first
  let secondCompatible :=
    capsuleFactorPermutation_target capsule j indexEquiv second
  let combinedCompatible :=
    capsuleFactorPermutationCompatibleComp capsule j indexEquiv first second
      firstPermutation secondPermutation firstCompatible secondCompatible
  let firstFactor :=
    capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
      first firstPermutation firstCompatible
  let secondFactor :=
    capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
      second secondPermutation secondCompatible
  let combinedFactor :=
    capsuleFactorTransportOf algorithm capsule j indexEquiv rationalPlace
      (first.comp second) (firstPermutation.trans secondPermutation)
      combinedCompatible
  have compositeReindex :
      packetMemberTransport algorithm capsule j indexEquiv rationalPlace topology
          (first.comp second) =
        packetMemberTransportOf algorithm capsule j indexEquiv rationalPlace
          topology (first.comp second)
          (firstPermutation.trans secondPermutation) combinedCompatible :=
    packetMemberTransportOf_congr algorithm capsule j indexEquiv rationalPlace
      topology (first.comp second)
      (capsuleFactorPermutation capsule j indexEquiv (first.comp second))
      (firstPermutation.trans secondPermutation)
      (capsuleFactorPermutation_target capsule j indexEquiv (first.comp second))
      combinedCompatible
      (capsuleFactorPermutation_comp capsule j indexEquiv first second)
  rw [compositeReindex]
  have factorComposition : ∀ targetIndex value,
      combinedFactor targetIndex value =
        secondFactor targetIndex
          (firstFactor (secondPermutation.symm targetIndex) value) := by
    intro targetIndex value
    exact capsuleFactorTransportOf_comp_apply algorithm capsule j indexEquiv
      rationalPlace first second firstPermutation secondPermutation
      firstCompatible secondCompatible targetIndex value
  have tensorComposition :=
    TensorTopology.reindexLinearEquiv_trans
      (sourceFactor := fun index =>
        algorithm.factor (capsule.object (indexEquiv index)) rationalPlace)
      (middleFactor := fun index =>
        algorithm.factor (capsule.object (indexEquiv index)) rationalPlace)
      (targetFactor := fun index =>
        algorithm.factor (capsule.object (indexEquiv index)) rationalPlace)
      firstPermutation secondPermutation firstFactor secondFactor combinedFactor
      factorComposition
  apply ContinuousLinearEquiv.ext
  funext value
  change
    TensorTopology.reindexLinearEquiv
        (firstPermutation.trans secondPermutation)
        combinedFactor value =
      ((TensorTopology.reindexLinearEquiv firstPermutation
          firstFactor).trans
        (TensorTopology.reindexLinearEquiv secondPermutation
          secondFactor)) value
  exact LinearEquiv.congr_fun tensorComposition value

end SourceMonoAnalyticLogShellAlgorithm

/--
The complete local packet family appearing in Theorem 3.11(i)(a).

It is indexed by actual rational places and actual absolute theta labels.  The
place-fiber equivalence identifies the packet's direct-summand indices with
the fixed set of places above `v_Q`, independently of the label.
-/
structure SourceTheorem311LocalData (l : PrimeGeFive) where
  placeAbove : SourceRationalPlace -> Type u
  [placeAboveFintype : ∀ vQ, Fintype (placeAbove vQ)]
  [placeAboveDecidableEq : ∀ vQ, DecidableEq (placeAbove vQ)]
  packet :
    SourceRationalPlace ->
      ∀ (label : IUTIIAbsoluteThetaLabel.{u} l),
      SourceMonoAnalyticTensorPacket.{u} label.tensorIndex
  packet_rationalPlace :
    ∀ vQ label, (packet vQ label).rationalPlace = vQ
  packetPlaceEquiv :
    ∀ vQ label, (packet vQ label).place ≃ placeAbove vQ
  integralConstruction :
    ∀ vQ label, SourcePacketIntegralConstruction (packet vQ label)
  normalizedLogVolume :
    ∀ vQ label,
      SourceNormalizedLogVolume (packet vQ label).carrier
  normalizedLogVolume_region :
    ∀ vQ label,
      (normalizedLogVolume vQ label).integralRegion =
        (integralConstruction vQ label).fullRegion.carrier

attribute [instance]
  SourceTheorem311LocalData.placeAboveFintype
  SourceTheorem311LocalData.placeAboveDecidableEq

namespace SourceTheorem311LocalData

variable {l : PrimeGeFive}

/-- The local family is indexed by the literal type `V(ℚ)`. -/
abbrev rationalPlace (_data : SourceTheorem311LocalData.{u} l) :=
  SourceRationalPlace

/-- The place kind is determined by the constructor of the rational place. -/
def placeKind (_data : SourceTheorem311LocalData.{u} l) :=
  SourceRationalPlace.kind

/-- The full integral region is computed from the fixed packet construction. -/
noncomputable def fullIntegral
    (data : SourceTheorem311LocalData.{u} l)
    (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    SourceIntegralRegionOn vQ.kind (data.packet vQ label).carrier ⊤ := by
  exact (data.integralConstruction vQ label).fullRegion.rekind
    (congrArg SourceRationalPlace.kind
      (data.packet_rationalPlace vQ label))

/-- The dependent place-kind recast does not change the underlying region. -/
theorem fullIntegral_carrier
    (data : SourceTheorem311LocalData.{u} l)
    (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (data.fullIntegral vQ label).carrier =
      (data.integralConstruction vQ label).fullRegion.carrier := by
  rfl

/-- The distinguished region is computed from that same packet construction. -/
noncomputable def distinguishedIntegral
    (data : SourceTheorem311LocalData.{u} l)
    (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l)
    (place : (data.packet vQ label).place) :
    SourceIntegralRegionOn vQ.kind (data.packet vQ label).carrier
      ((data.packet vQ label).distinguishedSubmodule
        label.distinguishedFactor place) := by
  exact
    ((data.integralConstruction vQ label).distinguishedRegion
      label.distinguishedFactor place).rekind
        (congrArg SourceRationalPlace.kind
          (data.packet_rationalPlace vQ label))

/-- The local normalized log-volume is derived from the measured integral region. -/
noncomputable def logVolume
    (data : SourceTheorem311LocalData.{u} l)
    (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) : ℝ :=
  (data.normalizedLogVolume vQ label).value

/--
The procession-normalized log-volume is the ordinary equal-weight average over
all absolute-label capsules.  This is the normalization forced by Proposition
3.9(i)-(ii) and Remark 3.9.3; no family of selectable capsule weights occurs.
-/
noncomputable def processionLogVolume
    (data : SourceTheorem311LocalData.{u} l)
    (vQ : data.rationalPlace) : ℝ :=
  (∑ label : IUTIIAbsoluteThetaLabel.{u} l, data.logVolume vQ label) /
    Fintype.card (IUTIIAbsoluteThetaLabel.{u} l)

end SourceTheorem311LocalData

namespace CategoryProcession

variable {C : CategoryTheory.Cat.{v, u}} {n : ℕ+}

/-- A fixed-length procession regarded as an object of the procession category. -/
def toObject (procession : CategoryProcession C n) :
    CategoryProcessionObject C where
  length := n
  procession := procession

/-- The actual automorphism group that generates Ind1. -/
abbrev AutomorphismGroup (procession : CategoryProcession C n) :=
  Aut procession.toObject

/-- A fixed procession as an object whose arrows retain actual iso members. -/
def toMemberObject (procession : CategoryProcession C n) :
    CategoryProcessionMemberObject C where
  length := n
  procession := procession

/-- The source-correct Ind1 group retains every component strip isomorphism. -/
abbrev MemberAutomorphismGroup (procession : CategoryProcession C n) :=
  Aut procession.toMemberObject

end CategoryProcession

namespace SourceDThetaBridgeCore.IsomorphismMember

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}
    {source target : SourceDThetaBridgeCore models}

/-- A bridge-isomorphism member induces an isomorphism in the procession category. -/
noncomputable def processionObjectIso
    (iso : SourceDThetaBridgeCore.IsomorphismMember source target) :
    source.procession.toObject ≅ target.procession.toObject where
  hom := iso.processionHom
  inv := iso.symm.processionHom
  hom_inv_id := by
    apply CategoryProcession.Hom.ext
    · rfl
    · apply heq_of_eq
      funext position
      apply CategoryCapsule.FullPolyMorphism.ext
      rfl
  inv_hom_id := by
    apply CategoryProcession.Hom.ext
    · rfl
    · apply heq_of_eq
      funext position
      apply CategoryCapsule.FullPolyMorphism.ext
      rfl

/-- The same bridge member induces an isomorphism of mono-analytic processions. -/
noncomputable def monoAnalyticProcessionObjectIso
    (iso : SourceDThetaBridgeCore.IsomorphismMember source target)
    (mono : SourceDMonoAnalyticization models) :
    (source.monoAnalyticProcession mono).toObject ≅
      (target.monoAnalyticProcession mono).toObject where
  hom := iso.monoAnalyticProcessionHom mono
  inv := iso.symm.monoAnalyticProcessionHom mono
  hom_inv_id := by
    apply CategoryProcession.Hom.ext
    · rfl
    · apply heq_of_eq
      funext position
      apply CategoryCapsule.FullPolyMorphism.ext
      rfl
  inv_hom_id := by
    apply CategoryProcession.Hom.ext
    · rfl
    · apply heq_of_eq
      funext position
      apply CategoryCapsule.FullPolyMorphism.ext
      rfl

/--
The same mono-analytic procession isomorphism in the source-correct category
that retains its actual component strip isomorphisms.
-/
noncomputable def monoAnalyticProcessionMemberObjectIso
    (iso : SourceDThetaBridgeCore.IsomorphismMember source target)
    (mono : SourceDMonoAnalyticization models) :
    (source.monoAnalyticProcession mono).toMemberObject ≅
      (target.monoAnalyticProcession mono).toMemberObject where
  hom :=
    { positionEmbedding := Function.Embedding.refl _
      positionStrictMono := strictMono_id
      component := fun position =>
        { indexEmbedding := Function.Embedding.refl _
          componentIso :=
            iso.monoAnalyticProcessionHomMember mono position } }
  inv :=
    { positionEmbedding := Function.Embedding.refl _
      positionStrictMono := strictMono_id
      component := fun position =>
        { indexEmbedding := Function.Embedding.refl _
          componentIso := fun index =>
            (iso.monoAnalyticProcessionHomMember mono position index).symm } }
  hom_inv_id := by
    apply CategoryProcession.MemberHom.ext
    · rfl
    · apply heq_of_eq
      funext position
      apply CategoryCapsule.FullMemberMorphism.ext
      · rfl
      · apply heq_of_eq
        funext index
        apply Iso.ext
        let component :=
          iso.monoAnalyticProcessionHomMember mono position index
        change component.hom ≫ component.inv = 𝟙 _
        exact component.hom_inv_id
  inv_hom_id := by
    apply CategoryProcession.MemberHom.ext
    · rfl
    · apply heq_of_eq
      funext position
      apply CategoryCapsule.FullMemberMorphism.ext
      · rfl
      · apply heq_of_eq
        funext index
        apply Iso.ext
        let component :=
          iso.monoAnalyticProcessionHomMember mono position index
        change component.inv ≫ component.hom = 𝟙 _
        exact component.inv_hom_id

end SourceDThetaBridgeCore.IsomorphismMember

/-- A group action presented by actual equivalences and its action laws. -/
structure SourceEquivalenceAction
    (G : Type u) [Group G] (X : Type v) where
  act : G -> X ≃ X
  one_act : ∀ x, act 1 x = x
  mul_act : ∀ g h x, act (g * h) x = act g (act h x)

namespace SourceEquivalenceAction

variable {G : Type u} [Group G] {X : Type v}

/-- Every source equivalence action is an honest group action. -/
@[reducible]
def toMulAction (action : SourceEquivalenceAction G X) : MulAction G X where
  smul g x := action.act g x
  one_smul := action.one_act
  mul_smul := action.mul_act

/-- Transport an honest action through an equivalence of realization types. -/
def congr {Y : Type v}
    (action : SourceEquivalenceAction G X) (equivalence : X ≃ Y) :
    SourceEquivalenceAction G Y where
  act g := equivalence.symm.trans ((action.act g).trans equivalence)
  one_act y := by
    change equivalence (action.act 1 (equivalence.symm y)) = y
    rw [action.one_act, equivalence.apply_symm_apply]
  mul_act g h y := by
    change
      equivalence (action.act (g * h) (equivalence.symm y)) =
        equivalence
          (action.act g
            (equivalence.symm
              (equivalence
                (action.act h (equivalence.symm y)))))
    rw [action.mul_act, equivalence.symm_apply_apply]

/-- Assemble pointwise actions on a dependent function type. -/
def pi {index : Type w} {Y : index -> Type v}
    (actions : ∀ i, SourceEquivalenceAction G (Y i)) :
    SourceEquivalenceAction G (∀ i, Y i) where
  act g :=
    { toFun := fun value i => (actions i).act g (value i)
      invFun := fun value i => ((actions i).act g).symm (value i)
      left_inv := fun value => by
        funext i
        exact ((actions i).act g).symm_apply_apply (value i)
      right_inv := fun value => by
        funext i
        exact ((actions i).act g).apply_symm_apply (value i) }
  one_act value := by
    funext i
    exact (actions i).one_act (value i)
  mul_act first second value := by
    funext i
    exact (actions i).mul_act first second (value i)

/-- Extend an action to a product while fixing the auxiliary component. -/
def prodRight {Y : Type w}
    (action : SourceEquivalenceAction G X) :
    SourceEquivalenceAction G (X × Y) where
  act g :=
    { toFun := fun value => (action.act g value.1, value.2)
      invFun := fun value => ((action.act g).symm value.1, value.2)
      left_inv := fun value => by
        ext
        · exact (action.act g).symm_apply_apply value.1
        · rfl
      right_inv := fun value => by
        ext
        · exact (action.act g).apply_symm_apply value.1
        · rfl }
  one_act value := by
    ext
    · exact action.one_act value.1
    · rfl
  mul_act g h value := by
    ext
    · exact action.mul_act g h value.1
    · rfl

end SourceEquivalenceAction

/-- Ind1 is precisely the action of automorphisms of the given procession. -/
abbrev SourceTheorem311Ind1Action
    {C : CategoryTheory.Cat.{v, u}} {n : ℕ+}
    (procession : CategoryProcession C n) (X : Type v) :=
  SourceEquivalenceAction procession.MemberAutomorphismGroup X

namespace SourceTheorem311Ind1Action

variable {C : CategoryTheory.Cat.{v, u}} {n : ℕ+}

/--
The Ind1 action induced by a functorial algorithm on processions.  This is the
formal content of Theorem 3.11(i)'s requirement that the construction be
functorial with respect to isomorphisms of processions.
-/
def ofProcessionFunctor
    (algorithm : CategoryProcessionMemberObject C ⥤ Type v)
    (procession : CategoryProcession C n) :
    SourceTheorem311Ind1Action procession
      (algorithm.obj procession.toMemberObject) where
  act automorphism :=
    (algorithm.mapIso automorphism).toEquiv
  one_act value := by
    change algorithm.map (𝟙 procession.toMemberObject) value = value
    rw [algorithm.map_id]
    rfl
  mul_act first second value := by
    change
      algorithm.map ((first * second).hom) value =
        algorithm.map first.hom (algorithm.map second.hom value)
    rw [Aut.Aut_mul_def]
    change
      algorithm.map (second.hom ≫ first.hom) value =
        algorithm.map first.hom (algorithm.map second.hom value)
    rw [algorithm.map_comp]
    rfl

@[simp]
theorem ofProcessionFunctor_act_apply
    (algorithm : CategoryProcessionMemberObject C ⥤ Type v)
    (procession : CategoryProcession C n)
    (automorphism : procession.MemberAutomorphismGroup)
    (value : algorithm.obj procession.toMemberObject) :
    (ofProcessionFunctor algorithm procession).act automorphism value =
      algorithm.map automorphism.hom value :=
  rfl

end SourceTheorem311Ind1Action

namespace SourceMonoAnalyticLogShellAlgorithm

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/-- The Ind1 action on a packet at one fixed procession position. -/
noncomputable def packetInd1Action
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {length : ℕ+}
    (procession : CategoryProcession
      (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models)) length)
    (position : Fin length.1)
    (j : ℕ)
    (indexEquiv : Fin (j + 1) ≃ (procession.capsule position).index)
    (rationalPlace : SourceRationalPlace)
    (topology : TensorTopology
      (fun index => algorithm.factor
        ((procession.capsule position).object (indexEquiv index))
        rationalPlace)) :
    SourceTheorem311Ind1Action procession topology.toPacket.carrier where
  act automorphism :=
    (algorithm.packetMemberTransport (procession.capsule position) j indexEquiv
      rationalPlace topology
      (automorphism.hom.componentSelf position)).toLinearEquiv.toEquiv
  one_act value := by
    change algorithm.packetMemberTransport (procession.capsule position) j
        indexEquiv rationalPlace topology
        ((CategoryProcession.MemberHom.id procession).componentSelf position)
        value = value
    rw [CategoryProcession.MemberHom.componentSelf_id]
    exact congrArg (fun transport => transport value)
      (algorithm.packetMemberTransport_id (procession.capsule position) j
        indexEquiv rationalPlace topology)
  mul_act first second value := by
    rw [Aut.Aut_mul_def]
    change algorithm.packetMemberTransport (procession.capsule position) j
        indexEquiv rationalPlace topology
        ((CategoryProcession.MemberHom.comp second.hom first.hom).componentSelf
          position) value =
      algorithm.packetMemberTransport (procession.capsule position) j indexEquiv
        rationalPlace topology (first.hom.componentSelf position)
        (algorithm.packetMemberTransport (procession.capsule position) j
          indexEquiv rationalPlace topology
          (second.hom.componentSelf position) value)
    rw [CategoryProcession.MemberHom.componentSelf_comp]
    exact congrArg (fun transport => transport value)
      (algorithm.packetMemberTransport_comp (procession.capsule position) j
        indexEquiv rationalPlace topology
        (second.hom.componentSelf position)
        (first.hom.componentSelf position))

end SourceMonoAnalyticLogShellAlgorithm

/--
The source-correct `Z x Z` LGP-Gaussian log-theta lattice for Theorem 3.11.

Its bridges are Definition 6.4 `D-Θ±` bridges, so the associated procession
has all `l±` absolute-label capsules.  The fixed `n,◦` bridge and every vertical
comparison to it are retained as actual compatible poly-isomorphism members.
-/
structure SourceAbsoluteLGPGaussianLogThetaLattice
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    (models : IUTIThetaHodgeTheaterModels theta) where
  bridge : ℤ × ℤ -> SourceFAbsoluteThetaBridge models
  theaters_distinct :
    Function.Injective (fun index => (bridge index).theater)
  monoAnalyticization : SourceDMonoAnalyticization models
  commonBridge : ℤ -> SourceFAbsoluteThetaBridge models
  verticalCoricityToCommon :
    ∀ n m : ℤ,
      SourceDAbsoluteThetaBridgeCore.IsomorphismMember
        (bridge (n, m)).associatedD (commonBridge n).associatedD

namespace SourceAbsoluteLGPGaussianLogThetaLattice

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/-- The actual theta-Hodge theater at an absolute LGP lattice site. -/
def theater
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) : SourceThetaHodgeTheater models :=
  (lattice.bridge (n, m)).theater

/-- The horizontal theta-link between adjacent absolute-lattice columns. -/
def horizontalThetaLink
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    SourceThetaLinkCore (lattice.theater n m) (lattice.theater (n + 1) m) :=
  SourceThetaLinkCore.ofTheaters _ _

/-- The full absolute-label procession at one lattice site. -/
noncomputable def monoAnalyticProcession
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models))
      theta.l.lPlusMinusPositive :=
  (lattice.bridge (n, m)).associatedD.monoAnalyticProcession
    lattice.monoAnalyticization

/-- The fixed `n,◦` mono-analytic procession with all absolute labels. -/
noncomputable def commonMonoAnalyticProcession
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n : ℤ) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models))
      theta.l.lPlusMinusPositive :=
  (lattice.commonBridge n).associatedD.monoAnalyticProcession
    lattice.monoAnalyticization

/-- The procession capsule whose size is `j+1` for the absolute label `|j|`. -/
noncomputable def capsuleAtLabel
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n : ℤ) (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :=
  (lattice.commonMonoAnalyticProcession n).capsule
    label.processionPosition

/-- The ordered packet-factor indices equal the selected procession capsule. -/
noncomputable def packetIndexEquiv
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n : ℤ) (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :
    Fin (label.tensorIndex + 1) ≃
      (lattice.capsuleAtLabel n label).index := by
  rw [← label.processionPosition_val]
  simpa [capsuleAtLabel, commonMonoAnalyticProcession,
    SourceDAbsoluteThetaBridgeCore.monoAnalyticProcession,
    SourceDAbsoluteThetaBridgeCore.procession,
    CategoryProcession.map, CategoryCapsule.map,
    CategoryCapsule.nestedProcession] using
      (Equiv.ulift.{u + 1, 0}.symm :
        Fin (label.processionPosition.1 + 1) ≃
          ULift.{u + 1} (Fin (label.processionPosition.1 + 1)))

/-- Vertical coricity gives actual members on all mono-analytic capsules. -/
noncomputable def verticalProcessionHomToCommonMember
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    ∀ position,
      (((lattice.verticalCoricityToCommon n m).processionHom.component
        position).map lattice.monoAnalyticization.functor).Members :=
  (lattice.verticalCoricityToCommon n m).monoAnalyticProcessionHomMember
    lattice.monoAnalyticization

/-- Vertical coricity gives the full procession map to the fixed circle. -/
noncomputable def verticalProcessionHomToCommon
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    CategoryProcession.Hom
      (lattice.monoAnalyticProcession n m)
      (lattice.commonMonoAnalyticProcession n) :=
  (lattice.verticalCoricityToCommon n m).processionHom
    |>.map lattice.monoAnalyticization.functor

/--
The local packet `S_(j+1)` computed from the actual `|j|` capsule of the
common absolute-label procession.
-/
noncomputable def localPacket
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) :
    SourceMonoAnalyticTensorPacket.{u} label.tensorIndex :=
  algorithm.packetOfCapsule
    (lattice.capsuleAtLabel n label) label.tensorIndex
    (lattice.packetIndexEquiv n label) rationalPlace topology

@[simp]
theorem localPacket_rationalPlace
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) :
    (lattice.localPacket algorithm n rationalPlace label topology).rationalPlace =
      rationalPlace :=
  rfl

/--
The actual Ind1 action on one local packet.  A procession automorphism acts
through its retained capsule member at the absolute label's fixed position.
-/
noncomputable def localInd1PacketAction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) :
    SourceTheorem311Ind1Action (lattice.commonMonoAnalyticProcession n)
      (lattice.localPacket algorithm n rationalPlace label topology).carrier :=
  algorithm.packetInd1Action (lattice.commonMonoAnalyticProcession n)
    label.processionPosition label.tensorIndex
    (lattice.packetIndexEquiv n label) rationalPlace topology

/--
At a nonarchimedean rational place, every packet summand carries precisely
the lattice of its selected-place log shell.
-/
noncomputable def nonarchimedeanShells
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean) :
    SourceNonarchimedeanPacketShells
      (lattice.localPacket algorithm n rationalPlace label topology) where
  summandIntegral factor place := by
    let strip :=
      (lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor)
    exact (algorithm.integralAbove strip rationalPlace place).asNonarchimedean
      hkind

/-- The packet factor lattice is exactly the direct sum of its log shells. -/
theorem nonarchimedeanShells_factorLattice
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean)
    (factor : Fin (label.tensorIndex + 1)) :
    (lattice.nonarchimedeanShells algorithm n rationalPlace label topology
        hkind).factorLattice factor =
      algorithm.factorIntegralLattice
        ((lattice.capsuleAtLabel n label).object
          (lattice.packetIndexEquiv n label factor))
        rationalPlace hkind := by
  ext value
  change
    (∀ place,
      (algorithm.factor
        ((lattice.capsuleAtLabel n label).object
          (lattice.packetIndexEquiv n label factor))
        rationalPlace).directSumIso.hom value place ∈
          ((algorithm.integralAbove
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label factor))
            rationalPlace place).asNonarchimedean hkind).lattice) ↔
      ∀ place, value place ∈
        ((algorithm.integralAbove
          ((lattice.capsuleAtLabel n label).object
          (lattice.packetIndexEquiv n label factor))
          rationalPlace place).asNonarchimedean hkind).lattice
  constructor <;> intro h place
  · simpa only [SourceMonoAnalyticLogShellAlgorithm.factor,
      SourceLocalLogDirectSum.ofLogarithmicShells_directSumIso_hom_apply]
      using h place
  · simpa only [SourceMonoAnalyticLogShellAlgorithm.factor,
      SourceLocalLogDirectSum.ofLogarithmicShells_directSumIso_hom_apply]
      using h place

/--
At an archimedean rational place, every packet summand carries precisely the
Hermitian metric of its selected-place log shell.
-/
noncomputable def archimedeanSummandMetric
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .archimedean)
    (factor : Fin (label.tensorIndex + 1))
    (place :
      (lattice.localPacket algorithm n rationalPlace label topology).place) :
    SourceArchimedeanIntegralStructure
      (((lattice.localPacket algorithm n rationalPlace label topology).factor
        factor).summand place) := by
  let strip :=
    (lattice.capsuleAtLabel n label).object
      (lattice.packetIndexEquiv n label factor)
  exact (algorithm.integralAbove strip rationalPlace place).asArchimedean hkind

/--
An integral construction on an actual procession packet, together with the
proof that its local inputs are exactly the log-shell algorithm's inputs.
-/
structure PacketIntegralConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) where
  construction :
    SourcePacketIntegralConstruction
      (lattice.localPacket algorithm n rationalPlace label topology)
  nonarchimedean_shells :
    ∀ hkind : rationalPlace.kind = .nonarchimedean,
      (construction.asNonarchimedean hkind).shells =
        lattice.nonarchimedeanShells algorithm n rationalPlace label
          topology hkind
  archimedean_summandMetric :
    ∀ (hkind : rationalPlace.kind = .archimedean)
      (factor : Fin (label.tensorIndex + 1))
      (place :
        (lattice.localPacket algorithm n rationalPlace label topology).place),
      (construction.asArchimedean hkind).summandMetric factor place =
        lattice.archimedeanSummandMetric algorithm n rationalPlace label
          topology hkind factor place
  logVolumeDecomposition :
    SourcePacketLogVolumeDecomposition
      (lattice.localPacket algorithm n rationalPlace label topology)
      construction.fullRegion.carrier
  logVolume_placeMultiplicity :
    ∀ place,
      logVolumeDecomposition.placeMultiplicity place =
        SourceSelectedPlace.moduliLocalDegree place.1
  logVolume_placeNormalizationDegree :
    ∀ place,
      logVolumeDecomposition.placeNormalizationDegree place =
        SourceSelectedPlace.moduliRationalLocalDegree place.1

/--
All local analytic data for one fixed vertical circle of the absolute LGP
lattice.  Packets, integral regions, and measures are tied to one construction.
-/
structure LocalConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n : ℤ) where
  topology :
    ∀ (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)
  integral :
    ∀ (rationalPlace : SourceRationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} theta.l),
      PacketIntegralConstruction lattice algorithm n rationalPlace label
        (topology rationalPlace label)

namespace LocalConstruction

/--
The source-local analytic construction produces the exact local-data family
used in Theorem 3.11(i)(a).
-/
noncomputable def toTheorem311LocalData
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n : ℤ}
    (construction : LocalConstruction lattice algorithm n) :
    SourceTheorem311LocalData.{u} theta.l where
  placeAbove := fun rationalPlace =>
    SourceSelectedPlaceAbove theta rationalPlace
  packet rationalPlace label :=
    lattice.localPacket algorithm n rationalPlace label
      (construction.topology rationalPlace label)
  packet_rationalPlace _ _ := rfl
  packetPlaceEquiv _ _ := Equiv.refl _
  integralConstruction rationalPlace label :=
    (construction.integral rationalPlace label).construction
  normalizedLogVolume rationalPlace label :=
    (construction.integral rationalPlace label).logVolumeDecomposition
      |>.toNormalizedLogVolume
  normalizedLogVolume_region _ _ := rfl

end LocalConstruction

end SourceAbsoluteLGPGaussianLogThetaLattice

/--
The earlier nonzero-label `Z x Z` lattice.

Every lattice site contains an actual F-theta bridge and hence an actual
theta-Hodge theater.  Vertical coricity is represented by compatible
isomorphism members of the associated D-theta bridges.  Mono-analyticization
is a single natural functor shared by the lattice.  This is the Proposition
4.11 `D-Θ` procession, not yet the Proposition 6.9 `D-Θ±` procession required
by Theorem 3.11; new source constructions must use
`SourceAbsoluteLGPGaussianLogThetaLattice`.
-/
structure SourceLGPGaussianLogThetaLattice
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    (models : IUTIThetaHodgeTheaterModels theta) where
  bridge : ℤ × ℤ -> SourceFThetaBridge models
  theaters_distinct :
    Function.Injective (fun index => (bridge index).theater)
  monoAnalyticization : SourceDMonoAnalyticization models
  verticalCoricity :
    ∀ n m : ℤ,
      SourceDThetaBridgeCore.IsomorphismMember
        (bridge (n, m)).associatedD
        (bridge (n, m + 1)).associatedD

namespace SourceLGPGaussianLogThetaLattice

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/-- The actual theta-Hodge theater at a lattice site. -/
def theater
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) : SourceThetaHodgeTheater models :=
  (lattice.bridge (n, m)).theater

/-- The fixed `n,circle` D-theta bridge, represented by the site `(n,0)`. -/
def commonDBridge
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n : ℤ) : SourceDThetaBridgeCore models :=
  (lattice.bridge (n, 0)).associatedD

/-- Coricity from a nonnegative lattice height to the common height zero. -/
noncomputable def verticalCoricityToZeroOfNat
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n : ℤ) :
    ∀ height : ℕ,
      SourceDThetaBridgeCore.IsomorphismMember
        (lattice.bridge (n, (height : ℤ))).associatedD
        (lattice.commonDBridge n)
  | 0 => SourceDThetaBridgeCore.IsomorphismMember.id _
  | height + 1 => by
      simpa only [Nat.cast_add, Nat.cast_one] using
        (lattice.verticalCoricity n (height : ℤ)).symm.comp
          (lattice.verticalCoricityToZeroOfNat n height)

/-- Coricity from a negative lattice height to the common height zero. -/
noncomputable def verticalCoricityToZeroOfNegSucc
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n : ℤ) :
    ∀ height : ℕ,
      SourceDThetaBridgeCore.IsomorphismMember
        (lattice.bridge (n, Int.negSucc height)).associatedD
        (lattice.commonDBridge n)
  | 0 => by
      simpa using lattice.verticalCoricity n (-1)
  | height + 1 => by
      have adjacent :=
        lattice.verticalCoricity n (Int.negSucc (height + 1))
      have tail :=
        lattice.verticalCoricityToZeroOfNegSucc n height
      simpa only [Int.reduceNegSucc, Int.negSucc_eq] using
        adjacent.comp tail

/--
Vertical coricity from every `n,m` site to the one common `n,circle` bridge.
-/
noncomputable def verticalCoricityToCommon
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    SourceDThetaBridgeCore.IsomorphismMember
      (lattice.bridge (n, m)).associatedD
      (lattice.commonDBridge n) :=
  match m with
  | .ofNat height => lattice.verticalCoricityToZeroOfNat n height
  | .negSucc height => lattice.verticalCoricityToZeroOfNegSucc n height

/-- The inverse comparison from the common bridge to any `n,m` site. -/
noncomputable def verticalCoricityFromCommon
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    SourceDThetaBridgeCore.IsomorphismMember
      (lattice.commonDBridge n)
      (lattice.bridge (n, m)).associatedD :=
  (lattice.verticalCoricityToCommon n m).symm

/-- The D-prime-strip procession constructed from the bridge at `(n,m)`. -/
noncomputable def dProcession
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDPrimeStrip models))
      theta.l.lStarPositive :=
  (lattice.bridge (n, m)).procession

/-- The D-prime-strip procession of the fixed `n,circle` bridge. -/
noncomputable def commonDProcession
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n : ℤ) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDPrimeStrip models))
      theta.l.lStarPositive :=
  (lattice.commonDBridge n).procession

/-- The mono-analytic procession constructed from the common bridge. -/
noncomputable def commonMonoAnalyticProcession
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n : ℤ) :
    CategoryProcession
      (CategoryTheory.Cat.of (SourceDMonoAnalyticPrimeStrip models))
      theta.l.lStarPositive :=
  (lattice.commonDBridge n).monoAnalyticProcession
    lattice.monoAnalyticization

/--
The mono-analytic procession obtained by applying the lattice's single
mono-analyticization functor to the D-prime-strip procession.
-/
noncomputable def monoAnalyticProcession
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    CategoryProcession
      (CategoryTheory.Cat.of
        (SourceDMonoAnalyticPrimeStrip models))
      theta.l.lStarPositive :=
  (lattice.bridge (n, m)).associatedD.monoAnalyticProcession
    lattice.monoAnalyticization

/-- Every lattice height maps, by derived coricity, to the common procession. -/
noncomputable def verticalProcessionHomToCommon
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    CategoryProcession.Hom
      (lattice.monoAnalyticProcession n m)
      (lattice.commonMonoAnalyticProcession n) :=
  (lattice.verticalCoricityToCommon n m).monoAnalyticProcessionHom
    lattice.monoAnalyticization

/-- Every component of the comparison to the common procession has an isomorphism member. -/
noncomputable def verticalProcessionHomToCommonMember
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    ∀ position,
      ((lattice.verticalCoricityToCommon n m).processionHom.component
        position |>.map lattice.monoAnalyticization.functor).Members :=
  (lattice.verticalCoricityToCommon n m).monoAnalyticProcessionHomMember
    lattice.monoAnalyticization

theorem monoAnalyticProcession_capsule_card
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ)
    (position : Fin theta.l.lStarPositive.1) :
    Fintype.card
        ((lattice.monoAnalyticProcession n m).capsule position).index =
      position.1 + 1 :=
  (lattice.bridge (n, m)).associatedD.monoAnalyticProcession_capsule_card
    lattice.monoAnalyticization position

/-- The horizontal theta-link between adjacent columns is constructed from the theaters. -/
def horizontalThetaLink
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    SourceThetaLinkCore (lattice.theater n m) (lattice.theater (n + 1) m) :=
  SourceThetaLinkCore.ofTheaters _ _

/-- Vertical coricity induces a morphism of mono-analytic processions. -/
noncomputable def verticalProcessionHom
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    CategoryProcession.Hom
      (lattice.monoAnalyticProcession n m)
      (lattice.monoAnalyticProcession n (m + 1)) :=
  (lattice.verticalCoricity n m).monoAnalyticProcessionHom
    lattice.monoAnalyticization

/-- Every component of the vertical procession map has an actual isomorphism member. -/
noncomputable def verticalProcessionHomMember
    (lattice : SourceLGPGaussianLogThetaLattice models)
    (n m : ℤ) :
    ∀ position,
      ((lattice.verticalCoricity n m).processionHom.component
        position |>.map lattice.monoAnalyticization.functor).Members :=
  (lattice.verticalCoricity n m).monoAnalyticProcessionHomMember
    lattice.monoAnalyticization

end SourceLGPGaussianLogThetaLattice

/--
Independent Ind2 choices for each direct summand of every tensor factor.
-/
abbrev SourceInd2Coordinate
    {j : ℕ} (packet : SourceMonoAnalyticTensorPacket.{u} j)
    (symmetry : Fin (j + 1) -> packet.place -> Type u) :=
  ∀ factor place, symmetry factor place

/--
The irreducible input for Ind2: independent group actions on the individual
place summands.  Actions on direct sums and tensor packets are derived below.
-/
structure SourceTheorem311Ind2SummandAction
    (kind : SourceRationalPlaceKind) {j : ℕ}
    (packet : SourceMonoAnalyticTensorPacket.{u} j) where
  symmetry : Fin (j + 1) -> packet.place -> Type u
  [symmetryGroup : ∀ factor place, Group (symmetry factor place)]
  summandAction :
    ∀ (a : Fin (j + 1)) (place : packet.place),
      symmetry a place ->
        (packet.factor a).summand place ≃ₗ[ℚ]
          (packet.factor a).summand place
  summandAction_one :
    ∀ a place x, summandAction a place 1 x = x
  summandAction_mul :
    ∀ a place g h x,
      summandAction a place (g * h) x =
        summandAction a place g
          (summandAction a place h x)
  archimedean_order_two :
    kind = .archimedean ->
      ∀ a place (g : symmetry a place), g * g = 1

attribute [instance]
  SourceTheorem311Ind2SummandAction.symmetryGroup

namespace SourceTheorem311Ind2SummandAction

variable {kind : SourceRationalPlaceKind} {j : ℕ}
variable {packet : SourceMonoAnalyticTensorPacket.{u} j}

/-- The direct-sum action induced coordinatewise from the summand actions. -/
noncomputable def factorAction
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (a : Fin (j + 1))
    (choices : ∀ place, ind2.symmetry a place) :
    (packet.factor a).carrier ≃ₗ[ℚ]
      (packet.factor a).carrier :=
  (packet.factor a).directSumIso.toLinearEquiv |>.trans <|
    (DFinsupp.mapRange.linearEquiv
      (fun place => ind2.summandAction a place (choices place))) |>.trans <|
      (packet.factor a).directSumIso.toLinearEquiv.symm

/-- The induced direct-sum action has the prescribed value on each summand. -/
theorem factorAction_on_summand
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (a : Fin (j + 1))
    (choices : ∀ place, ind2.symmetry a place)
    (place : packet.place)
    (x : (packet.factor a).summand place) :
    (packet.factor a).directSumIso.toLinearEquiv
        (ind2.factorAction a choices
          ((packet.factor a).directSumIso.inv
            (DirectSum.of
              (fun placeIndex =>
                (packet.factor a).summand placeIndex)
              place x))) =
      DirectSum.of
        (fun placeIndex =>
          (packet.factor a).summand placeIndex)
        place (ind2.summandAction a place (choices place) x) := by
  change
    (packet.factor a).directSumIso.toLinearEquiv
        ((packet.factor a).directSumIso.toLinearEquiv.symm
          ((DFinsupp.mapRange.linearEquiv
            (fun placeIndex =>
              ind2.summandAction a placeIndex (choices placeIndex)))
            ((packet.factor a).directSumIso.toLinearEquiv
              ((packet.factor a).directSumIso.toLinearEquiv.symm
                (DirectSum.of
                  (fun placeIndex =>
                    (packet.factor a).summand placeIndex)
                  place x))))) = _
  rw [LinearEquiv.apply_symm_apply]
  rw [LinearEquiv.apply_symm_apply]
  exact
    DFinsupp.mapRange_single
      (f := fun placeIndex value =>
        ind2.summandAction a placeIndex (choices placeIndex) value)
      (hf := fun placeIndex =>
        (ind2.summandAction a placeIndex
          (choices placeIndex)).map_zero)

theorem factorAction_one
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (a : Fin (j + 1))
    (x : (packet.factor a).carrier) :
    ind2.factorAction a 1 x = x := by
  change
    (packet.factor a).directSumIso.toLinearEquiv.symm
        ((DFinsupp.mapRange.linearEquiv
          (fun place => ind2.summandAction a place 1))
          ((packet.factor a).directSumIso.toLinearEquiv x)) = x
  apply (packet.factor a).directSumIso.toLinearEquiv.injective
  rw [LinearEquiv.apply_symm_apply]
  ext place
  simp [ind2.summandAction_one]

theorem factorAction_mul
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (a : Fin (j + 1))
    (first second : ∀ place, ind2.symmetry a place)
    (x : (packet.factor a).carrier) :
    ind2.factorAction a (first * second) x =
      ind2.factorAction a first
        (ind2.factorAction a second x) := by
  change
    (packet.factor a).directSumIso.toLinearEquiv.symm
        ((DFinsupp.mapRange.linearEquiv
          (fun place =>
            ind2.summandAction a place
              (first place * second place)))
          ((packet.factor a).directSumIso.toLinearEquiv x)) =
      (packet.factor a).directSumIso.toLinearEquiv.symm
        ((DFinsupp.mapRange.linearEquiv
          (fun place => ind2.summandAction a place (first place)))
          ((packet.factor a).directSumIso.toLinearEquiv
            ((packet.factor a).directSumIso.toLinearEquiv.symm
              ((DFinsupp.mapRange.linearEquiv
                (fun place =>
                  ind2.summandAction a place (second place)))
                ((packet.factor a).directSumIso.toLinearEquiv x)))))
  apply (packet.factor a).directSumIso.toLinearEquiv.injective
  rw [LinearEquiv.apply_symm_apply]
  rw [LinearEquiv.apply_symm_apply]
  rw [LinearEquiv.apply_symm_apply]
  ext place
  simp [ind2.summandAction_mul]

/-- The tensor-packet action induced from all factor actions. -/
noncomputable def packetAction
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (choices : SourceInd2Coordinate packet ind2.symmetry) :
    packet.carrier ≃ₗ[ℚ] packet.carrier :=
  packet.tensorIso.toLinearEquiv |>.trans <|
    (PiTensorProduct.congr
      (fun a => ind2.factorAction a (choices a))) |>.trans <|
      packet.tensorIso.toLinearEquiv.symm

/-- The induced packet action is literally the tensor product of factor actions. -/
theorem packetAction_on_tensor
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (choices : SourceInd2Coordinate packet ind2.symmetry)
    (x : packet.carrier) :
    packet.tensorIso.toLinearEquiv
        (ind2.packetAction choices x) =
      PiTensorProduct.map
        (fun a => (ind2.factorAction a (choices a)).toLinearMap)
        (packet.tensorIso.toLinearEquiv x) := by
  simp only [packetAction, LinearEquiv.trans_apply]
  rw [LinearEquiv.apply_symm_apply]
  rfl

theorem packetAction_one
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (x : packet.carrier) :
    ind2.packetAction 1 x = x := by
  change
    packet.tensorIso.toLinearEquiv.symm
        (PiTensorProduct.congr
          (fun a => ind2.factorAction a 1)
          (packet.tensorIso.toLinearEquiv x)) = x
  apply packet.tensorIso.toLinearEquiv.injective
  rw [LinearEquiv.apply_symm_apply]
  have hfactor :
      (fun a => ind2.factorAction a 1) =
        (fun a => LinearEquiv.refl ℚ (packet.factor a).carrier) := by
    funext a
    apply LinearEquiv.ext
    exact ind2.factorAction_one a
  rw [hfactor]
  simp [PiTensorProduct.congr]

theorem packetAction_mul
    (ind2 : SourceTheorem311Ind2SummandAction kind packet)
    (first second : SourceInd2Coordinate packet ind2.symmetry)
    (x : packet.carrier) :
    ind2.packetAction (first * second) x =
      ind2.packetAction first (ind2.packetAction second x) := by
  change
    packet.tensorIso.toLinearEquiv.symm
        (PiTensorProduct.congr
          (fun a => ind2.factorAction a (first a * second a))
          (packet.tensorIso.toLinearEquiv x)) =
      packet.tensorIso.toLinearEquiv.symm
        (PiTensorProduct.congr
          (fun a => ind2.factorAction a (first a))
          (packet.tensorIso.toLinearEquiv
            (packet.tensorIso.toLinearEquiv.symm
              (PiTensorProduct.congr
                (fun a => ind2.factorAction a (second a))
                (packet.tensorIso.toLinearEquiv x)))))
  apply packet.tensorIso.toLinearEquiv.injective
  rw [LinearEquiv.apply_symm_apply]
  rw [LinearEquiv.apply_symm_apply]
  rw [LinearEquiv.apply_symm_apply]
  change
    PiTensorProduct.map
        (fun a => (ind2.factorAction a (first a * second a)).toLinearMap)
        (packet.tensorIso.toLinearEquiv x) =
      PiTensorProduct.map
        (fun a => (ind2.factorAction a (first a)).toLinearMap)
        (PiTensorProduct.map
          (fun a => (ind2.factorAction a (second a)).toLinearMap)
          (packet.tensorIso.toLinearEquiv x))
  rw [← LinearMap.comp_apply, ← PiTensorProduct.map_comp]
  congr 1
  apply congrArg (fun maps => PiTensorProduct.map maps)
  funext a
  ext value
  exact ind2.factorAction_mul a (first a) (second a) value

end SourceTheorem311Ind2SummandAction

/--
The complete Ind2 action is the summand datum: its direct-sum and tensor
actions, action laws, and compatibility formulas are derived theorems.
-/
abbrev SourceTheorem311Ind2Action
    (kind : SourceRationalPlaceKind) {j : ℕ}
    (packet : SourceMonoAnalyticTensorPacket.{u} j) :=
  SourceTheorem311Ind2SummandAction kind packet

namespace SourceTheorem311Ind2Action

variable {kind : SourceRationalPlaceKind} {j : ℕ}
variable {packet : SourceMonoAnalyticTensorPacket.{u} j}

/-- Ind2 as an honest action of all independent coordinate choices. -/
noncomputable def action (ind2 : SourceTheorem311Ind2Action kind packet) :
  SourceEquivalenceAction
      (SourceInd2Coordinate packet ind2.symmetry)
      packet.carrier where
  act g :=
    (SourceTheorem311Ind2SummandAction.packetAction ind2 g).toEquiv
  one_act :=
    SourceTheorem311Ind2SummandAction.packetAction_one ind2
  mul_act :=
    SourceTheorem311Ind2SummandAction.packetAction_mul ind2

end SourceTheorem311Ind2Action

namespace SourceTheorem311LocalData

variable {l : PrimeGeFive}

/-- One simultaneous point of all local tensor packets in Theorem 3.11(i)(a). -/
abbrev Realization (data : SourceTheorem311LocalData.{u} l) :=
  ∀ (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l),
    (data.packet vQ label).carrier

end SourceTheorem311LocalData

/--
The irreducible Ind2 input over the complete local packet family: for every
rational place and absolute theta label, supply only the actions on individual
place summands.
-/
structure SourceTheorem311LocalInd2Action
    {l : PrimeGeFive} (data : SourceTheorem311LocalData.{u} l) where
  packetAction :
    ∀ vQ label,
      SourceTheorem311Ind2Action
        (data.placeKind vQ) (data.packet vQ label)

namespace SourceTheorem311LocalInd2Action

variable {l : PrimeGeFive} {data : SourceTheorem311LocalData.{u} l}

/-- All independent Ind2 choices in every summand of every local packet. -/
abbrev Choice
    (ind2 : SourceTheorem311LocalInd2Action data) :=
  ∀ (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l),
    SourceInd2Coordinate
      (data.packet vQ label)
      (ind2.packetAction vQ label).symmetry

/-- Ind2 acts on the complete local family by its derived packet actions. -/
noncomputable def action
    (ind2 : SourceTheorem311LocalInd2Action data) :
    SourceEquivalenceAction ind2.Choice data.Realization where
  act choices :=
    { toFun := fun value vQ label =>
        (ind2.packetAction vQ label).packetAction
          (choices vQ label) (value vQ label)
      invFun := fun value vQ label =>
        ((ind2.packetAction vQ label).packetAction
          (choices vQ label)).symm (value vQ label)
      left_inv := fun value => by
        funext vQ label
        exact
          ((ind2.packetAction vQ label).packetAction
            (choices vQ label)).symm_apply_apply (value vQ label)
      right_inv := fun value => by
        funext vQ label
        exact
          ((ind2.packetAction vQ label).packetAction
            (choices vQ label)).apply_symm_apply (value vQ label) }
  one_act value := by
    funext vQ label
    exact (ind2.packetAction vQ label).packetAction_one (value vQ label)
  mul_act first second value := by
    funext vQ label
    exact
      (ind2.packetAction vQ label).packetAction_mul
        (first vQ label) (second vQ label) (value vQ label)

@[simp]
theorem action_apply
    (ind2 : SourceTheorem311LocalInd2Action data)
    (choices : ind2.Choice) (value : data.Realization)
    (vQ : data.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    ind2.action.act choices value vQ label =
      (ind2.packetAction vQ label).packetAction
        (choices vQ label) (value vQ label) :=
  rfl

end SourceTheorem311LocalInd2Action

/--
A Kummer-induced isomorphism between local tensor packets.

The maps on direct sums and on the tensor packet are required to be induced
by the placewise Kummer maps.  The distinguished-submodule equation is the
typed form of the third pair of isomorphisms in Theorem 3.11(ii)(a).
-/
structure SourceTensorPacketKummerIso
    {j : ℕ}
    (source target : SourceMonoAnalyticTensorPacket.{u} j) where
  placeEquiv : source.place ≃ target.place
  summandKummer :
    ∀ (a : Fin (j + 1)) (place : source.place),
      (source.factor a).summand place ≃L[ℚ]
        (target.factor a).summand (placeEquiv place)
  factorKummer :
    ∀ a : Fin (j + 1),
      (source.factor a).carrier ≃L[ℚ]
        (target.factor a).carrier
  factorKummer_on_summand :
    ∀ a place x,
      (target.factor a).directSumIso.toLinearEquiv
          (factorKummer a
            ((source.factor a).directSumIso.inv
              (DirectSum.of
                (fun placeIndex =>
                  (source.factor a).summand placeIndex)
                place x))) =
        DirectSum.of
          (fun placeIndex =>
            (target.factor a).summand placeIndex)
          (placeEquiv place) (summandKummer a place x)
  packetKummer : source.carrier ≃L[ℚ] target.carrier
  packetKummer_on_tensor :
    ∀ x,
      target.tensorIso.toLinearEquiv (packetKummer x) =
        PiTensorProduct.congr
          (fun a => (factorKummer a).toLinearEquiv)
          (source.tensorIso.toLinearEquiv x)
  distinguishedSubmodule_map :
    ∀ distinguished place,
      Submodule.map packetKummer.toLinearEquiv.toLinearMap
          (source.distinguishedSubmodule distinguished place) =
        target.distinguishedSubmodule distinguished (placeEquiv place)

namespace SourceTensorPacketKummerIso

variable {j : ℕ} {source target : SourceMonoAnalyticTensorPacket.{u} j}

/--
Factorwise Hermitian isometries induce an isometry of the entire tensor packet.
The proof uses the actual tensor presentation, so it applies to arbitrary sums
of pure tensors rather than only to the displayed generators.
-/
theorem packetInner_compatible
    (kummer : SourceTensorPacketKummerIso source target)
    (sourceIntegral : SourceArchimedeanPacketIntegralConstruction source)
    (targetIntegral : SourceArchimedeanPacketIntegralConstruction target)
    (factorInner : ∀ factor first second,
      (targetIntegral.factorMetric factor).inner
          (kummer.factorKummer factor first)
          (kummer.factorKummer factor second) =
        (sourceIntegral.factorMetric factor).inner first second)
    (first second : source.carrier) :
    targetIntegral.packetMetric.inner
        (kummer.packetKummer first) (kummer.packetKummer second) =
      sourceIntegral.packetMetric.inner first second := by
  let factorEquiv :=
    fun factor => (kummer.factorKummer factor).toLinearEquiv
  have pureCompatibility
      (firstComponents secondComponents :
        ∀ factor, (source.factor factor).carrier) :
      targetIntegral.packetMetric.inner
          (target.tensorIso.inv
            (PiTensorProduct.tprod ℚ
              (fun factor => factorEquiv factor (firstComponents factor))))
          (target.tensorIso.inv
            (PiTensorProduct.tprod ℚ
              (fun factor => factorEquiv factor (secondComponents factor)))) =
        sourceIntegral.packetMetric.inner
          (source.tensorIso.inv (PiTensorProduct.tprod ℚ firstComponents))
          (source.tensorIso.inv (PiTensorProduct.tprod ℚ secondComponents)) := by
    rw [targetIntegral.packetMetric_inner_tprod,
      sourceIntegral.packetMetric_inner_tprod]
    apply Finset.prod_congr rfl
    intro factor _
    exact factorInner factor (firstComponents factor) (secondComponents factor)
  have tensorCompatibility : ∀ firstTensor secondTensor,
      targetIntegral.packetMetric.inner
          (target.tensorIso.inv
            (PiTensorProduct.congr factorEquiv firstTensor))
          (target.tensorIso.inv
            (PiTensorProduct.congr factorEquiv secondTensor)) =
        sourceIntegral.packetMetric.inner
          (source.tensorIso.inv firstTensor)
          (source.tensorIso.inv secondTensor) := by
    intro firstTensor
    induction firstTensor using PiTensorProduct.induction_on with
    | smul_tprod firstScalar firstComponents =>
        intro secondTensor
        induction secondTensor using PiTensorProduct.induction_on with
        | smul_tprod secondScalar secondComponents =>
            simp only [map_smul, PiTensorProduct.congr_tprod,
              LinearMap.smul_apply]
            rw [pureCompatibility]
        | add firstSecond secondSecond first_ih second_ih =>
            simp only [map_add, first_ih, second_ih]
    | add firstFirst secondFirst first_ih second_ih =>
        intro secondTensor
        simp only [map_add, LinearMap.add_apply, first_ih secondTensor,
          second_ih secondTensor]
  have targetFirst :
      target.tensorIso.inv
          (PiTensorProduct.congr factorEquiv
            (source.tensorIso.toLinearEquiv first)) =
        kummer.packetKummer first := by
    rw [show PiTensorProduct.congr factorEquiv
          (source.tensorIso.toLinearEquiv first) =
        target.tensorIso.toLinearEquiv (kummer.packetKummer first) by
      simpa only [factorEquiv] using
        (kummer.packetKummer_on_tensor first).symm]
    exact target.tensorIso.hom_inv_id_apply _
  have targetSecond :
      target.tensorIso.inv
          (PiTensorProduct.congr factorEquiv
            (source.tensorIso.toLinearEquiv second)) =
        kummer.packetKummer second := by
    rw [show PiTensorProduct.congr factorEquiv
          (source.tensorIso.toLinearEquiv second) =
        target.tensorIso.toLinearEquiv (kummer.packetKummer second) by
      simpa only [factorEquiv] using
        (kummer.packetKummer_on_tensor second).symm]
    exact target.tensorIso.hom_inv_id_apply _
  have sourceFirst :
      source.tensorIso.inv (source.tensorIso.toLinearEquiv first) = first :=
    source.tensorIso.hom_inv_id_apply first
  have sourceSecond :
      source.tensorIso.inv (source.tensorIso.toLinearEquiv second) = second :=
    source.tensorIso.hom_inv_id_apply second
  simpa only [targetFirst, targetSecond, sourceFirst, sourceSecond] using
    tensorCompatibility
      (source.tensorIso.toLinearEquiv first)
      (source.tensorIso.toLinearEquiv second)

/-- The induced packet Kummer map preserves the Hermitian seminorm. -/
theorem packetSeminorm_compatible
    (kummer : SourceTensorPacketKummerIso source target)
    (sourceIntegral : SourceArchimedeanPacketIntegralConstruction source)
    (targetIntegral : SourceArchimedeanPacketIntegralConstruction target)
    (factorInner : ∀ factor first second,
      (targetIntegral.factorMetric factor).inner
          (kummer.factorKummer factor first)
          (kummer.factorKummer factor second) =
        (sourceIntegral.factorMetric factor).inner first second)
    (value : source.carrier) :
    targetIntegral.packetMetric.seminorm (kummer.packetKummer value) =
      sourceIntegral.packetMetric.seminorm value := by
  have hsquare :
      targetIntegral.packetMetric.seminorm (kummer.packetKummer value) ^ 2 =
        sourceIntegral.packetMetric.seminorm value ^ 2 := by
    calc
      _ = targetIntegral.packetMetric.inner
            (kummer.packetKummer value) (kummer.packetKummer value) :=
        targetIntegral.packetMetric.seminorm_sq _
      _ = sourceIntegral.packetMetric.inner value value :=
        kummer.packetInner_compatible sourceIntegral targetIntegral
          factorInner value value
      _ = sourceIntegral.packetMetric.seminorm value ^ 2 :=
        (sourceIntegral.packetMetric.seminorm_sq value).symm
  nlinarith only [hsquare,
    apply_nonneg targetIntegral.packetMetric.seminorm
      (kummer.packetKummer value),
    apply_nonneg sourceIntegral.packetMetric.seminorm value]

/-- Every distinguished archimedean unit ball is preserved as an actual set. -/
theorem distinguishedUnitBall_image
    (kummer : SourceTensorPacketKummerIso source target)
    (sourceIntegral : SourceArchimedeanPacketIntegralConstruction source)
    (targetIntegral : SourceArchimedeanPacketIntegralConstruction target)
    (factorInner : ∀ factor first second,
      (targetIntegral.factorMetric factor).inner
          (kummer.factorKummer factor first)
          (kummer.factorKummer factor second) =
        (sourceIntegral.factorMetric factor).inner first second)
    (distinguished : Fin (j + 1)) (place : source.place) :
    kummer.packetKummer ''
        (Subtype.val ''
          (sourceIntegral.distinguishedMetric
            distinguished place).unitBall : Set source.carrier) =
      (Subtype.val ''
        (targetIntegral.distinguishedMetric
          distinguished (kummer.placeEquiv place)).unitBall :
            Set target.carrier) := by
  ext targetValue
  constructor
  · rintro ⟨_, ⟨sourceValue, hsourceUnit, rfl⟩, rfl⟩
    have htargetMem : kummer.packetKummer sourceValue.1 ∈
        target.distinguishedSubmodule distinguished
          (kummer.placeEquiv place) := by
      rw [← kummer.distinguishedSubmodule_map distinguished place]
      exact ⟨sourceValue.1, sourceValue.2, rfl⟩
    let targetSubtype :
        target.distinguishedSubmodule distinguished
          (kummer.placeEquiv place) :=
      ⟨kummer.packetKummer sourceValue.1, htargetMem⟩
    refine ⟨targetSubtype, ?_, rfl⟩
    rw [SourceArchimedeanIntegralStructure.unitBall,
      Seminorm.mem_closedBall_zero] at hsourceUnit ⊢
    rw [targetIntegral.distinguishedMetric_induced]
    rw [sourceIntegral.distinguishedMetric_induced] at hsourceUnit
    exact (kummer.packetSeminorm_compatible sourceIntegral targetIntegral
      factorInner sourceValue.1).symm ▸ hsourceUnit
  · rintro ⟨targetSubtype, htargetUnit, rfl⟩
    have htargetMap : targetSubtype.1 ∈
        Submodule.map kummer.packetKummer.toLinearEquiv.toLinearMap
          (source.distinguishedSubmodule distinguished place) := by
      rw [kummer.distinguishedSubmodule_map distinguished place]
      exact targetSubtype.2
    rcases htargetMap with ⟨sourceValue, hsourceMem, hvalue⟩
    refine ⟨sourceValue, ?_, hvalue⟩
    let sourceSubtype : source.distinguishedSubmodule distinguished place :=
      ⟨sourceValue, hsourceMem⟩
    refine ⟨sourceSubtype, ?_, rfl⟩
    rw [SourceArchimedeanIntegralStructure.unitBall,
      Seminorm.mem_closedBall_zero] at htargetUnit ⊢
    rw [sourceIntegral.distinguishedMetric_induced]
    rw [targetIntegral.distinguishedMetric_induced] at htargetUnit
    have hseminorm := kummer.packetSeminorm_compatible sourceIntegral
      targetIntegral factorInner sourceValue
    have hvalue' : kummer.packetKummer sourceValue = targetSubtype.1 := hvalue
    rw [hvalue'] at hseminorm
    change sourceIntegral.packetMetric.seminorm sourceValue ≤ 1
    rwa [← hseminorm]

end SourceTensorPacketKummerIso

namespace SourceMonoAnalyticLogShellAlgorithm

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}

/--
The tensor-packet Kummer isomorphism derived from a family of actual
mono-analytic prime-strip maps.
-/
noncomputable def tensorPacketKummerIso
    [SourceSelectedPlaceFiberFiniteness theta]
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    {j : ℕ} (rationalPlace : SourceRationalPlace)
    (sourceStrip targetStrip :
      Fin (j + 1) -> SourceDMonoAnalyticPrimeStrip models)
    (stripMap : ∀ index, sourceStrip index ⟶ targetStrip index)
    (sourceTopology : TensorTopology
      (fun index => algorithm.factor (sourceStrip index) rationalPlace))
    (targetTopology : TensorTopology
      (fun index => algorithm.factor (targetStrip index) rationalPlace)) :
    SourceTensorPacketKummerIso
      sourceTopology.toPacket targetTopology.toPacket where
  placeEquiv := Equiv.refl _
  summandKummer index place :=
    algorithm.transportAbove (stripMap index) rationalPlace place
  factorKummer index :=
    algorithm.factorTransport (stripMap index) rationalPlace
  factorKummer_on_summand index place value :=
    algorithm.factorTransport_on_summand
      (stripMap index) rationalPlace place value
  packetKummer :=
    sourceTopology.congr targetTopology
      (fun index => algorithm.factorTransport
        (stripMap index) rationalPlace)
  packetKummer_on_tensor value := by
    change
      PiTensorProduct.congr
          (fun index =>
            (algorithm.factorTransport
              (stripMap index) rationalPlace).toLinearEquiv)
          value =
        PiTensorProduct.congr
          (fun index =>
            (algorithm.factorTransport
              (stripMap index) rationalPlace).toLinearEquiv)
          value
    rfl
  distinguishedSubmodule_map distinguished place :=
    sourceTopology.congr_distinguishedSubmodule targetTopology
      (fun index => algorithm.factorTransport
        (stripMap index) rationalPlace)
      (fun index place =>
        (algorithm.transportAbove
          (stripMap index) rationalPlace place).toLinearEquiv)
      (fun index place value =>
        algorithm.factorTransport_on_summand
          (stripMap index) rationalPlace place value)
      distinguished place

end SourceMonoAnalyticLogShellAlgorithm

/--
The local tensor-packet and log-volume portion of the vertical log-Kummer
correspondence in Theorem 3.11(ii)(a).
-/
structure SourceTheorem311VerticalLocalKummer
    {l : PrimeGeFive}
    (source target : SourceTheorem311LocalData.{u} l) where
  rationalPlaceEquiv : source.rationalPlace ≃ target.rationalPlace
  placeKind_compatible :
    ∀ vQ,
      target.placeKind (rationalPlaceEquiv vQ) = source.placeKind vQ
  packetKummer :
    ∀ vQ label,
      SourceTensorPacketKummerIso
        (source.packet vQ label)
        (target.packet (rationalPlaceEquiv vQ) label)
  fullIntegral_image :
    ∀ vQ label,
      (packetKummer vQ label).packetKummer ''
          (source.fullIntegral vQ label).carrier =
        (target.fullIntegral (rationalPlaceEquiv vQ) label).carrier
  distinguishedIntegral_image :
    ∀ vQ label place,
      (packetKummer vQ label).packetKummer ''
          (source.distinguishedIntegral vQ label place).carrier =
        (target.distinguishedIntegral
          (rationalPlaceEquiv vQ) label
          ((packetKummer vQ label).placeEquiv place)).carrier
  logVolumeFunctional_compatible :
    ∀ vQ label,
      SourceNormalizedLogVolume.Compatible
        (source.normalizedLogVolume vQ label)
        (target.normalizedLogVolume (rationalPlaceEquiv vQ) label)
        (packetKummer vQ label).packetKummer

namespace SourceTheorem311VerticalLocalKummer

variable
    {l : PrimeGeFive}
    {source target : SourceTheorem311LocalData.{u} l}

/--
The numerical compatibility in Theorem 3.11(ii)(a) follows from transport of
the entire normalized log-volume functional and the proved image equation for
the integral packet; it is not an independent real-number equality.
-/
theorem logVolume_compatible
    (kummer : SourceTheorem311VerticalLocalKummer source target)
    (vQ : source.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    source.logVolume vQ label =
      target.logVolume (kummer.rationalPlaceEquiv vQ) label := by
  apply (kummer.logVolumeFunctional_compatible vQ label).value_eq
  calc
    (kummer.packetKummer vQ label).packetKummer ''
        (source.normalizedLogVolume vQ label).integralRegion =
        (kummer.packetKummer vQ label).packetKummer ''
          (source.fullIntegral vQ label).carrier := by
            rw [source.normalizedLogVolume_region]
            rw [source.fullIntegral_carrier]
    _ = (target.fullIntegral
          (kummer.rationalPlaceEquiv vQ) label).carrier :=
      kummer.fullIntegral_image vQ label
    _ = (target.normalizedLogVolume
          (kummer.rationalPlaceEquiv vQ) label).integralRegion := by
      rw [target.normalizedLogVolume_region]
      rw [target.fullIntegral_carrier]

end SourceTheorem311VerticalLocalKummer

/--
The multiplicative-to-additive map underlying a vertical log-link.

The domain retains the torsion-cyclotomic multiplicative monoid reconstructed
from the relevant tempered fundamental group.  The codomain is a rational
topological module, so its additive group has no nonzero finite torsion.
-/
structure SourceTheorem311VerticalLogLink
    (domain : SourceTorsionCyclotomicCommMonoid.{u}) where
  codomain : SourceTopologicalQModule.{u}
  logarithm : domain.carrierˣ →* Multiplicative codomain

namespace SourceTheorem311VerticalLogLink

variable {domain : SourceTorsionCyclotomicCommMonoid.{u}}

/--
Every root of unity maps to additive zero under the vertical log-link.  Thus
multiplication by an element in the possible overlap of adjacent log-link
domains contributes exactly the "addition by zero" of Theorem 3.11(ii).
-/
theorem rootsOfUnity_logarithm_eq_zero
    (link : SourceTheorem311VerticalLogLink domain)
    (n : ℕ+)
    (root : domain.RootsOfUnityGroup n) :
    (link.logarithm (root : domain.carrierˣ)).toAdd = 0 := by
  have hmap := congrArg link.logarithm root.property
  have hnsmul :
      n.val • (link.logarithm (root : domain.carrierˣ)).toAdd = 0 := by
    simpa only [map_pow, map_one] using congrArg Multiplicative.toAdd hmap
  have hnq : (n.val : ℚ) ≠ 0 := by
    exact_mod_cast n.ne_zero
  have hqsmul :
      (n.val : ℚ) • (link.logarithm (root : domain.carrierˣ)).toAdd = 0 := by
    simpa only [Nat.cast_smul_eq_nsmul] using hnsmul
  exact (smul_eq_zero.mp hqsmul).resolve_left hnq

/-- Two multiplicative values differ only by a finite-order root of unity. -/
def DiffersByRootOfUnity
    (first second : domain.carrierˣ) : Prop :=
  ∃ (n : ℕ+) (root : domain.RootsOfUnityGroup n),
    second = first * (root : domain.carrierˣ)

/--
The root-of-unity ambiguity is invisible after applying the log-link, exactly
as asserted in the compatibility paragraph of Theorem 3.11(ii).
-/
theorem logarithm_eq_of_differsByRootOfUnity
    (link : SourceTheorem311VerticalLogLink domain)
    {first second : domain.carrierˣ}
    (related : DiffersByRootOfUnity first second) :
    (link.logarithm second).toAdd =
      (link.logarithm first).toAdd := by
  obtain ⟨n, root, rfl⟩ := related
  rw [map_mul]
  change
    (link.logarithm first).toAdd +
        (link.logarithm (root : domain.carrierˣ)).toAdd =
      (link.logarithm first).toAdd
  rw [link.rootsOfUnity_logarithm_eq_zero n root, add_zero]

end SourceTheorem311VerticalLogLink

/--
An integer-indexed vertical line of log-links with the exact adjacent-domain
overlap property supplied by IUT III, Propositions 3.5 and 3.10.

The overlap criterion is retained as an upstream source obligation.  The
claimed mutual compatibility of Theorem 3.11(ii) is derived from it below.
-/
structure SourceTheorem311VerticalLogLinkFamily
    (domain : SourceTorsionCyclotomicCommMonoid.{u}) where
  codomain : SourceTopologicalQModule.{u}
  logarithm : ℤ -> domain.carrierˣ →* Multiplicative codomain
  domainAt : ℤ -> Set domain.carrierˣ
  adjacent_overlap_is_root :
    ∀ (m : ℤ) (value : domain.carrierˣ),
      value ∈ domainAt m ->
      value ∈ domainAt (m + 1) ->
        ∃ n : ℕ+, value ^ n.val = 1

namespace SourceTheorem311VerticalLogLinkFamily

variable {domain : SourceTorsionCyclotomicCommMonoid.{u}}

/-- One member of the vertical line as a multiplicative log-link. -/
def linkAt
    (family : SourceTheorem311VerticalLogLinkFamily domain)
    (m : ℤ) : SourceTheorem311VerticalLogLink domain where
  codomain := family.codomain
  logarithm := family.logarithm m

/--
Adjacent log-links agree on every common domain value: both logarithms are
zero because the overlap value is a root of unity.
-/
theorem adjacent_logarithm_eq_on_overlap
    (family : SourceTheorem311VerticalLogLinkFamily domain)
    (m : ℤ) (value : domain.carrierˣ)
    (hcurrent : value ∈ family.domainAt m)
    (hnext : value ∈ family.domainAt (m + 1)) :
    (family.logarithm m value).toAdd =
      (family.logarithm (m + 1) value).toAdd := by
  obtain ⟨n, hroot⟩ :=
    family.adjacent_overlap_is_root m value hcurrent hnext
  let root : domain.RootsOfUnityGroup n := ⟨value, hroot⟩
  exact
    (family.linkAt m).rootsOfUnity_logarithm_eq_zero n root |>.trans <|
      ((family.linkAt (m + 1)).rootsOfUnity_logarithm_eq_zero n root).symm

/--
If adjacent action representatives differ by a root of unity, then the two
logarithmic images agree.  Agreement of the two log maps on the first
representative comes from the adjacent-domain overlap theorem; the remaining
factor maps to zero.
-/
theorem adjacent_logarithm_eq_of_differsByRootOfUnity
    (family : SourceTheorem311VerticalLogLinkFamily domain)
    (m : ℤ) (first second : domain.carrierˣ)
    (hcurrent : first ∈ family.domainAt m)
    (hnext : first ∈ family.domainAt (m + 1))
    (related :
      SourceTheorem311VerticalLogLink.DiffersByRootOfUnity first second) :
    (family.logarithm m first).toAdd =
      (family.logarithm (m + 1) second).toAdd := by
  calc
    (family.logarithm m first).toAdd =
        (family.logarithm (m + 1) first).toAdd :=
      family.adjacent_logarithm_eq_on_overlap m first hcurrent hnext
    _ = (family.logarithm (m + 1) second).toAdd :=
      ((family.linkAt (m + 1)).logarithm_eq_of_differsByRootOfUnity
        related).symm

end SourceTheorem311VerticalLogLinkFamily

/--
The vertically coric `n, circle` container of Proposition 3.5.

This is fixed while `m` varies.  In particular, it is not an adjacent member of
the log-theta lattice: every `n,m` realization is compared with this one common
packet and one common integral structure.
-/
structure SourceTheorem311CoricContainer (l : PrimeGeFive) where
  packet :
    SourceRationalPlace -> ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
      SourceMonoAnalyticTensorPacket.{u} label.tensorIndex
  packet_rationalPlace :
    ∀ vQ label, (packet vQ label).rationalPlace = vQ
  integralConstruction :
    ∀ vQ label, SourcePacketIntegralConstruction (packet vQ label)
  normalizedLogVolume :
    ∀ vQ label, SourceNormalizedLogVolume (packet vQ label).carrier
  normalizedLogVolume_region :
    ∀ vQ label,
      (normalizedLogVolume vQ label).integralRegion =
        (integralConstruction vQ label).fullRegion.carrier

namespace SourceTheorem311CoricContainer

variable {l : PrimeGeFive}

/-- The common container is indexed by the literal type `V(ℚ)`. -/
abbrev rationalPlace (_container : SourceTheorem311CoricContainer.{u} l) :=
  SourceRationalPlace

/-- The common place kind is determined by the rational place. -/
def placeKind (_container : SourceTheorem311CoricContainer.{u} l) :=
  SourceRationalPlace.kind

/-- The common integral region is derived from its fixed packet construction. -/
noncomputable def integral
    (container : SourceTheorem311CoricContainer.{u} l)
    (vQ : container.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    SourceIntegralRegionOn vQ.kind (container.packet vQ label).carrier ⊤ := by
  exact (container.integralConstruction vQ label).fullRegion.rekind
    (congrArg SourceRationalPlace.kind
      (container.packet_rationalPlace vQ label))

/-- The coric place-kind recast leaves the integral packet itself unchanged. -/
theorem integral_carrier
    (container : SourceTheorem311CoricContainer.{u} l)
    (vQ : container.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (container.integral vQ label).carrier =
      (container.integralConstruction vQ label).fullRegion.carrier :=
  rfl

/-- The common log-volume is computed from the common measured container. -/
noncomputable def logVolume
    (container : SourceTheorem311CoricContainer.{u} l)
    (vQ : container.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) : ℝ :=
  (container.normalizedLogVolume vQ label).value

/-- The local Theorem 3.11 data is itself the fixed vertically coric container. -/
noncomputable def ofLocalData
    (data : SourceTheorem311LocalData.{u} l) :
    SourceTheorem311CoricContainer.{u} l where
  packet := data.packet
  packet_rationalPlace := data.packet_rationalPlace
  integralConstruction := data.integralConstruction
  normalizedLogVolume := data.normalizedLogVolume
  normalizedLogVolume_region := data.normalizedLogVolume_region

end SourceTheorem311CoricContainer

/--
The source-faithful Ind3 upper-semi system of Proposition 3.5(ii) and Theorem
3.11(ii).

For fixed `n`, `common` is the vertically coric `n,circle` container.  The
packets indexed by `m` are the non-coric `n,m` realizations.  `directKummer`
maps every realization to the common container.  At nonarchimedean places,
forward iterates of the log-link start in their actual domain at `m-r` and land
at `m`; their Kummer images are contained in the common integral module.  At
archimedean places, a subset of the radius-`pi` ball at `m` surjects onto the
domain of the backwards log correspondence at `m-r`.  These are intentionally
one-sided statements, not equalities or adjacent-packet linear maps.
-/
structure SourceTheorem311Ind3System (l : PrimeGeFive) where
  common : SourceTheorem311CoricContainer.{u} l
  packet :
    ℤ -> common.rationalPlace ->
      ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
        SourceMonoAnalyticTensorPacket.{u} label.tensorIndex
  packet_rationalPlace :
    ∀ m vQ label, (packet m vQ label).rationalPlace = vQ
  integralConstruction :
    ∀ m vQ label, SourcePacketIntegralConstruction (packet m vQ label)
  directKummer :
    ∀ m vQ label,
      SourceTensorPacketKummerIso
        (packet m vQ label) (common.packet vQ label)
  directKummerIntegral_image :
    ∀ m vQ label,
      (directKummer m vQ label).packetKummer ''
          (integralConstruction m vQ label).fullRegion.carrier =
        (common.integral vQ label).carrier
  unitInvariants :
    ∀ m vQ label, AddSubgroup (packet m vQ label).carrier
  radiusPiRegion :
    ∀ m vQ label, Set (packet m vQ label).carrier
  radiusPiRegion_is_piBall :
    ∀ m vQ label,
      common.placeKind vQ = .archimedean ->
        ∃ metric : SourceArchimedeanIntegralStructure
            (packet m vQ label).carrier,
          radiusPiRegion m vQ label = metric.piBall
  nonarchLogDomain :
    ∀ (m : ℤ) (steps : ℕ+) (vQ : common.rationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} l),
      Set (packet (m - (steps.1 : ℤ)) vQ label).carrier
  nonarchLogDomain_mem_units :
    ∀ m steps vQ label x,
      x ∈ nonarchLogDomain m steps vQ label ->
        x ∈ unitInvariants (m - (steps.1 : ℤ)) vQ label
  nonarchLogIterate :
    ∀ m steps vQ label,
      {x // x ∈ nonarchLogDomain m steps vQ label} ->
        (packet m vQ label).carrier
  nonarch_direct_contained :
    ∀ m vQ label,
      common.placeKind vQ = .nonarchimedean ->
        Set.MapsTo
          (directKummer m vQ label).packetKummer
          (unitInvariants m vQ label : Set _)
          (common.integral vQ label).carrier
  nonarch_logKummer_contained :
    ∀ m steps vQ label,
      common.placeKind vQ = .nonarchimedean ->
        ∀ x,
          (directKummer m vQ label).packetKummer
              (nonarchLogIterate m steps vQ label x) ∈
            (common.integral vQ label).carrier
  arch_direct_units_contained :
    ∀ m vQ label,
      common.placeKind vQ = .archimedean ->
        Set.MapsTo
          (directKummer m vQ label).packetKummer
          (unitInvariants m vQ label : Set _)
          (common.integral vQ label).carrier
  arch_direct_piBall_contained :
    ∀ m vQ label,
      common.placeKind vQ = .archimedean ->
        Set.MapsTo
          (directKummer m vQ label).packetKummer
          (radiusPiRegion m vQ label)
          (common.integral vQ label).carrier
  archLogDomain :
    ∀ (m : ℤ) (steps : ℕ+) (vQ : common.rationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} l),
      Set (packet (m - (steps.1 : ℤ)) vQ label).carrier
  archLogDomain_mem_units :
    ∀ m steps vQ label x,
      x ∈ archLogDomain m steps vQ label ->
        x ∈ unitInvariants (m - (steps.1 : ℤ)) vQ label
  archLogPreimage :
    ∀ (m : ℤ) (_steps : ℕ+) (vQ : common.rationalPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} l),
      Set (packet m vQ label).carrier
  archLogPreimage_mem_piBall :
    ∀ m steps vQ label,
      common.placeKind vQ = .archimedean ->
        archLogPreimage m steps vQ label ⊆ radiusPiRegion m vQ label
  archLogIterate :
    ∀ m steps vQ label,
      {x // x ∈ archLogPreimage m steps vQ label} ->
        {y // y ∈ archLogDomain m steps vQ label}
  archLogIterate_surjective :
    ∀ m steps vQ label,
      common.placeKind vQ = .archimedean ->
        Function.Surjective (archLogIterate m steps vQ label)
  sourceNormalizedLogVolume :
    ∀ m vQ label,
      SourceNormalizedLogVolume (packet m vQ label).carrier
  sourceNormalizedLogVolume_region :
    ∀ m vQ label,
      (sourceNormalizedLogVolume m vQ label).integralRegion =
        (integralConstruction m vQ label).fullRegion.carrier
  logVolumeFunctional_compatible :
    ∀ m vQ label,
      SourceNormalizedLogVolume.Compatible
        (sourceNormalizedLogVolume m vQ label)
        (common.normalizedLogVolume vQ label)
        (directKummer m vQ label).packetKummer

namespace SourceTheorem311Ind3System

variable {l : PrimeGeFive}

/-- The actual integral packet at the non-coric vertical coordinate `m`. -/
noncomputable def sourceIntegral
    (system : SourceTheorem311Ind3System.{u} l)
    (m : ℤ) (vQ : system.common.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    SourceIntegralRegionOn vQ.kind (system.packet m vQ label).carrier ⊤ :=
  (system.integralConstruction m vQ label).fullRegion.rekind
    (congrArg SourceRationalPlace.kind
      (system.packet_rationalPlace m vQ label))

@[simp]
theorem sourceIntegral_carrier
    (system : SourceTheorem311Ind3System.{u} l)
    (m : ℤ) (vQ : system.common.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (system.sourceIntegral m vQ label).carrier =
      (system.integralConstruction m vQ label).fullRegion.carrier :=
  rfl

theorem logVolume_eq_common
    (system : SourceTheorem311Ind3System.{u} l)
    (m : ℤ) (vQ : system.common.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (system.sourceNormalizedLogVolume m vQ label).value =
      system.common.logVolume vQ label := by
  apply (system.logVolumeFunctional_compatible m vQ label).value_eq
  calc
    (system.directKummer m vQ label).packetKummer ''
        (system.sourceNormalizedLogVolume m vQ label).integralRegion =
        (system.directKummer m vQ label).packetKummer ''
          (system.sourceIntegral m vQ label).carrier := by
      rw [system.sourceNormalizedLogVolume_region,
        system.sourceIntegral_carrier]
    _ = (system.common.integral vQ label).carrier :=
      system.directKummerIntegral_image m vQ label
    _ = (system.common.normalizedLogVolume vQ label).integralRegion := by
      rw [system.common.normalizedLogVolume_region,
        system.common.integral_carrier]

/-- Precise common-container compatibility makes log-volume independent of `m`. -/
theorem logVolume_eq_logVolume
    (system : SourceTheorem311Ind3System.{u} l)
    (first second : ℤ) (vQ : system.common.rationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (system.sourceNormalizedLogVolume first vQ label).value =
      (system.sourceNormalizedLogVolume second vQ label).value :=
  (system.logVolume_eq_common first vQ label).trans
    (system.logVolume_eq_common second vQ label).symm

end SourceTheorem311Ind3System

/--
A splitting monoid embedded in a distinguished tensor submodule and acting
multiplicatively on it, as in Theorem 3.11(i)(b).
-/
structure SourceLGPSplittingMonoidAction
    (M : SourceTopologicalQModule.{u}) (target : Submodule ℚ M) where
  monoid : Type u
  [monoidStructure : CommMonoid monoid]
  embedding : monoid ↪ M
  embedding_mem_target : ∀ value, embedding value ∈ target
  act : monoid -> M →ₗ[ℚ] M
  one_act : act 1 = LinearMap.id
  mul_act : ∀ first second,
    act (first * second) = (act first).comp (act second)
  act_mem_target :
    ∀ scalar value, value ∈ target -> act scalar value ∈ target

attribute [instance] SourceLGPSplittingMonoidAction.monoidStructure

namespace SourceLGPSplittingMonoidAction

variable {M : SourceTopologicalQModule.{u}} {target : Submodule ℚ M}

/-- The source splitting monoid acts honestly on its distinguished submodule. -/
@[reducible]
def targetMulAction
    (splitting : SourceLGPSplittingMonoidAction M target) :
    MulAction splitting.monoid target where
  smul scalar value :=
    ⟨splitting.act scalar value.1,
      splitting.act_mem_target scalar value.1 value.2⟩
  one_smul value := by
    apply Subtype.ext
    exact DFunLike.congr_fun splitting.one_act value.1
  mul_smul first second value := by
    apply Subtype.ext
    exact DFunLike.congr_fun
      (splitting.mul_act first second) value.1

end SourceLGPSplittingMonoidAction

/-- A structure-preserving Kummer isomorphism of splitting-monoid actions. -/
structure SourceLGPSplittingMonoidKummerIso
    {sourceModule targetModule : SourceTopologicalQModule.{u}}
    {sourceSubmodule : Submodule ℚ sourceModule}
    {targetSubmodule : Submodule ℚ targetModule}
    (source :
      SourceLGPSplittingMonoidAction sourceModule sourceSubmodule)
    (target :
      SourceLGPSplittingMonoidAction targetModule targetSubmodule)
    (moduleKummer : sourceModule ≃L[ℚ] targetModule) where
  monoidKummer : source.monoid ≃* target.monoid
  embedding_compatible :
    ∀ value,
      moduleKummer (source.embedding value) =
        target.embedding (monoidKummer value)
  action_compatible :
    ∀ scalar value,
      moduleKummer (source.act scalar value) =
        target.act (monoidKummer scalar) (moduleKummer value)

/--
The bad-prime clause of Proposition 3.5(ii)(c).

Every `m`-indexed splitting monoid acts on its own distinguished module and is
transported by an actual Kummer isomorphism to one common vertically coric
action.  `relatedAcrossLog` records only those portions of adjacent actions that
the log-link can compare.  The source theorem says exactly that such a pair
differs by a root of unity; it does not identify the complete actions.
-/
structure SourceTheorem311BadPrimeUpperSemiCompatibility
    {sourceModule : ℤ -> SourceTopologicalQModule.{u}}
    {sourceSubmodule : ∀ m, Submodule ℚ (sourceModule m)}
    {commonModule : SourceTopologicalQModule.{u}}
    {commonSubmodule : Submodule ℚ commonModule}
    (sourceAction :
      ∀ m, SourceLGPSplittingMonoidAction
        (sourceModule m) (sourceSubmodule m))
    (commonAction :
      SourceLGPSplittingMonoidAction commonModule commonSubmodule)
    (moduleKummer : ∀ m, sourceModule m ≃L[ℚ] commonModule) where
  splittingKummer :
    ∀ m,
      SourceLGPSplittingMonoidKummerIso
        (sourceAction m) commonAction (moduleKummer m)
  logDomain : SourceTorsionCyclotomicCommMonoid.{u}
  logLinks : SourceTheorem311VerticalLogLinkFamily logDomain
  scalarToLogUnit :
    ∀ m, (sourceAction m).monoid -> logDomain.carrierˣ
  relatedAcrossLog :
    ∀ m, (sourceAction m).monoid ->
      (sourceAction (m + 1)).monoid -> Prop
  related_current_mem_domain :
    ∀ m first second,
      relatedAcrossLog m first second ->
        scalarToLogUnit m first ∈ logLinks.domainAt m
  related_next_mem_domain :
    ∀ m first second,
      relatedAcrossLog m first second ->
        scalarToLogUnit m first ∈ logLinks.domainAt (m + 1)
  related_only_by_rootOfUnity :
    ∀ m first second,
      relatedAcrossLog m first second ->
        SourceTheorem311VerticalLogLink.DiffersByRootOfUnity
          (scalarToLogUnit m first)
          (scalarToLogUnit (m + 1) second)

namespace SourceTheorem311BadPrimeUpperSemiCompatibility

variable
    {sourceModule : ℤ -> SourceTopologicalQModule.{u}}
    {sourceSubmodule : ∀ m, Submodule ℚ (sourceModule m)}
    {commonModule : SourceTopologicalQModule.{u}}
    {commonSubmodule : Submodule ℚ commonModule}
    {sourceAction :
      ∀ m, SourceLGPSplittingMonoidAction
        (sourceModule m) (sourceSubmodule m)}
    {commonAction :
      SourceLGPSplittingMonoidAction commonModule commonSubmodule}
    {moduleKummer : ∀ m, sourceModule m ≃L[ℚ] commonModule}

/-- The only adjacent bad-prime ambiguity becomes addition by zero. -/
theorem logarithm_eq_of_relatedAcrossLog
    (compatibility :
      SourceTheorem311BadPrimeUpperSemiCompatibility
        sourceAction commonAction moduleKummer)
    (m : ℤ) (first : (sourceAction m).monoid)
    (second : (sourceAction (m + 1)).monoid)
    (related : compatibility.relatedAcrossLog m first second) :
    (compatibility.logLinks.logarithm m
        (compatibility.scalarToLogUnit m first)).toAdd =
      (compatibility.logLinks.logarithm (m + 1)
        (compatibility.scalarToLogUnit (m + 1) second)).toAdd :=
  compatibility.logLinks.adjacent_logarithm_eq_of_differsByRootOfUnity
    m
    (compatibility.scalarToLogUnit m first)
    (compatibility.scalarToLogUnit (m + 1) second)
    (compatibility.related_current_mem_domain m first second related)
    (compatibility.related_next_mem_domain m first second related)
    (compatibility.related_only_by_rootOfUnity m first second related)

end SourceTheorem311BadPrimeUpperSemiCompatibility

/--
The labeled constants, `kappa`-solvable fundamental groups, number fields,
and global Frobenioids occurring in Theorem 3.11(ii).
-/
structure SourceTheorem311LabeledData (l : PrimeGeFive) where
  cuspLabel : Type u
  constantGroup : cuspLabel -> ProfiniteGrp.{u}
  kappaSol :
    IUTIIAbsoluteThetaLabel.{u} l -> ProfiniteGrp.{u}
  mInfinityKappa :
    IUTIIAbsoluteThetaLabel.{u} l -> ProfiniteGrp.{u}
  kappaToMInfinity :
    ∀ label, kappaSol label ⟶ mInfinityKappa label
  numberField :
    IUTIIAbsoluteThetaLabel.{u} l -> Type u
  [numberFieldField : ∀ label, Field (numberField label)]
  [numberFieldIsNumberField :
    ∀ label, NumberField (numberField label)]
  nonRealifiedMOD :
    IUTIIAbsoluteThetaLabel.{u} l ->
      SplitFrobenioidPresentation.{u}
  nonRealifiedMod :
    IUTIIAbsoluteThetaLabel.{u} l ->
      SplitFrobenioidPresentation.{u}
  realifiedMOD :
    IUTIIAbsoluteThetaLabel.{u} l ->
      SplitFrobenioidPresentation.{u}
  realifiedMod :
    IUTIIAbsoluteThetaLabel.{u} l ->
      SplitFrobenioidPresentation.{u}
  nonRealifiedComparison :
    ∀ label,
      SplitFrobenioidEquivalence
        (nonRealifiedMOD label) (nonRealifiedMod label)
  realifiedComparison :
    ∀ label,
      SplitFrobenioidEquivalence
        (realifiedMOD label) (realifiedMod label)

attribute [instance]
  SourceTheorem311LabeledData.numberFieldField
  SourceTheorem311LabeledData.numberFieldIsNumberField

/--
The vertical labeled Kummer isomorphisms in the first display and part (c) of
Theorem 3.11(ii), using actual profinite-group, field, and Frobenioid maps.
-/
structure SourceTheorem311LabeledKummerIso
    {l : PrimeGeFive}
    (source target : SourceTheorem311LabeledData.{u} l) where
  cuspLabelEquiv : source.cuspLabel ≃ target.cuspLabel
  constantKummer :
    ∀ label,
      source.constantGroup label ≅
        target.constantGroup (cuspLabelEquiv label)
  kappaSolKummer :
    ∀ label,
      source.kappaSol label ≅ target.kappaSol label
  mInfinityKummer :
    ∀ label,
      source.mInfinityKappa label ≅ target.mInfinityKappa label
  kappaMInfinity_compatible :
    ∀ label,
      (kappaSolKummer label).hom ≫ target.kappaToMInfinity label =
        source.kappaToMInfinity label ≫ (mInfinityKummer label).hom
  numberFieldKummer :
    ∀ label,
      source.numberField label ≃+* target.numberField label
  nonRealifiedMODKummer :
    ∀ label,
      SplitFrobenioidEquivalence
        (source.nonRealifiedMOD label)
        (target.nonRealifiedMOD label)
  nonRealifiedModKummer :
    ∀ label,
      SplitFrobenioidEquivalence
        (source.nonRealifiedMod label)
        (target.nonRealifiedMod label)
  realifiedMODKummer :
    ∀ label,
      SplitFrobenioidEquivalence
        (source.realifiedMOD label)
        (target.realifiedMOD label)
  realifiedModKummer :
    ∀ label,
      SplitFrobenioidEquivalence
        (source.realifiedMod label)
        (target.realifiedMod label)
  nonRealifiedComparison_compatible :
    ∀ label,
      (source.nonRealifiedComparison label).carrier.functor ⋙
          (nonRealifiedModKummer label).carrier.functor ≅
        (nonRealifiedMODKummer label).carrier.functor ⋙
          (target.nonRealifiedComparison label).carrier.functor
  realifiedComparison_compatible :
    ∀ label,
      (source.realifiedComparison label).carrier.functor ⋙
          (realifiedModKummer label).carrier.functor ≅
        (realifiedMODKummer label).carrier.functor ⋙
          (target.realifiedComparison label).carrier.functor

/--
The complete unquotiented multiradial presentation of Theorem 3.11(i)(a-c).

Bad places are mapped to the fixed place fibers of the local data, so each
splitting monoid acts on the exact distinguished tensor submodule.  The number
field maps are actual rational-linear embeddings into every local component;
joint injectivity is the typed global inclusion in the product of packets.
-/
structure SourceTheorem311MultiradialPresentation (l : PrimeGeFive) where
  localData : SourceTheorem311LocalData.{u} l
  badPlace : Type u
  [badPlaceFintype : Fintype badPlace]
  badRationalPlace : badPlace -> localData.rationalPlace
  badPlaceAbove :
    ∀ place : badPlace, localData.placeAbove (badRationalPlace place)
  splitting :
    ∀ (place : badPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} l),
      SourceLGPSplittingMonoidAction
        (localData.packet (badRationalPlace place) label).carrier
        ((localData.packet (badRationalPlace place) label).distinguishedSubmodule
          label.distinguishedFactor
          ((localData.packetPlaceEquiv (badRationalPlace place) label).symm
            (badPlaceAbove place)))
  labeled : SourceTheorem311LabeledData.{u} l
  numberFieldToLocal :
    ∀ (label : IUTIIAbsoluteThetaLabel.{u} l)
      (vQ : localData.rationalPlace),
      labeled.numberField label →ₗ[ℚ]
        (localData.packet vQ label).carrier
  numberField_jointly_injective :
    ∀ label,
      Function.Injective
        (fun value vQ => numberFieldToLocal label vQ value)

attribute [instance]
  SourceTheorem311MultiradialPresentation.badPlaceFintype

namespace SourceTheorem311MultiradialPresentation

variable {l : PrimeGeFive}

/--
One simultaneous choice of the nonlocal objects carried by a multiradial
presentation.  Frobenioid entries are objects of the actual carrier categories.
-/
structure AuxiliaryRealization
    (presentation : SourceTheorem311MultiradialPresentation.{u} l) where
  splittingValue :
    ∀ (place : presentation.badPlace)
      (label : IUTIIAbsoluteThetaLabel.{u} l),
      (presentation.splitting place label).monoid
  numberFieldValue :
    ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
      presentation.labeled.numberField label
  nonRealifiedMODObject :
    ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
      (presentation.labeled.nonRealifiedMOD label).frobenioid.carrier
  nonRealifiedModObject :
    ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
      (presentation.labeled.nonRealifiedMod label).frobenioid.carrier
  realifiedMODObject :
    ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
      (presentation.labeled.realifiedMOD label).frobenioid.carrier
  realifiedModObject :
    ∀ label : IUTIIAbsoluteThetaLabel.{u} l,
      (presentation.labeled.realifiedMod label).frobenioid.carrier

/-- The complete realization type before imposing Ind1 and Ind2. -/
abbrev Realization
    (presentation : SourceTheorem311MultiradialPresentation.{u} l) :=
  presentation.localData.Realization × presentation.AuxiliaryRealization

/-- The derived complete Ind1 action; all nonlocal data is fixed. -/
noncomputable def ind1Action
    {C : CategoryTheory.Cat.{u, u + 1}} {length : ℕ+}
    (procession : CategoryProcession C length)
    (presentation : SourceTheorem311MultiradialPresentation.{u} l)
    (ind1 : SourceTheorem311Ind1Action procession
      presentation.localData.Realization) :
    SourceTheorem311Ind1Action procession presentation.Realization :=
  ind1.prodRight (Y := presentation.AuxiliaryRealization)

/-- The derived complete Ind2 action; all nonlocal data is fixed. -/
noncomputable def ind2Action
    (presentation : SourceTheorem311MultiradialPresentation.{u} l)
    (ind2 : SourceTheorem311LocalInd2Action presentation.localData) :
    SourceEquivalenceAction ind2.Choice presentation.Realization :=
  ind2.action.prodRight

end SourceTheorem311MultiradialPresentation

namespace SourceAbsoluteLGPGaussianLogThetaLattice

variable
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
