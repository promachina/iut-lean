    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
