/-- The `|j|` capsule at the non-coric lattice site `(n,m)`. -/
noncomputable def siteCapsuleAtLabel
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :=
  (lattice.monoAnalyticProcession n m).capsule
    label.processionPosition

/-- The `j+1` tensor factors in the non-coric site capsule. -/
noncomputable def sitePacketIndexEquiv
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) (label : IUTIIAbsoluteThetaLabel.{u} theta.l) :
    Fin (label.tensorIndex + 1) ≃
      (lattice.siteCapsuleAtLabel n m label).index := by
  rw [← label.processionPosition_val]
  simpa [siteCapsuleAtLabel, monoAnalyticProcession,
    SourceDAbsoluteThetaBridgeCore.monoAnalyticProcession,
    SourceDAbsoluteThetaBridgeCore.procession,
    CategoryProcession.map, CategoryCapsule.map,
    CategoryCapsule.nestedProcession] using
      (Equiv.ulift.{u + 1, 0}.symm :
        Fin (label.processionPosition.1 + 1) ≃
          ULift.{u + 1} (Fin (label.processionPosition.1 + 1)))

/--
The component isomorphism from a non-coric factor to the corresponding factor
of the fixed vertical-circle procession.
-/
noncomputable def verticalStripIsoToCommon
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (n m : ℤ) (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (factor : Fin (label.tensorIndex + 1)) :
    (lattice.siteCapsuleAtLabel n m label).object
        (lattice.sitePacketIndexEquiv n m label factor) ≅
      (lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label factor) := by
  exact lattice.verticalProcessionHomToCommonMember n m
    label.processionPosition
    (lattice.sitePacketIndexEquiv n m label factor)

/-- The actual local tensor packet at the non-coric site `(n,m)`. -/
noncomputable def siteLocalPacket
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace)) :
    SourceMonoAnalyticTensorPacket.{u} label.tensorIndex :=
  algorithm.packetOfCapsule
    (lattice.siteCapsuleAtLabel n m label) label.tensorIndex
    (lattice.sitePacketIndexEquiv n m label) rationalPlace topology

/-- The finite-place shell inputs on the actual non-coric `(n,m)` packet. -/
noncomputable def siteNonarchimedeanShells
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean) :
    SourceNonarchimedeanPacketShells
      (lattice.siteLocalPacket algorithm n m rationalPlace label topology) where
  summandIntegral factor place := by
    let strip :=
      (lattice.siteCapsuleAtLabel n m label).object
        (lattice.sitePacketIndexEquiv n m label factor)
    exact (algorithm.integralAbove strip rationalPlace place).asNonarchimedean
      hkind

/-- The non-coric packet factor lattice has the same direct-sum formula. -/
theorem siteNonarchimedeanShells_factorLattice
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean)
    (factor : Fin (label.tensorIndex + 1)) :
    (lattice.siteNonarchimedeanShells algorithm n m rationalPlace label topology
        hkind).factorLattice factor =
      algorithm.factorIntegralLattice
        ((lattice.siteCapsuleAtLabel n m label).object
          (lattice.sitePacketIndexEquiv n m label factor))
        rationalPlace hkind := by
  ext value
  change
    (∀ place,
      (algorithm.factor
        ((lattice.siteCapsuleAtLabel n m label).object
          (lattice.sitePacketIndexEquiv n m label factor))
        rationalPlace).directSumIso.hom value place ∈
          ((algorithm.integralAbove
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label factor))
            rationalPlace place).asNonarchimedean hkind).lattice) ↔
      ∀ place, value place ∈
        ((algorithm.integralAbove
          ((lattice.siteCapsuleAtLabel n m label).object
          (lattice.sitePacketIndexEquiv n m label factor))
          rationalPlace place).asNonarchimedean hkind).lattice
  constructor <;> intro h place
  · simpa only [SourceMonoAnalyticLogShellAlgorithm.factor,
      SourceLocalLogDirectSum.ofLogarithmicShells_directSumIso_hom_apply]
      using h place
  · simpa only [SourceMonoAnalyticLogShellAlgorithm.factor,
      SourceLocalLogDirectSum.ofLogarithmicShells_directSumIso_hom_apply]
      using h place

/-- The infinite-place Hermitian inputs on the actual non-coric packet. -/
noncomputable def siteArchimedeanSummandMetric
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .archimedean)
    (factor : Fin (label.tensorIndex + 1))
    (place :
      (lattice.siteLocalPacket algorithm n m rationalPlace label topology).place) :
    SourceArchimedeanIntegralStructure
      (((lattice.siteLocalPacket algorithm n m rationalPlace label topology).factor
        factor).summand place) := by
  let strip :=
    (lattice.siteCapsuleAtLabel n m label).object
      (lattice.sitePacketIndexEquiv n m label factor)
  exact (algorithm.integralAbove strip rationalPlace place).asArchimedean hkind

/--
An integral construction on the actual non-coric `(n,m)` packet, tied to the
same log-shell algorithm as the common vertical-circle packet.
-/
structure SitePacketIntegralConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (topology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace)) where
  construction :
    SourcePacketIntegralConstruction
      (lattice.siteLocalPacket algorithm n m rationalPlace label topology)
  nonarchimedean_shells :
    ∀ hkind : rationalPlace.kind = .nonarchimedean,
      (construction.asNonarchimedean hkind).shells =
        lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
          topology hkind
  archimedean_summandMetric :
    ∀ (hkind : rationalPlace.kind = .archimedean)
      (factor : Fin (label.tensorIndex + 1))
      (place :
        (lattice.siteLocalPacket algorithm n m rationalPlace label
          topology).place),
      (construction.asArchimedean hkind).summandMetric factor place =
        lattice.siteArchimedeanSummandMetric algorithm n m rationalPlace label
          topology hkind factor place
  logVolumeDecomposition :
    SourcePacketLogVolumeDecomposition
      (lattice.siteLocalPacket algorithm n m rationalPlace label topology)
      construction.fullRegion.carrier
  logVolume_placeMultiplicity :
    ∀ place,
      logVolumeDecomposition.placeMultiplicity place =
        SourceSelectedPlace.moduliLocalDegree place.1
  logVolume_placeNormalizationDegree :
    ∀ place,
      logVolumeDecomposition.placeNormalizationDegree place =
        SourceSelectedPlace.moduliRationalLocalDegree place.1

/--
Vertical coricity and log-shell functoriality construct the local tensor Kummer
isomorphism from `(n,m)` to the fixed `(n,circle)` packet.
-/
noncomputable def verticalPacketKummerIso
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) :
    SourceTensorPacketKummerIso
      (lattice.siteLocalPacket algorithm n m rationalPlace label siteTopology)
      (lattice.localPacket algorithm n rationalPlace label commonTopology) :=
  algorithm.tensorPacketKummerIso rationalPlace
    (fun index =>
      (lattice.siteCapsuleAtLabel n m label).object
        (lattice.sitePacketIndexEquiv n m label index))
    (fun index =>
      (lattice.capsuleAtLabel n label).object
        (lattice.packetIndexEquiv n label index))
    (fun index => (lattice.verticalStripIsoToCommon n m label index).hom)
    siteTopology commonTopology

/--
The complete integral-and-volume comparison for one vertical packet.  Module
transport and radial measure-space transport form a commuting square; weighted
content compatibility is derived from that square.
-/
structure VerticalPacketIntegralConstruction
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)) where
  siteIntegral : SitePacketIntegralConstruction lattice algorithm n m
    rationalPlace label siteTopology
  commonIntegral : PacketIntegralConstruction lattice algorithm n
    rationalPlace label commonTopology
  logVolumeCompatible :
    SourcePacketLogVolumeDecomposition.Compatible
      siteIntegral.logVolumeDecomposition
      commonIntegral.logVolumeDecomposition
      (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer
  logVolumeCompatible_placeEquiv :
    logVolumeCompatible.coordinatePlaceEquiv =
      (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).placeEquiv

namespace VerticalPacketIntegralConstruction

/-- The vertical product-measure square induces full functional compatibility. -/
theorem logVolumeFunctional_compatible
    [SourceSelectedPlaceFiberFiniteness theta]
    {lattice : SourceAbsoluteLGPGaussianLogThetaLattice models}
    {algorithm : SourceMonoAnalyticLogShellAlgorithm models}
    {n m : ℤ} {rationalPlace : SourceRationalPlace}
    {label : IUTIIAbsoluteThetaLabel.{u} theta.l}
    {siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace)}
    {commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace)}
    (construction : VerticalPacketIntegralConstruction lattice algorithm n m
      rationalPlace label siteTopology commonTopology) :
    SourceNormalizedLogVolume.Compatible
      construction.siteIntegral.logVolumeDecomposition.toNormalizedLogVolume
      construction.commonIntegral.logVolumeDecomposition.toNormalizedLogVolume
      (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer :=
  construction.logVolumeCompatible.toNormalizedLogVolume_compatible

end VerticalPacketIntegralConstruction

/--
At a finite rational place, the vertical Kummer summand map carries the actual
site log-shell lattice to the actual common log-shell lattice.
-/
theorem verticalSummandLattice_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean)
    (factor : Fin (label.tensorIndex + 1))
    (place :
      (lattice.siteLocalPacket algorithm n m rationalPlace label
        siteTopology).place) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).summandKummer factor place ''
        ((lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
          siteTopology hkind).summandIntegral factor place).lattice =
      ((lattice.nonarchimedeanShells algorithm n rationalPlace label
        commonTopology hkind).summandIntegral factor
          ((lattice.verticalPacketKummerIso algorithm n m rationalPlace label
            siteTopology commonTopology).placeEquiv place)).lattice := by
  have transported :=
    algorithm.transportAbove_integral
      (lattice.verticalStripIsoToCommon n m label factor).hom
      rationalPlace place
  change
    algorithm.transportAbove
          (lattice.verticalStripIsoToCommon n m label factor).hom
          rationalPlace place ''
        ((algorithm.integralAbove
          ((lattice.siteCapsuleAtLabel n m label).object
            (lattice.sitePacketIndexEquiv n m label factor))
          rationalPlace place).asNonarchimedean hkind).lattice =
      ((algorithm.integralAbove
        ((lattice.capsuleAtLabel n label).object
          (lattice.packetIndexEquiv n label factor))
        rationalPlace place).asNonarchimedean hkind).lattice
  calc
    _ = algorithm.transportAbove
          (lattice.verticalStripIsoToCommon n m label factor).hom
          rationalPlace place ''
        (algorithm.integralAbove
          ((lattice.siteCapsuleAtLabel n m label).object
            (lattice.sitePacketIndexEquiv n m label factor))
          rationalPlace place).carrier := by
      rw [SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice]
    _ = (algorithm.integralAbove
          ((lattice.capsuleAtLabel n label).object
            (lattice.packetIndexEquiv n label factor))
          rationalPlace place).carrier := transported
    _ = _ := by
      rw [SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice]

/-- The vertical Kummer map preserves each full finite direct-sum lattice. -/
theorem verticalFactorLattice_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean)
    (factor : Fin (label.tensorIndex + 1)) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).factorKummer factor ''
        ((lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
          siteTopology hkind).factorLattice factor : Set _) =
      ((lattice.nonarchimedeanShells algorithm n rationalPlace label
        commonTopology hkind).factorLattice factor : Set _) := by
  rw [lattice.siteNonarchimedeanShells_factorLattice,
    lattice.nonarchimedeanShells_factorLattice]
  change
    algorithm.factorTransport
        (lattice.verticalStripIsoToCommon n m label factor).hom rationalPlace ''
        (algorithm.factorIntegralLattice
          ((lattice.siteCapsuleAtLabel n m label).object
            (lattice.sitePacketIndexEquiv n m label factor))
          rationalPlace hkind : Set _) =
      (algorithm.factorIntegralLattice
        ((lattice.capsuleAtLabel n label).object
          (lattice.packetIndexEquiv n label factor))
        rationalPlace hkind : Set _)
  exact algorithm.factorTransport_integralLattice_image
    (lattice.verticalStripIsoToCommon n m label factor).hom rationalPlace hkind

/-- The vertical packet Kummer map preserves all pure integral tensors. -/
theorem verticalPureIntegralTensors_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).packetKummer ''
        (lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
          siteTopology hkind).pureIntegralTensors =
      (lattice.nonarchimedeanShells algorithm n rationalPlace label
        commonTopology hkind).pureIntegralTensors := by
  let kummer := lattice.verticalPacketKummerIso algorithm n m rationalPlace
    label siteTopology commonTopology
  let siteShells := lattice.siteNonarchimedeanShells algorithm n m rationalPlace
    label siteTopology hkind
  let commonShells := lattice.nonarchimedeanShells algorithm n rationalPlace
    label commonTopology hkind
  ext tensor
  constructor
  · rintro ⟨sourceTensor, ⟨components, hintegral, rfl⟩, rfl⟩
    refine ⟨fun factor => kummer.factorKummer factor (components factor), ?_, ?_⟩
    · intro factor
      have himage : kummer.factorKummer factor (components factor) ∈
          kummer.factorKummer factor ''
            (siteShells.factorLattice factor : Set _) :=
        ⟨components factor, hintegral factor, rfl⟩
      simpa only [kummer, siteShells, commonShells,
        lattice.verticalFactorLattice_image algorithm n m rationalPlace label
          siteTopology commonTopology hkind factor] using himage
    · apply commonTopology.toPacket.tensorIso.toLinearEquiv.injective
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ components))) =
        commonTopology.toPacket.tensorIso.toLinearEquiv
          (commonTopology.toPacket.tensorIso.inv
            (PiTensorProduct.tprod ℚ
              (fun factor => kummer.factorKummer factor (components factor))))
      have htransport := kummer.packetKummer_on_tensor
        (siteTopology.toPacket.tensorIso.inv
          (PiTensorProduct.tprod ℚ components))
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ components))) =
        PiTensorProduct.congr
          (fun factor => (kummer.factorKummer factor).toLinearEquiv)
          (siteTopology.toPacket.tensorIso.toLinearEquiv
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ components))) at htransport
      calc
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (siteTopology.toPacket.tensorIso.toLinearEquiv
                (siteTopology.toPacket.tensorIso.inv
                  (PiTensorProduct.tprod ℚ components))) := htransport
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (PiTensorProduct.tprod ℚ components) := by
          exact congrArg
            (PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv))
            (siteTopology.toPacket.tensorIso.inv_hom_id_apply _)
        _ = PiTensorProduct.tprod ℚ
              (fun factor => kummer.factorKummer factor (components factor)) :=
          PiTensorProduct.congr_tprod _ components
        _ = _ := by
          exact (commonTopology.toPacket.tensorIso.inv_hom_id_apply _).symm
  · rintro ⟨components, hintegral, rfl⟩
    let sourceComponents :
        ∀ factor,
          (siteTopology.toPacket.factor factor).carrier :=
      fun factor => (kummer.factorKummer factor).symm (components factor)
    refine ⟨siteTopology.toPacket.tensorIso.inv
        (PiTensorProduct.tprod ℚ sourceComponents), ?_, ?_⟩
    · refine ⟨sourceComponents, ?_, rfl⟩
      intro factor
      have himage : components factor ∈
          kummer.factorKummer factor ''
            (siteShells.factorLattice factor : Set _) := by
        simpa only [kummer, siteShells, commonShells,
          lattice.verticalFactorLattice_image algorithm n m rationalPlace label
            siteTopology commonTopology hkind factor] using hintegral factor
      rcases himage with ⟨preimage, hpreimage, heq⟩
      have hsource : sourceComponents factor = preimage := by
        change (kummer.factorKummer factor).symm (components factor) = preimage
        rw [← heq, ContinuousLinearEquiv.symm_apply_apply]
      rwa [hsource]
    · apply commonTopology.toPacket.tensorIso.toLinearEquiv.injective
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ sourceComponents))) =
        commonTopology.toPacket.tensorIso.toLinearEquiv
          (commonTopology.toPacket.tensorIso.inv
            (PiTensorProduct.tprod ℚ components))
      have htransport := kummer.packetKummer_on_tensor
        (siteTopology.toPacket.tensorIso.inv
          (PiTensorProduct.tprod ℚ sourceComponents))
      change commonTopology.toPacket.tensorIso.toLinearEquiv
          (kummer.packetKummer
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ sourceComponents))) =
        PiTensorProduct.congr
          (fun factor => (kummer.factorKummer factor).toLinearEquiv)
          (siteTopology.toPacket.tensorIso.toLinearEquiv
            (siteTopology.toPacket.tensorIso.inv
              (PiTensorProduct.tprod ℚ sourceComponents))) at htransport
      calc
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (siteTopology.toPacket.tensorIso.toLinearEquiv
                (siteTopology.toPacket.tensorIso.inv
                  (PiTensorProduct.tprod ℚ sourceComponents))) := htransport
        _ = PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv)
              (PiTensorProduct.tprod ℚ sourceComponents) := by
          exact congrArg
            (PiTensorProduct.congr
              (fun factor => (kummer.factorKummer factor).toLinearEquiv))
            (siteTopology.toPacket.tensorIso.inv_hom_id_apply _)
        _ = PiTensorProduct.tprod ℚ
              (fun factor => kummer.factorKummer factor
                (sourceComponents factor)) :=
          PiTensorProduct.congr_tprod _ sourceComponents
        _ = PiTensorProduct.tprod ℚ components := by
          congr 1
          funext factor
          exact (kummer.factorKummer factor).apply_symm_apply
            (components factor)
        _ = _ := by
          exact (commonTopology.toPacket.tensorIso.inv_hom_id_apply _).symm

