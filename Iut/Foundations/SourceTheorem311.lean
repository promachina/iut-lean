/--
At a finite rational place, the vertical Kummer summand map carries the actual
site log-shell lattice to the actual common log-shell lattice.
-/
theorem verticalSummandLattice_image
    [SourceSelectedPlaceFiberFiniteness theta]
    (lattice : SourceAbsoluteLGPGaussianLogThetaLattice models)
    (algorithm : SourceMonoAnalyticLogShellAlgorithm models)
    (n m : ℤ) (rationalPlace : SourceRationalPlace)
    (label : IUTIIAbsoluteThetaLabel.{u} theta.l)
    (siteTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.siteCapsuleAtLabel n m label).object
              (lattice.sitePacketIndexEquiv n m label index))
            rationalPlace))
    (commonTopology :
      SourceMonoAnalyticLogShellAlgorithm.TensorTopology
        (fun index =>
          algorithm.factor
            ((lattice.capsuleAtLabel n label).object
              (lattice.packetIndexEquiv n label index))
            rationalPlace))
    (hkind : rationalPlace.kind = .nonarchimedean)
    (factor : Fin (label.tensorIndex + 1))
    (place :
      (lattice.siteLocalPacket algorithm n m rationalPlace label
        siteTopology).place) :
    (lattice.verticalPacketKummerIso algorithm n m rationalPlace label
        siteTopology commonTopology).summandKummer factor place ''
        ((lattice.siteNonarchimedeanShells algorithm n m rationalPlace label
          siteTopology hkind).summandIntegral factor place).lattice =
      ((lattice.nonarchimedeanShells algorithm n rationalPlace label
        commonTopology hkind).summandIntegral factor
          ((lattice.verticalPacketKummerIso algorithm n m rationalPlace label
            siteTopology commonTopology).placeEquiv place)).lattice := by
  have transported :=
    algorithm.transportAbove_integral
      (lattice.verticalStripIsoToCommon n m label factor).hom
      rationalPlace place
  change
    algorithm.transportAbove
          (lattice.verticalStripIsoToCommon n m label factor).hom
          rationalPlace place ''
        ((algorithm.integralAbove
          ((lattice.siteCapsuleAtLabel n m label).object
            (lattice.sitePacketIndexEquiv n m label factor))
          rationalPlace place).asNonarchimedean hkind).lattice =
      ((algorithm.integralAbove
        ((lattice.capsuleAtLabel n label).object
          (lattice.packetIndexEquiv n label factor))
        rationalPlace place).asNonarchimedean hkind).lattice
  calc
    _ = algorithm.transportAbove
          (lattice.verticalStripIsoToCommon n m label factor).hom
          rationalPlace place ''
        (algorithm.integralAbove
          ((lattice.siteCapsuleAtLabel n m label).object
            (lattice.sitePacketIndexEquiv n m label factor))
          rationalPlace place).carrier := by
      rw [SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice]
    _ = (algorithm.integralAbove
          ((lattice.capsuleAtLabel n label).object
            (lattice.packetIndexEquiv n label factor))
          rationalPlace place).carrier := transported
    _ = _ := by
      rw [SourceMonoAnalyticIntegralStructure.asNonarchimedean_lattice]

