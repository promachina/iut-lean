/--
Horizontal-link compatibility as an isomorphism in an arrow category.

The source and target objects are horizontal arrows.  Thus `verticalKummer`
is exactly a commutative square whose two vertical sides are isomorphisms.
-/
structure SourceHorizontalKummerCompatibility
    (C : Type u) [Category.{v} C] where
  sourceHorizontal : Arrow C
  targetHorizontal : Arrow C
  verticalKummer : sourceHorizontal ≅ targetHorizontal

namespace SourceHorizontalKummerCompatibility

variable {C : Type u} [Category.{v} C]

/-- The horizontal/vertical Kummer square commutes. -/
theorem commutes
    (compatibility : SourceHorizontalKummerCompatibility C) :
    compatibility.verticalKummer.hom.left ≫
        compatibility.targetHorizontal.hom =
      compatibility.sourceHorizontal.hom ≫
        compatibility.verticalKummer.hom.right :=
  compatibility.verticalKummer.hom.w

/--
The compatible square transports arbitrary automorphisms of its domain and
codomain horizontal arrows.  This is the literal stabilized/equivariant/
functorial property used in Theorem 3.11(iii)(c,d).
-/
def automorphismEquiv
    (compatibility : SourceHorizontalKummerCompatibility C) :
    Aut compatibility.sourceHorizontal ≃*
      Aut compatibility.targetHorizontal :=
  Aut.autMulEquivOfIso compatibility.verticalKummer

end SourceHorizontalKummerCompatibility

/--
An isomorphism of actual projective systems of mono-theta environments.

The natural isomorphism controls every transition map.  At each modulus, its
component is required to agree pointwise with a realization preserving the
outer-symmetry subgroup, cyclotome, and theta-section conjugacy class.
-/
structure SourceMonoThetaProjectiveSystemIso
    (source target : SourceMonoThetaProjectiveSystem.{u}) where
  groupDiagramIso : source.groupDiagram ≅ target.groupDiagram
  environmentRealization :
    ∀ modulus,
      SourceMonoThetaEnvironmentRealization
        (source.environment modulus).data
        (target.environment modulus).data
  component_compatible :
    ∀ modulus value,
      (groupDiagramIso.hom.app modulus).toMonoidHom value =
        (environmentRealization modulus).groupIso value

/-- One generator step after adding the upper-semi Ind3 relation. -/
inductive SourceTheorem311TotalIndeterminacyStep
    {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
    {X : Type v}
    (ind1 : SourceEquivalenceAction G1 X)
    (ind2 : SourceEquivalenceAction G2 X)
    (ind3 : X -> X -> Prop) : X -> X -> Prop
  | ind1 (g : G1) (x : X) :
      SourceTheorem311TotalIndeterminacyStep
        ind1 ind2 ind3 x (ind1.act g x)
  | ind2 (g : G2) (x : X) :
      SourceTheorem311TotalIndeterminacyStep
        ind1 ind2 ind3 x (ind2.act g x)
  | ind3 {x y : X} (related : ind3 x y) :
      SourceTheorem311TotalIndeterminacyStep
        ind1 ind2 ind3 x y

/-- The equivalence relation generated by exactly Ind1, Ind2, and Ind3. -/
def sourceTheorem311TotalIndeterminacySetoid
    {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
    {X : Type v}
    (ind1 : SourceEquivalenceAction G1 X)
    (ind2 : SourceEquivalenceAction G2 X)
    (ind3 : X -> X -> Prop) : Setoid X :=
  Relation.EqvGen.setoid
    (SourceTheorem311TotalIndeterminacyStep ind1 ind2 ind3)

/--
A horizontal evaluation that is invariant under every one of the three
source indeterminacies.
-/
structure SourceTheorem311HorizontalEvaluationCompatibility
    {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
    {X : Type v} (Y : Type u)
    (ind1 : SourceEquivalenceAction G1 X)
    (ind2 : SourceEquivalenceAction G2 X)
    (ind3 : X -> X -> Prop) where
  evaluation : X -> Y
  ind1_compatible :
    ∀ g x, evaluation (ind1.act g x) = evaluation x
  ind2_compatible :
    ∀ g x, evaluation (ind2.act g x) = evaluation x
  ind3_compatible :
    ∀ {x y}, ind3 x y -> evaluation x = evaluation y

namespace SourceTheorem311HorizontalEvaluationCompatibility

variable {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
variable {X : Type v} {Y : Type u}
variable {ind1 : SourceEquivalenceAction G1 X}
variable {ind2 : SourceEquivalenceAction G2 X}
variable {ind3 : X -> X -> Prop}

/-- The compatible horizontal evaluation descends to the full quotient. -/
def descend
    (compatibility :
      SourceTheorem311HorizontalEvaluationCompatibility
        Y ind1 ind2 ind3) :
    Quotient
        (sourceTheorem311TotalIndeterminacySetoid
          ind1 ind2 ind3) ->
      Y :=
  Quotient.lift compatibility.evaluation <| by
    intro first second related
    induction related with
    | rel first second step =>
      cases step with
        | ind1 g => exact (compatibility.ind1_compatible g first).symm
        | ind2 g => exact (compatibility.ind2_compatible g first).symm
        | ind3 relation => exact compatibility.ind3_compatible relation
    | refl => rfl
    | symm _ _ _ ih => exact ih.symm
    | trans _ _ _ _ _ ih₁ ih₂ => exact ih₁.trans ih₂

theorem descend_mk
    (compatibility :
      SourceTheorem311HorizontalEvaluationCompatibility
        Y ind1 ind2 ind3)
    (value : X) :
    compatibility.descend
        (Quotient.mk
          (sourceTheorem311TotalIndeterminacySetoid
            ind1 ind2 ind3) value) =
      compatibility.evaluation value :=
  rfl

end SourceTheorem311HorizontalEvaluationCompatibility

/-- A single generator step of the combined Ind1/Ind2 relation. -/
inductive SourceTheorem311IndeterminacyStep
    {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
    {X : Type v}
    (ind1 : SourceEquivalenceAction G1 X)
    (ind2 : SourceEquivalenceAction G2 X) : X -> X -> Prop
  | ind1 (g : G1) (x : X) :
      SourceTheorem311IndeterminacyStep ind1 ind2 x (ind1.act g x)
  | ind2 (g : G2) (x : X) :
      SourceTheorem311IndeterminacyStep ind1 ind2 x (ind2.act g x)

/-- The equivalence relation generated jointly by the actual Ind1 and Ind2 actions. -/
def sourceTheorem311IndeterminacySetoid
    {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
    {X : Type v}
    (ind1 : SourceEquivalenceAction G1 X)
    (ind2 : SourceEquivalenceAction G2 X) : Setoid X :=
  Relation.EqvGen.setoid
    (SourceTheorem311IndeterminacyStep ind1 ind2)

/-- The multiradial output modulo precisely the generated Ind1/Ind2 relation. -/
abbrev SourceTheorem311IndeterminacyQuotient
    {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
    {X : Type v}
    (ind1 : SourceEquivalenceAction G1 X)
    (ind2 : SourceEquivalenceAction G2 X) :=
  Quotient (sourceTheorem311IndeterminacySetoid ind1 ind2)

namespace SourceTheorem311IndeterminacyQuotient

variable {G1 : Type u} [Group G1] {G2 : Type w} [Group G2]
variable {X : Type v}
variable (ind1 : SourceEquivalenceAction G1 X)
variable (ind2 : SourceEquivalenceAction G2 X)

/-- The quotient identifies every Ind1 procession-automorphism image. -/
theorem sound_ind1 (g : G1) (x : X) :
    (Quotient.mk
        (sourceTheorem311IndeterminacySetoid ind1 ind2) x :
        SourceTheorem311IndeterminacyQuotient ind1 ind2) =
      Quotient.mk
        (sourceTheorem311IndeterminacySetoid ind1 ind2)
        (ind1.act g x) := by
  exact @Quotient.sound X
    (sourceTheorem311IndeterminacySetoid ind1 ind2)
    x (ind1.act g x)
    (Relation.EqvGen.rel _ _
      (SourceTheorem311IndeterminacyStep.ind1 g x))

/-- The quotient identifies every independent Ind2 coordinate image. -/
theorem sound_ind2 (g : G2) (x : X) :
    (Quotient.mk
        (sourceTheorem311IndeterminacySetoid ind1 ind2) x :
        SourceTheorem311IndeterminacyQuotient ind1 ind2) =
      Quotient.mk
        (sourceTheorem311IndeterminacySetoid ind1 ind2)
        (ind2.act g x) := by
  exact @Quotient.sound X
    (sourceTheorem311IndeterminacySetoid ind1 ind2)
    x (ind2.act g x)
    (Relation.EqvGen.rel _ _
      (SourceTheorem311IndeterminacyStep.ind2 g x))

end SourceTheorem311IndeterminacyQuotient

/-- An equivalence intertwining both actions that generate the multiradial quotient. -/
structure SourceTheorem311TwoActionEquivalence
    {sourceG1 targetG1 : Type w}
    [Group sourceG1] [Group targetG1]
    {sourceG2 targetG2 : Type u}
    [Group sourceG2] [Group targetG2]
    {sourceX targetX : Type v}
    (sourceInd1 : SourceEquivalenceAction sourceG1 sourceX)
    (sourceInd2 : SourceEquivalenceAction sourceG2 sourceX)
    (targetInd1 : SourceEquivalenceAction targetG1 targetX)
    (targetInd2 : SourceEquivalenceAction targetG2 targetX) where
  ind1GroupEquiv : sourceG1 ≃* targetG1
  ind2GroupEquiv : sourceG2 ≃* targetG2
  valueEquiv : sourceX ≃ targetX
  ind1_compatible :
    ∀ groupElement value,
      valueEquiv (sourceInd1.act groupElement value) =
        targetInd1.act (ind1GroupEquiv groupElement) (valueEquiv value)
  ind2_compatible :
    ∀ groupElement value,
      valueEquiv (sourceInd2.act groupElement value) =
        targetInd2.act (ind2GroupEquiv groupElement) (valueEquiv value)

namespace SourceTheorem311TwoActionEquivalence

variable
    {sourceG1 targetG1 : Type w}
    [Group sourceG1] [Group targetG1]
    {sourceG2 targetG2 : Type u}
    [Group sourceG2] [Group targetG2]
    {sourceX targetX : Type v}
    {sourceInd1 : SourceEquivalenceAction sourceG1 sourceX}
    {sourceInd2 : SourceEquivalenceAction sourceG2 sourceX}
    {targetInd1 : SourceEquivalenceAction targetG1 targetX}
    {targetInd2 : SourceEquivalenceAction targetG2 targetX}

/-- Equivariance preserves the equivalence closure generated by Ind1 and Ind2. -/
theorem relation_compatible
    (equivalence :
      SourceTheorem311TwoActionEquivalence
        sourceInd1 sourceInd2 targetInd1 targetInd2)
    (first second : sourceX) :
    (sourceTheorem311IndeterminacySetoid sourceInd1 sourceInd2) first second ↔
      (sourceTheorem311IndeterminacySetoid targetInd1 targetInd2)
        (equivalence.valueEquiv first) (equivalence.valueEquiv second) := by
  constructor
  · intro related
    induction related with
    | rel first second step =>
        cases step with
        | ind1 groupElement =>
            rw [equivalence.ind1_compatible]
            exact Relation.EqvGen.rel _ _
              (SourceTheorem311IndeterminacyStep.ind1
                (equivalence.ind1GroupEquiv groupElement)
                (equivalence.valueEquiv first))
        | ind2 groupElement =>
            rw [equivalence.ind2_compatible]
            exact Relation.EqvGen.rel _ _
              (SourceTheorem311IndeterminacyStep.ind2
                (equivalence.ind2GroupEquiv groupElement)
                (equivalence.valueEquiv first))
    | refl => exact Relation.EqvGen.refl _
    | symm _ _ _ ih => exact ih.symm
    | trans first middle second _ _ ihFirst ihSecond =>
        exact Relation.EqvGen.trans
          (equivalence.valueEquiv first)
          (equivalence.valueEquiv middle)
          (equivalence.valueEquiv second)
          ihFirst ihSecond
  · intro related
    have backward_ind1 :
        ∀ groupElement value,
          equivalence.valueEquiv.symm
              (targetInd1.act groupElement value) =
            sourceInd1.act
              (equivalence.ind1GroupEquiv.symm groupElement)
              (equivalence.valueEquiv.symm value) := by
      intro groupElement value
      apply equivalence.valueEquiv.injective
      rw [equivalence.valueEquiv.apply_symm_apply]
      rw [equivalence.ind1_compatible]
      rw [equivalence.ind1GroupEquiv.apply_symm_apply]
      rw [equivalence.valueEquiv.apply_symm_apply]
    have backward_ind2 :
        ∀ groupElement value,
          equivalence.valueEquiv.symm
              (targetInd2.act groupElement value) =
            sourceInd2.act
              (equivalence.ind2GroupEquiv.symm groupElement)
              (equivalence.valueEquiv.symm value) := by
      intro groupElement value
      apply equivalence.valueEquiv.injective
      rw [equivalence.valueEquiv.apply_symm_apply]
      rw [equivalence.ind2_compatible]
      rw [equivalence.ind2GroupEquiv.apply_symm_apply]
      rw [equivalence.valueEquiv.apply_symm_apply]
    have pullRelation :
        ∀ {targetFirst targetSecond : targetX},
          (sourceTheorem311IndeterminacySetoid targetInd1 targetInd2)
              targetFirst targetSecond ->
            (sourceTheorem311IndeterminacySetoid sourceInd1 sourceInd2)
              (equivalence.valueEquiv.symm targetFirst)
              (equivalence.valueEquiv.symm targetSecond) := by
      intro targetFirst targetSecond targetRelated
      induction targetRelated with
      | rel first second step =>
          cases step with
          | ind1 groupElement =>
              rw [backward_ind1]
              exact Relation.EqvGen.rel _ _
                (SourceTheorem311IndeterminacyStep.ind1
                  (equivalence.ind1GroupEquiv.symm groupElement)
                  (equivalence.valueEquiv.symm first))
          | ind2 groupElement =>
              rw [backward_ind2]
              exact Relation.EqvGen.rel _ _
                (SourceTheorem311IndeterminacyStep.ind2
                  (equivalence.ind2GroupEquiv.symm groupElement)
                  (equivalence.valueEquiv.symm first))
      | refl => exact Relation.EqvGen.refl _
      | symm _ _ _ ih => exact ih.symm
      | trans first middle second _ _ ihFirst ihSecond =>
          exact Relation.EqvGen.trans
            (equivalence.valueEquiv.symm first)
            (equivalence.valueEquiv.symm middle)
            (equivalence.valueEquiv.symm second)
            ihFirst ihSecond
    have pulledBack := pullRelation related
    simpa using pulledBack

/-- The equivariant equivalence descends to an equivalence of exact quotients. -/
noncomputable def quotientEquiv
    (equivalence :
      SourceTheorem311TwoActionEquivalence
        sourceInd1 sourceInd2 targetInd1 targetInd2) :
    SourceTheorem311IndeterminacyQuotient sourceInd1 sourceInd2 ≃
      SourceTheorem311IndeterminacyQuotient targetInd1 targetInd2 :=
  Quotient.congr equivalence.valueEquiv equivalence.relation_compatible

end SourceTheorem311TwoActionEquivalence

namespace SourceTheorem311MultiradialAlgorithm

variable
    {l : PrimeGeFive}
    {C : CategoryTheory.Cat.{u, u + 1}} {length : ℕ+}
    {procession : CategoryProcession C length}
    {presentation : SourceTheorem311MultiradialPresentation.{u} l}

/-- The exact multiradial output modulo the generated Ind1/Ind2 relation. -/
abbrev Quotient
    (algorithm :
      SourceTheorem311MultiradialAlgorithm procession presentation)
    (ind2 : SourceTheorem311LocalInd2Action presentation.localData) :=
  SourceTheorem311IndeterminacyQuotient
    algorithm.ind1Action (presentation.ind2Action ind2)

/-- Every procession automorphism is identified in the multiradial quotient. -/
theorem quotient_sound_ind1
    (algorithm :
      SourceTheorem311MultiradialAlgorithm procession presentation)
    (ind2 : SourceTheorem311LocalInd2Action presentation.localData)
    (automorphism : procession.MemberAutomorphismGroup)
    (value : presentation.Realization) :
    (Quotient.mk
        (sourceTheorem311IndeterminacySetoid
          algorithm.ind1Action (presentation.ind2Action ind2)) value :
        algorithm.Quotient ind2) =
      Quotient.mk
        (sourceTheorem311IndeterminacySetoid
          algorithm.ind1Action (presentation.ind2Action ind2))
        (algorithm.ind1Action.act automorphism value) :=
  SourceTheorem311IndeterminacyQuotient.sound_ind1
    algorithm.ind1Action (presentation.ind2Action ind2)
    automorphism value

/-- Every independent tensor-summand action is identified in the quotient. -/
theorem quotient_sound_ind2
    (algorithm :
      SourceTheorem311MultiradialAlgorithm procession presentation)
    (ind2 : SourceTheorem311LocalInd2Action presentation.localData)
    (choices : ind2.Choice)
    (value : presentation.Realization) :
    (Quotient.mk
        (sourceTheorem311IndeterminacySetoid
          algorithm.ind1Action (presentation.ind2Action ind2)) value :
        algorithm.Quotient ind2) =
      Quotient.mk
        (sourceTheorem311IndeterminacySetoid
          algorithm.ind1Action (presentation.ind2Action ind2))
        ((presentation.ind2Action ind2).act choices value) :=
  SourceTheorem311IndeterminacyQuotient.sound_ind2
    algorithm.ind1Action (presentation.ind2Action ind2)
    choices value

end SourceTheorem311MultiradialAlgorithm

/--
The final permutation/bi-coric functoriality clause of Theorem 3.11(i).

The bridge member supplies the bi-coric isomorphism of the initial D-strip and
the induced isomorphism of mono-analytic processions.  The two-action
equivalence states that the resulting transport intertwines both Ind1 and Ind2;
the Ind1 group equivalence is required to be the conjugation equivalence induced
by that very procession isomorphism.
-/
structure SourceTheorem311PermutationBiCoricCompatibility
    {Fmod F K : Type u}
    [Field Fmod] [NumberField Fmod]
    [Field F] [NumberField F]
    [Field K] [NumberField K]
    [Algebra Fmod F] [Algebra F K] [Algebra Fmod K]
    [IsScalarTower Fmod F K]
    [FiniteDimensional Fmod F] [IsGalois Fmod F]
    [FiniteDimensional F K] [IsGalois F K]
    {theta : SourceInitialThetaCore Fmod F K}
    {models : IUTIThetaHodgeTheaterModels theta}
    (mono : SourceDMonoAnalyticization models)
    (sourceBridge targetBridge : SourceDThetaBridgeCore models)
    (sourcePresentation targetPresentation :
      SourceTheorem311MultiradialPresentation.{u} theta.l)
    (sourceAlgorithm :
