    (algorithm :
      SourceTheorem311MultiradialAlgorithm procession presentation) :
    SourceTheorem311Ind1Action procession presentation.Realization :=
  (SourceTheorem311Ind1Action.ofProcessionFunctor
    algorithm.functor procession).congr algorithm.realizationEquiv

