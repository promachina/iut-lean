noncomputable def chosenComparison
    (_theory :
      pair.LocalKummerRootTheory
        coefficientAction coefficientCyclotomeEquiv subgroup)
    (value : pair.fixedSubmonoid subgroup)
    (first second :
      pair.CompatibleRootSystem
        (value : pair.arithmeticMonoid.carrier)) :
    pair.CompatibleRootComparison
      (value : pair.arithmeticMonoid.carrier)
      first second :=
  CompatibleRootComparison.ofModel pair
    (value : pair.arithmeticMonoid.carrier) first second

noncomputable def kummerValue
    (theory :
      pair.LocalKummerRootTheory
        coefficientAction coefficientCyclotomeEquiv subgroup)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient))
    (value : pair.fixedSubmonoid subgroup) :
    ContinuousH1
      (coefficientAction.comap
        (openSubgroupInclusion subgroup)) :=
  (theory.chosen value).localClass equivariant

theorem kummerValue_one
    (theory :
      pair.LocalKummerRootTheory
        coefficientAction coefficientCyclotomeEquiv subgroup)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    theory.kummerValue equivariant 1 = 1 := by
  let chosenRealization :=
    theory.chosen (1 : pair.fixedSubmonoid subgroup)
  let trivialRealization :=
    ContinuousKummerRootRealization.oneOn
      pair coefficientAction coefficientCyclotomeEquiv subgroup
  let comparison :=
    theory.chosenComparison
      (1 : pair.fixedSubmonoid subgroup)
      chosenRealization.toKummerRootRealization.rootSystem
      trivialRealization.toKummerRootRealization.rootSystem
  calc
    theory.kummerValue equivariant 1 =
        chosenRealization.localClass equivariant := rfl
    _ = trivialRealization.localClass equivariant :=
      comparison.localClass_eq
        chosenRealization trivialRealization
        rfl rfl equivariant
    _ = 1 :=
      ContinuousKummerRootRealization.oneOn_localClass
        pair coefficientAction coefficientCyclotomeEquiv
        subgroup equivariant

theorem kummerValue_mul
    (theory :
      pair.LocalKummerRootTheory
        coefficientAction coefficientCyclotomeEquiv subgroup)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient))
    (first second : pair.fixedSubmonoid subgroup) :
    theory.kummerValue equivariant (first * second) =
      theory.kummerValue equivariant first *
        theory.kummerValue equivariant second := by
  let firstRealization := theory.chosen first
  let secondRealization := theory.chosen second
  let productRealization :=
    firstRealization.mulSame secondRealization
  let chosenProduct := theory.chosen (first * second)
  let comparison :=
    theory.chosenComparison (first * second)
      chosenProduct.toKummerRootRealization.rootSystem
      productRealization.toKummerRootRealization.rootSystem
  calc
    theory.kummerValue equivariant (first * second) =
        chosenProduct.localClass equivariant := rfl
    _ = productRealization.localClass equivariant :=
      comparison.localClass_eq
        chosenProduct productRealization
        rfl rfl equivariant
    _ =
        firstRealization.localClass equivariant *
          secondRealization.localClass equivariant :=
      ContinuousKummerRootRealization.mulSame_localClass
        firstRealization secondRealization equivariant
    _ =
        theory.kummerValue equivariant first *
          theory.kummerValue equivariant second := rfl

/-- The local Kummer map M^H -> H1(H, mu_Z(M)) of Proposition 3.2(ii). -/
noncomputable def kummerMap
    (theory :
      pair.LocalKummerRootTheory
        coefficientAction coefficientCyclotomeEquiv subgroup)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    pair.fixedSubmonoid subgroup →*
      ContinuousH1
        (coefficientAction.comap
          (openSubgroupInclusion subgroup)) where
  toFun := theory.kummerValue equivariant
  map_one' := theory.kummerValue_one equivariant
  map_mul' := theory.kummerValue_mul equivariant

/-- The canonical local root theory over a prescribed open subgroup. -/
noncomputable def canonical
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G) :
    pair.LocalKummerRootTheory
      pair.continuousCyclotomeAction
      (ContinuousMulEquiv.refl
        (SourceMonoidCyclotome pair.arithmeticMonoid.carrier)).toMulEquiv
      subgroup :=
  ofContinuousEquiv pair pair.continuousCyclotomeAction
    (ContinuousMulEquiv.refl
      (SourceMonoidCyclotome pair.arithmeticMonoid.carrier))
    subgroup

/--
The source-constructed map `M^H -> H^1(H, mu_Z(M))` of Proposition 3.2(ii).
-/
noncomputable def canonicalKummerMap
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G) :
    pair.fixedSubmonoid subgroup →*
      ContinuousH1
        (pair.continuousCyclotomeAction.comap
          (openSubgroupInclusion subgroup)) :=
  (canonical pair subgroup).kummerMap (by
    intro _ _
    rfl)

/--
The local and direct-limit Kummer maps are the same construction after the
canonical map from H1(H, mu) to its germ.
-/
theorem local_toGerm_eq_global
    (globalTheory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (localTheory :
      pair.LocalKummerRootTheory
        coefficientAction coefficientCyclotomeEquiv subgroup)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient))
    (value : pair.fixedSubmonoid subgroup) :
    ContinuousH1.toGerm subgroup
        (localTheory.kummerMap equivariant value) =
      globalTheory.kummerMap equivariant
        (value : pair.arithmeticMonoid.carrier) := by
  let globalRealization :=
    (globalTheory.chosen
      (value : pair.arithmeticMonoid.carrier)).2
  let localRealization := localTheory.chosen value
  let comparison :=
    globalTheory.chosenComparison
      (value : pair.arithmeticMonoid.carrier)
      globalRealization.toKummerRootRealization.rootSystem
      localRealization.toKummerRootRealization.rootSystem
  calc
    ContinuousH1.toGerm subgroup
          (localTheory.kummerMap equivariant value) =
        localRealization.germ equivariant := rfl
    _ = globalRealization.germ equivariant :=
      (comparison.germ_eq
        globalRealization localRealization
        rfl rfl equivariant).symm
    _ =
        globalTheory.kummerMap equivariant
          (value : pair.arithmeticMonoid.carrier) := rfl

/--
The two canonical Kummer maps of Proposition 3.2(ii) commute with passage from
`H^1(H, mu_Z(M))` to the direct-limit germ.
-/
theorem canonicalKummerMap_toGerm
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G)
    (value : pair.fixedSubmonoid subgroup) :
    ContinuousH1.toGerm subgroup
        (canonicalKummerMap pair subgroup value) =
      KummerRootTheory.canonicalKummerMap pair
        (value : pair.arithmeticMonoid.carrier) := by
  exact
    local_toGerm_eq_global
      (KummerRootTheory.canonical pair)
      (canonical pair subgroup)
      (by
        intro _ _
        rfl)
      value

end LocalKummerRootTheory

/-- The Galois augmentation transported from the chosen model pair. -/
noncomputable def augmentation
    (pair : SourceMLFGaloisTMPair G) :
    G ⟶ SourceMLFAbsoluteGaloisGroup pair.modelField :=
  pair.model.augmentation.comp
    (ContinuousMonoidHom.toContinuousMonoidHom
      pair.groupIso.symm)

/-- The transported Galois augmentation remains surjective. -/
theorem augmentation_surjective
    (pair : SourceMLFGaloisTMPair G) :
    Function.Surjective pair.augmentation.toFun := by
  intro arithmeticGaloisElement
  rcases pair.model.augmentation_surjective arithmeticGaloisElement with
    ⟨modelElement, hmodelElement⟩
  refine ⟨pair.groupIso modelElement, ?_⟩
  change
    pair.model.augmentation.toFun
        (pair.groupIso.symm
          (pair.groupIso modelElement)) =
      arithmeticGaloisElement
  rw [pair.groupIso.symm_apply_apply]
  exact hmodelElement

end SourceMLFGaloisTMPair

/--
The unit Kummer embedding attached to the `M_TM` arithmetic monoid in
Absolute Anabelian Topics III, Proposition 3.2(ii), and used in IUT II,
Corollary 1.12(c).  Proposition 3.2(ii) supplies the map; injectivity is the
separate multiplicative case of Definition 1.5(b), available for an MLF by
Remark 1.5.4(i).

The constant subgroup is not supplied independently: it is derived below as
the range of the compatible-root Kummer map.  The pair already carries the
literal MLF model certificate, and callers can no longer supply an unrelated
homomorphism into cohomology.
-/
structure SourceIUTIIUnitKummerEmbedding
    (G : TopologicalGroupCat.{u})
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    [IsMulCommutative A]
    (coefficientAction : ContinuousGroupAction G A) where
  tmPair : SourceMLFGaloisTMPair G
  coefficientCyclotomeEquiv :
    A ≃ₜ*
      SourceMonoidCyclotome tmPair.arithmeticMonoid.carrier
  coefficientCyclotomeEquiv_equivariant :
    ∀ g coefficient,
      coefficientCyclotomeEquiv
          (coefficientAction.act g coefficient) =
        tmPair.cyclotomeAction g
          (coefficientCyclotomeEquiv coefficient)
  /-- The multiplicative MLF Kummer-faithfulness theorem of Remark 1.5.4(i). -/
  unitKummerFaithful :
    Function.Injective
      (((SourceMLFGaloisTMPair.KummerRootTheory.ofContinuousEquiv
            tmPair coefficientAction coefficientCyclotomeEquiv).kummerMap
          coefficientCyclotomeEquiv_equivariant).comp
        { toFun := Units.val
          map_one' := rfl
          map_mul' := fun _ _ => rfl })

namespace SourceIUTIIUnitKummerEmbedding

variable
  {G : TopologicalGroupCat.{u}}
  {A : Type u}
  [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
  [IsMulCommutative A]
  {coefficientAction : ContinuousGroupAction G A}

/-- The continuous root theory is derived from the coefficient identification. -/
noncomputable def rootTheory
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    embedding.tmPair.KummerRootTheory
      coefficientAction
      embedding.coefficientCyclotomeEquiv.toMulEquiv :=
  SourceMLFGaloisTMPair.KummerRootTheory.ofContinuousEquiv
    embedding.tmPair coefficientAction
    embedding.coefficientCyclotomeEquiv

/-- The full arithmetic-monoid Kummer map constructed from compatible roots. -/
noncomputable def monoidKummer
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    embedding.tmPair.arithmeticMonoid.carrier →*
      ContinuousH1Germ coefficientAction :=
  embedding.rootTheory.kummerMap
    embedding.coefficientCyclotomeEquiv_equivariant

/-- The unit Kummer map is the restriction of the full monoid Kummer map. -/
noncomputable def unitKummer
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    embedding.tmPair.arithmeticMonoid.carrierˣ →*
      ContinuousH1Germ coefficientAction :=
  embedding.monoidKummer.comp
    { toFun := Units.val
      map_one' := rfl
      map_mul' := fun _ _ => rfl }

/-- The unit Kummer map is injective by the stored MLF Kummer-faithfulness theorem. -/
theorem unitKummer_injective
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    Function.Injective embedding.unitKummer :=
  by
    simpa [unitKummer, monoidKummer, rootTheory] using
      embedding.unitKummerFaithful

/--
IUT II's `M_TM^x`, as the actual image of the unit Kummer map rather than an
arbitrary subgroup of cohomology.
-/
noncomputable def constantSubgroup
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    Subgroup (ContinuousH1Germ coefficientAction) :=
  embedding.unitKummer.range

/-- The image of the torsion units of `M_TM`. -/
noncomputable def torsionUnitImage
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    Subgroup (ContinuousH1Germ coefficientAction) :=
  (CommGroup.torsion
    embedding.tmPair.arithmeticMonoid.carrierˣ).map
    embedding.unitKummer

/--
The source definition `M_TM^mu = (M_TM^x)_tors`: injectivity of the Kummer
embedding identifies it exactly with the image of the torsion units.
-/
theorem torsionUnitImage_eq_constant_torsion
    (embedding :
      SourceIUTIIUnitKummerEmbedding
        G coefficientAction) :
    embedding.torsionUnitImage =
      embedding.constantSubgroup ⊓
        CommGroup.torsion
          (ContinuousH1Germ coefficientAction) := by
  ext value
  constructor
  · rintro ⟨unit, hunit, rfl⟩
    exact
      ⟨⟨unit, rfl⟩,
        embedding.unitKummer.isOfFinOrder hunit⟩
  · rintro ⟨⟨unit, hunit⟩, hvalue⟩
    subst value
    refine ⟨unit, ?_, rfl⟩
    change IsOfFinOrder
      (embedding.unitKummer unit) at hvalue
    change IsOfFinOrder unit
    exact
      embedding.unitKummer_injective.isOfFinOrder_iff.mp
        hvalue

end SourceIUTIIUnitKummerEmbedding

/--
The symmetrized family in IUT II, Corollary 3.5(i), after identifying labels
`t` and `-t`.

The family remains indexed by the full nonzero absolute-label set.  An
isomorphism of action pairs is supplied over each transport in the exact
unit/sign quotient action; base-to-label isomorphisms are then derived by
transitivity.  The identity and multiplication fields assert that these
isomorphisms form the coherent transport induced by an outer group action.
-/
structure SourceIUTIISymmetrizingIsomorphisms
    (l : PrimeGeFive) where
  pair :
    IUTIPositiveLabel.{u} l →
      SourceTopologicalGroupMonoidActionPair.{u}
  baseLabel :
    IUTIPositiveLabel.{u} l
  outerTransport :
    ∀ symmetry label,
      SourceTopologicalGroupMonoidActionPair.Iso
        (pair label)
        (pair
          (iutIISignQuotientPermHom
            l symmetry label))
  outerTransport_one :
    ∀ label,
      SourceTopologicalGroupMonoidActionPair.Iso.castTarget
          (congrArg pair (by
            rw [map_one]
            rfl))
          (outerTransport 1 label) =
        SourceTopologicalGroupMonoidActionPair.Iso.refl
          (pair label)
  outerTransport_mul :
    ∀ first second label,
      SourceTopologicalGroupMonoidActionPair.Iso.castTarget
          (congrArg pair (by
            rw [map_mul]
            rfl))
          (outerTransport (first * second) label) =
        (outerTransport second label).trans
          (outerTransport first
            (iutIISignQuotientPermHom
              l second label))

namespace SourceIUTIISymmetrizingIsomorphisms

variable
  {l : PrimeGeFive}
  (symmetry :
    SourceIUTIISymmetrizingIsomorphisms.{u} l)

/-- A chosen unit/sign symmetry carrying the base label to a target label. -/
noncomputable def connectingSymmetry
    (label : IUTIPositiveLabel.{u} l) :
    (ZMod l.value)ˣ ⧸ zmodSignUnitSubgroup l :=
  Classical.choose
    (iutIISignQuotientPermHom_transitive
      l symmetry.baseLabel label)

theorem connectingSymmetry_maps
    (label : IUTIPositiveLabel.{u} l) :
    iutIISignQuotientPermHom l
        (symmetry.connectingSymmetry label)
        symmetry.baseLabel =
      label :=
  Classical.choose_spec
    (iutIISignQuotientPermHom_transitive
      l symmetry.baseLabel label)

/--
The base-to-label symmetrizing isomorphism derived from the transitive label
action and the lifted outer transport.
-/
noncomputable def fromBase
    (label : IUTIPositiveLabel.{u} l) :
    SourceTopologicalGroupMonoidActionPair.Iso
      (symmetry.pair symmetry.baseLabel)
      (symmetry.pair label) := by
  let transport :=
    symmetry.outerTransport
      (symmetry.connectingSymmetry label)
      symmetry.baseLabel
  rw [symmetry.connectingSymmetry_maps label] at transport
  exact transport

/--
The diagonal monoid homomorphism into the direct product of all nonzero
absolute-label factors.
-/
noncomputable def diagonalMonoidHom :
    (symmetry.pair symmetry.baseLabel).monoidCarrier →*
      ∀ label,
        (symmetry.pair label).monoidCarrier :=
  Pi.monoidHom fun label =>
    (symmetry.fromBase label).monoidIso.toMulEquiv.toMonoidHom

/--
The diagonal embedding retains the base monoid faithfully; symmetrization
does not collapse the label-indexed family.
-/
theorem diagonalMonoidHom_injective :
    Function.Injective symmetry.diagonalMonoidHom := by
  intro first second h
  have hbase :
      (symmetry.fromBase symmetry.baseLabel).monoidIso first =
        (symmetry.fromBase symmetry.baseLabel).monoidIso second :=
    congrFun h symmetry.baseLabel
  exact
    (symmetry.fromBase
      symmetry.baseLabel).monoidIso.injective hbase

/-- The actual diagonal submonoid determined by the symmetrizing isomorphisms. -/
noncomputable def diagonalRangeSubmonoid :
    Submonoid
      (∀ label,
        (symmetry.pair label).monoidCarrier) :=
  MonoidHom.mrange symmetry.diagonalMonoidHom

/--
The base constant monoid is multiplicatively isomorphic to its full
symmetrized diagonal range.
-/
noncomputable def diagonalRangeMulEquiv :
    (symmetry.pair symmetry.baseLabel).monoidCarrier ≃*
      symmetry.diagonalRangeSubmonoid :=
  MulEquiv.ofBijective
    symmetry.diagonalMonoidHom.mrangeRestrict
    ⟨by
      intro first second h
      apply symmetry.diagonalMonoidHom_injective
      exact congrArg Subtype.val h,
    MonoidHom.mrangeRestrict_surjective
      symmetry.diagonalMonoidHom⟩

/-- The symmetrized diagonal embedding is continuous in every label coordinate. -/
theorem continuous_diagonalMonoidHom :
    Continuous symmetry.diagonalMonoidHom := by
  apply continuous_pi
  intro label
  exact
    (symmetry.fromBase label).monoidIso.continuous

/--
The base monoid and its diagonal range are isomorphic as topological monoids.
The inverse is the base-label projection followed by the inverse
symmetrizing isomorphism.
-/
noncomputable def diagonalRangeContinuousMulEquiv :
    (symmetry.pair symmetry.baseLabel).monoidCarrier ≃ₜ*
      symmetry.diagonalRangeSubmonoid where
  toFun monoidElement :=
    ⟨symmetry.diagonalMonoidHom monoidElement,
      ⟨monoidElement, rfl⟩⟩
  invFun profile :=
    (symmetry.fromBase
      symmetry.baseLabel).monoidIso.symm
        (profile.1 symmetry.baseLabel)
  left_inv monoidElement := by
    change
      (symmetry.fromBase
          symmetry.baseLabel).monoidIso.symm
          ((symmetry.diagonalMonoidHom
            monoidElement) symmetry.baseLabel) =
        monoidElement
    exact
      (symmetry.fromBase
        symmetry.baseLabel).monoidIso.symm_apply_apply
          monoidElement
  right_inv profile := by
    rcases profile with
      ⟨_profile, ⟨monoidElement, rfl⟩⟩
    apply Subtype.ext
    change
      symmetry.diagonalMonoidHom
          ((symmetry.fromBase
              symmetry.baseLabel).monoidIso.symm
            ((symmetry.diagonalMonoidHom
              monoidElement) symmetry.baseLabel)) =
        symmetry.diagonalMonoidHom monoidElement
    apply congrArg symmetry.diagonalMonoidHom
    exact
      (symmetry.fromBase
        symmetry.baseLabel).monoidIso.symm_apply_apply
          monoidElement
  map_mul' first second := by
    apply Subtype.ext
    exact map_mul symmetry.diagonalMonoidHom first second
  continuous_toFun :=
    symmetry.continuous_diagonalMonoidHom.subtype_mk _
  continuous_invFun :=
    (symmetry.fromBase
        symmetry.baseLabel).monoidIso.symm.continuous.comp
      ((continuous_apply symmetry.baseLabel).comp
        continuous_subtype_val)

/-- The symmetrizing isomorphism between any two labeled factors. -/
noncomputable def between
    (first second : IUTIPositiveLabel.{u} l) :
    SourceTopologicalGroupMonoidActionPair.Iso
      (symmetry.pair first)
      (symmetry.pair second) :=
  (symmetry.fromBase first).symm.trans
    (symmetry.fromBase second)

/-- Diagonal embedding of the base factor's units into all labeled factors. -/
noncomputable def diagonalUnitsHom :
    (symmetry.pair
      symmetry.baseLabel).monoidCarrierˣ →*
      ∀ label,
        (symmetry.pair label).monoidCarrier :=
  symmetry.diagonalMonoidHom.comp
    (Units.coeHom
      (symmetry.pair
        symmetry.baseLabel).monoidCarrier)

/-- The symmetrized diagonal unit submonoid in the labeled direct product. -/
noncomputable def diagonalUnitSubmonoid :
    Submonoid
      (∀ label,
        (symmetry.pair label).monoidCarrier) :=
  MonoidHom.mrange symmetry.diagonalUnitsHom

/--
The base acting group acts diagonally on the heterogeneous labeled product,
using the symmetrizing group isomorphism at every label.
-/
noncomputable def diagonalActionMulAut
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup) :
    MulAut
      (∀ label,
        (symmetry.pair label).monoidCarrier) :=
  MulEquiv.piCongrRight fun label =>
    (symmetry.pair label).action
      ((symmetry.fromBase label).groupIso
        groupElement)

/-- The transported diagonal actions form an actual group action homomorphism. -/
noncomputable def diagonalActionHom :
    (symmetry.pair
        symmetry.baseLabel).actingGroup →*
      MulAut
        (∀ label,
          (symmetry.pair label).monoidCarrier) where
  toFun :=
    symmetry.diagonalActionMulAut
  map_one' := by
    apply MulEquiv.ext
    intro profile
    funext label
    change
      (symmetry.pair label).action
          ((symmetry.fromBase label).groupIso 1)
          (profile label) =
        profile label
    rw [map_one, map_one]
    rfl
  map_mul' first second := by
    apply MulEquiv.ext
    intro profile
    funext label
    change
      (symmetry.pair label).action
          ((symmetry.fromBase label).groupIso
            (first * second))
          (profile label) =
        (symmetry.pair label).action
          ((symmetry.fromBase label).groupIso first)
          ((symmetry.pair label).action
            ((symmetry.fromBase label).groupIso second)
            (profile label))
    rw [map_mul, map_mul]
    rfl

/-- The diagonal constant embedding is equivariant for the transported action. -/
theorem diagonalMonoidHom_equivariant
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup)
    (monoidElement :
      (symmetry.pair
        symmetry.baseLabel).monoidCarrier) :
    symmetry.diagonalActionMulAut groupElement
        (symmetry.diagonalMonoidHom monoidElement) =
      symmetry.diagonalMonoidHom
        ((symmetry.pair
          symmetry.baseLabel).action
            groupElement monoidElement) := by
  funext label
  change
    (symmetry.pair label).action
        ((symmetry.fromBase label).groupIso
          groupElement)
        ((symmetry.fromBase label).monoidIso
          monoidElement) =
      (symmetry.fromBase label).monoidIso
        ((symmetry.pair
          symmetry.baseLabel).action
            groupElement monoidElement)
  exact
    ((symmetry.fromBase label).equivariant
      groupElement monoidElement).symm

/-- The transported diagonal action preserves the full diagonal range. -/
theorem diagonalAction_mem_diagonalRangeSubmonoid
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup)
    {profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier}
    (profile_mem :
      profile ∈ symmetry.diagonalRangeSubmonoid) :
    symmetry.diagonalActionMulAut groupElement profile ∈
      symmetry.diagonalRangeSubmonoid := by
  rcases profile_mem with
    ⟨monoidElement, rfl⟩
  refine
    ⟨(symmetry.pair
        symmetry.baseLabel).action
          groupElement monoidElement, ?_⟩
  exact
    (symmetry.diagonalMonoidHom_equivariant
      groupElement monoidElement).symm

/--
The topological diagonal-range isomorphism intertwines the base action and
the transported action on every label coordinate.
-/
theorem diagonalRangeContinuousMulEquiv_equivariant
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup)
    (monoidElement :
      (symmetry.pair
        symmetry.baseLabel).monoidCarrier) :
    (symmetry.diagonalRangeContinuousMulEquiv
        ((symmetry.pair
          symmetry.baseLabel).action
            groupElement monoidElement) :
      ∀ label,
        (symmetry.pair label).monoidCarrier) =
      symmetry.diagonalActionMulAut groupElement
        (symmetry.diagonalRangeContinuousMulEquiv
          monoidElement :
          symmetry.diagonalRangeSubmonoid) :=
  (symmetry.diagonalMonoidHom_equivariant
    groupElement monoidElement).symm

/-- The transported diagonal action preserves the diagonal unit submonoid. -/
theorem diagonalAction_mem_diagonalUnitSubmonoid
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup)
    (unit :
      (symmetry.pair
        symmetry.baseLabel).monoidCarrierˣ) :
    symmetry.diagonalActionMulAut groupElement
        (symmetry.diagonalUnitsHom unit) ∈
      symmetry.diagonalUnitSubmonoid := by
  let transportedUnit :
      (symmetry.pair
        symmetry.baseLabel).monoidCarrierˣ :=
    Units.map
      ((symmetry.pair
        symmetry.baseLabel).action
          groupElement).toMonoidHom
      unit
  refine ⟨transportedUnit, ?_⟩
  funext label
  change
    (symmetry.fromBase label).monoidIso
        ((symmetry.pair
          symmetry.baseLabel).action
            groupElement (unit :
              (symmetry.pair
                symmetry.baseLabel).monoidCarrier)) =
      (symmetry.pair label).action
        ((symmetry.fromBase label).groupIso
          groupElement)
        ((symmetry.fromBase label).monoidIso
          (unit :
            (symmetry.pair
              symmetry.baseLabel).monoidCarrier))
  exact
    (symmetry.fromBase label).equivariant
      groupElement unit

/--
The finite Gaussian monoid in the heterogeneous labeled product, generated
by symmetrized diagonal units and the natural powers of one value profile.
-/
noncomputable def gaussianMonoid
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier) :
    Submonoid
      (∀ label,
        (symmetry.pair label).monoidCarrier) :=
  symmetry.diagonalUnitSubmonoid ⊔
    Submonoid.closure {profile}

theorem profile_mem_gaussianMonoid
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier) :
    profile ∈ symmetry.gaussianMonoid profile := by
  apply Submonoid.mem_sup_right
  exact
    Submonoid.subset_closure
      (Set.mem_singleton profile)

theorem diagonalUnit_mem_gaussianMonoid
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier)
    (unit :
      (symmetry.pair
        symmetry.baseLabel).monoidCarrierˣ) :
    symmetry.diagonalUnitsHom unit ∈
      symmetry.gaussianMonoid profile := by
  apply Submonoid.mem_sup_left
  exact ⟨unit, rfl⟩

/--
If the orbit of the value profile remains in its Gaussian monoid, then the
transported diagonal action preserves the entire generated Gaussian monoid.
-/
theorem diagonalAction_map_gaussianMonoid_le
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier)
    (profile_stable :
      ∀ groupElement,
        symmetry.diagonalActionMulAut groupElement
            profile ∈
          symmetry.gaussianMonoid profile)
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup) :
    (symmetry.gaussianMonoid profile).map
        (symmetry.diagonalActionMulAut
          groupElement).toMonoidHom ≤
      symmetry.gaussianMonoid profile := by
  rw [gaussianMonoid, Submonoid.map_sup]
  apply sup_le
  · rintro value ⟨source, hSource, rfl⟩
    rcases hSource with ⟨unit, rfl⟩
    apply Submonoid.mem_sup_left
    exact
      symmetry.diagonalAction_mem_diagonalUnitSubmonoid
        groupElement unit
  · rw [Submonoid.map_le_iff_le_comap,
      Submonoid.closure_le]
    intro value hValue
    rw [Set.mem_singleton_iff] at hValue
    subst value
    exact profile_stable groupElement

/-- Under profile stability, each transported action maps the Gaussian monoid onto itself. -/
theorem diagonalAction_map_gaussianMonoid_eq
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier)
    (profile_stable :
      ∀ groupElement,
        symmetry.diagonalActionMulAut groupElement
            profile ∈
          symmetry.gaussianMonoid profile)
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup) :
    (symmetry.gaussianMonoid profile).map
        (symmetry.diagonalActionMulAut
          groupElement).toMonoidHom =
      symmetry.gaussianMonoid profile := by
  apply le_antisymm
  · exact
      symmetry.diagonalAction_map_gaussianMonoid_le
        profile profile_stable groupElement
  · intro value hValue
    let inverseValue :=
      symmetry.diagonalActionMulAut
        groupElement⁻¹ value
    have hInverse :
        inverseValue ∈
          symmetry.gaussianMonoid profile := by
      apply
        symmetry.diagonalAction_map_gaussianMonoid_le
          profile profile_stable groupElement⁻¹
      exact ⟨value, hValue, rfl⟩
    refine ⟨inverseValue, hInverse, ?_⟩
    change
      symmetry.diagonalActionMulAut groupElement
          (symmetry.diagonalActionMulAut
            groupElement⁻¹ value) =
        value
    calc
      _ =
          (symmetry.diagonalActionHom groupElement *
            symmetry.diagonalActionHom
              groupElement⁻¹) value :=
        rfl
      _ =
          symmetry.diagonalActionHom
              (groupElement * groupElement⁻¹) value := by
        rw [map_mul]
      _ = value := by simp

/-- The induced automorphism of a profile-stable Gaussian monoid. -/
noncomputable def gaussianMonoidActionMulAut
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier)
    (profile_stable :
      ∀ groupElement,
        symmetry.diagonalActionMulAut groupElement
            profile ∈
          symmetry.gaussianMonoid profile)
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup) :
    MulAut (symmetry.gaussianMonoid profile) :=
  ((symmetry.diagonalActionMulAut
      groupElement).submonoidMap
        (symmetry.gaussianMonoid profile)).trans
    (MulEquiv.submonoidCongr
      (symmetry.diagonalAction_map_gaussianMonoid_eq
        profile profile_stable groupElement))

@[simp]
theorem gaussianMonoidActionMulAut_coe
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier)
    (profile_stable :
      ∀ groupElement,
        symmetry.diagonalActionMulAut groupElement
            profile ∈
          symmetry.gaussianMonoid profile)
    (groupElement :
      (symmetry.pair
        symmetry.baseLabel).actingGroup)
    (value : symmetry.gaussianMonoid profile) :
    ((symmetry.gaussianMonoidActionMulAut
        profile profile_stable groupElement value :
      symmetry.gaussianMonoid profile) :
      ∀ label,
        (symmetry.pair label).monoidCarrier) =
      symmetry.diagonalActionMulAut
        groupElement value :=
  rfl

/-- The natural action on a profile-stable Gaussian monoid. -/
noncomputable def gaussianMonoidActionHom
    (profile :
      ∀ label,
        (symmetry.pair label).monoidCarrier)
    (profile_stable :
      ∀ groupElement,
        symmetry.diagonalActionMulAut groupElement
            profile ∈
          symmetry.gaussianMonoid profile) :
    (symmetry.pair
        symmetry.baseLabel).actingGroup →*
      MulAut (symmetry.gaussianMonoid profile) where
  toFun :=
    symmetry.gaussianMonoidActionMulAut
      profile profile_stable
  map_one' := by
    apply MulEquiv.ext
    intro value
    apply Subtype.ext
    change
      symmetry.diagonalActionHom 1 value =
        value
    rw [map_one]
    rfl
  map_mul' first second := by
    apply MulEquiv.ext
    intro value
    apply Subtype.ext
    change
      symmetry.diagonalActionHom
          (first * second) value =
        symmetry.diagonalActionHom first
          (symmetry.diagonalActionHom second value)
    rw [map_mul]
    rfl

end SourceIUTIISymmetrizingIsomorphisms

/--
A value profile is a simultaneous choice of one theta value at every nonzero
absolute label.
-/
structure SourceIUTIIValueProfile
    {M : Type u}
    (l : PrimeGeFive)
    (thetaValues :
      IUTIIAbsoluteThetaLabel.{u} l → Set M) where
  toFun : IUTIPositiveLabel.{u} l → M
  mem_thetaValues :
    ∀ j,
      toFun j ∈
        thetaValues
          (IUTIIAbsoluteThetaLabel.nonzero
            (IUTIPositiveLabel.signLabel j))

namespace SourceIUTIIValueProfile

variable
  {M : Type u}
  {l : PrimeGeFive}
  {thetaValues :
    IUTIIAbsoluteThetaLabel.{u} l → Set M}

instance :
    CoeFun
      (SourceIUTIIValueProfile l thetaValues)
      (fun _ => IUTIPositiveLabel.{u} l → M) :=
  ⟨SourceIUTIIValueProfile.toFun⟩

/--
A value profile is exactly a dependent choice of one element from every
nonzero absolute-label theta-value fiber.
-/
def equivPi :
    SourceIUTIIValueProfile l thetaValues ≃
      ∀ j : IUTIPositiveLabel.{u} l,
        { value : M //
          value ∈
            thetaValues
              (IUTIIAbsoluteThetaLabel.nonzero
                (IUTIPositiveLabel.signLabel j)) } where
  toFun profile j :=
    ⟨profile j, profile.mem_thetaValues j⟩
  invFun choices :=
    { toFun := fun j => choices j
      mem_thetaValues := fun j => (choices j).2 }
  left_inv profile := by
    cases profile
    rfl
  right_inv choices := by
    funext j
    rfl

/--
Corollary 3.5(ii)'s value-profile count.  If every nonzero label fiber has
cardinality `2l`, then the set of simultaneous profiles has cardinality
`(2l)^(l*)`; the exponent is derived from the actual positive-label type.
-/
theorem natCard_eq_twoEll_pow_lStar
    [∀ j : IUTIPositiveLabel.{u} l,
      Finite
        { value : M //
          value ∈
            thetaValues
              (IUTIIAbsoluteThetaLabel.nonzero
                (IUTIPositiveLabel.signLabel j)) }]
    (fiber_card :
      ∀ j : IUTIPositiveLabel.{u} l,
        Nat.card
            { value : M //
              value ∈
                thetaValues
                  (IUTIIAbsoluteThetaLabel.nonzero
                    (IUTIPositiveLabel.signLabel j)) } =
          2 * l.value) :
    Nat.card (SourceIUTIIValueProfile l thetaValues) =
      (2 * l.value) ^ l.lStar := by
  rw [Nat.card_congr equivPi, Nat.card_pi]
  simp_rw [fiber_card]
  simp [IUTIPositiveLabel, CategoryCapsule.FiniteIndex]

end SourceIUTIIValueProfile

/--
Two value profiles differ coordinatewise by `N`-torsion units.

The unit may depend on the coordinate.  This distinction is required by the
independent `mu_(2l)` indeterminacies in IUT II, Corollary 3.5(ii).
-/
def ValueProfilesDifferByPointwiseTorsion
    {I M : Type u}
    [CommMonoid M]
    (N : ℕ) (first second : I → M) : Prop :=
  ∀ i,
    ∃ unit : Mˣ,
      unit ^ N = 1 ∧
        second i = (unit : M) * first i

namespace ValueProfilesDifferByPointwiseTorsion

variable
  {I M : Type u}
  [CommMonoid M]
  {N : ℕ}
  {first second : I → M}

/-- Coordinatewise `N`-torsion ambiguity disappears after the `N`-th power. -/
theorem pow_eq
    (h :
      ValueProfilesDifferByPointwiseTorsion
        N first second) :
    second ^ N = first ^ N := by
  funext i
  rcases h i with
    ⟨unit, hunit, hsecond⟩
  have hunit_coe :
      (unit : M) ^ N = 1 := by
    simpa using
      congrArg (fun value : Mˣ => (value : M))
        hunit
  change second i ^ N = first i ^ N
  simp [hsecond, mul_pow, hunit_coe]

end ValueProfilesDifferByPointwiseTorsion

/-- A subgroup of units whose elements all have exponent dividing `N`. -/
structure TorsionUnitSubgroup
    (M : Type u)
    [CommMonoid M]
    (N : ℕ) where
  units : Subgroup Mˣ
  pow_eq_one :
    ∀ unit : units,
      (unit : Mˣ) ^ N = 1

namespace TorsionUnitSubgroup

variable
  {M : Type u}
  [CommMonoid M]
  {N : ℕ}

/-- The orbit of a monoid element under multiplication by torsion units. -/
def orbit
    (torsion : TorsionUnitSubgroup M N)
    (base : M) : Set M :=
  { value |
      ∃ unit : torsion.units,
        value = (unit : Mˣ) * base }

/--
Two elements of the same torsion-unit orbit differ by an `N`-torsion unit.
-/
theorem exists_torsionUnit_mul_eq
    (torsion : TorsionUnitSubgroup M N)
    {base first second : M}
    (hfirst : first ∈ torsion.orbit base)
    (hsecond : second ∈ torsion.orbit base) :
    ∃ unit : Mˣ,
      unit ^ N = 1 ∧
        second = (unit : M) * first := by
  rcases hfirst with ⟨firstUnit, rfl⟩
  rcases hsecond with ⟨secondUnit, rfl⟩
  refine
    ⟨(secondUnit : Mˣ) * (firstUnit : Mˣ)⁻¹,
      ?_,
      ?_⟩
  · rw [mul_pow, inv_pow,
      torsion.pow_eq_one secondUnit,
      torsion.pow_eq_one firstUnit]
    simp
  · simp [mul_assoc]

end TorsionUnitSubgroup

/--
A `mu_(2l)`-action realized as multiplication by actual `2l`-torsion units.

This is the algebraic compatibility needed to pass from the continuous
`H¹`-orbits of Corollary 2.8 to the theta-value orbit family used in
Corollary 3.5(ii).
-/
structure SourceIUTIIMultiplicativeTorsionAction
    (l : PrimeGeFive)
    (Mu2l M : Type u)
    [Group Mu2l] [CommGroup M]
    [MulAction Mu2l M] where
  unitEmbedding : Mu2l →* Mˣ
  unitEmbedding_injective :
    Function.Injective unitEmbedding
  unitEmbedding_pow :
    ∀ scalar,
      unitEmbedding scalar ^ (2 * l.value) = 1
  smul_eq_unit_mul :
    ∀ scalar value,
      scalar • value =
        (unitEmbedding scalar : M) * value

/--
A multiplicative `mu`-action by finite-order units, without a common exponent.
This is the action on the infinite-theta orbit in Corollaries 1.12 and 2.8.
-/
structure SourceIUTIIMultiplicativeFiniteOrderAction
    (Mu M : Type u)
    [Group Mu] [CommGroup M]
    [MulAction Mu M] where
  unitEmbedding : Mu →* Mˣ
  unitEmbedding_isOfFinOrder :
    ∀ scalar,
      IsOfFinOrder (unitEmbedding scalar : M)
  smul_eq_unit_mul :
    ∀ scalar value,
      scalar • value =
        (unitEmbedding scalar : M) * value

namespace SourceIUTIIMultiplicativeTorsionAction

variable
  {l : PrimeGeFive}
  {Mu2l M : Type u}
  [Group Mu2l] [CommGroup M]
  [MulAction Mu2l M]

/-- Multiplication by embedded torsion units acts freely on every group element. -/
theorem actionMap_injective
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l M)
    (value : M) :
    Function.Injective
      (fun scalar : Mu2l => scalar • value) := by
  intro first second h
  apply multiplicative.unitEmbedding_injective
  apply Units.ext
  apply mul_right_cancel (b := value)
  simpa only [multiplicative.smul_eq_unit_mul] using h

/-- The exact range of the multiplicative `mu_(2l)`-action in the unit group. -/
def toTorsionUnitSubgroup
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l M) :
    TorsionUnitSubgroup M (2 * l.value) where
  units :=
    multiplicative.unitEmbedding.range
  pow_eq_one := by
    intro unit
    rcases unit with
      ⟨unit, ⟨scalar, hscalar⟩⟩
    change unit ^ (2 * l.value) = 1
    rw [← hscalar]
    exact multiplicative.unitEmbedding_pow scalar

/--
Forget the common `2l` exponent while retaining the fact that every acting
unit has finite order.
-/
def toFiniteOrderAction
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l M) :
    SourceIUTIIMultiplicativeFiniteOrderAction
      Mu2l M where
  unitEmbedding :=
    multiplicative.unitEmbedding
  unitEmbedding_isOfFinOrder := by
    intro scalar
    apply isOfFinOrder_iff_pow_eq_one.mpr
    refine
      ⟨2 * l.value,
        Nat.mul_pos (by omega) l.prime.pos, ?_⟩
    exact congrArg Units.val
      (multiplicative.unitEmbedding_pow scalar)
  smul_eq_unit_mul :=
    multiplicative.smul_eq_unit_mul

end SourceIUTIIMultiplicativeTorsionAction

namespace SourceIUTIIMultiplicativeFiniteOrderAction

variable
  {Mu M : Type u}
  [Group Mu] [CommGroup M]
  [MulAction Mu M]

/--
If a represented orbit is based at the identity, then every value in the
orbit is torsion.
-/
theorem orbitCarrier_subset_torsion
    (multiplicative :
      SourceIUTIIMultiplicativeFiniteOrderAction
        Mu M)
    (orbit : GroupActionOrbit Mu M)
    (representative_eq_one :
      orbit.representative = 1) :
    orbit.carrier ⊆ CommGroup.torsion M := by
  intro value hvalue
  rcases MulAction.mem_orbit_iff.mp hvalue with
    ⟨scalar, hscalar⟩
  rw [← hscalar,
    multiplicative.smul_eq_unit_mul,
    representative_eq_one,
    mul_one]
  exact
    multiplicative.unitEmbedding_isOfFinOrder
      scalar

end SourceIUTIIMultiplicativeFiniteOrderAction

/--
An absolute-label family of theta-value orbits under one fixed torsion-unit
subgroup.
-/
structure SourceIUTIITorsionThetaValueFamily
    (l : PrimeGeFive)
    (M : Type u)
    [CommMonoid M] where
  torsionUnits :
    TorsionUnitSubgroup M (2 * l.value)
  representative :
    IUTIIAbsoluteThetaLabel.{u} l → M

namespace SourceIUTIITorsionThetaValueFamily

variable
  {l : PrimeGeFive}
  {M : Type u}
  [CommMonoid M]

/-- The `mu_(2l)`-orbit at an absolute theta label. -/
def thetaValues
    (family :
      SourceIUTIITorsionThetaValueFamily l M) :
    IUTIIAbsoluteThetaLabel.{u} l → Set M :=
  fun label =>
    family.torsionUnits.orbit
      (family.representative label)

/--
Any two value profiles selected from the same `mu_(2l)`-orbit family differ
coordinatewise by `2l`-torsion.
-/
theorem profiles_differByPointwiseTorsion
    (family :
      SourceIUTIITorsionThetaValueFamily l M)
    (first second :
      SourceIUTIIValueProfile
        l family.thetaValues) :
    ValueProfilesDifferByPointwiseTorsion
      (2 * l.value) first second := by
  intro j
  exact
    family.torsionUnits.exists_torsionUnit_mul_eq
      (first.mem_thetaValues j)
      (second.mem_thetaValues j)

/-- The orbit family has a canonical value profile given by its representatives. -/
def representativeProfile
    (family :
      SourceIUTIITorsionThetaValueFamily l M) :
    SourceIUTIIValueProfile
      l family.thetaValues where
  toFun := fun label =>
    family.representative
      (IUTIIAbsoluteThetaLabel.nonzero
        (IUTIPositiveLabel.signLabel label))
  mem_thetaValues := by
    intro label
    refine
      ⟨⟨1, family.torsionUnits.units.one_mem⟩, ?_⟩
    simp

end SourceIUTIITorsionThetaValueFamily

namespace SourceIUTIIMultiplicativeTorsionAction

variable
  {l : PrimeGeFive}
  {Mu2l M : Type u}
  [Group Mu2l] [CommGroup M]
  [MulAction Mu2l M]

/--
Derive the theta-value torsion family from represented `mu_(2l)`-orbits.
-/
def toTorsionThetaValueFamily
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l M)
    (thetaOrbits :
      IUTIIAbsoluteThetaLabel.{u} l →
        GroupActionOrbit Mu2l M) :
    SourceIUTIITorsionThetaValueFamily l M where
  torsionUnits :=
    multiplicative.toTorsionUnitSubgroup
  representative := fun label =>
    (thetaOrbits label).representative

/--
The derived multiplicative torsion orbit is exactly the original group-action
orbit at every absolute theta label.
-/
theorem thetaValues_eq_orbitCarriers
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l M)
    (thetaOrbits :
      IUTIIAbsoluteThetaLabel.{u} l →
        GroupActionOrbit Mu2l M)
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (multiplicative.toTorsionThetaValueFamily
        thetaOrbits).thetaValues label =
      (thetaOrbits label).carrier := by
  ext value
  constructor
  · rintro ⟨unit, hvalue⟩
    rcases unit.2 with
      ⟨scalar, hscalar⟩
    apply MulAction.mem_orbit_iff.mpr
    refine ⟨scalar, ?_⟩
    rw [multiplicative.smul_eq_unit_mul]
    rw [hscalar]
    exact hvalue.symm
  · intro hvalue
    rcases MulAction.mem_orbit_iff.mp hvalue with
      ⟨scalar, hscalar⟩
    refine
      ⟨⟨multiplicative.unitEmbedding scalar,
          ⟨scalar, rfl⟩⟩, ?_⟩
    calc
      value =
          scalar •
            (thetaOrbits label).representative :=
        hscalar.symm
      _ =
          (multiplicative.unitEmbedding scalar : M) *
            (thetaOrbits label).representative :=
        multiplicative.smul_eq_unit_mul
          scalar (thetaOrbits label).representative

end SourceIUTIIMultiplicativeTorsionAction

namespace SourceIUTIIThetaEvaluationOrbits

variable
  {G A Mu2l Mu : Type u}
  [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
  [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
  [IsMulCommutative A]
  {l : PrimeGeFive}
  {action : ContinuousGroupAction G A}
  [Group Mu2l] [Group Mu]
  [MulAction Mu2l (ContinuousH1Germ action)]
  [MulAction Mu (ContinuousH1Germ action)]

/--
The Corollary 3.5 theta-value family derived from the evaluated continuous
`H¹` theta orbits and their multiplicative torsion realization.
-/
def toTorsionThetaValueFamily
    (orbits :
      SourceIUTIIThetaEvaluationOrbits
        (G := G) (A := A)
        (Mu2l := Mu2l) (Mu := Mu)
        l action)
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l (ContinuousH1Germ action)) :
    SourceIUTIITorsionThetaValueFamily
      l (ContinuousH1Germ action) :=
  multiplicative.toTorsionThetaValueFamily
    orbits.theta

theorem toTorsionThetaValueFamily_thetaValues
    (orbits :
      SourceIUTIIThetaEvaluationOrbits
        (G := G) (A := A)
        (Mu2l := Mu2l) (Mu := Mu)
        l action)
    (multiplicative :
      SourceIUTIIMultiplicativeTorsionAction
        l Mu2l (ContinuousH1Germ action))
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    (orbits.toTorsionThetaValueFamily
        multiplicative).thetaValues label =
      (orbits.theta label).carrier :=
  multiplicative.thetaValues_eq_orbitCarriers
    orbits.theta label

end SourceIUTIIThetaEvaluationOrbits

/-- The diagonal homomorphism from units into a direct product of monoids. -/
def diagonalUnitsHom
    {I M : Type u}
    [Monoid M] :
    Mˣ →* (I → M) where
  toFun unit _ := unit
  map_one' := by
    funext
    rfl
  map_mul' _ _ := by
    funext
    rfl

/-- The diagonal constant-unit submonoid in a direct product. -/
def diagonalConstantUnitSubmonoid
    {I M : Type u}
    [Monoid M] :
    Submonoid (I → M) :=
  MonoidHom.mrange (diagonalUnitsHom (I := I) (M := M))

/-- The natural-power submonoid generated by one value profile. -/
def valueProfileNaturalPowers
    {I M : Type u}
    [Monoid M]
    (profile : I → M) :
    Submonoid (I → M) :=
  Submonoid.closure {profile}

/--
The finite Gaussian monoid
`Psi_cns^x_<I> * profile^N` of IUT II, Corollary 3.5(ii).
-/
def sourceGaussianMonoid
    {I M : Type u}
    [Monoid M]
    (profile : I → M) :
    Submonoid (I → M) :=
  diagonalConstantUnitSubmonoid ⊔
    valueProfileNaturalPowers profile

namespace sourceGaussianMonoid

variable
  {I M : Type u}
  [Monoid M]
  (profile : I → M)

theorem profile_mem :
    profile ∈ sourceGaussianMonoid profile := by
  apply Submonoid.mem_sup_right
  exact Submonoid.subset_closure (Set.mem_singleton profile)

theorem diagonal_unit_mem (unit : Mˣ) :
    diagonalUnitsHom (I := I) unit ∈
      sourceGaussianMonoid profile := by
  apply Submonoid.mem_sup_left
  exact ⟨unit, rfl⟩

theorem profile_pow_mem (n : ℕ) :
    profile ^ n ∈ sourceGaussianMonoid profile :=
  (sourceGaussianMonoid profile).pow_mem
    (profile_mem profile) n

end sourceGaussianMonoid

/--
The submonoid generated by diagonal units and the powers
`profile^(N * n)`.
-/
def sourceScaledGaussianMonoid
    {I M : Type u}
    [CommMonoid M]
    (N : ℕ) (profile : I → M) :
    Submonoid (I → M) :=
  sourceGaussianMonoid (profile ^ N)

/--
The profile-independent `2l`-multiple submonoid
`Psi_(2l * xi)` of IUT II, Corollary 3.5(ii).
-/
def sourceTwoEllGaussianSubmonoid
    {I M : Type u}
    [CommMonoid M]
    (l : PrimeGeFive) (profile : I → M) :
    Submonoid (I → M) :=
  sourceScaledGaussianMonoid
    (2 * l.value) profile

theorem sourceTwoEllGaussianSubmonoid_eq
    {I M : Type u}
    [CommMonoid M]
    (l : PrimeGeFive)
    {first second : I → M}
    (h :
      ValueProfilesDifferByPointwiseTorsion
        (2 * l.value) first second) :
    sourceTwoEllGaussianSubmonoid l first =
      sourceTwoEllGaussianSubmonoid l second := by
  unfold sourceTwoEllGaussianSubmonoid
    sourceScaledGaussianMonoid
  rw [h.pow_eq]

/--
The `2l`-multiple Gaussian submonoid is independent of the chosen value
profile in a fixed `mu_(2l)`-orbit family.
-/
theorem SourceIUTIITorsionThetaValueFamily.twoEllGaussianSubmonoid_eq
    {M : Type u}
    [CommMonoid M]
    (l : PrimeGeFive)
    (family :
      SourceIUTIITorsionThetaValueFamily l M)
    (first second :
      SourceIUTIIValueProfile
        l family.thetaValues) :
    sourceTwoEllGaussianSubmonoid l first =
      sourceTwoEllGaussianSubmonoid l second :=
  sourceTwoEllGaussianSubmonoid_eq l
    (family.profiles_differByPointwiseTorsion
      first second)

/--
The common `2l`-multiple Gaussian submonoid attached to the entire theta-value
orbit family, named without choosing an arbitrary value profile.
-/
def SourceIUTIITorsionThetaValueFamily.profileIndependentTwoEllGaussianSubmonoid
    {M : Type u}
    [CommMonoid M]
    (l : PrimeGeFive)
    (family :
      SourceIUTIITorsionThetaValueFamily l M) :
    Submonoid (IUTIPositiveLabel.{u} l → M) :=
  sourceTwoEllGaussianSubmonoid l
    family.representativeProfile

/--
Every value profile selected from the orbit family produces the same
`2l`-multiple Gaussian submonoid as the profile-independent object.
-/
theorem SourceIUTIITorsionThetaValueFamily.twoEllGaussianSubmonoid_eq_profileIndependent
    {M : Type u}
    [CommMonoid M]
    (l : PrimeGeFive)
    (family :
      SourceIUTIITorsionThetaValueFamily l M)
    (profile :
      SourceIUTIIValueProfile
        l family.thetaValues) :
    sourceTwoEllGaussianSubmonoid l profile =
      family.profileIndependentTwoEllGaussianSubmonoid l :=
  family.twoEllGaussianSubmonoid_eq
    l profile family.representativeProfile

/--
A choice of one positive integral root of a value profile at every index.

The source only determines these roots up to torsion; that ambiguity is
recorded separately below rather than hidden by a uniqueness field.
-/
structure ValueProfileRootSystem
    {I M : Type u}
    [CommMonoid M]
    (profile : I → M) where
  root : ℕ+ → I → M
  root_pow :
    ∀ n,
      root n ^ n.val = profile

/-- Two candidate `N`-th roots differ by diagonal `N`-torsion. -/
def ValueProfilesDifferByDiagonalTorsion
    {I M : Type u}
    [CommMonoid M]
    (N : ℕ+) (first second : I → M) : Prop :=
  ∃ unit : Mˣ,
    unit ^ N.val = 1 ∧
      second =
        diagonalUnitsHom (I := I) unit * first

/--
Two positive-integral root systems differ, at each denominator, by the
diagonal torsion ambiguity stated in IUT II, Corollary 3.5(ii).
-/
def ValueProfileRootSystemsDifferByDiagonalTorsion
    {I M : Type u}
    [CommMonoid M]
    {profile : I → M}
    (first second : ValueProfileRootSystem profile) : Prop :=
  ∀ N,
    ValueProfilesDifferByDiagonalTorsion
      N (first.root N) (second.root N)

/-- The submonoid generated by every chosen positive integral root. -/
def valueProfileRationalPowers
    {I M : Type u}
    [CommMonoid M]
    {profile : I → M}
    (roots : ValueProfileRootSystem profile) :
    Submonoid (I → M) :=
  Submonoid.closure (Set.range roots.root)

/--
The rational-root Gaussian monoid
`Psi_cns^x_<I> * profile^(Q>=0)`.
-/
def sourceInfiniteGaussianMonoid
    {I M : Type u}
    [CommMonoid M]
    {profile : I → M}
    (roots : ValueProfileRootSystem profile) :
    Submonoid (I → M) :=
  diagonalConstantUnitSubmonoid ⊔
    valueProfileRationalPowers roots

namespace sourceInfiniteGaussianMonoid

variable
  {I M : Type u}
  [CommMonoid M]
  {profile : I → M}
  (roots : ValueProfileRootSystem profile)

theorem root_mem (N : ℕ+) :
    roots.root N ∈ sourceInfiniteGaussianMonoid roots := by
  apply Submonoid.mem_sup_right
  exact Submonoid.subset_closure ⟨N, rfl⟩

theorem diagonal_unit_mem (unit : Mˣ) :
    diagonalUnitsHom (I := I) unit ∈
      sourceInfiniteGaussianMonoid roots := by
  apply Submonoid.mem_sup_left
  exact ⟨unit, rfl⟩

theorem profile_mem (N : ℕ+) :
    profile ∈ sourceInfiniteGaussianMonoid roots := by
  have hroot :
      roots.root N ^ N.val ∈
        sourceInfiniteGaussianMonoid roots :=
    (sourceInfiniteGaussianMonoid roots).pow_mem
      (root_mem roots N) N.val
  simpa only [roots.root_pow N] using hroot

end sourceInfiniteGaussianMonoid

/--
Changing every chosen root by its permitted diagonal torsion ambiguity does
not change the rational-root Gaussian monoid.
-/
theorem sourceInfiniteGaussianMonoid_eq_of_differByDiagonalTorsion
    {I M : Type u}
    [CommMonoid M]
    {profile : I → M}
    (first second :
      ValueProfileRootSystem profile)
    (h :
      ValueProfileRootSystemsDifferByDiagonalTorsion
        first second) :
    sourceInfiniteGaussianMonoid first =
      sourceInfiniteGaussianMonoid second := by
  apply le_antisymm
  · change
      diagonalConstantUnitSubmonoid ⊔
          valueProfileRationalPowers first ≤
        sourceInfiniteGaussianMonoid second
    apply sup_le
    · intro value hvalue
      exact Submonoid.mem_sup_left hvalue
    · rw [valueProfileRationalPowers,
        Submonoid.closure_le]
      intro root hroot
      rcases hroot with ⟨N, rfl⟩
      rcases h N with
        ⟨unit, _hunit, hsecond⟩
      have hfirst :
          first.root N =
            diagonalUnitsHom (I := I) unit⁻¹ *
              second.root N := by
        funext index
        have hcoordinate :=
          congrFun hsecond index
        change second.root N index =
          (unit : M) * first.root N index at hcoordinate
        change
          first.root N index =
            ((unit⁻¹ : Mˣ) : M) *
              second.root N index
        rw [hcoordinate]
        simp
      rw [hfirst]
      exact
        (sourceInfiniteGaussianMonoid second).mul_mem
          (sourceInfiniteGaussianMonoid.diagonal_unit_mem
            second unit⁻¹)
          (sourceInfiniteGaussianMonoid.root_mem
            second N)
  · change
      diagonalConstantUnitSubmonoid ⊔
          valueProfileRationalPowers second ≤
        sourceInfiniteGaussianMonoid first
    apply sup_le
    · intro value hvalue
      exact Submonoid.mem_sup_left hvalue
    · rw [valueProfileRationalPowers,
        Submonoid.closure_le]
      intro root hroot
      rcases hroot with ⟨N, rfl⟩
      rcases h N with
        ⟨unit, _hunit, hsecond⟩
      rw [hsecond]
      exact
        (sourceInfiniteGaussianMonoid first).mul_mem
          (sourceInfiniteGaussianMonoid.diagonal_unit_mem
            first unit)
          (sourceInfiniteGaussianMonoid.root_mem
            first N)

/--
An actual `q^(j^2)` value profile on the ordered representatives
`j = 1, ..., l*`.
-/
def thetaPowerValueProfile
    {M : Type u}
    [Monoid M]
    (l : PrimeGeFive) (q : M) :
    IUTIPositiveLabel.{u} l → M :=
  fun j => q ^ (IUTIPositiveLabel.representative j) ^ 2

@[simp]
theorem thetaPowerValueProfile_apply
    {M : Type u}
    [Monoid M]
    (l : PrimeGeFive) (q : M)
    (j : IUTIPositiveLabel.{u} l) :
    thetaPowerValueProfile l q j =
      q ^ (IUTIPositiveLabel.representative j) ^ 2 :=
  rfl

/-- The Gaussian monoid generated by all actual `q^(j^2)` theta values. -/
def thetaPowerGaussianMonoid
    {M : Type u}
    [Monoid M]
    (l : PrimeGeFive) (q : M) :
    Submonoid (IUTIPositiveLabel.{u} l → M) :=
  sourceGaussianMonoid (thetaPowerValueProfile l q)

theorem thetaPowerProfile_mem_gaussian
    {M : Type u}
    [Monoid M]
    (l : PrimeGeFive) (q : M) :
    thetaPowerValueProfile l q ∈
      thetaPowerGaussianMonoid l q :=
  sourceGaussianMonoid.profile_mem
    (thetaPowerValueProfile l q)

end Iut
