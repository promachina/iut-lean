/-!
# Source objects for IUT II theta evaluation

This module starts the source-faithful replacement for the old real-degree
pilot model.  Theta values live in continuous `H^1` germs and are retained as
orbits under actual group actions.  Independently, the algebraic Gaussian
monoid generated by a value profile is constructed as a submonoid of a direct
product, exactly in the shape used in IUT II, Corollary 3.5(ii).

The two restriction operations are derived from actual continuous group
homomorphisms and equivariance proofs.  Constructing those groups, maps, and
actions from a mono-theta projective system, together with the symmetrizing
isomorphisms, source construction of the root choices, and zero-label
splittings, remains an explicit ledger obligation.
-/

namespace Iut

universe u

open scoped nonZeroDivisors

/--
The label set `|F_l|`: the zero label together with the nonzero labels modulo
the sign involution.
-/
abbrev IUTIIAbsoluteThetaLabel (l : PrimeGeFive) : Type u :=
  Option
    (ULift.{u}
      (EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value)))

namespace IUTIIAbsoluteThetaLabel

variable {l : PrimeGeFive}

/-- The zero element of `|F_l|`. -/
def zero : IUTIIAbsoluteThetaLabel.{u} l :=
  none

/-- Include a nonzero sign label into `|F_l|`. -/
def nonzero
    (label :
      EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    IUTIIAbsoluteThetaLabel.{u} l :=
  some (ULift.up label)

end IUTIIAbsoluteThetaLabel

/-- An orbit represented by an element of a genuine group action. -/
structure GroupActionOrbit
    (S X : Type u)
    [Group S] [MulAction S X] where
  representative : X

namespace GroupActionOrbit

variable
  {S X : Type u}
  [Group S] [MulAction S X]

/-- The carrier of the represented orbit. -/
def carrier (orbit : GroupActionOrbit S X) : Set X :=
  MulAction.orbit S orbit.representative

theorem representative_mem
    (orbit : GroupActionOrbit S X) :
    orbit.representative ∈ orbit.carrier :=
  ⟨1, by simp⟩

/--
When the action map at the representative is injective, the acting group is
equivalent to the represented orbit itself.
-/
noncomputable def groupEquivCarrier
    (orbit : GroupActionOrbit S X)
    (action_injective :
      Function.Injective
        (fun scalar : S =>
          scalar • orbit.representative)) :
    S ≃ orbit.carrier :=
  Equiv.ofBijective
    (fun scalar =>
      ⟨scalar • orbit.representative, scalar, rfl⟩)
    ⟨by
      intro first second h
      apply action_injective
      exact congrArg Subtype.val h,
    by
      rintro ⟨value, scalar, hscalar⟩
      refine ⟨scalar, ?_⟩
      apply Subtype.ext
      exact hscalar⟩

/-- A free represented orbit has the cardinality of its acting group. -/
theorem natCard_carrier_eq_group
    (orbit : GroupActionOrbit S X)
    (action_injective :
      Function.Injective
        (fun scalar : S =>
          scalar • orbit.representative)) :
    Nat.card orbit.carrier = Nat.card S :=
  Nat.card_congr
    (orbit.groupEquivCarrier action_injective).symm

end GroupActionOrbit

/-- A map that commutes with the action defining two orbit spaces. -/
structure EquivariantOrbitMap
    (S X Y : Type u)
    [Group S] [MulAction S X] [MulAction S Y] where
  toFun : X → Y
  map_smul :
    ∀ (s : S) (x : X),
      toFun (s • x) = s • toFun x

namespace EquivariantOrbitMap

variable
  {S X Y : Type u}
  [Group S] [MulAction S X] [MulAction S Y]

/-- Map a represented orbit through an equivariant map. -/
def map
    (f : EquivariantOrbitMap S X Y)
    (orbit : GroupActionOrbit S X) :
    GroupActionOrbit S Y :=
  ⟨f.toFun orbit.representative⟩

theorem carrier_map
    (f : EquivariantOrbitMap S X Y)
    (orbit : GroupActionOrbit S X) :
    (f.map orbit).carrier =
      f.toFun '' orbit.carrier := by
  ext y
  constructor
  · rintro ⟨s, rfl⟩
    exact
      ⟨s • orbit.representative,
        ⟨s, rfl⟩,
        f.map_smul s orbit.representative⟩
  · rintro ⟨x, ⟨s, rfl⟩, rfl⟩
    exact
      ⟨s, (f.map_smul s orbit.representative).symm⟩

/-- An equivariant map descends to the quotients by the source and target actions. -/
def onOrbitQuotients
    (f : EquivariantOrbitMap S X Y) :
    MulAction.orbitRel.Quotient S X →
      MulAction.orbitRel.Quotient S Y :=
  Quotient.map f.toFun
    (by
      intro first second h
      change
        MulAction.orbitRel S X first second at h
      change
        MulAction.orbitRel S Y
          (f.toFun first) (f.toFun second)
      rw [MulAction.orbitRel_apply] at h ⊢
      rcases h with ⟨s, hs⟩
      refine ⟨s, ?_⟩
      calc
        s • f.toFun second =
            f.toFun (s • second) :=
          (f.map_smul s second).symm
        _ = f.toFun first :=
          congrArg f.toFun hs)

@[simp]
theorem onOrbitQuotients_mk
    (f : EquivariantOrbitMap S X Y)
    (value : X) :
    f.onOrbitQuotients
        (Quotient.mk'' value) =
      Quotient.mk'' (f.toFun value) :=
  rfl

end EquivariantOrbitMap

/--
The product action encoding two independent copies of the same conjugacy
group: the first acts only on the inertia choice, the second only on the
ambient-subgroup choice.
-/
instance independentConjugacyMulAction
    {Conjugacy InertiaChoice AmbientChoice : Type u}
    [Monoid Conjugacy]
    [MulAction Conjugacy InertiaChoice]
    [MulAction Conjugacy AmbientChoice] :
    MulAction (Conjugacy × Conjugacy)
      (InertiaChoice × AmbientChoice) where
  smul conjugations choices :=
    (conjugations.1 • choices.1,
      conjugations.2 • choices.2)
  one_smul choices := by
    rcases choices with ⟨inertia, ambient⟩
    change (1 • inertia, 1 • ambient) =
      (inertia, ambient)
    rw [one_smul, one_smul]
  mul_smul first second choices := by
    rcases first with ⟨firstInertia, firstAmbient⟩
    rcases second with
      ⟨secondInertia, secondAmbient⟩
    rcases choices with ⟨inertia, ambient⟩
    change
      ((firstInertia * secondInertia) • inertia,
        (firstAmbient * secondAmbient) • ambient) =
      (firstInertia • secondInertia • inertia,
        firstAmbient • secondAmbient • ambient)
    rw [mul_smul, mul_smul]

/--
The two theta-value orbit families in IUT II, Corollary 2.8(i), after the
restriction to decomposition groups.

Indexing by `IUTIIAbsoluteThetaLabel` makes the paper's assertion that the
result depends only on `|t|` part of the type.
-/
structure SourceIUTIIThetaEvaluationOrbits
    {G A Mu2l Mu : Type u}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (l : PrimeGeFive)
    (action : ContinuousGroupAction G A)
    [Group Mu2l]
    [Group Mu]
    [MulAction Mu2l (ContinuousH1Germ action)]
    [MulAction Mu (ContinuousH1Germ action)] where
  theta :
    IUTIIAbsoluteThetaLabel.{u} l →
      GroupActionOrbit Mu2l
        (ContinuousH1Germ action)
  infiniteTheta :
    IUTIIAbsoluteThetaLabel.{u} l →
      GroupActionOrbit Mu
        (ContinuousH1Germ action)

/--
The defining relation for `infinity-theta` in IUT II, Proposition 1.4: an
element belongs to the infinite-theta set exactly when some positive power is
a theta value up to torsion.
-/
def SourceIUTIIInfiniteThetaRelation
    {G A Mu2l Mu : Type u}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    [IsMulCommutative A]
    {l : PrimeGeFive}
    {action : ContinuousGroupAction G A}
    [Group Mu2l] [Group Mu]
    [MulAction Mu2l (ContinuousH1Germ action)]
    [MulAction Mu (ContinuousH1Germ action)]
    (orbits :
      SourceIUTIIThetaEvaluationOrbits
        (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
        l action) : Prop :=
  ∀ label value,
    value ∈ (orbits.infiniteTheta label).carrier ↔
      ∃ exponent : ℕ+,
        ∃ theta,
          theta ∈ (orbits.theta label).carrier ∧
            ∃ torsion,
              torsion ∈
                  CommGroup.torsion
                    (ContinuousH1Germ action) ∧
                value ^ exponent.val =
                  theta * torsion

/--
The independent-conjugacy equivariance required by IUT II, Corollary 2.8(ii).

The two copies of `Conjugacy` act separately on the inertia choice and the
ambient-subgroup choice.  The output is an actual family of theta and
infinite-theta `H¹` orbits.  Constructing this action and evaluation from a
mono-theta projective system remains a separate source obligation.
-/
structure SourceIUTIIIndependentConjugacyEvaluationAlgorithm
    {Conjugacy InertiaChoice AmbientChoice G A Mu2l Mu :
      Type u}
    [Group Conjugacy]
    [MulAction Conjugacy InertiaChoice]
    [MulAction Conjugacy AmbientChoice]
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (l : PrimeGeFive)
    (action : ContinuousGroupAction G A)
    [Group Mu2l] [Group Mu]
    [MulAction Mu2l (ContinuousH1Germ action)]
    [MulAction Mu (ContinuousH1Germ action)]
    [MulAction (Conjugacy × Conjugacy)
      (SourceIUTIIThetaEvaluationOrbits
        (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
        l action)] where
  evaluate :
    InertiaChoice × AmbientChoice →
      SourceIUTIIThetaEvaluationOrbits
        (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
        l action
  independent_conjugacy_equivariant :
    ∀ (conjugations : Conjugacy × Conjugacy)
        (choices : InertiaChoice × AmbientChoice),
      evaluate (conjugations • choices) =
        conjugations • evaluate choices

namespace SourceIUTIIIndependentConjugacyEvaluationAlgorithm

variable
  {Conjugacy InertiaChoice AmbientChoice G A Mu2l Mu :
    Type u}
  [Group Conjugacy]
  [MulAction Conjugacy InertiaChoice]
  [MulAction Conjugacy AmbientChoice]
  [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
  [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
  {l : PrimeGeFive}
  {action : ContinuousGroupAction G A}
  [Group Mu2l] [Group Mu]
  [MulAction Mu2l (ContinuousH1Germ action)]
  [MulAction Mu (ContinuousH1Germ action)]
  [MulAction (Conjugacy × Conjugacy)
    (SourceIUTIIThetaEvaluationOrbits
      (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
      l action)]

variable
  (algorithm :
    SourceIUTIIIndependentConjugacyEvaluationAlgorithm
      (Conjugacy := Conjugacy)
      (InertiaChoice := InertiaChoice)
      (AmbientChoice := AmbientChoice)
      (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
      l action)

/-- Corollary 2.8(ii) evaluation as an equivariant map for the product action. -/
def toEquivariantOrbitMap :
    EquivariantOrbitMap
      (Conjugacy × Conjugacy)
      (InertiaChoice × AmbientChoice)
      (SourceIUTIIThetaEvaluationOrbits
        (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
        l action) where
  toFun := algorithm.evaluate
  map_smul :=
    algorithm.independent_conjugacy_equivariant

/--
The evaluation algorithm on independent-conjugacy classes, derived from its
two-variable equivariance.
-/
def onIndependentConjugacyClasses :
    MulAction.orbitRel.Quotient
        (Conjugacy × Conjugacy)
        (InertiaChoice × AmbientChoice) →
      MulAction.orbitRel.Quotient
        (Conjugacy × Conjugacy)
        (SourceIUTIIThetaEvaluationOrbits
          (G := G) (A := A) (Mu2l := Mu2l) (Mu := Mu)
          l action) :=
  algorithm.toEquivariantOrbitMap.onOrbitQuotients

end SourceIUTIIIndependentConjugacyEvaluationAlgorithm

/--
The two restriction operations in IUT II, Corollary 2.8(i).

The first and second outputs are derived by restricting actual continuous
`H^1` germs.  Equivariance records precisely the compatibility needed to map
the `mu_(2l)`- and `mu`-orbits.  Construction of the three paper groups, the
two homomorphisms, and these equivariance proofs from a mono-theta projective
system remains a source obligation.
-/
structure SourceIUTIICorollary28RestrictionStages
    {G H K A Mu2l Mu : Type u}
    [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [Group H] [TopologicalSpace H] [IsTopologicalGroup H]
    [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (l : PrimeGeFive)
    (action : ContinuousGroupAction G A)
    (firstRestriction : H →ₜ* G)
    (secondRestriction : K →ₜ* H)
    [Group Mu2l] [Group Mu]
    [MulAction Mu2l (ContinuousH1Germ action)]
    [MulAction Mu
      (ContinuousH1Germ action)]
    [MulAction Mu2l
      (ContinuousH1Germ (action.comap firstRestriction))]
    [MulAction Mu
      (ContinuousH1Germ (action.comap firstRestriction))]
    [MulAction Mu2l
      (ContinuousH1Germ
        ((action.comap firstRestriction).comap
          secondRestriction))]
    [MulAction Mu
      (ContinuousH1Germ
        ((action.comap firstRestriction).comap
          secondRestriction))] where
  ambient :
    SourceIUTIIThetaEvaluationOrbits
      (G := G) (A := A)
      (Mu2l := Mu2l) (Mu := Mu)
      l action
  first_theta_equivariant :
    ∀ (s : Mu2l)
        (value : ContinuousH1Germ action),
      ContinuousH1Germ.restrict firstRestriction
          (s • value) =
        s • ContinuousH1Germ.restrict firstRestriction value
  first_infiniteTheta_equivariant :
    ∀ (s : Mu)
        (value : ContinuousH1Germ action),
      ContinuousH1Germ.restrict firstRestriction
          (s • value) =
        s • ContinuousH1Germ.restrict firstRestriction value
  second_theta_equivariant :
    ∀ (s : Mu2l)
        (value :
          ContinuousH1Germ
            (action.comap firstRestriction)),
      ContinuousH1Germ.restrict secondRestriction
          (s • value) =
        s • ContinuousH1Germ.restrict secondRestriction value
  second_infiniteTheta_equivariant :
    ∀ (s : Mu)
        (value :
          ContinuousH1Germ
            (action.comap firstRestriction)),
      ContinuousH1Germ.restrict secondRestriction
          (s • value) =
        s • ContinuousH1Germ.restrict secondRestriction value

namespace SourceIUTIICorollary28RestrictionStages

variable
  {G H K A Mu2l Mu : Type u}
  [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
  [Group H] [TopologicalSpace H] [IsTopologicalGroup H]
  [Group K] [TopologicalSpace K] [IsTopologicalGroup K]
  [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
  {l : PrimeGeFive}
  {action : ContinuousGroupAction G A}
  {firstRestriction : H →ₜ* G}
  {secondRestriction : K →ₜ* H}
  [Group Mu2l] [Group Mu]
  [MulAction Mu2l (ContinuousH1Germ action)]
  [MulAction Mu
    (ContinuousH1Germ action)]
  [MulAction Mu2l
    (ContinuousH1Germ (action.comap firstRestriction))]
  [MulAction Mu
    (ContinuousH1Germ (action.comap firstRestriction))]
  [MulAction Mu2l
    (ContinuousH1Germ
      ((action.comap firstRestriction).comap
        secondRestriction))]
  [MulAction Mu
    (ContinuousH1Germ
      ((action.comap firstRestriction).comap
        secondRestriction))]

variable
  (stages :
    SourceIUTIICorollary28RestrictionStages
      (G := G) (H := H) (K := K) (A := A)
      (Mu2l := Mu2l) (Mu := Mu)
      l action firstRestriction secondRestriction)

/-- The first restriction as an equivariant map for theta-value orbits. -/
def firstThetaMap :
    EquivariantOrbitMap Mu2l
      (ContinuousH1Germ action)
      (ContinuousH1Germ
        (action.comap firstRestriction)) where
  toFun :=
    ContinuousH1Germ.restrict firstRestriction
  map_smul :=
    stages.first_theta_equivariant

/-- The first restriction as an equivariant map for infinite-theta orbits. -/
def firstInfiniteThetaMap :
    EquivariantOrbitMap Mu
      (ContinuousH1Germ action)
      (ContinuousH1Germ
        (action.comap firstRestriction)) where
  toFun :=
    ContinuousH1Germ.restrict firstRestriction
  map_smul :=
    stages.first_infiniteTheta_equivariant

/-- The first restricted family of theta and infinite-theta orbits. -/
def afterFirst :
    SourceIUTIIThetaEvaluationOrbits
      (G := H) (A := A)
      (Mu2l := Mu2l) (Mu := Mu)
      l (action.comap firstRestriction) where
  theta := fun label =>
    (stages.firstThetaMap).map
      (stages.ambient.theta label)
  infiniteTheta := fun label =>
    (stages.firstInfiniteThetaMap).map
      (stages.ambient.infiniteTheta label)

/-- The second restriction as an equivariant map for theta-value orbits. -/
def secondThetaMap :
    EquivariantOrbitMap Mu2l
      (ContinuousH1Germ
        (action.comap firstRestriction))
      (ContinuousH1Germ
        ((action.comap firstRestriction).comap
          secondRestriction)) where
  toFun :=
    ContinuousH1Germ.restrict secondRestriction
  map_smul :=
    stages.second_theta_equivariant

/-- The second restriction as an equivariant map for infinite-theta orbits. -/
def secondInfiniteThetaMap :
    EquivariantOrbitMap Mu
      (ContinuousH1Germ
        (action.comap firstRestriction))
      (ContinuousH1Germ
        ((action.comap firstRestriction).comap
          secondRestriction)) where
  toFun :=
    ContinuousH1Germ.restrict secondRestriction
  map_smul :=
    stages.second_infiniteTheta_equivariant

/--
The final `|F_l|`-indexed orbit families after the two paper restriction
operations.
-/
def afterSecond :
    SourceIUTIIThetaEvaluationOrbits
      (G := K) (A := A)
      (Mu2l := Mu2l) (Mu := Mu)
      l
      ((action.comap firstRestriction).comap
        secondRestriction) where
  theta := fun label =>
    (stages.secondThetaMap).map
      ((stages.afterFirst).theta label)
  infiniteTheta := fun label =>
    (stages.secondInfiniteThetaMap).map
      ((stages.afterFirst).infiniteTheta label)

@[simp]
theorem afterSecond_theta_representative
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    ((stages.afterSecond).theta label).representative =
      ContinuousH1Germ.restrict secondRestriction
        (ContinuousH1Germ.restrict firstRestriction
          (stages.ambient.theta label).representative) :=
  rfl

@[simp]
theorem afterSecond_infiniteTheta_representative
    (label : IUTIIAbsoluteThetaLabel.{u} l) :
    ((stages.afterSecond).infiniteTheta label).representative =
      ContinuousH1Germ.restrict secondRestriction
        (ContinuousH1Germ.restrict firstRestriction
          (stages.ambient.infiniteTheta label).representative) :=
  rfl

/--
The composite of the two Corollary 2.8 restriction operations on abelian
continuous `H¹` germs.
-/
def totalRestrictionMonoidHom
    [IsMulCommutative A] :
    ContinuousH1Germ action →*
      ContinuousH1Germ
        ((action.comap firstRestriction).comap
          secondRestriction) :=
  (ContinuousH1Germ.restrictMonoidHom
    secondRestriction).comp
      (ContinuousH1Germ.restrictMonoidHom
        firstRestriction)

@[simp]
theorem totalRestrictionMonoidHom_apply
    [IsMulCommutative A]
    (value : ContinuousH1Germ action) :
    totalRestrictionMonoidHom
        (action := action)
        (firstRestriction := firstRestriction)
        (secondRestriction := secondRestriction)
        value =
      ContinuousH1Germ.restrict secondRestriction
        (ContinuousH1Germ.restrict
          firstRestriction value) :=
  rfl

/-- The composite restriction sends every ambient theta-orbit value into the final orbit. -/
theorem totalRestriction_mem_afterSecond_theta_carrier
    [IsMulCommutative A]
    (label : IUTIIAbsoluteThetaLabel.{u} l)
    {value : ContinuousH1Germ action}
    (hvalue :
      value ∈
        (stages.ambient.theta label).carrier) :
    totalRestrictionMonoidHom
        (action := action)
        (firstRestriction := firstRestriction)
        (secondRestriction := secondRestriction)
        value ∈
      ((stages.afterSecond).theta label).carrier := by
  have hfirst :
      ContinuousH1Germ.restrict
          firstRestriction value ∈
        ((stages.afterFirst).theta label).carrier := by
    change
      stages.firstThetaMap.toFun value ∈
        (stages.firstThetaMap.map
          (stages.ambient.theta label)).carrier
    rw [EquivariantOrbitMap.carrier_map]
    exact ⟨value, hvalue, rfl⟩
  change
    stages.secondThetaMap.toFun
        (ContinuousH1Germ.restrict
          firstRestriction value) ∈
      (stages.secondThetaMap.map
        ((stages.afterFirst).theta label)).carrier
  rw [EquivariantOrbitMap.carrier_map]
  exact
    ⟨ContinuousH1Germ.restrict
        firstRestriction value,
      hfirst, rfl⟩

/--
The composite restriction sends every ambient infinite-theta-orbit value into
the final infinite-theta orbit.
-/
theorem totalRestriction_mem_afterSecond_infiniteTheta_carrier
    [IsMulCommutative A]
    (label : IUTIIAbsoluteThetaLabel.{u} l)
    {value : ContinuousH1Germ action}
    (hvalue :
      value ∈
        (stages.ambient.infiniteTheta label).carrier) :
    totalRestrictionMonoidHom
        (action := action)
        (firstRestriction := firstRestriction)
        (secondRestriction := secondRestriction)
        value ∈
      ((stages.afterSecond).infiniteTheta label).carrier := by
  have hfirst :
      ContinuousH1Germ.restrict
          firstRestriction value ∈
        ((stages.afterFirst).infiniteTheta
          label).carrier := by
    change
      stages.firstInfiniteThetaMap.toFun value ∈
        (stages.firstInfiniteThetaMap.map
          (stages.ambient.infiniteTheta label)).carrier
    rw [EquivariantOrbitMap.carrier_map]
    exact ⟨value, hvalue, rfl⟩
  change
    stages.secondInfiniteThetaMap.toFun
        (ContinuousH1Germ.restrict
          firstRestriction value) ∈
      (stages.secondInfiniteThetaMap.map
        ((stages.afterFirst).infiniteTheta
          label)).carrier
  rw [EquivariantOrbitMap.carrier_map]
  exact
    ⟨ContinuousH1Germ.restrict
        firstRestriction value,
      hfirst, rfl⟩

/--
At the zero label, an ambient theta or infinite-theta orbit represented by
the cohomological identity remains represented by the identity after both
restriction operations.
-/
theorem afterSecond_zero_representatives
    [IsMulCommutative A]
    (theta_zero :
      (stages.ambient.theta
        IUTIIAbsoluteThetaLabel.zero).representative =
          1)
    (infiniteTheta_zero :
      (stages.ambient.infiniteTheta
        IUTIIAbsoluteThetaLabel.zero).representative =
          1) :
    ((stages.afterSecond).theta
        IUTIIAbsoluteThetaLabel.zero).representative =
        1 ∧
      ((stages.afterSecond).infiniteTheta
        IUTIIAbsoluteThetaLabel.zero).representative =
        1 := by
  constructor
  · rw [stages.afterSecond_theta_representative,
      theta_zero]
    simp
  · rw [stages.afterSecond_infiniteTheta_representative,
      infiniteTheta_zero]
    simp

end SourceIUTIICorollary28RestrictionStages

/-- Multiplication by a unit on a nonzero EtaleTheta `l`-torsion label. -/
def etaleThetaUnitSmulNonzeroLabel
    (l : PrimeGeFive)
    (unit : (ZMod l.value)ˣ)
    (label :
      EtaleTheta.NonzeroLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    EtaleTheta.NonzeroLabel
      (EtaleTheta.LTorsionLabel l.value) where
  val :=
    Multiplicative.ofAdd
      ((unit : ZMod l.value) *
        Multiplicative.toAdd label.1)
  property := by
    intro hzero
    apply label.2
    apply Multiplicative.toAdd.injective
    have hproduct :=
      congrArg Multiplicative.toAdd hzero
    have hproduct_zero :
        (unit : ZMod l.value) *
            Multiplicative.toAdd label.1 =
          0 := by
      simpa using hproduct
    calc
      Multiplicative.toAdd label.1 =
          ((unit : ZMod l.value)⁻¹ *
            ((unit : ZMod l.value) *
              Multiplicative.toAdd label.1)) := by
            simp
      _ = 0 := by
        rw [hproduct_zero]
        simp

@[simp]
theorem etaleThetaUnitSmulNonzeroLabel_one
    (l : PrimeGeFive)
    (label :
      EtaleTheta.NonzeroLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    etaleThetaUnitSmulNonzeroLabel l 1 label =
      label := by
  apply Subtype.ext
  apply Multiplicative.toAdd.injective
  simp [etaleThetaUnitSmulNonzeroLabel]

@[simp]
theorem etaleThetaUnitSmulNonzeroLabel_mul
    (l : PrimeGeFive)
    (first second : (ZMod l.value)ˣ)
    (label :
      EtaleTheta.NonzeroLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    etaleThetaUnitSmulNonzeroLabel
        l (first * second) label =
      etaleThetaUnitSmulNonzeroLabel l first
        (etaleThetaUnitSmulNonzeroLabel
          l second label) := by
  apply Subtype.ext
  apply Multiplicative.toAdd.injective
  simp [etaleThetaUnitSmulNonzeroLabel,
    mul_assoc]

@[simp]
theorem etaleThetaUnitSmulNonzeroLabel_inv
    (l : PrimeGeFive)
    (unit : (ZMod l.value)ˣ)
    (label :
      EtaleTheta.NonzeroLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    etaleThetaUnitSmulNonzeroLabel l unit label⁻¹ =
      (etaleThetaUnitSmulNonzeroLabel
        l unit label)⁻¹ := by
  apply Subtype.ext
  apply Multiplicative.toAdd.injective
  simp [etaleThetaUnitSmulNonzeroLabel,
    mul_neg]

/-- The unit action descended to nonzero EtaleTheta labels modulo sign. -/
def etaleThetaUnitActionOnSignLabel
    (l : PrimeGeFive)
    (unit : (ZMod l.value)ˣ) :
    EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value) →
      EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value) :=
  Quotient.map
    (etaleThetaUnitSmulNonzeroLabel l unit)
    (by
      intro first second h
      rcases h with h | h
      · exact Or.inl (congrArg _ h)
      · exact
          Or.inr
            ((congrArg _ h).trans
              (etaleThetaUnitSmulNonzeroLabel_inv
                l unit second)))

@[simp]
theorem etaleThetaUnitActionOnSignLabel_one
    (l : PrimeGeFive)
    (label :
      EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    etaleThetaUnitActionOnSignLabel l 1 label =
      label := by
  refine Quotient.inductionOn label ?_
  intro representative
  apply Quotient.sound
  exact
    Or.inl
      (etaleThetaUnitSmulNonzeroLabel_one
        l representative)

@[simp]
theorem etaleThetaUnitActionOnSignLabel_mul
    (l : PrimeGeFive)
    (first second : (ZMod l.value)ˣ)
    (label :
      EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    etaleThetaUnitActionOnSignLabel
        l (first * second) label =
      etaleThetaUnitActionOnSignLabel l first
        (etaleThetaUnitActionOnSignLabel
          l second label) := by
  refine Quotient.inductionOn label ?_
  intro representative
  apply Quotient.sound
  exact
    Or.inl
      (etaleThetaUnitSmulNonzeroLabel_mul
        l first second representative)

@[simp]
theorem etaleThetaUnitActionOnSignLabel_neg_one
    (l : PrimeGeFive)
    (label :
      EtaleTheta.SignLabel
        (EtaleTheta.LTorsionLabel l.value)) :
    etaleThetaUnitActionOnSignLabel l (-1) label =
      label := by
  refine Quotient.inductionOn label ?_
  intro representative
  apply Quotient.sound
  right
  apply Subtype.ext
  apply Multiplicative.toAdd.injective
  simp [etaleThetaUnitSmulNonzeroLabel]

/-- The unit action transported to the ordered nonzero absolute labels. -/
noncomputable def iutIIUnitActionOnPositiveLabel
    (l : PrimeGeFive)
    (unit : (ZMod l.value)ˣ)
    (label : IUTIPositiveLabel.{u} l) :
    IUTIPositiveLabel.{u} l :=
  IUTIPositiveLabel.signLabelEquiv.symm
    (etaleThetaUnitActionOnSignLabel l unit
      (IUTIPositiveLabel.signLabelEquiv label))

/-- The action of `(Z/lZ)^x` on the full positive label set. -/
@[reducible]
noncomputable def iutIIUnitMulActionOnPositiveLabels
    (l : PrimeGeFive) :
    MulAction (ZMod l.value)ˣ
      (IUTIPositiveLabel.{u} l) where
  smul :=
    iutIIUnitActionOnPositiveLabel l
  one_smul label := by
    change
      iutIIUnitActionOnPositiveLabel l 1 label =
        label
    apply IUTIPositiveLabel.signLabelEquiv.injective
    simp only [iutIIUnitActionOnPositiveLabel,
      Equiv.apply_symm_apply,
      etaleThetaUnitActionOnSignLabel_one]
  mul_smul first second label := by
    change
      iutIIUnitActionOnPositiveLabel
          l (first * second) label =
        iutIIUnitActionOnPositiveLabel l first
          (iutIIUnitActionOnPositiveLabel
            l second label)
    apply IUTIPositiveLabel.signLabelEquiv.injective
    simp only [iutIIUnitActionOnPositiveLabel,
      Equiv.apply_symm_apply,
      etaleThetaUnitActionOnSignLabel_mul]

theorem iutIIUnitActionOnPositiveLabel_sign_trivial
    (l : PrimeGeFive)
    {unit : (ZMod l.value)ˣ}
    (hunit : unit ∈ zmodSignUnitSubgroup l)
    (label : IUTIPositiveLabel.{u} l) :
    iutIIUnitActionOnPositiveLabel l unit label =
      label := by
  rcases hunit with rfl | rfl
  · apply IUTIPositiveLabel.signLabelEquiv.injective
    simp [iutIIUnitActionOnPositiveLabel]
  · apply IUTIPositiveLabel.signLabelEquiv.injective
    simp [iutIIUnitActionOnPositiveLabel]

/--
The permutation representation of the exact unit/sign quotient
`(Z/lZ)^x / {+1,-1}` on nonzero absolute labels.
-/
noncomputable def iutIISignQuotientPermHom
    (l : PrimeGeFive) :
    (ZMod l.value)ˣ ⧸ zmodSignUnitSubgroup l →*
      Equiv.Perm (IUTIPositiveLabel.{u} l) := by
  letI : MulAction (ZMod l.value)ˣ
      (IUTIPositiveLabel.{u} l) :=
    iutIIUnitMulActionOnPositiveLabels l
  apply QuotientGroup.lift
    (zmodSignUnitSubgroup l)
    (MulAction.toPermHom
      (ZMod l.value)ˣ
      (IUTIPositiveLabel.{u} l))
  intro unit hunit
  apply Equiv.ext
  intro label
  exact
    iutIIUnitActionOnPositiveLabel_sign_trivial
      l hunit label

/-- The actual `F_l^(x+-)` action on the positive label set. -/
@[reducible]
noncomputable def iutIISignQuotientMulActionOnPositiveLabels
    (l : PrimeGeFive) :
    MulAction
      ((ZMod l.value)ˣ ⧸ zmodSignUnitSubgroup l)
      (IUTIPositiveLabel.{u} l) where
  smul symmetry label :=
    iutIISignQuotientPermHom l symmetry label
  one_smul label := by
    change
      iutIISignQuotientPermHom l 1 label =
        label
    rw [map_one]
    rfl
  mul_smul first second label := by
    change
      iutIISignQuotientPermHom
          l (first * second) label =
        iutIISignQuotientPermHom l first
          (iutIISignQuotientPermHom
            l second label)
    rw [map_mul]
    rfl

/-- The unit action is transitive on nonzero absolute labels. -/
theorem iutIIUnitActionOnPositiveLabels_transitive
    (l : PrimeGeFive)
    (first second : IUTIPositiveLabel.{u} l) :
    ∃ unit : (ZMod l.value)ˣ,
      iutIIUnitActionOnPositiveLabel
          l unit first =
        second := by
  letI : Fact (Nat.Prime l.value) :=
    ⟨l.prime⟩
  let ratio : ZMod l.value :=
    IUTIPositiveLabel.coordinate second /
      IUTIPositiveLabel.coordinate first
  have ratio_ne_zero : ratio ≠ 0 :=
    div_ne_zero
      (IUTIPositiveLabel.coordinate_ne_zero
        second)
      (IUTIPositiveLabel.coordinate_ne_zero
        first)
  let unit : (ZMod l.value)ˣ :=
    Units.mk0 ratio ratio_ne_zero
  refine ⟨unit, ?_⟩
  apply IUTIPositiveLabel.signLabelEquiv.injective
  simp only [iutIIUnitActionOnPositiveLabel,
    Equiv.apply_symm_apply]
  change
    etaleThetaUnitActionOnSignLabel l unit
        (IUTIPositiveLabel.signLabel first) =
      IUTIPositiveLabel.signLabel second
  apply Quotient.sound
  left
  apply Subtype.ext
  apply Multiplicative.toAdd.injective
  change
    ratio * IUTIPositiveLabel.coordinate first =
      IUTIPositiveLabel.coordinate second
  exact
    div_mul_cancel₀ _
      (IUTIPositiveLabel.coordinate_ne_zero
        first)

/--
The exact unit/sign quotient acts transitively on the full nonzero
absolute-label set.
-/
theorem iutIISignQuotientPermHom_transitive
    (l : PrimeGeFive)
    (first second : IUTIPositiveLabel.{u} l) :
    ∃ symmetry :
        (ZMod l.value)ˣ ⧸ zmodSignUnitSubgroup l,
      iutIISignQuotientPermHom
          l symmetry first =
        second := by
  rcases
      iutIIUnitActionOnPositiveLabels_transitive
        l first second with
    ⟨unit, hunit⟩
  refine
    ⟨QuotientGroup.mk unit, ?_⟩
  exact hunit

theorem iutIISignQuotientAction_transitive
    (l : PrimeGeFive)
    (first second : IUTIPositiveLabel.{u} l) :
    letI :=
      iutIISignQuotientMulActionOnPositiveLabels l
    ∃ symmetry :
        (ZMod l.value)ˣ ⧸ zmodSignUnitSubgroup l,
      symmetry • first = second := by
  letI :=
    iutIISignQuotientMulActionOnPositiveLabels l
  exact
    iutIISignQuotientPermHom_transitive
      l first second

/--
A topological group acting continuously by automorphisms on a topological
monoid.
-/
structure SourceTopologicalGroupMonoidActionPair where
  actingGroup : TopologicalGroupCat.{u}
  monoidCarrier : Type u
  [monoidStructure : Monoid monoidCarrier]
  [monoidTopology : TopologicalSpace monoidCarrier]
  [monoidContinuousMul : ContinuousMul monoidCarrier]
  action :
    actingGroup →*
      MulAut monoidCarrier
  continuous_action :
    Continuous fun input :
      actingGroup × monoidCarrier =>
        action input.1 input.2

namespace SourceTopologicalGroupMonoidActionPair

attribute [instance] monoidStructure
  monoidTopology monoidContinuousMul

/-- An isomorphism of topological group/monoid action pairs. -/
structure Iso
    (source target :
      SourceTopologicalGroupMonoidActionPair) where
  groupIso :
    source.actingGroup ≃ₜ*
      target.actingGroup
  monoidIso :
    source.monoidCarrier ≃ₜ*
      target.monoidCarrier
  equivariant :
    ∀ groupElement monoidElement,
      monoidIso
          (source.action groupElement monoidElement) =
        target.action
          (groupIso groupElement)
          (monoidIso monoidElement)

namespace Iso

variable
  {first second third :
    SourceTopologicalGroupMonoidActionPair}

/--
Change only the target index of an action-pair isomorphism along an equality.
This is used to state coherence for an action on a label-indexed family, whose
target labels are propositionally, rather than definitionally, equal.
-/
def castTarget
    {target' :
      SourceTopologicalGroupMonoidActionPair}
    (target_eq : second = target')
    (pairIso : Iso first second) :
    Iso first target' :=
  target_eq ▸ pairIso

/-- The identity isomorphism of an action pair. -/
def refl
    (pair : SourceTopologicalGroupMonoidActionPair) :
    Iso pair pair where
  groupIso :=
    _root_.ContinuousMulEquiv.refl
      pair.actingGroup
  monoidIso :=
    _root_.ContinuousMulEquiv.refl
      pair.monoidCarrier
  equivariant := by
    intro groupElement monoidElement
    rfl

/-- Composition of action-pair isomorphisms. -/
def trans
    (firstIso : Iso first second)
    (secondIso : Iso second third) :
    Iso first third where
  groupIso :=
    firstIso.groupIso.trans
      secondIso.groupIso
  monoidIso :=
    firstIso.monoidIso.trans
      secondIso.monoidIso
  equivariant := by
    intro groupElement monoidElement
    change
      secondIso.monoidIso
          (firstIso.monoidIso
            (first.action groupElement monoidElement)) =
        third.action
          (secondIso.groupIso
            (firstIso.groupIso groupElement))
          (secondIso.monoidIso
            (firstIso.monoidIso monoidElement))
    rw [firstIso.equivariant,
      secondIso.equivariant]

/-- Inverse of an action-pair isomorphism. -/
def symm
    (pairIso : Iso first second) :
    Iso second first where
  groupIso :=
    pairIso.groupIso.symm
  monoidIso :=
    pairIso.monoidIso.symm
  equivariant := by
    intro groupElement monoidElement
    apply pairIso.monoidIso.injective
    rw [pairIso.equivariant]
    simp

end Iso

end SourceTopologicalGroupMonoidActionPair

/--
The algebraic presentation of `TM` allowed by Absolute Anabelian Topics III,
Remark 3.1.1: a torsion-cyclotomic abelian monoid.  Omitting the topology and
ind-presentation prevents an arbitrary topology from serving as a model
certificate; the paper proves that they are intrinsic to this monoid data.

`AddCircle (1 : Q)` is the additive quotient `Q/Z`; `Multiplicative` expresses
the paper's multiplicative convention.
-/
structure SourceTorsionCyclotomicCommMonoid where
  carrier : Type u
  [commMonoidStructure : CommMonoid carrier]
  [cancelMul : IsCancelMul carrier]
  torsion_cyclotomic :
    Nonempty
      (CommGroup.torsion carrierˣ ≃*
        Multiplicative (AddCircle (1 : ℚ)))

attribute [instance]
  SourceTorsionCyclotomicCommMonoid.commMonoidStructure
  SourceTorsionCyclotomicCommMonoid.cancelMul

namespace SourceTorsionCyclotomicCommMonoid

/-- Every point of the rational circle has finite additive order. -/
theorem rationalCircle_isOfFinAddOrder
    (q : AddCircle (1 : ℚ)) : IsOfFinAddOrder q := by
  obtain ⟨r, rfl⟩ := QuotientAddGroup.mk'_surjective _ q
  have horder :
      addOrderOf
          (QuotientAddGroup.mk'
            (AddSubgroup.zmultiples (1 : ℚ)) r) =
        r.den := by
    rw [QuotientAddGroup.mk'_apply]
    simpa only [Rat.cast_id, mul_one] using
      (AddCircle.addOrderOf_coe_rat (p := (1 : ℚ)) (q := r))
  exact addOrderOf_pos_iff.mp (horder.symm ▸ r.den_pos)

/-- The multiplicative rational circle is a torsion group. -/
theorem multiplicativeRationalCircle_isOfFinOrder
    (q : Multiplicative (AddCircle (1 : ℚ))) : IsOfFinOrder q :=
  rationalCircle_isOfFinAddOrder q.toAdd

/-- The `n`-torsion subgroup of `Q/Z` has exactly `n` elements. -/
theorem rationalCircle_torsion_natCard
    (n : ℕ) (hn : 0 < n) :
    Nat.card
        {q : AddCircle (1 : ℚ) // n • q = 0} =
      n := by
  letI : Finite {q : AddCircle (1 : ℚ) // n • q = 0} :=
    (AddCircle.finite_torsion (1 : ℚ) hn).to_subtype
  rw [← ENat.coe_inj, ← ENat.card_eq_coe_natCard]
  apply le_antisymm
  · exact
      AddCircle.card_torsion_le_of_isSMulRegular
        (1 : ℚ) n hn.ne'
          (.of_right_eq_zero_of_smul fun _ => by
            simp [hn.ne'])
  · let inclusion :
        Fin n → {q : AddCircle (1 : ℚ) // n • q = 0} :=
      fun k =>
        ⟨((k.val : ℚ) / n : ℚ), by
          calc
            n • (((k.val : ℚ) / n : ℚ) :
                AddCircle (1 : ℚ)) =
              ((n • ((k.val : ℚ) / n : ℚ) : ℚ) :
                AddCircle (1 : ℚ)) :=
              (AddCircle.coe_nsmul
                (p := (1 : ℚ))
                (n := n)
                (x := ((k.val : ℚ) / n : ℚ))).symm
            _ = ((k.val : ℚ) : AddCircle (1 : ℚ)) := by
              congr 1
              change
                (n : ℚ) * ((k.val : ℚ) / n) = k.val
              field_simp
            _ = 0 := by
              rw [QuotientAddGroup.eq_zero_iff]
              exact ⟨k.val, by simp⟩⟩
    have inclusion_injective : Function.Injective inclusion := by
      intro first second h
      apply Fin.ext
      have hfirst :
          ((first.val : ℚ) / n : ℚ) ∈
            Set.Ico (0 : ℚ) (0 + 1) := by
        constructor
        · positivity
        · rw [zero_add, div_lt_one (by positivity)]
          exact_mod_cast first.isLt
      have hsecond :
          ((second.val : ℚ) / n : ℚ) ∈
            Set.Ico (0 : ℚ) (0 + 1) := by
        constructor
        · positivity
        · rw [zero_add, div_lt_one (by positivity)]
          exact_mod_cast second.isLt
      have hrat :
          (first.val : ℚ) / n =
            (second.val : ℚ) / n :=
        (AddCircle.coe_eq_coe_iff_of_mem_Ico
          hfirst hsecond).mp
            (congrArg Subtype.val h)
      have hval : (first.val : ℚ) = second.val :=
        (div_left_inj'
          (show (n : ℚ) ≠ 0 by positivity)).mp hrat
      exact_mod_cast hval
    simpa using
      (ENat.card_le_card_of_injective inclusion_injective)

variable (M : SourceTorsionCyclotomicCommMonoid)

/-- A fixed algebraic identification of the torsion units with `Q/Z`. -/
noncomputable def torsionEquiv :
    CommGroup.torsion M.carrierˣ ≃*
      Multiplicative (AddCircle (1 : ℚ)) :=
  Classical.choice M.torsion_cyclotomic

/--
The `n`-th roots of unity in a torsion-cyclotomic monoid are exactly the
`n`-torsion points of `Q/Z` under its defining cyclotomic equivalence.
-/
noncomputable def rootsOfUnityEquiv
    (n : ℕ) (hn : 0 < n) :
    {u : M.carrierˣ // u ^ n = 1} ≃
      {q : AddCircle (1 : ℚ) // n • q = 0} where
  toFun u := by
    let torsionValue : CommGroup.torsion M.carrierˣ :=
      ⟨u.1,
        isOfFinOrder_iff_pow_eq_one.mpr
          ⟨n, hn, u.2⟩⟩
    refine
      ⟨(M.torsionEquiv torsionValue).toAdd, ?_⟩
    have hpow : torsionValue ^ n = 1 := by
      apply Subtype.ext
      exact u.2
    change
      (M.torsionEquiv torsionValue ^ n).toAdd =
        (1 : Multiplicative (AddCircle (1 : ℚ))).toAdd
    congr 1
    rw [← map_pow, hpow, map_one]
  invFun q := by
    let targetTorsion : CommGroup.torsion M.carrierˣ :=
      (M.torsionEquiv).symm
        (Multiplicative.ofAdd q.1)
    refine ⟨targetTorsion.1, ?_⟩
    have htarget :
        (Multiplicative.ofAdd q.1 :
          Multiplicative (AddCircle (1 : ℚ))) ^ n = 1 := by
      apply Multiplicative.toAdd.injective
      exact q.2
    have hpow : targetTorsion ^ n = 1 := by
      apply (M.torsionEquiv).injective
      rw [map_pow, map_one,
        (M.torsionEquiv).apply_symm_apply]
      exact htarget
    exact congrArg Subtype.val hpow
  left_inv u := by
    apply Subtype.ext
    change
      ((M.torsionEquiv).symm
        (M.torsionEquiv
          (⟨u.1,
            isOfFinOrder_iff_pow_eq_one.mpr
              ⟨n, hn, u.2⟩⟩ :
            CommGroup.torsion M.carrierˣ))).1 = u.1
    rw [(M.torsionEquiv).symm_apply_apply]
  right_inv q := by
    apply Subtype.ext
    change
      ((M.torsionEquiv
        ((M.torsionEquiv).symm
          (Multiplicative.ofAdd q.1))).toAdd) =
        q.1
    rw [(M.torsionEquiv).apply_symm_apply]
    rfl

/-- The `n`-th roots of unity have exactly `n` elements. -/
theorem rootsOfUnity_natCard (n : ℕ) (hn : 0 < n) :
    Nat.card {u : M.carrierˣ // u ^ n = 1} = n := by
  rw [Nat.card_congr (M.rootsOfUnityEquiv n hn)]
  exact rationalCircle_torsion_natCard n hn

/-- The subgroup of units killed by the positive exponent `n`. -/
def rootsOfUnitySubgroup (n : ℕ+) :
    Subgroup M.carrierˣ where
  carrier := {u | u ^ n.val = 1}
  one_mem' := by simp
  mul_mem' := by
    intro first second hfirst hsecond
    change first ^ n.val = 1 at hfirst
    change second ^ n.val = 1 at hsecond
    change (first * second) ^ n.val = 1
    rw [mul_pow, hfirst, hsecond, one_mul]
  inv_mem' := by
    intro unit hunit
    change unit ^ n.val = 1 at hunit
    change unit⁻¹ ^ n.val = 1
    rw [inv_pow, hunit, inv_one]

/-- The actual finite group `mu_n(M)` of `n`-th roots of unity. -/
abbrev RootsOfUnityGroup (n : ℕ+) : Type u :=
  M.rootsOfUnitySubgroup n

/-- Forget the subgroup wrapper on the actual roots-of-unity group. -/
noncomputable def rootsOfUnityGroupSubtypeEquiv
    (n : ℕ+) :
    M.RootsOfUnityGroup n ≃
      {u : M.carrierˣ // u ^ n.val = 1} :=
  Equiv.refl _

noncomputable instance rootsOfUnityGroup_finite
    (n : ℕ+) : Finite (M.RootsOfUnityGroup n) :=
  letI : Finite
      {q : AddCircle (1 : ℚ) // n.val • q = 0} :=
    (AddCircle.finite_torsion (1 : ℚ) n.pos).to_subtype
  letI : Finite {u : M.carrierˣ // u ^ n.val = 1} :=
    Finite.of_equiv
      {q : AddCircle (1 : ℚ) // n.val • q = 0}
      (M.rootsOfUnityEquiv n.val n.pos).symm
  Finite.of_equiv
    {u : M.carrierˣ // u ^ n.val = 1}
    (M.rootsOfUnityGroupSubtypeEquiv n).symm

/-- The actual roots-of-unity group has its defining order. -/
theorem rootsOfUnityGroup_natCard (n : ℕ+) :
    Nat.card (M.RootsOfUnityGroup n) = n.val := by
  rw [Nat.card_congr
    (M.rootsOfUnityGroupSubtypeEquiv n)]
  exact M.rootsOfUnity_natCard n.val n.pos

/-- For each positive `n`, the `n`-torsion units form a finite set. -/
theorem rootsOfUnity_finite (n : ℕ) (hn : 0 < n) :
    Set.Finite {u : M.carrierˣ | u ^ n = 1} := by
  let target : Set (AddCircle (1 : ℚ)) := {q | n • q = 0}
  let f : {u : M.carrierˣ // u ^ n = 1} → target := fun u =>
    ⟨(torsionEquiv M
        ⟨u.1, isOfFinOrder_iff_pow_eq_one.mpr ⟨n, hn, u.2⟩⟩).toAdd,
      by
        let torsionValue : CommGroup.torsion M.carrierˣ :=
          ⟨u.1, isOfFinOrder_iff_pow_eq_one.mpr ⟨n, hn, u.2⟩⟩
        have hpow : torsionValue ^ n = 1 := by
          apply Subtype.ext
          exact u.2
        change
          (torsionEquiv M torsionValue ^ n).toAdd =
            (1 : Multiplicative (AddCircle (1 : ℚ))).toAdd
        congr 1
        rw [← map_pow, hpow, map_one]⟩
  apply Set.finite_coe_iff.mpr
  letI : Finite target :=
    (AddCircle.finite_torsion (1 : ℚ) hn).to_subtype
  exact Finite.of_injective f fun first second equality => by
    apply Subtype.ext
    let firstTorsion : CommGroup.torsion M.carrierˣ :=
      ⟨first.1,
        isOfFinOrder_iff_pow_eq_one.mpr ⟨n, hn, first.2⟩⟩
    let secondTorsion : CommGroup.torsion M.carrierˣ :=
      ⟨second.1,
        isOfFinOrder_iff_pow_eq_one.mpr ⟨n, hn, second.2⟩⟩
    have equalityAdd :
        (torsionEquiv M firstTorsion).toAdd =
          (torsionEquiv M secondTorsion).toAdd :=
      congrArg Subtype.val equality
    have equalityMul :
        torsionEquiv M firstTorsion =
          torsionEquiv M secondTorsion :=
      congrArg Multiplicative.ofAdd equalityAdd
    exact congrArg
      (fun value : CommGroup.torsion M.carrierˣ =>
        (value : M.carrierˣ))
      ((torsionEquiv M).injective equalityMul)

end SourceTorsionCyclotomicCommMonoid

/--
A topological presentation of a torsion-cyclotomic abelian monoid for
downstream continuous constructions.  This is not itself the model-realization
certificate for an MLF-Galois pair.

`AddCircle (1 : Q)` is the additive quotient `Q/Z`; `Multiplicative` expresses
the paper's multiplicative convention.  `Nonempty` records abstract
isomorphism without choosing extra cyclotomic rigidity data.
-/
structure SourceTorsionCyclotomicTopologicalCommMonoid where
  carrier : Type u
  [commMonoidStructure : CommMonoid carrier]
  [topology : TopologicalSpace carrier]
  [continuousMul : ContinuousMul carrier]
  torsion_cyclotomic :
    Nonempty
      (CommGroup.torsion carrierˣ ≃*
        Multiplicative (AddCircle (1 : ℚ)))

attribute [instance]
  SourceTorsionCyclotomicTopologicalCommMonoid.commMonoidStructure
  SourceTorsionCyclotomicTopologicalCommMonoid.topology
  SourceTorsionCyclotomicTopologicalCommMonoid.continuousMul

/--
The cyclotome `mu_Z(M) = Hom(Q/Z,M)` of Absolute Anabelian Topics III,
Definition 3.1(v).  A homomorphism from a group into a monoid lands in units,
so the codomain is written as `M^x` without changing the mathematical object.
-/
abbrev SourceMonoidCyclotome
    (M : Type u) [CommMonoid M] :
    Type u :=
  Multiplicative (AddCircle (1 : ℚ)) →* Mˣ

namespace SourceMonoidCyclotome

variable (M : Type u) [CommMonoid M]

/-- The underlying-function homomorphism used for pointwise convergence. -/
def coeFunctionMonoidHom :
    SourceMonoidCyclotome M →*
      (Multiplicative (AddCircle (1 : ℚ)) → Mˣ) where
  toFun hom := hom
  map_one' := rfl
  map_mul' _ _ := rfl

/--
The pointwise topology on `Hom(Q/Z,M)`, with every unit coordinate discrete.
For a torsion-cyclotomic monoid these coordinates have finite image; this is
the topology underlying the profinite cyclotome of Definition 3.1(v).
-/
@[implicit_reducible]
noncomputable def topology :
    TopologicalSpace (SourceMonoidCyclotome M) := by
  letI : TopologicalSpace Mˣ := ⊥
  exact TopologicalSpace.induced (coeFunctionMonoidHom M) inferInstance

noncomputable instance instTopologicalSpace :
    TopologicalSpace (SourceMonoidCyclotome M) :=
  topology M

/-- Pointwise multiplication and inversion make the cyclotome a topological group. -/
noncomputable instance instIsTopologicalGroup :
    IsTopologicalGroup (SourceMonoidCyclotome M) := by
  letI : TopologicalSpace Mˣ := ⊥
  letI : DiscreteTopology Mˣ := ⟨rfl⟩
  exact topologicalGroup_induced (coeFunctionMonoidHom M)

/-- Continuity into the cyclotome is coordinatewise continuity into discrete units. -/
theorem continuous_iff_eval_discrete
    {X : Type u} [TopologicalSpace X]
    (f : X → SourceMonoidCyclotome M) :
    Continuous f ↔
      ∀ q : Multiplicative (AddCircle (1 : ℚ)),
        @Continuous X Mˣ _ ⊥ (fun x => f x q) := by
  letI : TopologicalSpace Mˣ := ⊥
  change
    @Continuous X (SourceMonoidCyclotome M) _ (topology M) f ↔ _
  rw [topology, continuous_induced_rng, continuous_pi_iff]
  rfl

/-- Evaluation at one torsion coordinate is continuous into the discrete unit group. -/
theorem continuous_eval_discrete
    (q : Multiplicative (AddCircle (1 : ℚ))) :
    @Continuous (SourceMonoidCyclotome M) Mˣ _ ⊥
      (fun cyclotome => cyclotome q) :=
  (continuous_iff_eval_discrete M id).mp continuous_id q

end SourceMonoidCyclotome

namespace SourceMonoidCyclotome

open Topology

variable (M : SourceTorsionCyclotomicCommMonoid)

noncomputable local instance unitTopologicalSpace :
    TopologicalSpace M.carrierˣ := ⊥

noncomputable local instance unitDiscreteTopology :
    DiscreteTopology M.carrierˣ := ⟨rfl⟩

/-- The finite coordinate range forced by the order of `q`. -/
abbrev Coordinate
    (q : Multiplicative (AddCircle (1 : ℚ))) :=
  {u : M.carrierˣ // u ^ orderOf q = 1}

noncomputable instance coordinateFinite
    (q : Multiplicative (AddCircle (1 : ℚ))) :
    Finite (Coordinate M q) :=
  (M.rootsOfUnity_finite (orderOf q)
    (SourceTorsionCyclotomicCommMonoid.multiplicativeRationalCircle_isOfFinOrder
      q).orderOf_pos).to_subtype

noncomputable instance coordinateTopologicalSpace
    (q : Multiplicative (AddCircle (1 : ℚ))) :
    TopologicalSpace (Coordinate M q) :=
  TopologicalSpace.induced Subtype.val (unitTopologicalSpace M)

noncomputable instance coordinateT2Space
    (q : Multiplicative (AddCircle (1 : ℚ))) :
    T2Space (Coordinate M q) :=
  IsEmbedding.subtypeVal.t2Space

/-- Evaluation with its finite-order coordinate bound retained. -/
noncomputable def boundedCoe :
    SourceMonoidCyclotome M.carrier →
      ∀ q : Multiplicative (AddCircle (1 : ℚ)), Coordinate M q :=
  fun hom q =>
    ⟨hom q, by
      rw [← map_pow, pow_orderOf_eq_one, map_one]⟩

/-- Forget the finite-order proofs in the bounded coordinate product. -/
noncomputable def boundedInclusion :
    (∀ q : Multiplicative (AddCircle (1 : ℚ)), Coordinate M q) →
      Multiplicative (AddCircle (1 : ℚ)) → M.carrierˣ :=
  fun values q => values q

theorem boundedInclusion_isEmbedding :
    @IsEmbedding
      (∀ q : Multiplicative (AddCircle (1 : ℚ)), Coordinate M q)
      (Multiplicative (AddCircle (1 : ℚ)) → M.carrierˣ)
      inferInstance
      Pi.topologicalSpace
      (boundedInclusion M) := by
  change
    IsEmbedding
      (Pi.map fun _ => ((↑) : Coordinate M _ → M.carrierˣ))
  exact Topology.IsEmbedding.piMap fun _ => IsEmbedding.subtypeVal

/-- The bounded evaluation map induces the pointwise cyclotome topology. -/
theorem boundedCoe_isInducing : IsInducing (boundedCoe M) := by
  have sourceInducing :
      @IsInducing
        (SourceMonoidCyclotome M.carrier)
        (Multiplicative (AddCircle (1 : ℚ)) → M.carrierˣ)
        (topology M.carrier)
        Pi.topologicalSpace
        (coeFunctionMonoidHom M.carrier) :=
    Topology.IsInducing.induced _
  have composedInducing :
      IsInducing (boundedInclusion M ∘ boundedCoe M) := by
    simpa [boundedInclusion, boundedCoe, coeFunctionMonoidHom] using
      sourceInducing
  exact
    ((boundedInclusion_isEmbedding M).toIsInducing.of_comp_iff).mp
      composedInducing

theorem boundedCoe_injective : Function.Injective (boundedCoe M) := by
  intro first second equality
  apply MonoidHom.ext
  intro q
  exact congrArg (fun values => (values q : M.carrierˣ)) equality

/-- The bounded homomorphisms are the pullback of the closed monoid-hom range. -/
theorem range_boundedCoe :
    Set.range (boundedCoe M) =
      boundedInclusion M ⁻¹'
        Set.range
          ((↑) : SourceMonoidCyclotome M.carrier →
            Multiplicative (AddCircle (1 : ℚ)) → M.carrierˣ) := by
  ext values
  constructor
  · rintro ⟨hom, rfl⟩
    exact ⟨hom, rfl⟩
  · rintro ⟨hom, equality⟩
    refine ⟨hom, (boundedInclusion_isEmbedding M).injective ?_⟩
    simpa [boundedInclusion, boundedCoe] using equality

theorem boundedCoe_isClosed_range :
    IsClosed (Set.range (boundedCoe M)) := by
  rw [range_boundedCoe]
  exact
    (MonoidHom.isClosed_range_coe
      (Multiplicative (AddCircle (1 : ℚ))) M.carrierˣ).preimage
      (boundedInclusion_isEmbedding M).continuous

/-- The cyclotome is a closed subspace of a product of finite discrete groups. -/
theorem boundedCoe_isClosedEmbedding : IsClosedEmbedding (boundedCoe M) :=
  ⟨⟨boundedCoe_isInducing M, boundedCoe_injective M⟩,
    boundedCoe_isClosed_range M⟩

noncomputable instance instCompactSpaceOfTorsionCyclotomic :
    CompactSpace (SourceMonoidCyclotome M.carrier) :=
  (boundedCoe_isClosedEmbedding M).compactSpace

noncomputable instance instT2SpaceOfTorsionCyclotomic :
    T2Space (SourceMonoidCyclotome M.carrier) :=
  (boundedCoe_isClosedEmbedding M).isEmbedding.t2Space

noncomputable instance instTotallyDisconnectedSpaceOfTorsionCyclotomic :
    TotallyDisconnectedSpace (SourceMonoidCyclotome M.carrier) := by
  let embedding := (boundedCoe_isClosedEmbedding M).isEmbedding
  rw [← embedding.isTotallyDisconnected_range]
  exact isTotallyDisconnected_of_totallyDisconnectedSpace _

/-- The profinite space underlying `mu_Z(M)` in Definition 3.1(v). -/
noncomputable def asProfinite : Profinite :=
  Profinite.of (SourceMonoidCyclotome M.carrier)

/-- The profinite cyclotome has no nontrivial element divisible in all degrees. -/
theorem eq_one_of_roots
    (value : SourceMonoidCyclotome M.carrier)
    (roots : ∀ n : ℕ, 0 < n →
      ∃ root : SourceMonoidCyclotome M.carrier,
        root ^ n = value) :
    value = 1 :=
  SourceKummerFaithfulness.eq_one_of_roots_in_profinite value roots

end SourceMonoidCyclotome

/--
The ring of integers of the algebraic closure of an MLF, realized as the
integral closure of the base valuation ring.
-/
noncomputable abbrev SourceMLFAlgebraicIntegerRing
    (K : Type u) [Field K] [ValuativeRel K] :
    Type u :=
  integralClosure
    (Valuation.integer (ValuativeRel.valuation K))
    (AlgebraicClosure K)

/--
The source monoid `O_(kbar)^triangle`: the nonzero elements of the integral
closure of `O_k` in `kbar`.
-/
noncomputable abbrev SourceMLFIntegralMonoid
    (K : Type u) [Field K] [ValuativeRel K] :
    Type u :=
  (SourceMLFAlgebraicIntegerRing K)⁰

/-- The absolute Galois group of an MLF with its actual Krull topology. -/
noncomputable abbrev SourceMLFAbsoluteGaloisGroup
    (K : Type u) [Field K] [CharZero K] :
    TopologicalGroupCat.{u} :=
  TopologicalGroupCat.ofProfinite
    (InfiniteGalois.profiniteGalGrp
      K (AlgebraicClosure K))

namespace SourceMLFIntegralMonoid

variable
  (K : Type u) [Field K] [ValuativeRel K]
  [TopologicalSpace K] [IsNonarchimedeanLocalField K]
  [CharZero K]

/-- A Galois automorphism restricted to the integral closure of `O_k`. -/
noncomputable def integralClosureAlgEquiv
    (sigma : AlgebraicClosure K ≃ₐ[K] AlgebraicClosure K) :
    SourceMLFAlgebraicIntegerRing K ≃+*
      SourceMLFAlgebraicIntegerRing K :=
  ((sigma.restrictScalars
    (Valuation.integer (ValuativeRel.valuation K))).mapIntegralClosure).toRingEquiv

/-- The induced automorphism of the nonzero integral multiplicative monoid. -/
noncomputable def galoisMulAut
    (sigma : AlgebraicClosure K ≃ₐ[K] AlgebraicClosure K) :
    MulAut (SourceMLFIntegralMonoid K) where
  toFun value :=
    ⟨integralClosureAlgEquiv K sigma value,
      mem_nonZeroDivisors_of_ne_zero
        (by
          rw [← map_zero (integralClosureAlgEquiv K sigma)]
          exact
            (integralClosureAlgEquiv K sigma).injective.ne
              (nonZeroDivisors.coe_ne_zero value))⟩
  invFun value :=
    ⟨integralClosureAlgEquiv K sigma.symm value,
      mem_nonZeroDivisors_of_ne_zero
        (by
          rw [← map_zero (integralClosureAlgEquiv K sigma.symm)]
          exact
            (integralClosureAlgEquiv K sigma.symm).injective.ne
              (nonZeroDivisors.coe_ne_zero value))⟩
  left_inv value := by
    apply Subtype.ext
    apply Subtype.ext
    exact sigma.left_inv value.1.1
  right_inv value := by
    apply Subtype.ext
    apply Subtype.ext
    exact sigma.right_inv value.1.1
  map_mul' first second := by
    apply Subtype.ext
    apply Subtype.ext
    exact map_mul sigma first.1.1 second.1.1

/-- The natural absolute-Galois action on `O_(kbar)^triangle`. -/
noncomputable def galoisAction :
    SourceMLFAbsoluteGaloisGroup K →*
      MulAut (SourceMLFIntegralMonoid K) where
  toFun := galoisMulAut K
  map_one' := by
    apply MulEquiv.ext
    intro value
    apply Subtype.ext
    apply Subtype.ext
    rfl
  map_mul' first second := by
    apply MulEquiv.ext
    intro value
    apply Subtype.ext
    apply Subtype.ext
    rfl

/--
The Krull-open absolute-Galois subgroup fixing one element of
`O_(kbar)^triangle`. Algebraicity is exactly what makes the stabilizer open.
-/
noncomputable def absoluteOpenStabilizer
    (value : SourceMLFIntegralMonoid K) :
    OpenSubgroup (SourceMLFAbsoluteGaloisGroup K) := by
  change
    OpenSubgroup
      ((AlgebraicClosure K) ≃ₐ[K] (AlgebraicClosure K))
  exact
    ⟨MulAction.stabilizer
        ((AlgebraicClosure K) ≃ₐ[K] (AlgebraicClosure K))
        value.1.1,
      stabilizer_isOpen_of_isIntegral value.1.1⟩

/-- The integral closure `O_kbar` has `kbar` as its fraction field. -/
theorem algebraicClosure_isFractionRing :
    IsFractionRing
      (SourceMLFAlgebraicIntegerRing K)
      (AlgebraicClosure K) := by
  let baseRing :=
    Valuation.integer (ValuativeRel.valuation K)
  letI :
      Algebra.IsAlgebraic baseRing (AlgebraicClosure K) :=
    IsFractionRing.comap_isAlgebraic_iff.mpr
      (inferInstance :
        Algebra.IsAlgebraic K (AlgebraicClosure K))
  exact
    integralClosure.isFractionRing_of_algebraic
      (fun value equality =>
        (FaithfulSMul.algebraMap_injective
          baseRing (AlgebraicClosure K)) (by
            rw [map_zero]
            exact equality))

/-- Include a nonzero algebraic integer in `kbar^x`. -/
noncomputable def toAlgebraicClosureUnits :
    SourceMLFIntegralMonoid K →*
      (AlgebraicClosure K)ˣ where
  toFun value :=
    Units.mk0 value.1.1
      (fun equality =>
        nonZeroDivisors.coe_ne_zero value
          (Subtype.ext equality))
  map_one' := by
    apply Units.ext
    rfl
  map_mul' first second := by
    apply Units.ext
    rfl

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
/-- Send a formal quotient of nonzero algebraic integers to its quotient in `kbar^x`. -/
noncomputable def groupificationToAlgebraicClosureUnits :
    Algebra.GrothendieckGroup (SourceMLFIntegralMonoid K) →*
      (AlgebraicClosure K)ˣ :=
  Algebra.GrothendieckGroup.lift
    (toAlgebraicClosureUnits K)

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
@[simp]
theorem groupificationToAlgebraicClosureUnits_of
    (value : SourceMLFIntegralMonoid K) :
    groupificationToAlgebraicClosureUnits K
        (Algebra.GrothendieckGroup.of value) =
      toAlgebraicClosureUnits K value := by
  let universalProperty :=
    Equiv.symm_apply_apply
      (Algebra.GrothendieckGroup.lift
        (M := SourceMLFIntegralMonoid K)
        (G := (AlgebraicClosure K)ˣ))
      (toAlgebraicClosureUnits K)
  change
    (Algebra.GrothendieckGroup.lift
        (toAlgebraicClosureUnits K)).comp
          Algebra.GrothendieckGroup.of =
      toAlgebraicClosureUnits K at universalProperty
  exact DFunLike.congr_fun universalProperty value

/-- An injective monoid map into a group remains injective after groupification. -/
theorem grothendieckLift_injective
    {M B : Type u} [CommMonoid M] [CommGroup B]
    (hom : M →* B)
    (hom_injective : Function.Injective hom) :
    Function.Injective
      (Algebra.GrothendieckGroup.lift hom) := by
  letI : IsCancelMul M :=
    hom_injective.isCancelMul hom (map_mul hom)
  change Function.Injective
    ((Localization.monoidOf (⊤ : Submonoid M)).lift
      (fun _ => Group.isUnit _))
  rw [Submonoid.LocalizationMap.lift_injective_iff]
  intro first second
  constructor
  · intro equality
    exact congrArg hom
      (Algebra.GrothendieckGroup.of_injective equality)
  · intro equality
    exact congrArg Algebra.GrothendieckGroup.of
      (hom_injective equality)

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
/-- Every element of `kbar^x` is a quotient of nonzero algebraic integers. -/
theorem groupificationToAlgebraicClosureUnits_surjective :
    Function.Surjective
      (groupificationToAlgebraicClosureUnits K) := by
  letI :
      IsFractionRing
        (SourceMLFAlgebraicIntegerRing K)
        (AlgebraicClosure K) :=
    algebraicClosure_isFractionRing K
  intro value
  obtain ⟨numerator, denominator, denominatorRegular,
      quotient_eq⟩ :=
    IsFractionRing.div_surjective
      (SourceMLFAlgebraicIntegerRing K)
      (value : AlgebraicClosure K)
  have numerator_ne_zero : numerator ≠ 0 := by
    intro equality
    subst numerator
    have value_eq_zero : (value : AlgebraicClosure K) = 0 := by
      simpa using quotient_eq.symm
    exact value.ne_zero value_eq_zero
  let numeratorMonoid : SourceMLFIntegralMonoid K :=
    ⟨numerator,
      mem_nonZeroDivisors_iff_ne_zero.mpr numerator_ne_zero⟩
  let denominatorMonoid : SourceMLFIntegralMonoid K :=
    ⟨denominator, denominatorRegular⟩
  refine
    ⟨Algebra.GrothendieckGroup.of numeratorMonoid /
        Algebra.GrothendieckGroup.of denominatorMonoid, ?_⟩
  rw [map_div, groupificationToAlgebraicClosureUnits_of,
    groupificationToAlgebraicClosureUnits_of]
  apply Units.ext
  exact quotient_eq

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
/-- The formal quotient map to `kbar^x` is injective. -/
theorem groupificationToAlgebraicClosureUnits_injective :
    Function.Injective
      (groupificationToAlgebraicClosureUnits K) :=
  grothendieckLift_injective
    (toAlgebraicClosureUnits K) (by
      intro first second equality
      apply Subtype.ext
      apply Subtype.ext
      exact congrArg Units.val equality)

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
/-- The groupification of `O_kbar^triangle` is canonically `kbar^x`. -/
noncomputable def groupificationEquivAlgebraicClosureUnits :
    Algebra.GrothendieckGroup (SourceMLFIntegralMonoid K) ≃*
      (AlgebraicClosure K)ˣ :=
  MulEquiv.ofBijective
    (groupificationToAlgebraicClosureUnits K)
    ⟨groupificationToAlgebraicClosureUnits_injective K,
      groupificationToAlgebraicClosureUnits_surjective K⟩

/--
A finite-order element of `kbar^x` is an actual unit of
`O_kbar^triangle`: both it and its inverse are integral over `O_k`.
-/
noncomputable def torsionUnit
    (value : (AlgebraicClosure K)ˣ)
    (n : ℕ) (n_ne_zero : n ≠ 0)
    (value_pow : value ^ n = 1) :
    (SourceMLFIntegralMonoid K)ˣ := by
  let baseRing :=
    Valuation.integer (ValuativeRel.valuation K)
  have value_integral :
      IsIntegral baseRing (value : AlgebraicClosure K) := by
    apply IsIntegral.of_pow (Nat.pos_of_ne_zero n_ne_zero)
    rw [← Units.val_pow_eq_pow_val, value_pow]
    exact isIntegral_one
  have inverse_pow : value⁻¹ ^ n = 1 := by
    rw [inv_pow, value_pow, inv_one]
  have inverse_integral :
      IsIntegral baseRing (value⁻¹ : AlgebraicClosure K) := by
    apply IsIntegral.of_pow (Nat.pos_of_ne_zero n_ne_zero)
    have inverse_pow_value := congrArg Units.val inverse_pow
    have inverse_pow_base :
        ((value : AlgebraicClosure K)⁻¹) ^ n = 1 := by
      simpa only [Units.val_pow_eq_pow_val,
        Units.val_inv_eq_inv_val, Units.val_one] using inverse_pow_value
    rw [inverse_pow_base]
    exact isIntegral_one
  let integralValue : SourceMLFAlgebraicIntegerRing K :=
    ⟨value, value_integral⟩
  let integralInverse : SourceMLFAlgebraicIntegerRing K :=
    ⟨value⁻¹, inverse_integral⟩
  let monoidValue : SourceMLFIntegralMonoid K :=
    ⟨integralValue,
      mem_nonZeroDivisors_iff_ne_zero.mpr (by
        intro equality
        exact value.ne_zero (congrArg Subtype.val equality))⟩
  let monoidInverse : SourceMLFIntegralMonoid K :=
    ⟨integralInverse,
      mem_nonZeroDivisors_iff_ne_zero.mpr (by
        intro equality
        have underlying :=
          congrArg
            (fun z : SourceMLFAlgebraicIntegerRing K =>
              (z : AlgebraicClosure K)) equality
        exact value⁻¹.ne_zero (by
          simpa [integralInverse] using underlying))⟩
  exact
    { val := monoidValue
      inv := monoidInverse
      val_inv := by
        apply Subtype.ext
        apply Subtype.ext
        simpa [monoidValue, monoidInverse,
          integralValue, integralInverse] using value.val_inv
      inv_val := by
        apply Subtype.ext
        apply Subtype.ext
        simpa [monoidValue, monoidInverse,
          integralValue, integralInverse] using value.inv_val }

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
/-- The integral torsion unit maps back to the specified element of `kbar^x`. -/
theorem torsionUnit_image
    (value : (AlgebraicClosure K)ˣ)
    (n : ℕ) (n_ne_zero : n ≠ 0)
    (value_pow : value ^ n = 1) :
    groupificationEquivAlgebraicClosureUnits K
        (Algebra.GrothendieckGroup.of
          ((torsionUnit K value n n_ne_zero value_pow :
            (SourceMLFIntegralMonoid K)ˣ) :
              SourceMLFIntegralMonoid K)) =
      value := by
  change
    groupificationToAlgebraicClosureUnits K
        (Algebra.GrothendieckGroup.of
          ((torsionUnit K value n n_ne_zero value_pow :
            (SourceMLFIntegralMonoid K)ˣ) :
              SourceMLFIntegralMonoid K)) =
      value
  rw [groupificationToAlgebraicClosureUnits_of]
  apply Units.ext
  rfl

/-- Algebraic closedness makes `kbar^x` rootable by every positive integer. -/
@[implicit_reducible]
noncomputable def algebraicClosureUnitsRootableByNat :
    RootableBy (AlgebraicClosure K)ˣ ℕ :=
  rootableByOfPowLeftSurj _ _ fun {n} n_ne_zero value => by
    obtain ⟨root, root_pow⟩ :=
      IsAlgClosed.exists_pow_nat_eq
        (value : AlgebraicClosure K)
        (Nat.pos_of_ne_zero n_ne_zero)
    have root_ne_zero : root ≠ 0 := by
      intro root_eq_zero
      subst root
      rw [zero_pow n_ne_zero] at root_pow
      exact value.ne_zero root_pow.symm
    refine ⟨Units.mk0 root root_ne_zero, ?_⟩
    apply Units.ext
    exact root_pow

set_option synthInstance.maxHeartbeats 200000 in
-- Unfolding the integral-closure nonzero-divisor monoid requires a larger instance-search budget.
/-- Consequently the groupification of `O_kbar^triangle` is rootable. -/
@[implicit_reducible]
noncomputable def groupificationRootableByNat :
    RootableBy
      (Algebra.GrothendieckGroup (SourceMLFIntegralMonoid K)) ℕ := by
  letI : RootableBy (AlgebraicClosure K)ˣ ℕ :=
    algebraicClosureUnitsRootableByNat K
  let equivalence :=
    groupificationEquivAlgebraicClosureUnits K
  exact
    rootableByOfPowLeftSurj _ _
      fun {n} n_ne_zero value => by
        obtain ⟨root, root_pow⟩ :=
          RootableBy.surjective_pow
            ((AlgebraicClosure K)ˣ) ℕ
            n_ne_zero (equivalence value)
        refine ⟨equivalence.symm root, ?_⟩
        apply equivalence.injective
        simpa using root_pow

end SourceMLFIntegralMonoid

end Iut

namespace Algebra.GrothendieckGroup

variable {M N : Type u} [CommMonoid M] [CommMonoid N]

/-- The groupification map induced by a multiplicative equivalence. -/
noncomputable def mapEquiv (equivalence : M ≃* N) :
    Algebra.GrothendieckGroup M →*
      Algebra.GrothendieckGroup N :=
  lift (of.comp equivalence.toMonoidHom)

@[simp]
theorem mapEquiv_of
    (equivalence : M ≃* N)
    (value : M) :
    mapEquiv equivalence (of value) =
      of (equivalence value) := by
  let universalProperty :=
    Equiv.symm_apply_apply
      (lift
        (M := M)
        (G := Algebra.GrothendieckGroup N))
      (of.comp equivalence.toMonoidHom)
  change
    (lift
        (of.comp equivalence.toMonoidHom)).comp of =
      of.comp equivalence.toMonoidHom at universalProperty
  exact DFunLike.congr_fun universalProperty value

/-- Groupification carries a multiplicative equivalence to a group equivalence. -/
noncomputable def congr (equivalence : M ≃* N) :
    Algebra.GrothendieckGroup M ≃*
      Algebra.GrothendieckGroup N where
  toFun := mapEquiv equivalence
  invFun := mapEquiv equivalence.symm
  left_inv value := by
    suffices
        (mapEquiv equivalence.symm).comp
            (mapEquiv equivalence) =
          MonoidHom.id _ by
      exact DFunLike.congr_fun this value
    apply lift.symm.injective
    ext monoidValue
    simp only [lift_symm_apply, MonoidHom.comp_apply,
      mapEquiv_of, MonoidHom.id_apply,
      equivalence.symm_apply_apply]
  right_inv value := by
    suffices
        (mapEquiv equivalence).comp
            (mapEquiv equivalence.symm) =
          MonoidHom.id _ by
      exact DFunLike.congr_fun this value
    apply lift.symm.injective
    ext monoidValue
    simp only [lift_symm_apply, MonoidHom.comp_apply,
      mapEquiv_of, MonoidHom.id_apply,
      equivalence.apply_symm_apply]
  map_mul' first second :=
    map_mul (mapEquiv equivalence) first second

end Algebra.GrothendieckGroup

namespace Iut

/--
The remaining torsion-cyclotomic certificate on the literal model monoid
`O_(kbar)^triangle`.  Its carrier and Galois action are constructed above;
identifying all roots of unity with `Q/Z` is the exact library gap.
-/
structure SourceMLFModelTMStructure
    (K : Type u) [Field K] [ValuativeRel K]
    [TopologicalSpace K] [IsNonarchimedeanLocalField K]
    [CharZero K] where
  torsion_cyclotomic :
    Nonempty
      (CommGroup.torsion (SourceMLFIntegralMonoid K)ˣ ≃*
        Multiplicative (AddCircle (1 : ℚ)))

namespace SourceMLFModelTMStructure

variable
  {K : Type u} [Field K] [ValuativeRel K]
  [TopologicalSpace K] [IsNonarchimedeanLocalField K]
  [CharZero K]

/-- The literal model monoid packaged as a torsion-cyclotomic object. -/
noncomputable def arithmeticMonoid
    (model : SourceMLFModelTMStructure K) :
    SourceTorsionCyclotomicCommMonoid.{u} where
  carrier := SourceMLFIntegralMonoid K
  commMonoidStructure := inferInstance
  cancelMul :=
    { mul_left_cancel := by
        intro value first second equality
        apply SetCoe.ext
        exact
          (isRegular_iff_mem_nonZeroDivisors.mpr value.2).left
            (congrArg Subtype.val equality)
      mul_right_cancel := by
        intro value first second equality
        apply SetCoe.ext
        exact
          (isRegular_iff_mem_nonZeroDivisors.mpr value.2).right
            (congrArg Subtype.val equality) }
  torsion_cyclotomic := model.torsion_cyclotomic

end SourceMLFModelTMStructure

/--
A model MLF-Galois `TM`-pair from Absolute Anabelian Topics III,
Definition 3.1(i): a topological group `Pi_k`, a continuous surjection to the
Krull-topological `G_k`, and the resulting action on `O_(kbar)^triangle`.
-/
structure SourceMLFModelTMPair
    (K : Type u) [Field K] [ValuativeRel K]
    [TopologicalSpace K] [IsNonarchimedeanLocalField K]
    [CharZero K] where
  modelStructure : SourceMLFModelTMStructure K
  galoisGroup : TopologicalGroupCat.{u}
  augmentation :
    galoisGroup ⟶ SourceMLFAbsoluteGaloisGroup K
  augmentation_surjective : Function.Surjective augmentation.toFun

namespace SourceMLFModelTMPair

variable
  {K : Type u} [Field K] [ValuativeRel K]
  [TopologicalSpace K] [IsNonarchimedeanLocalField K]
  [CharZero K]

/-- The model action obtained by composing with the Galois augmentation. -/
noncomputable def action
    (model : SourceMLFModelTMPair K) :
    model.galoisGroup →*
      MulAut (SourceMLFIntegralMonoid K) :=
  (SourceMLFIntegralMonoid.galoisAction K).comp
    model.augmentation.toMonoidHom

end SourceMLFModelTMPair

/--
A separately useful topological presentation of torsion-cyclotomic action
data.  The source-faithful MLF-Galois pair below instead uses Remark 3.1.1's
topology-free presentation, so this record cannot certify a model pair.
-/
structure SourceMLFGaloisTMPairData
    (G : TopologicalGroupCat.{u}) where
  arithmeticMonoid :
    SourceTorsionCyclotomicTopologicalCommMonoid.{u}
  action :
    G →* MulAut arithmeticMonoid.carrier
  continuous_action :
    Continuous fun input :
      G × arithmeticMonoid.carrier =>
        action input.1 input.2

namespace SourceMLFGaloisTMPairData

/-- The induced action on `mu_Z(M)` by postcomposition on the unit values. -/
def cyclotomeActionMulAut
    {G : TopologicalGroupCat.{u}}
    (pair : SourceMLFGaloisTMPairData G)
    (g : G) :
    MulAut (SourceMonoidCyclotome pair.arithmeticMonoid.carrier) where
  toFun cyclotome :=
    (Units.map (pair.action g).toMonoidHom).comp
      cyclotome
  invFun cyclotome :=
    (Units.map (pair.action g⁻¹).toMonoidHom).comp
      cyclotome
  left_inv cyclotome := by
    ext value
    simp
  right_inv cyclotome := by
    ext value
    simp
  map_mul' first second := by
    ext value
    simp

/-- The induced cyclotome automorphisms form a genuine Galois action. -/
def cyclotomeAction
    {G : TopologicalGroupCat.{u}}
    (pair : SourceMLFGaloisTMPairData G) :
    G →* MulAut
      (SourceMonoidCyclotome pair.arithmeticMonoid.carrier) where
  toFun := pair.cyclotomeActionMulAut
  map_one' := by
    apply MulEquiv.ext
    intro cyclotome
    ext value
    simp [cyclotomeActionMulAut]
  map_mul' first second := by
    apply MulEquiv.ext
    intro cyclotome
    ext value
    simp [cyclotomeActionMulAut]

/-- Forget the torsion-cyclotomic property but retain the actual action pair. -/
def toActionPair
    {G : TopologicalGroupCat.{u}}
    (pair : SourceMLFGaloisTMPairData G) :
    SourceTopologicalGroupMonoidActionPair where
  actingGroup := G
  monoidCarrier := pair.arithmeticMonoid.carrier
  action := pair.action
  continuous_action := pair.continuous_action

end SourceMLFGaloisTMPairData

/--
An MLF-Galois `TM`-pair in the exact algebraic presentation authorized by
Absolute Anabelian Topics III, Remark 3.1.1: its group and monoid action are
equivariantly isomorphic to a literal model pair over a mixed-characteristic
nonarchimedean local field, as required by Definition 3.1(ii).
-/
structure SourceMLFGaloisTMPair
    (G : TopologicalGroupCat.{u}) where
  arithmeticMonoid : SourceTorsionCyclotomicCommMonoid.{u}
  action : G →* MulAut arithmeticMonoid.carrier
  modelField : Type u
  [modelFieldStructure : Field modelField]
  [modelValuativeRel : ValuativeRel modelField]
  [modelTopology : TopologicalSpace modelField]
  [modelIsMLF : IsNonarchimedeanLocalField modelField]
  [modelCharZero : CharZero modelField]
  model : SourceMLFModelTMPair modelField
  groupIso : model.galoisGroup ≃ₜ* G
  monoidIso :
    SourceMLFIntegralMonoid modelField ≃*
      arithmeticMonoid.carrier
  equivariant :
    ∀ modelGroupElement modelMonoidElement,
      monoidIso
          (model.action modelGroupElement modelMonoidElement) =
        action (groupIso modelGroupElement)
          (monoidIso modelMonoidElement)

attribute [instance]
  SourceMLFGaloisTMPair.modelFieldStructure
  SourceMLFGaloisTMPair.modelValuativeRel
  SourceMLFGaloisTMPair.modelTopology
  SourceMLFGaloisTMPair.modelIsMLF
  SourceMLFGaloisTMPair.modelCharZero

namespace SourceMLFGaloisTMPair

variable {G : TopologicalGroupCat.{u}}

/-- Pull the Krull-open stabilizer of a model element back to the model group `Pi_k`. -/
noncomputable def modelOpenStabilizer
    (pair : SourceMLFGaloisTMPair G)
    (value : SourceMLFIntegralMonoid pair.modelField) :
    OpenSubgroup pair.model.galoisGroup :=
  (SourceMLFIntegralMonoid.absoluteOpenStabilizer
      pair.modelField value).comap
    pair.model.augmentation.toMonoidHom
    pair.model.augmentation.continuous_toFun

/--
The canonical open stabilizer of a monoid element, transported from the
literal MLF model through the group and monoid isomorphisms.
-/
noncomputable def openStabilizer
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier) :
    OpenSubgroup G :=
  (pair.modelOpenStabilizer (pair.monoidIso.symm value)).comap
    pair.groupIso.symm.toMonoidHom
    pair.groupIso.symm.continuous_toFun

/-- Every element of the canonical open stabilizer fixes the monoid value. -/
theorem openStabilizer_fixed
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (g : pair.openStabilizer value) :
    pair.action (g : G) value = value := by
  calc
    pair.action (g : G) value =
        pair.action
          (pair.groupIso (pair.groupIso.symm (g : G)))
          (pair.monoidIso (pair.monoidIso.symm value)) := by simp
    _ = pair.monoidIso
          (pair.model.action (pair.groupIso.symm (g : G))
            (pair.monoidIso.symm value)) :=
      (pair.equivariant
        (pair.groupIso.symm (g : G))
        (pair.monoidIso.symm value)).symm
    _ = pair.monoidIso (pair.monoidIso.symm value) := by
      apply congrArg pair.monoidIso
      apply Subtype.ext
      apply Subtype.ext
      exact g.property
    _ = value := pair.monoidIso.apply_symm_apply value

/-- The action on `M` extended functorially to its Grothendieck group. -/
noncomputable def grothendieckActionHom
    (pair : SourceMLFGaloisTMPair G)
    (g : G) :
    Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier →*
      Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier :=
  Algebra.GrothendieckGroup.lift
    ((Algebra.GrothendieckGroup.of).comp
      (pair.action g).toMonoidHom)

@[simp]
theorem grothendieckActionHom_of
    (pair : SourceMLFGaloisTMPair G)
    (g : G)
    (value : pair.arithmeticMonoid.carrier) :
    pair.grothendieckActionHom g
        (Algebra.GrothendieckGroup.of value) =
      Algebra.GrothendieckGroup.of
        (pair.action g value) := by
  let generatorMap :=
    (Algebra.GrothendieckGroup.of).comp
      (pair.action g).toMonoidHom
  have universalProperty :=
    Equiv.symm_apply_apply
      (Algebra.GrothendieckGroup.lift
        (M := pair.arithmeticMonoid.carrier)
        (G :=
          Algebra.GrothendieckGroup
            pair.arithmeticMonoid.carrier))
      generatorMap
  change
    (Algebra.GrothendieckGroup.lift generatorMap).comp
        Algebra.GrothendieckGroup.of =
      generatorMap at universalProperty
  exact DFunLike.congr_fun universalProperty value

/-- Each extended action is an automorphism of the Grothendieck group. -/
noncomputable def grothendieckActionMulAut
    (pair : SourceMLFGaloisTMPair G)
    (g : G) :
    MulAut
      (Algebra.GrothendieckGroup
        pair.arithmeticMonoid.carrier) where
  toFun := pair.grothendieckActionHom g
  invFun := pair.grothendieckActionHom g⁻¹
  left_inv value := by
    suffices
        (pair.grothendieckActionHom g⁻¹).comp
            (pair.grothendieckActionHom g) =
          MonoidHom.id _ by
      exact DFunLike.congr_fun this value
    apply Algebra.GrothendieckGroup.lift.symm.injective
    ext monoidValue
    simp only [Algebra.GrothendieckGroup.lift_symm_apply,
      MonoidHom.comp_apply, grothendieckActionHom_of,
      MonoidHom.id_apply]
    rw [map_inv]
    exact
      congrArg Algebra.GrothendieckGroup.of
        ((pair.action g).symm_apply_apply monoidValue)
  right_inv value := by
    suffices
        (pair.grothendieckActionHom g).comp
            (pair.grothendieckActionHom g⁻¹) =
          MonoidHom.id _ by
      exact DFunLike.congr_fun this value
    apply Algebra.GrothendieckGroup.lift.symm.injective
    ext monoidValue
    simp only [Algebra.GrothendieckGroup.lift_symm_apply,
      MonoidHom.comp_apply, grothendieckActionHom_of,
      MonoidHom.id_apply]
    rw [map_inv]
    exact
      congrArg Algebra.GrothendieckGroup.of
        ((pair.action g).apply_symm_apply monoidValue)
  map_mul' first second :=
    map_mul (pair.grothendieckActionHom g) first second

@[simp]
theorem grothendieckActionMulAut_of
    (pair : SourceMLFGaloisTMPair G)
    (g : G)
    (value : pair.arithmeticMonoid.carrier) :
    pair.grothendieckActionMulAut g
        (Algebra.GrothendieckGroup.of value) =
      Algebra.GrothendieckGroup.of
        (pair.action g value) :=
  pair.grothendieckActionHom_of g value

theorem grothendieckActionHom_one
    (pair : SourceMLFGaloisTMPair G) :
    pair.grothendieckActionHom 1 =
      MonoidHom.id _ := by
  apply Algebra.GrothendieckGroup.lift.symm.injective
  ext monoidValue
  simp only [Algebra.GrothendieckGroup.lift_symm_apply,
    MonoidHom.comp_apply, grothendieckActionHom_of,
    MonoidHom.id_apply, map_one]
  rfl

theorem grothendieckActionHom_mul
    (pair : SourceMLFGaloisTMPair G)
    (first second : G) :
    pair.grothendieckActionHom (first * second) =
      (pair.grothendieckActionHom first).comp
        (pair.grothendieckActionHom second) := by
  apply Algebra.GrothendieckGroup.lift.symm.injective
  ext monoidValue
  simp only [Algebra.GrothendieckGroup.lift_symm_apply,
    MonoidHom.comp_apply, grothendieckActionHom_of,
    map_mul]
  rfl

/-- The extended automorphisms form the action on the groupification. -/
noncomputable def grothendieckAction
    (pair : SourceMLFGaloisTMPair G) :
    G →* MulAut
      (Algebra.GrothendieckGroup
        pair.arithmeticMonoid.carrier) where
  toFun := pair.grothendieckActionMulAut
  map_one' := by
    apply MulEquiv.ext
    intro value
    exact DFunLike.congr_fun pair.grothendieckActionHom_one value
  map_mul' first second := by
    apply MulEquiv.ext
    intro value
    exact
      DFunLike.congr_fun
        (pair.grothendieckActionHom_mul first second)
        value

/-- The groupification action regarded as an ordinary multiplicative action. -/
@[implicit_reducible]
noncomputable def groupificationMulAction
    (pair : SourceMLFGaloisTMPair G) :
    MulAction G
      (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) :=
  MulAction.compHom _ pair.grothendieckAction

/--
An explicit open subgroup fixing a groupification element: intersect the
canonical open stabilizers of a localization numerator and denominator.
-/
noncomputable def groupificationOpenStabilizer
    (pair : SourceMLFGaloisTMPair G)
    (value : Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) :
    OpenSubgroup G :=
  pair.openStabilizer ((Localization.monoidOf ⊤).sec value).1 ⊓
    pair.openStabilizer (((Localization.monoidOf ⊤).sec value).2 :
      pair.arithmeticMonoid.carrier)

/-- The groupification action fixes an element on its constructed open stabilizer. -/
theorem groupificationOpenStabilizer_fixed
    (pair : SourceMLFGaloisTMPair G)
    (value : Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier)
    (g : pair.groupificationOpenStabilizer value) :
    pair.grothendieckAction (g : G) value = value := by
  let numerator := ((Localization.monoidOf ⊤).sec value).1
  let denominator : pair.arithmeticMonoid.carrier :=
    ((Localization.monoidOf ⊤).sec value).2
  have value_eq :
      value = Algebra.GrothendieckGroup.of numerator /
        Algebra.GrothendieckGroup.of denominator := by
    symm
    simpa [Submonoid.LocalizationMap.mk'] using
      (Localization.monoidOf ⊤).mk'_sec value
  calc
    pair.grothendieckAction (g : G) value =
        pair.grothendieckAction (g : G)
          (Algebra.GrothendieckGroup.of numerator /
            Algebra.GrothendieckGroup.of denominator) :=
      congrArg (pair.grothendieckAction (g : G)) value_eq
    _ = Algebra.GrothendieckGroup.of (pair.action (g : G) numerator) /
          Algebra.GrothendieckGroup.of (pair.action (g : G) denominator) := by
      rw [map_div]
      congr 1
      · exact pair.grothendieckActionHom_of (g : G) numerator
      · exact pair.grothendieckActionHom_of (g : G) denominator
    _ = Algebra.GrothendieckGroup.of numerator /
          Algebra.GrothendieckGroup.of denominator := by
      rw [pair.openStabilizer_fixed numerator
          (⟨(g : G), g.property.1⟩ : pair.openStabilizer numerator),
        pair.openStabilizer_fixed denominator
          (⟨(g : G), g.property.2⟩ : pair.openStabilizer denominator)]
    _ = value := value_eq.symm

/-- Every stabilizer for the groupification action is Krull-open. -/
theorem groupification_stabilizer_isOpen
    (pair : SourceMLFGaloisTMPair G)
    (value : Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) :
    letI := pair.groupificationMulAction
    IsOpen (MulAction.stabilizer G value : Set G) := by
  letI := pair.groupificationMulAction
  apply Subgroup.isOpen_mono
    (H₁ := pair.groupificationOpenStabilizer value)
    (H₂ := MulAction.stabilizer G value)
  · intro g hg
    exact pair.groupificationOpenStabilizer_fixed value ⟨g, hg⟩
  · exact (pair.groupificationOpenStabilizer value).isOpen

/-- The groupification action is continuous when its algebraic carrier is discrete. -/
theorem groupificationAction_continuous_discrete
    (pair : SourceMLFGaloisTMPair G) :
    letI : TopologicalSpace
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⊥
    letI := pair.groupificationMulAction
    ContinuousSMul G
      (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := by
  letI : TopologicalSpace
      (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⊥
  letI : DiscreteTopology
      (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⟨rfl⟩
  letI := pair.groupificationMulAction
  exact continuousSMul_iff_stabilizer_isOpen.mpr
    pair.groupification_stabilizer_isOpen

/-- Postcomposition by one Galois automorphism on the monoid cyclotome. -/
def cyclotomeActionMulAut
    (pair : SourceMLFGaloisTMPair G)
    (g : G) :
    MulAut
      (SourceMonoidCyclotome pair.arithmeticMonoid.carrier) where
  toFun cyclotome :=
    (Units.map (pair.action g).toMonoidHom).comp cyclotome
  invFun cyclotome :=
    (Units.map (pair.action g⁻¹).toMonoidHom).comp cyclotome
  left_inv cyclotome := by
    ext value
    simp
  right_inv cyclotome := by
    ext value
    simp
  map_mul' first second := by
    ext value
    simp

/-- The induced action on the literal monoid cyclotome. -/
def cyclotomeAction
    (pair : SourceMLFGaloisTMPair G) :
    G →* MulAut
      (SourceMonoidCyclotome pair.arithmeticMonoid.carrier) where
  toFun := pair.cyclotomeActionMulAut
  map_one' := by
    apply MulEquiv.ext
    intro cyclotome
    ext value
    simp [cyclotomeActionMulAut]
  map_mul' first second := by
    apply MulEquiv.ext
    intro cyclotome
    ext value
    simp [cyclotomeActionMulAut]

/-- The action induced on the unit group of the arithmetic monoid. -/
def unitActionMulAut
    (pair : SourceMLFGaloisTMPair G)
    (g : G) :
    MulAut pair.arithmeticMonoid.carrierˣ :=
  Units.mapEquiv (pair.action g)

/-- The unit automorphisms form a genuine action. -/
def unitAction
    (pair : SourceMLFGaloisTMPair G) :
    G →* MulAut pair.arithmeticMonoid.carrierˣ where
  toFun := pair.unitActionMulAut
  map_one' := by
    apply MulEquiv.ext
    intro unit
    apply Units.ext
    simp [unitActionMulAut]
  map_mul' first second := by
    apply MulEquiv.ext
    intro unit
    apply Units.ext
    simp [unitActionMulAut]

/-- The unit action regarded as an ordinary multiplicative action. -/
@[implicit_reducible]
noncomputable def unitMulAction
    (pair : SourceMLFGaloisTMPair G) :
    MulAction G pair.arithmeticMonoid.carrierˣ :=
  MulAction.compHom _ pair.unitAction

/-- Every unit stabilizer is Krull-open. -/
theorem unit_stabilizer_isOpen
    (pair : SourceMLFGaloisTMPair G)
    (unit : pair.arithmeticMonoid.carrierˣ) :
    letI := pair.unitMulAction
    IsOpen (MulAction.stabilizer G unit : Set G) := by
  letI := pair.unitMulAction
  apply Subgroup.isOpen_mono
    (H₁ := pair.openStabilizer (unit : pair.arithmeticMonoid.carrier))
    (H₂ := MulAction.stabilizer G unit)
  · intro g hg
    apply Units.ext
    exact pair.openStabilizer_fixed unit ⟨g, hg⟩
  · exact (pair.openStabilizer (unit : pair.arithmeticMonoid.carrier)).isOpen

/-- The action on units is continuous for the discrete algebraic topology. -/
theorem unitAction_continuous_discrete
    (pair : SourceMLFGaloisTMPair G) :
    letI : TopologicalSpace pair.arithmeticMonoid.carrierˣ := ⊥
    letI := pair.unitMulAction
    ContinuousSMul G pair.arithmeticMonoid.carrierˣ := by
  letI : TopologicalSpace pair.arithmeticMonoid.carrierˣ := ⊥
  letI : DiscreteTopology pair.arithmeticMonoid.carrierˣ := ⟨rfl⟩
  letI := pair.unitMulAction
  exact continuousSMul_iff_stabilizer_isOpen.mpr
    pair.unit_stabilizer_isOpen

/-!
## The `times-mu` Kummer quotient

The following declarations implement IUT II, Definition 4.9(i).  In
particular, `O^{times-mu}` is the actual unit group modulo all torsion, and
the Kummer indeterminacy is the orbit under the exact `Ism` subgroup determined
by the images of the open-subgroup invariants.
-/

/-- The literal quotient `O^times / O^mu` of units by all torsion units. -/
abbrev UnitModuloTorsion (pair : SourceMLFGaloisTMPair G) :=
  pair.arithmeticMonoid.carrierˣ ⧸
    CommGroup.torsion pair.arithmeticMonoid.carrierˣ

/-- The quotient map kills exactly the torsion units. -/
theorem unitModuloTorsion_eq_one_iff
    (pair : SourceMLFGaloisTMPair G)
    (unit : pair.arithmeticMonoid.carrierˣ) :
    (QuotientGroup.mk unit : pair.UnitModuloTorsion) = 1 ↔
      unit ∈ CommGroup.torsion pair.arithmeticMonoid.carrierˣ := by
  exact QuotientGroup.eq_one_iff
    (N := CommGroup.torsion pair.arithmeticMonoid.carrierˣ) unit

/-- Every Galois automorphism preserves the subgroup of torsion units. -/
theorem unitAction_mem_torsion_iff
    (pair : SourceMLFGaloisTMPair G) (g : G)
    (unit : pair.arithmeticMonoid.carrierˣ) :
    pair.unitActionMulAut g unit ∈
        CommGroup.torsion pair.arithmeticMonoid.carrierˣ ↔
      unit ∈ CommGroup.torsion pair.arithmeticMonoid.carrierˣ := by
  rw [CommGroup.mem_torsion, CommGroup.mem_torsion]
  constructor
  · intro hfinite
    rcases isOfFinOrder_iff_pow_eq_one.mp hfinite with
      ⟨n, hn, hpow⟩
    apply isOfFinOrder_iff_pow_eq_one.mpr
    refine ⟨n, hn, ?_⟩
    apply (pair.unitActionMulAut g).injective
    rw [map_pow, map_one]
    exact hpow
  · intro hfinite
    rcases isOfFinOrder_iff_pow_eq_one.mp hfinite with
      ⟨n, hn, hpow⟩
    apply isOfFinOrder_iff_pow_eq_one.mpr
    refine ⟨n, hn, ?_⟩
    rw [← map_pow, hpow, map_one]

/-- One Galois automorphism descended to the quotient by all torsion. -/
noncomputable def unitModuloTorsionActionHom
    (pair : SourceMLFGaloisTMPair G) (g : G) :
    pair.UnitModuloTorsion →* pair.UnitModuloTorsion :=
  QuotientGroup.map
    (CommGroup.torsion pair.arithmeticMonoid.carrierˣ)
    (CommGroup.torsion pair.arithmeticMonoid.carrierˣ)
    (pair.unitActionMulAut g).toMonoidHom
    (by
      intro unit hunit
      exact (pair.unitAction_mem_torsion_iff g unit).mpr hunit)

@[simp]
theorem unitModuloTorsionActionHom_mk
    (pair : SourceMLFGaloisTMPair G) (g : G)
    (unit : pair.arithmeticMonoid.carrierˣ) :
    pair.unitModuloTorsionActionHom g
        (QuotientGroup.mk unit) =
      QuotientGroup.mk (pair.unitActionMulAut g unit) :=
  rfl

/-- The descended map is an automorphism of `O^{times-mu}`. -/
noncomputable def unitModuloTorsionActionMulAut
    (pair : SourceMLFGaloisTMPair G) (g : G) :
    MulAut pair.UnitModuloTorsion where
  toFun := pair.unitModuloTorsionActionHom g
  invFun := pair.unitModuloTorsionActionHom g⁻¹
  left_inv value := by
    induction value using QuotientGroup.induction_on with
    | _ unit =>
      change QuotientGroup.mk
          (pair.unitActionMulAut g⁻¹
            (pair.unitActionMulAut g unit)) =
        QuotientGroup.mk unit
      congr 1
      apply Units.ext
      simp [unitActionMulAut]
  right_inv value := by
    induction value using QuotientGroup.induction_on with
    | _ unit =>
      change QuotientGroup.mk
          (pair.unitActionMulAut g
            (pair.unitActionMulAut g⁻¹ unit)) =
        QuotientGroup.mk unit
      congr 1
      apply Units.ext
      simp [unitActionMulAut]
  map_mul' := map_mul (pair.unitModuloTorsionActionHom g)

@[simp]
theorem unitModuloTorsionActionMulAut_mk
    (pair : SourceMLFGaloisTMPair G) (g : G)
    (unit : pair.arithmeticMonoid.carrierˣ) :
    pair.unitModuloTorsionActionMulAut g
        (QuotientGroup.mk unit) =
      QuotientGroup.mk (pair.unitActionMulAut g unit) :=
  rfl

/-- The descended automorphisms form the Galois action on `O^{times-mu}`. -/
noncomputable def unitModuloTorsionAction
    (pair : SourceMLFGaloisTMPair G) :
    G →* MulAut pair.UnitModuloTorsion where
  toFun := pair.unitModuloTorsionActionMulAut
  map_one' := by
    apply MulEquiv.ext
    intro value
    induction value using QuotientGroup.induction_on with
    | _ unit =>
      change QuotientGroup.mk (pair.unitActionMulAut 1 unit) =
        QuotientGroup.mk unit
      congr 1
      apply Units.ext
      simp [unitActionMulAut]
  map_mul' first second := by
    apply MulEquiv.ext
    intro value
    induction value using QuotientGroup.induction_on with
    | _ unit =>
      change QuotientGroup.mk
          (pair.unitActionMulAut (first * second) unit) =
        QuotientGroup.mk
          (pair.unitActionMulAut first
            (pair.unitActionMulAut second unit))
      congr 1
      apply Units.ext
      simp [unitActionMulAut]

/-- The subgroup of units fixed by one Krull-open subgroup `H`. -/
def fixedUnitSubgroup
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G) :
    Subgroup pair.arithmeticMonoid.carrierˣ where
  carrier :=
    {unit | ∀ g : subgroup,
      pair.unitActionMulAut (g : G) unit = unit}
  one_mem' := fun _ => map_one _
  mul_mem' := by
    intro first second hfirst hsecond g
    rw [map_mul, hfirst g, hsecond g]
  inv_mem' := by
    intro unit hunit g
    rw [map_inv, hunit g]

/--
The submodule `I_H^kappa`: the image of the `H`-fixed units in
`O^{times-mu}`.
-/
noncomputable def invariantUnitImage
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G) :
    Subgroup pair.UnitModuloTorsion :=
  (pair.fixedUnitSubgroup subgroup).map
    (QuotientGroup.mk'
      (CommGroup.torsion pair.arithmeticMonoid.carrierˣ))

/-- The defining predicate for the group `Ism` in IUT II, Example 1.8(iv). -/
def IsKummerIsometry
    (pair : SourceMLFGaloisTMPair G)
    (automorphism : MulAut pair.UnitModuloTorsion) : Prop :=
  (∀ g value,
      automorphism (pair.unitModuloTorsionAction g value) =
        pair.unitModuloTorsionAction g (automorphism value)) ∧
    ∀ subgroup,
      automorphism '' (pair.invariantUnitImage subgroup :
          Set pair.UnitModuloTorsion) =
        (pair.invariantUnitImage subgroup :
          Set pair.UnitModuloTorsion)

/--
The actual `Ism` subgroup: equivariant automorphisms preserving every
open-subgroup invariant image.
-/
noncomputable def kummerIsmSubgroup
    (pair : SourceMLFGaloisTMPair G) :
    Subgroup (MulAut pair.UnitModuloTorsion) where
  carrier := pair.IsKummerIsometry
  one_mem' := by
    constructor
    · intro g value
      rfl
    · intro subgroup
      ext value
      change
        (∃ source ∈ pair.invariantUnitImage subgroup,
            source = value) ↔
          value ∈ pair.invariantUnitImage subgroup
      simp
  mul_mem' := by
    intro first second hfirst hsecond
    constructor
    · intro g value
      change first (second (pair.unitModuloTorsionAction g value)) =
        pair.unitModuloTorsionAction g (first (second value))
      rw [hsecond.1, hfirst.1]
    · intro subgroup
      ext value
      constructor
      · rintro ⟨source, hsource, hvalue⟩
        change first (second source) = value at hvalue
        have hsecondSource :
            second source ∈ pair.invariantUnitImage subgroup := by
          have : second source ∈
              second '' (pair.invariantUnitImage subgroup :
                Set pair.UnitModuloTorsion) :=
            ⟨source, hsource, rfl⟩
          simpa only [hsecond.2 subgroup] using this
        have hfirstSource :
            first (second source) ∈
              pair.invariantUnitImage subgroup := by
          have : first (second source) ∈
              first '' (pair.invariantUnitImage subgroup :
                Set pair.UnitModuloTorsion) :=
            ⟨second source, hsecondSource, rfl⟩
          simpa only [hfirst.2 subgroup] using this
        rwa [hvalue] at hfirstSource
      · intro hvalue
        have hfirstImage : value ∈
            first '' (pair.invariantUnitImage subgroup :
              Set pair.UnitModuloTorsion) := by
          simpa only [hfirst.2 subgroup] using hvalue
        rcases hfirstImage with ⟨middle, hmiddle, rfl⟩
        have hsecondImage : middle ∈
            second '' (pair.invariantUnitImage subgroup :
              Set pair.UnitModuloTorsion) := by
          simpa only [hsecond.2 subgroup] using hmiddle
        rcases hsecondImage with ⟨source, hsource, rfl⟩
        exact ⟨source, hsource, rfl⟩
  inv_mem' := by
    intro automorphism hautomorphism
    constructor
    · intro g value
      apply automorphism.injective
      change
        automorphism (automorphism.symm
          (pair.unitModuloTorsionAction g value)) =
        automorphism
          (pair.unitModuloTorsionAction g
            (automorphism.symm value))
      rw [automorphism.apply_symm_apply]
      rw [hautomorphism.1 g (automorphism.symm value)]
      rw [automorphism.apply_symm_apply]
    · intro subgroup
      ext value
      constructor
      · rintro ⟨source, hsource, rfl⟩
        change automorphism.symm source ∈
          pair.invariantUnitImage subgroup
        have himage : source ∈
            automorphism '' (pair.invariantUnitImage subgroup :
              Set pair.UnitModuloTorsion) := by
          simpa only [hautomorphism.2 subgroup] using hsource
        rcases himage with ⟨preimage, hpreimage, heq⟩
        have hinverse : automorphism.symm source = preimage := by
          rw [← heq, automorphism.symm_apply_apply]
        rw [hinverse]
        exact hpreimage
      · intro hvalue
        refine ⟨automorphism value, ?_, ?_⟩
        · have : automorphism value ∈
              automorphism '' (pair.invariantUnitImage subgroup :
                Set pair.UnitModuloTorsion) :=
            ⟨value, hvalue, rfl⟩
          simpa only [hautomorphism.2 subgroup] using this
        · exact automorphism.symm_apply_apply value

/-- The group `Ism` attached to the literal `times-mu` quotient. -/
noncomputable abbrev KummerIsm (pair : SourceMLFGaloisTMPair G) :=
  pair.kummerIsmSubgroup

/--
One representative of a `times-mu` Kummer structure between two literal MLF
models: it is equivariant and carries every `I_H^kappa` onto its counterpart.
-/
structure TimesMuKummerIsomorphism
    (source target : SourceMLFGaloisTMPair G) where
  equiv : source.UnitModuloTorsion ≃* target.UnitModuloTorsion
  equivariant :
    ∀ g value,
      equiv (source.unitModuloTorsionAction g value) =
        target.unitModuloTorsionAction g (equiv value)
  invariantImage :
    ∀ subgroup,
      equiv '' (source.invariantUnitImage subgroup :
          Set source.UnitModuloTorsion) =
        (target.invariantUnitImage subgroup :
          Set target.UnitModuloTorsion)

namespace TimesMuKummerIsomorphism

@[ext]
theorem ext
    {source target : SourceMLFGaloisTMPair G}
    (first second : TimesMuKummerIsomorphism source target)
    (equiv_eq : first.equiv = second.equiv) :
    first = second := by
  cases first
  cases second
  cases equiv_eq
  rfl

/-- The identity representative of the `times-mu` Kummer orbit. -/
noncomputable def refl (pair : SourceMLFGaloisTMPair G) :
    TimesMuKummerIsomorphism pair pair where
  equiv := MulEquiv.refl _
  equivariant _ _ := rfl
  invariantImage _ := by
    ext value
    simp

/-- Precomposition by `Ism`, with the inverse convention for a left action. -/
noncomputable def precompose
    {source target : SourceMLFGaloisTMPair G}
    (isometry : source.KummerIsm)
    (comparison : TimesMuKummerIsomorphism source target) :
    TimesMuKummerIsomorphism source target := by
  let inverse : source.KummerIsm := isometry⁻¹
  refine
    { equiv := inverse.1.trans comparison.equiv
      equivariant := ?_
      invariantImage := ?_ }
  · intro g value
    change
      comparison.equiv
          (inverse.1 (source.unitModuloTorsionAction g value)) =
        target.unitModuloTorsionAction g
          (comparison.equiv (inverse.1 value))
    rw [inverse.property.1]
    exact comparison.equivariant g (inverse.1 value)
  · intro subgroup
    change
      (comparison.equiv ∘ inverse.1) ''
          (source.invariantUnitImage subgroup :
            Set source.UnitModuloTorsion) =
        (target.invariantUnitImage subgroup :
          Set target.UnitModuloTorsion)
    rw [Set.image_comp, inverse.property.2 subgroup,
      comparison.invariantImage subgroup]

/-- The defining left action of `Ism` on compatible Kummer isomorphisms. -/
@[implicit_reducible]
noncomputable def mulAction
    (source target : SourceMLFGaloisTMPair G) :
    MulAction source.KummerIsm
      (TimesMuKummerIsomorphism source target) where
  smul := precompose
  one_smul comparison := by
    apply ext
    apply MulEquiv.ext
    intro value
    rfl
  mul_smul first second comparison := by
    apply ext
    apply MulEquiv.ext
    intro value
    rfl

/-- Two compatible representatives differ by an actual source `Ism` element. -/
noncomputable def sourceDifference
    {source target : SourceMLFGaloisTMPair G}
    (first second : TimesMuKummerIsomorphism source target) :
    source.KummerIsm := by
  refine ⟨first.equiv.trans second.equiv.symm, ?_⟩
  constructor
  · intro g value
    apply second.equiv.injective
    change
      second.equiv
          (second.equiv.symm
            (first.equiv
              (source.unitModuloTorsionAction g value))) =
        second.equiv
          (source.unitModuloTorsionAction g
            (second.equiv.symm (first.equiv value)))
    rw [second.equiv.apply_symm_apply]
    rw [first.equivariant]
    rw [second.equivariant]
    rw [second.equiv.apply_symm_apply]
  · intro subgroup
    change
      (second.equiv.symm ∘ first.equiv) ''
          (source.invariantUnitImage subgroup :
            Set source.UnitModuloTorsion) =
        (source.invariantUnitImage subgroup :
          Set source.UnitModuloTorsion)
    rw [Set.image_comp, first.invariantImage subgroup,
      ← second.invariantImage subgroup]
    exact Equiv.symm_image_image second.equiv.toEquiv _

theorem sourceDifference_smul_first
    {source target : SourceMLFGaloisTMPair G}
    (first second : TimesMuKummerIsomorphism source target) :
    letI := mulAction source target
    sourceDifference first second • first = second := by
  letI := mulAction source target
  apply ext
  apply MulEquiv.ext
  intro value
  change
    first.equiv
        ((first.equiv.trans second.equiv.symm).symm value) =
      second.equiv value
  simp

noncomputable instance
    {source target : SourceMLFGaloisTMPair G} :
    MulAction source.KummerIsm
      (TimesMuKummerIsomorphism source target) :=
  mulAction source target

/--
A `times-mu` Kummer structure is the `Ism`-orbit of all compatible
representatives, exactly as in Definition 4.9(i).
-/
abbrev TimesMuKummerOrbit
    (source target : SourceMLFGaloisTMPair G) :=
  MulAction.orbitRel.Quotient source.KummerIsm
    (TimesMuKummerIsomorphism source target)

/-- The orbit represented by one compatible Kummer isomorphism. -/
noncomputable def orbitOf
    {source target : SourceMLFGaloisTMPair G}
    (comparison : TimesMuKummerIsomorphism source target) :
    TimesMuKummerOrbit source target :=
  Quotient.mk'' comparison

/--
The invariant-image conditions determine a unique `Ism`-orbit: any two
compatible Kummer isomorphisms represent the same Kummer structure.
-/
theorem orbitOf_eq
    {source target : SourceMLFGaloisTMPair G}
    (first second : TimesMuKummerIsomorphism source target) :
    orbitOf first = orbitOf second := by
  apply Quotient.sound
  change first ∈ MulAction.orbit source.KummerIsm second
  rw [MulAction.mem_orbit_iff]
  exact ⟨sourceDifference second first,
    sourceDifference_smul_first second first⟩

end TimesMuKummerIsomorphism

/-- The profinite cyclotome with its canonical continuous Galois action. -/
noncomputable def continuousCyclotomeAction
    (pair : SourceMLFGaloisTMPair G) :
    ContinuousGroupAction G
      (SourceMonoidCyclotome pair.arithmeticMonoid.carrier) where
  automorphism := pair.cyclotomeAction
  continuous_action := by
    rw [SourceMonoidCyclotome.continuous_iff_eval_discrete]
    intro q
    letI : TopologicalSpace pair.arithmeticMonoid.carrierˣ := ⊥
    letI : DiscreteTopology pair.arithmeticMonoid.carrierˣ := ⟨rfl⟩
    letI := pair.unitMulAction
    letI : ContinuousSMul G pair.arithmeticMonoid.carrierˣ :=
      pair.unitAction_continuous_discrete
    change Continuous fun input :
      G × SourceMonoidCyclotome pair.arithmeticMonoid.carrier =>
        input.1 • input.2 q
    exact continuous_smul.comp
      (continuous_fst.prodMk
        ((SourceMonoidCyclotome.continuous_eval_discrete
            pair.arithmeticMonoid.carrier q).comp continuous_snd))

/-- The submonoid fixed by an open subgroup, denoted M^H in Proposition 3.2(ii). -/
def fixedSubmonoid
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G) :
    Submonoid pair.arithmeticMonoid.carrier where
  carrier :=
    { value |
      ∀ g : subgroup,
        pair.action (g : G) value = value }
  one_mem' := fun g => map_one (pair.action (g : G))
  mul_mem' := by
    intro first second firstFixed secondFixed g
    rw [map_mul, firstFixed g, secondFixed g]

/-- Embed the units of `M` into the groupification of `M`. -/
noncomputable def unitGrothendieckHom
    (pair : SourceMLFGaloisTMPair G) :
    pair.arithmeticMonoid.carrierˣ →*
      Algebra.GrothendieckGroup
        pair.arithmeticMonoid.carrier :=
  (Algebra.GrothendieckGroup.of).comp
    { toFun := Units.val
      map_one' := rfl
      map_mul' := fun _ _ => rfl }

/-- Cancellativity makes the unit embedding in the groupification faithful. -/
theorem unitGrothendieckHom_injective
    (pair : SourceMLFGaloisTMPair G) :
    Function.Injective pair.unitGrothendieckHom := by
  intro first second equality
  apply Units.ext
  exact
    Algebra.GrothendieckGroup.of_injective
      (M := pair.arithmeticMonoid.carrier)
      equality

@[simp]
theorem unitGrothendieckHom_action
    (pair : SourceMLFGaloisTMPair G)
    (g : G)
    (unit : pair.arithmeticMonoid.carrierˣ) :
    pair.grothendieckAction g
        (pair.unitGrothendieckHom unit) =
      pair.unitGrothendieckHom
        (Units.map (pair.action g).toMonoidHom unit) := by
  change
    pair.grothendieckActionMulAut g
        (Algebra.GrothendieckGroup.of (unit : _)) =
      Algebra.GrothendieckGroup.of
        (pair.action g (unit : _))
  exact pair.grothendieckActionMulAut_of g unit

/-- Rootability of a multiplicative group is divisibility of its additive type tag. -/
@[implicit_reducible]
noncomputable def additiveDivisibleByNatOfRootable
    {B : Type u} [CommGroup B] [RootableBy B ℕ] :
    DivisibleBy (Additive B) ℕ where
  div value n :=
    Additive.ofMul (RootableBy.root value.toMul n)
  div_zero value := by
    change RootableBy.root value.toMul 0 = 1
    exact RootableBy.root_zero value.toMul
  div_cancel value hn := by
    change (RootableBy.root value.toMul _ ^ _) = value.toMul
    exact RootableBy.root_cancel value.toMul hn

/--
Extend the homomorphism `Z -> B` sending `1` to `value` across `Z -> Q`.
Divisibility makes `B` injective as an abelian group, so this produces one
coherent system of all rational powers, not unrelated choices of roots.
-/
noncomputable def rootableRationalPowers
    {B : Type u} [CommGroup B] [RootableBy B ℕ]
    (value : B) :
    ℚ →+ Additive B := by
  letI : DivisibleBy (Additive B) ℕ :=
    additiveDivisibleByNatOfRootable
  letI : DivisibleBy (Additive B) ℤ :=
    AddGroup.divisibleByIntOfDivisibleByNat (Additive B)
  let integerMap :
      AddCommGrpCat.of (ULift.{u} ℤ) ⟶
        AddCommGrpCat.of (Additive B) :=
    AddCommGrpCat.ofHom
      (uliftZMultiplesHom
        (Additive B) (Additive.ofMul value))
  let integerInRational :
      AddCommGrpCat.of (ULift.{u} ℤ) ⟶
        AddCommGrpCat.of (ULift.{u} ℚ) :=
    AddCommGrpCat.ofHom
      (AddEquiv.ulift.symm.toAddMonoidHom.comp
        ((Int.castAddHom ℚ).comp
          AddEquiv.ulift.toAddMonoidHom))
  letI : CategoryTheory.Mono integerInRational :=
    CategoryTheory.ConcreteCategory.mono_of_injective
      integerInRational (by
        intro first second equality
        apply ULift.ext
        exact
          Int.cast_injective
            (show (first.down : ℚ) = (second.down : ℚ) from
              congrArg ULift.down equality))
  exact
    (CategoryTheory.Injective.factorThru
      integerMap integerInRational).hom.comp
        AddEquiv.ulift.symm.toAddMonoidHom

/-- The extended rational-power system takes `1` to its prescribed element. -/
theorem rootableRationalPowers_one
    {B : Type u} [CommGroup B] [RootableBy B ℕ]
    (value : B) :
    rootableRationalPowers value 1 =
      Additive.ofMul value := by
  letI : DivisibleBy (Additive B) ℕ :=
    additiveDivisibleByNatOfRootable
  letI : DivisibleBy (Additive B) ℤ :=
    AddGroup.divisibleByIntOfDivisibleByNat (Additive B)
  let integerMap :
      AddCommGrpCat.of (ULift.{u} ℤ) ⟶
        AddCommGrpCat.of (Additive B) :=
    AddCommGrpCat.ofHom
      (uliftZMultiplesHom
        (Additive B) (Additive.ofMul value))
  let integerInRational :
      AddCommGrpCat.of (ULift.{u} ℤ) ⟶
        AddCommGrpCat.of (ULift.{u} ℚ) :=
    AddCommGrpCat.ofHom
      (AddEquiv.ulift.symm.toAddMonoidHom.comp
        ((Int.castAddHom ℚ).comp
          AddEquiv.ulift.toAddMonoidHom))
  letI : CategoryTheory.Mono integerInRational :=
    CategoryTheory.ConcreteCategory.mono_of_injective
      integerInRational (by
        intro first second equality
        apply ULift.ext
        exact
          Int.cast_injective
            (show (first.down : ℚ) = (second.down : ℚ) from
              congrArg ULift.down equality))
  have factorization :=
    CategoryTheory.Injective.comp_factorThru
      integerMap integerInRational
  have atOne :=
    CategoryTheory.congr_fun factorization
      (ULift.up (1 : ℤ))
  rw [AddCommGrpCat.comp_apply] at atOne
  have integerInRational_one :
      integerInRational (ULift.up (1 : ℤ)) =
        ULift.up (1 : ℚ) :=
    rfl
  have integerMap_one :
      integerMap (ULift.up (1 : ℤ)) =
        Additive.ofMul value := by
    change (1 : ℤ) • Additive.ofMul value =
      Additive.ofMul value
    exact one_zsmul _
  rw [integerInRational_one, integerMap_one] at atOne
  change
    (CategoryTheory.Injective.factorThru
      integerMap integerInRational).hom
        (ULift.up (1 : ℚ)) =
      Additive.ofMul value at atOne
  exact atOne

/--
The model isomorphism transports rootability of `kbar^x` to the groupification
of the arithmetic monoid of any MLF-Galois `TM`-pair.
-/
@[implicit_reducible]
noncomputable def groupificationRootableByNat
    (pair : SourceMLFGaloisTMPair G) :
    RootableBy
      (Algebra.GrothendieckGroup
        pair.arithmeticMonoid.carrier) ℕ := by
  letI :
      RootableBy
        (Algebra.GrothendieckGroup
          (SourceMLFIntegralMonoid pair.modelField)) ℕ :=
    SourceMLFIntegralMonoid.groupificationRootableByNat
      pair.modelField
  let equivalence :=
    Algebra.GrothendieckGroup.congr pair.monoidIso
  exact
    rootableByOfPowLeftSurj _ _
      fun {n} n_ne_zero value => by
        obtain ⟨root, root_pow⟩ :=
          RootableBy.surjective_pow
            (Algebra.GrothendieckGroup
              (SourceMLFIntegralMonoid pair.modelField)) ℕ
            n_ne_zero (equivalence.symm value)
        refine ⟨equivalence root, ?_⟩
        calc
          equivalence root ^ n = equivalence (root ^ n) :=
            (map_pow equivalence root n).symm
          _ = equivalence (equivalence.symm value) :=
            congrArg equivalence root_pow
          _ = value := equivalence.apply_symm_apply value

/--
A compatible system of rational powers of one arithmetic-monoid element.
Writing it as an additive homomorphism from `Q` to the multiplicative
groupification makes every identity `(x^(1/mn))^m = x^(1/n)` definitional.
-/
structure CompatibleRootSystem
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier) where
  roots :
    ℚ →+
      Additive
        (Algebra.GrothendieckGroup
          pair.arithmeticMonoid.carrier)
  root_one :
    roots 1 =
      Additive.ofMul
        (Algebra.GrothendieckGroup.of value)

namespace CompatibleRootSystem

/--
Construct compatible rational powers from the literal algebraic-closure model.
This discharges the bare root-system existence part of Proposition 3.2(ii).
-/
noncomputable def ofModel
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier) :
    pair.CompatibleRootSystem value := by
  letI :
      RootableBy
        (Algebra.GrothendieckGroup
          pair.arithmeticMonoid.carrier) ℕ :=
    pair.groupificationRootableByNat
  exact
    { roots :=
        rootableRationalPowers
          (Algebra.GrothendieckGroup.of value)
      root_one :=
        rootableRationalPowers_one
          (Algebra.GrothendieckGroup.of value) }

/--
At rational exponent `q`, two compatible root systems differ by an element
whose order divides the denominator of `q`.
-/
theorem quotient_pow_den
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (first second : pair.CompatibleRootSystem value)
    (q : ℚ) :
    ((second.roots q).toMul /
      (first.roots q).toMul) ^ q.den = 1 := by
  have first_nsmul := first.roots.map_nsmul q.den q
  have second_nsmul := second.roots.map_nsmul q.den q
  have denominator_smul : q.den • q = (q.num : ℚ) := by
    simpa [nsmul_eq_mul] using q.den_mul_eq_num
  have first_integer := first.roots.map_zsmul q.num 1
  have second_integer := second.roots.map_zsmul q.num 1
  have first_integer' :
      first.roots (q.num : ℚ) =
        q.num • first.roots 1 := by
    simpa using first_integer
  have second_integer' :
      second.roots (q.num : ℚ) =
        q.num • second.roots 1 := by
    simpa using second_integer
  have roots_integer_equal :
      first.roots (q.num : ℚ) =
        second.roots (q.num : ℚ) := by
    rw [first_integer', second_integer',
      first.root_one, second.root_one]
  have roots_power_equal :
      (first.roots q).toMul ^ q.den =
        (second.roots q).toMul ^ q.den := by
    apply Additive.ofMul.injective
    change q.den • first.roots q = q.den • second.roots q
    rw [← first_nsmul, ← second_nsmul,
      denominator_smul, roots_integer_equal]
  rw [div_pow, roots_power_equal]
  simp

/-- Apply one Galois element to every rational root of a fixed monoid value. -/
noncomputable def galoisTranslate
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (rootSystem : pair.CompatibleRootSystem value)
    (g : G)
    (fixed : pair.action g value = value) :
    pair.CompatibleRootSystem value where
  roots :=
    { toFun := fun q =>
        Additive.ofMul
          (pair.grothendieckAction g
            (rootSystem.roots q).toMul)
      map_zero' := by
        apply Additive.toMul.injective
        change
          pair.grothendieckAction g
              (rootSystem.roots 0).toMul = 1
        have root_zero :=
          congrArg Additive.toMul rootSystem.roots.map_zero
        change (rootSystem.roots 0).toMul = 1 at root_zero
        rw [root_zero, map_one]
      map_add' := by
        intro first second
        apply Additive.toMul.injective
        change
          pair.grothendieckAction g
              (rootSystem.roots (first + second)).toMul =
            pair.grothendieckAction g
                (rootSystem.roots first).toMul *
              pair.grothendieckAction g
                (rootSystem.roots second).toMul
        have root_add :=
          congrArg Additive.toMul
            (rootSystem.roots.map_add first second)
        change
          (rootSystem.roots (first + second)).toMul =
            (rootSystem.roots first).toMul *
              (rootSystem.roots second).toMul at root_add
        rw [root_add, map_mul] }
  root_one := by
    apply Additive.toMul.injective
    change
      pair.grothendieckAction g
          (rootSystem.roots 1).toMul =
        Algebra.GrothendieckGroup.of value
    have root_one := congrArg Additive.toMul rootSystem.root_one
    change
      (rootSystem.roots 1).toMul =
        Algebra.GrothendieckGroup.of value at root_one
    rw [root_one]
    have action_of := pair.grothendieckActionMulAut_of g value
    change
      pair.grothendieckAction g
          (Algebra.GrothendieckGroup.of value) =
        Algebra.GrothendieckGroup.of (pair.action g value) at action_of
    rw [action_of, fixed]

set_option synthInstance.maxHeartbeats 200000 in
-- Transport through the nested groupifications requires a larger instance-search budget.
/-- Every quotient of compatible roots is represented by an arithmetic-monoid unit. -/
theorem quotientUnit_exists
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (first second : pair.CompatibleRootSystem value)
    (q : ℚ) :
    ∃ unit : pair.arithmeticMonoid.carrierˣ,
      pair.unitGrothendieckHom unit =
        (second.roots q).toMul / (first.roots q).toMul := by
  let groupEquiv :=
    Algebra.GrothendieckGroup.congr pair.monoidIso
  let quotient :=
    (second.roots q).toMul / (first.roots q).toMul
  let modelQuotient := groupEquiv.symm quotient
  let fieldEquiv :=
    SourceMLFIntegralMonoid.groupificationEquivAlgebraicClosureUnits
      pair.modelField
  let fieldQuotient := fieldEquiv modelQuotient
  have quotient_pow : quotient ^ q.den = 1 :=
    quotient_pow_den pair value first second q
  have model_pow : modelQuotient ^ q.den = 1 := by
    apply groupEquiv.injective
    calc
      groupEquiv (modelQuotient ^ q.den) = quotient ^ q.den := by
        rw [map_pow, show groupEquiv modelQuotient = quotient from
          groupEquiv.apply_symm_apply quotient]
      _ = 1 := quotient_pow
      _ = groupEquiv 1 := (map_one groupEquiv).symm
  have field_pow : fieldQuotient ^ q.den = 1 := by
    calc
      fieldQuotient ^ q.den = fieldEquiv (modelQuotient ^ q.den) :=
        (map_pow fieldEquiv modelQuotient q.den).symm
      _ = fieldEquiv 1 := congrArg fieldEquiv model_pow
      _ = 1 := map_one fieldEquiv
  let sourceUnit :=
    SourceMLFIntegralMonoid.torsionUnit
      pair.modelField fieldQuotient q.den q.den_ne_zero field_pow
  refine ⟨Units.map pair.monoidIso.toMonoidHom sourceUnit, ?_⟩
  change
    Algebra.GrothendieckGroup.of
        ((Units.map pair.monoidIso.toMonoidHom sourceUnit :
          pair.arithmeticMonoid.carrierˣ) :
            pair.arithmeticMonoid.carrier) =
      quotient
  rw [Units.coe_map]
  change
    Algebra.GrothendieckGroup.of
        (pair.monoidIso
          (sourceUnit : SourceMLFIntegralMonoid pair.modelField)) =
      quotient
  rw [← Algebra.GrothendieckGroup.mapEquiv_of
    pair.monoidIso
    (sourceUnit : SourceMLFIntegralMonoid pair.modelField)]
  change
    groupEquiv
        (Algebra.GrothendieckGroup.of
          (sourceUnit : SourceMLFIntegralMonoid pair.modelField)) =
      quotient
  apply groupEquiv.symm.injective
  rw [groupEquiv.symm_apply_apply]
  apply fieldEquiv.injective
  rw [SourceMLFIntegralMonoid.torsionUnit_image]

end CompatibleRootSystem

/--
The exact root input in Absolute Anabelian Topics III, Proposition 3.2(ii):
an open subgroup fixes `value`, and its action on every compatible rational
power differs from that power by an integral unit.  `ratio_spec` records that
integrality assertion; the ratio, its homomorphism laws, and the cocycle are
derived below.
-/
structure KummerRootRealization
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G)
    (value : pair.arithmeticMonoid.carrier) where
  fixed :
    ∀ g : subgroup,
      pair.action (g : G) value = value
  rootSystem : pair.CompatibleRootSystem value
  ratioUnit :
    subgroup → ℚ →
      pair.arithmeticMonoid.carrierˣ
  ratio_spec :
    ∀ (g : subgroup) (q : ℚ),
      pair.unitGrothendieckHom (ratioUnit g q) =
        pair.grothendieckAction (g : G)
            (rootSystem.roots q).toMul /
          (rootSystem.roots q).toMul

namespace KummerRootRealization

variable
  {pair : SourceMLFGaloisTMPair G}
  {subgroup : OpenSubgroup G}
  {value : pair.arithmeticMonoid.carrier}

/--
Construct all integral Galois root ratios from a fixed-element proof and a
compatible root system. The ratio at `g,q` is the integral comparison with the
Galois-translated root system.
-/
noncomputable def ofRootSystem
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G)
    (value : pair.arithmeticMonoid.carrier)
    (fixed : ∀ g : subgroup, pair.action (g : G) value = value)
    (rootSystem : pair.CompatibleRootSystem value) :
    pair.KummerRootRealization subgroup value where
  fixed := fixed
  rootSystem := rootSystem
  ratioUnit g q :=
    Classical.choose
      (CompatibleRootSystem.quotientUnit_exists
        pair value rootSystem
        (CompatibleRootSystem.galoisTranslate
          pair value rootSystem (g : G) (fixed g)) q)
  ratio_spec g q :=
    Classical.choose_spec
      (CompatibleRootSystem.quotientUnit_exists
        pair value rootSystem
        (CompatibleRootSystem.galoisTranslate
          pair value rootSystem (g : G) (fixed g)) q)

/-- The root ratio is forced to be trivial at rational exponent zero. -/
theorem ratioUnit_zero
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup) :
    realization.ratioUnit g 0 = 1 := by
  apply pair.unitGrothendieckHom_injective
  rw [realization.ratio_spec]
  simp

/-- Multiplicativity of root ratios is derived from compatibility of the roots. -/
theorem ratioUnit_add
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup)
    (first second : ℚ) :
    realization.ratioUnit g (first + second) =
      realization.ratioUnit g first *
        realization.ratioUnit g second := by
  apply pair.unitGrothendieckHom_injective
  rw [map_mul]
  rw [realization.ratio_spec,
    realization.ratio_spec,
    realization.ratio_spec]
  have rootsAdd :=
    congrArg Additive.toMul
      (realization.rootSystem.roots.map_add first second)
  change
    (realization.rootSystem.roots (first + second)).toMul =
      (realization.rootSystem.roots first).toMul *
        (realization.rootSystem.roots second).toMul at rootsAdd
  rw [rootsAdd, map_mul]
  simp only [div_eq_mul_inv]
  rw [mul_inv_rev]
  ac_rfl

/-- For each group element, compatible roots give a homomorphism `Q -> M^x`. -/
def ratioAddHom
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup) :
    ℚ →+ Additive pair.arithmeticMonoid.carrierˣ where
  toFun q := Additive.ofMul (realization.ratioUnit g q)
  map_zero' := congrArg Additive.ofMul (realization.ratioUnit_zero g)
  map_add' first second :=
    congrArg Additive.ofMul
      (realization.ratioUnit_add g first second)

@[simp]
theorem ratioAddHom_apply
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup)
    (q : ℚ) :
    (realization.ratioAddHom g q).toMul =
      realization.ratioUnit g q :=
  rfl

/-- Fixing the original monoid element makes the root ratio trivial at `1`. -/
theorem ratioUnit_one
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup) :
    realization.ratioUnit g 1 = 1 := by
  apply pair.unitGrothendieckHom_injective
  rw [realization.ratio_spec]
  have rootOne :=
    congrArg Additive.toMul
      realization.rootSystem.root_one
  change
    (realization.rootSystem.roots 1).toMul =
      Algebra.GrothendieckGroup.of value at rootOne
  rw [rootOne]
  have actionOf :=
    pair.grothendieckActionMulAut_of (g : G) value
  change
    pair.grothendieckAction (g : G)
        (Algebra.GrothendieckGroup.of value) =
      Algebra.GrothendieckGroup.of
        (pair.action (g : G) value) at actionOf
  rw [actionOf]
  rw [realization.fixed]
  rw [map_one]
  simp only [div_eq_mul_inv, mul_inv_cancel]

/-- The integer subgroup lies in the kernel of every root-ratio homomorphism. -/
theorem zmultiples_le_ratioAddHom_ker
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup) :
    AddSubgroup.zmultiples (1 : ℚ) ≤
      (realization.ratioAddHom g).ker := by
  rw [AddSubgroup.zmultiples_le]
  change realization.ratioAddHom g 1 = 0
  apply Additive.toMul.injective
  exact realization.ratioUnit_one g

/--
The root-ratio character descended through `Q/Z`; this is the paper's
`mu_Z(M) = Hom(Q/Z,M)` value before assembling the crossed homomorphism.
-/
def ratioCyclotome
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup) :
    SourceMonoidCyclotome pair.arithmeticMonoid.carrier :=
  AddMonoidHom.toMultiplicativeLeft
    (QuotientAddGroup.lift
      (AddSubgroup.zmultiples (1 : ℚ))
      (realization.ratioAddHom g)
      (realization.zmultiples_le_ratioAddHom_ker g))

@[simp]
theorem ratioCyclotome_mk
    (realization : pair.KummerRootRealization subgroup value)
    (g : subgroup)
    (q : ℚ) :
    realization.ratioCyclotome g
        (Multiplicative.ofAdd
          (q : AddCircle (1 : ℚ))) =
      realization.ratioUnit g q :=
  rfl

/-- The Galois root ratios satisfy the crossed-homomorphism identity. -/
theorem ratioUnit_mul_group
    (realization : pair.KummerRootRealization subgroup value)
    (first second : subgroup)
    (q : ℚ) :
    realization.ratioUnit (first * second) q =
      realization.ratioUnit first q *
        Units.map (pair.action (first : G)).toMonoidHom
          (realization.ratioUnit second q) := by
  apply pair.unitGrothendieckHom_injective
  rw [map_mul, ← pair.unitGrothendieckHom_action]
  rw [realization.ratio_spec,
    realization.ratio_spec,
    realization.ratio_spec]
  change
    pair.grothendieckAction
          ((first : G) * (second : G))
          (realization.rootSystem.roots q).toMul /
        (realization.rootSystem.roots q).toMul =
      (pair.grothendieckAction (first : G)
            (realization.rootSystem.roots q).toMul /
          (realization.rootSystem.roots q).toMul) *
        pair.grothendieckAction (first : G)
          (pair.grothendieckAction (second : G)
              (realization.rootSystem.roots q).toMul /
            (realization.rootSystem.roots q).toMul)
  have actionMul :
      pair.grothendieckAction
          ((first : G) * (second : G))
          (realization.rootSystem.roots q).toMul =
        pair.grothendieckAction (first : G)
          (pair.grothendieckAction (second : G)
            (realization.rootSystem.roots q).toMul) :=
    DFunLike.congr_fun
      (pair.grothendieckActionHom_mul
        (first : G) (second : G))
      (realization.rootSystem.roots q).toMul
  rw [actionMul, map_div, mul_comm, div_mul_div_cancel]

/-- The descended `Q/Z` characters obey the same crossed-homomorphism law. -/
theorem ratioCyclotome_mul_group
    (realization : pair.KummerRootRealization subgroup value)
    (first second : subgroup) :
    realization.ratioCyclotome (first * second) =
      realization.ratioCyclotome first *
        pair.cyclotomeAction (first : G)
          (realization.ratioCyclotome second) := by
  apply MonoidHom.ext
  intro circle
  let additiveCircle : AddCircle (1 : ℚ) := circle.toAdd
  change
    realization.ratioCyclotome (first * second)
          (Multiplicative.ofAdd additiveCircle) =
      (realization.ratioCyclotome first *
          pair.cyclotomeAction (first : G)
            (realization.ratioCyclotome second))
        (Multiplicative.ofAdd additiveCircle)
  induction additiveCircle using Quotient.inductionOn with
  | _ q =>
      change
        realization.ratioUnit (first * second) q =
          realization.ratioUnit first q *
            Units.map (pair.action (first : G)).toMonoidHom
              (realization.ratioUnit second q)
      exact realization.ratioUnit_mul_group first second q

/-- Every rational-coordinate integral root ratio is locally constant. -/
theorem ratioUnit_isLocallyConstant
    (realization : pair.KummerRootRealization subgroup value)
    (q : ℚ) :
    IsLocallyConstant fun g : subgroup => realization.ratioUnit g q := by
  let root := (realization.rootSystem.roots q).toMul
  have orbitContinuous :
      @Continuous subgroup
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier)
        _ ⊥
        (fun g => pair.grothendieckAction (g : G) root) := by
    letI : TopologicalSpace
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⊥
    letI : DiscreteTopology
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⟨rfl⟩
    letI := pair.groupificationMulAction
    letI : ContinuousSMul G
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) :=
      pair.groupificationAction_continuous_discrete
    exact continuous_smul.comp
      (continuous_subtype_val.prodMk continuous_const)
  have orbitLocallyConstant :
      IsLocallyConstant fun g : subgroup =>
        pair.grothendieckAction (g : G) root := by
    letI : TopologicalSpace
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⊥
    letI : DiscreteTopology
        (Algebra.GrothendieckGroup pair.arithmeticMonoid.carrier) := ⟨rfl⟩
    exact (IsLocallyConstant.iff_continuous _).mpr orbitContinuous
  have quotientLocallyConstant :
      IsLocallyConstant fun g : subgroup =>
        pair.grothendieckAction (g : G) root / root :=
    orbitLocallyConstant.comp (fun actedRoot => actedRoot / root)
  have embeddedLocallyConstant :
      IsLocallyConstant
        (pair.unitGrothendieckHom ∘
          fun g : subgroup => realization.ratioUnit g q) := by
    have embedded_eq :
        (pair.unitGrothendieckHom ∘
            fun g : subgroup => realization.ratioUnit g q) =
          fun g : subgroup =>
            pair.grothendieckAction (g : G) root / root := by
      funext g
      exact realization.ratio_spec g q
    rw [embedded_eq]
    exact quotientLocallyConstant
  exact
    IsLocallyConstant.desc
      (fun g : subgroup => realization.ratioUnit g q)
      pair.unitGrothendieckHom
      embeddedLocallyConstant
      pair.unitGrothendieckHom_injective

/-- The root-ratio map is continuous for the canonical cyclotome topology. -/
theorem ratioCyclotome_continuous
    (realization : pair.KummerRootRealization subgroup value) :
    Continuous realization.ratioCyclotome := by
  rw [SourceMonoidCyclotome.continuous_iff_eval_discrete]
  intro circle
  let additiveCircle : AddCircle (1 : ℚ) := circle.toAdd
  change
    @Continuous subgroup pair.arithmeticMonoid.carrierˣ _ ⊥
      (fun g => realization.ratioCyclotome g
        (Multiplicative.ofAdd additiveCircle))
  induction additiveCircle using Quotient.inductionOn with
  | _ q =>
      change
        @Continuous subgroup pair.arithmeticMonoid.carrierˣ _ ⊥
          (fun g => realization.ratioUnit g q)
      letI : TopologicalSpace pair.arithmeticMonoid.carrierˣ := ⊥
      letI : DiscreteTopology pair.arithmeticMonoid.carrierˣ := ⟨rfl⟩
      exact
        (IsLocallyConstant.iff_continuous _).mp
          (realization.ratioUnit_isLocallyConstant q)

end KummerRootRealization

namespace CompatibleRootSystem

variable {pair : SourceMLFGaloisTMPair G}

/-- The compatible root system of the monoid identity. -/
def one :
    pair.CompatibleRootSystem (1 : pair.arithmeticMonoid.carrier) where
  roots := 0
  root_one := by
    change
      (1 :
        Algebra.GrothendieckGroup
          pair.arithmeticMonoid.carrier) =
        Algebra.GrothendieckGroup.of 1
    exact (map_one Algebra.GrothendieckGroup.of).symm

/-- Pointwise products give compatible roots of a product. -/
def mul
    {firstValue secondValue : pair.arithmeticMonoid.carrier}
    (first : pair.CompatibleRootSystem firstValue)
    (second : pair.CompatibleRootSystem secondValue) :
    pair.CompatibleRootSystem (firstValue * secondValue) where
  roots := first.roots + second.roots
  root_one := by
    change
      (first.roots 1).toMul *
          (second.roots 1).toMul =
        Algebra.GrothendieckGroup.of
          (firstValue * secondValue)
    rw [first.root_one, second.root_one]
    change
      Algebra.GrothendieckGroup.of firstValue *
          Algebra.GrothendieckGroup.of secondValue =
        Algebra.GrothendieckGroup.of
          (firstValue * secondValue)
    rw [map_mul]

end CompatibleRootSystem

namespace KummerRootRealization

variable
  {pair : SourceMLFGaloisTMPair G}
  {firstSubgroup secondSubgroup : OpenSubgroup G}
  {firstValue secondValue : pair.arithmeticMonoid.carrier}

/-- The trivial root realization of the monoid identity on any open subgroup. -/
def oneOn
    (pair : SourceMLFGaloisTMPair G)
    (subgroup : OpenSubgroup G) :
    pair.KummerRootRealization
      subgroup
      (1 : pair.arithmeticMonoid.carrier) where
  fixed g := map_one (pair.action (g : G))
  rootSystem := CompatibleRootSystem.one
  ratioUnit := fun _ _ => 1
  ratio_spec g q := by
    rw [map_one]
    change
      1 =
        pair.grothendieckAction (g : G) 1 / 1
    rw [map_one, div_one]

/-- The trivial root realization on the full group. -/
def one :
    pair.KummerRootRealization
      (⊤ : OpenSubgroup G)
      (1 : pair.arithmeticMonoid.carrier) :=
  oneOn pair ⊤

/-- Multiply root realizations after restricting to the intersection. -/
def mul
    (first :
      pair.KummerRootRealization firstSubgroup firstValue)
    (second :
      pair.KummerRootRealization secondSubgroup secondValue) :
    pair.KummerRootRealization
      (firstSubgroup ⊓ secondSubgroup)
      (firstValue * secondValue) where
  fixed g := by
    rw [map_mul,
      first.fixed
        (⟨(g : G), g.property.1⟩ : firstSubgroup),
      second.fixed
        (⟨(g : G), g.property.2⟩ : secondSubgroup)]
  rootSystem :=
    first.rootSystem.mul second.rootSystem
  ratioUnit g q :=
    first.ratioUnit
        (⟨(g : G), g.property.1⟩ : firstSubgroup) q *
      second.ratioUnit
        (⟨(g : G), g.property.2⟩ : secondSubgroup) q
  ratio_spec g q := by
    rw [map_mul, first.ratio_spec, second.ratio_spec]
    change
      (pair.grothendieckAction (g : G)
            (first.rootSystem.roots q).toMul /
          (first.rootSystem.roots q).toMul) *
          (pair.grothendieckAction (g : G)
              (second.rootSystem.roots q).toMul /
            (second.rootSystem.roots q).toMul) =
        pair.grothendieckAction (g : G)
            ((first.rootSystem.roots q).toMul *
              (second.rootSystem.roots q).toMul) /
          ((first.rootSystem.roots q).toMul *
            (second.rootSystem.roots q).toMul)
    rw [map_mul]
    simp only [div_eq_mul_inv, mul_inv_rev]
    ac_rfl

/-- Multiplication specialized to two realizations on the same subgroup. -/
def mulSame
    {subgroup : OpenSubgroup G}
    (first :
      pair.KummerRootRealization subgroup firstValue)
    (second :
      pair.KummerRootRealization subgroup secondValue) :
    pair.KummerRootRealization
      subgroup (firstValue * secondValue) where
  fixed g := by
    rw [map_mul, first.fixed g, second.fixed g]
  rootSystem :=
    first.rootSystem.mul second.rootSystem
  ratioUnit g q :=
    first.ratioUnit g q * second.ratioUnit g q
  ratio_spec g q := by
    rw [map_mul, first.ratio_spec, second.ratio_spec]
    change
      (pair.grothendieckAction (g : G)
            (first.rootSystem.roots q).toMul /
          (first.rootSystem.roots q).toMul) *
          (pair.grothendieckAction (g : G)
              (second.rootSystem.roots q).toMul /
            (second.rootSystem.roots q).toMul) =
        pair.grothendieckAction (g : G)
            ((first.rootSystem.roots q).toMul *
              (second.rootSystem.roots q).toMul) /
          ((first.rootSystem.roots q).toMul *
            (second.rootSystem.roots q).toMul)
    rw [map_mul]
    simp only [div_eq_mul_inv, mul_inv_rev]
    ac_rfl

@[simp]
theorem mul_ratioCyclotome
    (first :
      pair.KummerRootRealization firstSubgroup firstValue)
    (second :
      pair.KummerRootRealization secondSubgroup secondValue)
    (g :
      (firstSubgroup ⊓ secondSubgroup :
        OpenSubgroup G)) :
    (first.mul second).ratioCyclotome g =
      first.ratioCyclotome
          (⟨(g : G), g.property.1⟩ : firstSubgroup) *
        second.ratioCyclotome
          (⟨(g : G), g.property.2⟩ : secondSubgroup) := by
  apply MonoidHom.ext
  intro circle
  let additiveCircle : AddCircle (1 : ℚ) := circle.toAdd
  change
    (first.mul second).ratioCyclotome g
          (Multiplicative.ofAdd additiveCircle) =
      (first.ratioCyclotome
            (⟨(g : G), g.property.1⟩ : firstSubgroup) *
          second.ratioCyclotome
            (⟨(g : G), g.property.2⟩ : secondSubgroup))
        (Multiplicative.ofAdd additiveCircle)
  induction additiveCircle using Quotient.inductionOn with
  | _ q => rfl

@[simp]
theorem mulSame_ratioCyclotome
    {subgroup : OpenSubgroup G}
    (first :
      pair.KummerRootRealization subgroup firstValue)
    (second :
      pair.KummerRootRealization subgroup secondValue)
    (g : subgroup) :
    (first.mulSame second).ratioCyclotome g =
      first.ratioCyclotome g *
        second.ratioCyclotome g := by
  apply MonoidHom.ext
  intro circle
  let additiveCircle : AddCircle (1 : ℚ) := circle.toAdd
  change
    (first.mulSame second).ratioCyclotome g
          (Multiplicative.ofAdd additiveCircle) =
      (first.ratioCyclotome g * second.ratioCyclotome g)
        (Multiplicative.ofAdd additiveCircle)
  induction additiveCircle using Quotient.inductionOn with
  | _ q => rfl

end KummerRootRealization

/--
A root realization together with the sole topological input needed for
continuous Kummer theory: continuity of the already-derived root-ratio map
after transport to the chosen coefficient group.
-/
structure ContinuousKummerRootRealization
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (subgroup : OpenSubgroup G)
    (value : pair.arithmeticMonoid.carrier)
    extends pair.KummerRootRealization subgroup value where
  continuous_ratio :
    Continuous fun g : subgroup =>
      coefficientCyclotomeEquiv.symm
        (toKummerRootRealization.ratioCyclotome g)

namespace ContinuousKummerRootRealization

variable
  {A : Type u}
  [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
  {pair : SourceMLFGaloisTMPair G}
  {coefficientAction : ContinuousGroupAction G A}
  {coefficientCyclotomeEquiv :
    A ≃*
      SourceMonoidCyclotome pair.arithmeticMonoid.carrier}
  {subgroup : OpenSubgroup G}
  {value : pair.arithmeticMonoid.carrier}

/-- The continuous crossed homomorphism obtained from the compatible roots. -/
def cocycle
    (realization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv subgroup value)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    ContinuousOneCocycle
      (coefficientAction.comap
        (openSubgroupInclusion subgroup)) where
  toFun g :=
    coefficientCyclotomeEquiv.symm
      (realization.toKummerRootRealization.ratioCyclotome g)
  continuous_toFun := realization.continuous_ratio
  map_mul' first second := by
    apply coefficientCyclotomeEquiv.injective
    rw [map_mul,
      coefficientCyclotomeEquiv.apply_symm_apply,
      coefficientCyclotomeEquiv.apply_symm_apply]
    change
      realization.toKummerRootRealization.ratioCyclotome
          (first * second) =
        realization.toKummerRootRealization.ratioCyclotome first *
          coefficientCyclotomeEquiv
            (coefficientAction.act (first : G)
              (coefficientCyclotomeEquiv.symm
                (realization.toKummerRootRealization.ratioCyclotome
                  second)))
    rw [equivariant,
      coefficientCyclotomeEquiv.apply_symm_apply]
    exact
      realization.toKummerRootRealization.ratioCyclotome_mul_group
        first second

/-- The open-subgroup representative constructed from the root cocycle. -/
def representative
    (realization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv subgroup value)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    ContinuousH1GermRepresentative coefficientAction where
  subgroup := subgroup
  cocycle := realization.cocycle equivariant

/-- The direct-limit `H^1` class constructed from compatible roots. -/
def germ
    (realization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv subgroup value)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    ContinuousH1Germ coefficientAction :=
  ContinuousH1Germ.classOf
    (realization.representative equivariant)

/-- The class in H1 of the specified open subgroup, before passage to germs. -/
def localClass
    (realization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv subgroup value)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    ContinuousH1
      (coefficientAction.comap
        (openSubgroupInclusion subgroup)) :=
  ContinuousH1.classOf (realization.cocycle equivariant)

@[simp]
theorem toGerm_localClass
    (realization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv subgroup value)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    ContinuousH1.toGerm subgroup
        (realization.localClass equivariant) =
      realization.germ equivariant :=
  rfl

/-- The continuous trivial root realization on any open subgroup. -/
def oneOn
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (subgroup : OpenSubgroup G) :
    pair.ContinuousKummerRootRealization
      coefficientAction coefficientCyclotomeEquiv
      subgroup
      (1 : pair.arithmeticMonoid.carrier) where
  toKummerRootRealization :=
    KummerRootRealization.oneOn pair subgroup
  continuous_ratio := by
    convert
      (continuous_const :
        Continuous fun _ : subgroup => (1 : A))
      using 1
    funext g
    apply coefficientCyclotomeEquiv.injective
    rw [map_one, coefficientCyclotomeEquiv.apply_symm_apply]
    ext q
    rfl

/-- The continuous trivial root realization on the full group. -/
def one
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier) :
    pair.ContinuousKummerRootRealization
      coefficientAction coefficientCyclotomeEquiv
      (⊤ : OpenSubgroup G)
      (1 : pair.arithmeticMonoid.carrier) :=
  oneOn pair coefficientAction coefficientCyclotomeEquiv ⊤

/-- Multiply continuous root realizations on their common open subgroup. -/
def mul
    {firstSubgroup secondSubgroup : OpenSubgroup G}
    {firstValue secondValue : pair.arithmeticMonoid.carrier}
    (first :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        firstSubgroup firstValue)
    (second :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        secondSubgroup secondValue) :
    pair.ContinuousKummerRootRealization
      coefficientAction coefficientCyclotomeEquiv
      (firstSubgroup ⊓ secondSubgroup)
      (firstValue * secondValue) where
  toKummerRootRealization :=
    first.toKummerRootRealization.mul
      second.toKummerRootRealization
  continuous_ratio := by
    have firstContinuous :
        Continuous fun g :
            (firstSubgroup ⊓ secondSubgroup : OpenSubgroup G) =>
          coefficientCyclotomeEquiv.symm
            (first.toKummerRootRealization.ratioCyclotome
              (⟨(g : G), g.property.1⟩ : firstSubgroup)) :=
      first.continuous_ratio.comp
        (continuous_subtype_val.subtype_mk
          (fun
            (g :
              (firstSubgroup ⊓ secondSubgroup :
                OpenSubgroup G)) =>
              g.property.1))
    have secondContinuous :
        Continuous fun g :
            (firstSubgroup ⊓ secondSubgroup : OpenSubgroup G) =>
          coefficientCyclotomeEquiv.symm
            (second.toKummerRootRealization.ratioCyclotome
              (⟨(g : G), g.property.2⟩ : secondSubgroup)) :=
      second.continuous_ratio.comp
        (continuous_subtype_val.subtype_mk
          (fun
            (g :
              (firstSubgroup ⊓ secondSubgroup :
                OpenSubgroup G)) =>
              g.property.2))
    convert firstContinuous.mul secondContinuous using 1
    funext g
    change
      coefficientCyclotomeEquiv.symm
          ((first.toKummerRootRealization.mul
            second.toKummerRootRealization).ratioCyclotome g) =
        coefficientCyclotomeEquiv.symm
            (first.toKummerRootRealization.ratioCyclotome
              (⟨(g : G), g.property.1⟩ : firstSubgroup)) *
          coefficientCyclotomeEquiv.symm
            (second.toKummerRootRealization.ratioCyclotome
              (⟨(g : G), g.property.2⟩ : secondSubgroup))
    rw [KummerRootRealization.mul_ratioCyclotome, map_mul]

/-- Multiplication specialized to continuous realizations on one subgroup. -/
def mulSame
    {subgroup : OpenSubgroup G}
    {firstValue secondValue : pair.arithmeticMonoid.carrier}
    (first :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup firstValue)
    (second :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup secondValue) :
    pair.ContinuousKummerRootRealization
      coefficientAction coefficientCyclotomeEquiv
      subgroup (firstValue * secondValue) where
  toKummerRootRealization :=
    first.toKummerRootRealization.mulSame
      second.toKummerRootRealization
  continuous_ratio := by
    convert first.continuous_ratio.mul second.continuous_ratio using 1
    funext g
    change
      coefficientCyclotomeEquiv.symm
          ((first.toKummerRootRealization.mulSame
            second.toKummerRootRealization).ratioCyclotome g) =
        coefficientCyclotomeEquiv.symm
            (first.toKummerRootRealization.ratioCyclotome g) *
          coefficientCyclotomeEquiv.symm
            (second.toKummerRootRealization.ratioCyclotome g)
    rw [KummerRootRealization.mulSame_ratioCyclotome, map_mul]

/-- The trivial root realization gives the identity H1 germ. -/
theorem one_germ
    [IsMulCommutative A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    (one pair coefficientAction coefficientCyclotomeEquiv).germ
        equivariant =
      1 := by
  apply Quotient.sound
  refine
    ContinuousH1GermRepresentative.Equivalent.of_equal_on
      (⊤ : OpenSubgroup G) le_rfl (fun _ _ => trivial) ?_
  intro g
  change
    (1 : A) =
      coefficientCyclotomeEquiv.symm
        ((one pair coefficientAction coefficientCyclotomeEquiv)
          |>.toKummerRootRealization.ratioCyclotome g)
  apply coefficientCyclotomeEquiv.injective
  rw [map_one, coefficientCyclotomeEquiv.apply_symm_apply]
  ext q
  rfl

/-- Products of root systems compute products of their H1 germs. -/
theorem mul_germ
    [IsMulCommutative A]
    {firstSubgroup secondSubgroup : OpenSubgroup G}
    {firstValue secondValue : pair.arithmeticMonoid.carrier}
    (first :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        firstSubgroup firstValue)
    (second :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        secondSubgroup secondValue)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    (first.mul second).germ equivariant =
      first.germ equivariant * second.germ equivariant := by
  apply Quotient.sound
  refine
    ContinuousH1GermRepresentative.Equivalent.of_equal_on
      (firstSubgroup ⊓ secondSubgroup)
      le_rfl le_rfl ?_
  intro g
  change
    coefficientCyclotomeEquiv.symm
          (first.toKummerRootRealization.ratioCyclotome
            (⟨(g : G), g.property.1⟩ : firstSubgroup)) *
        coefficientCyclotomeEquiv.symm
          (second.toKummerRootRealization.ratioCyclotome
            (⟨(g : G), g.property.2⟩ : secondSubgroup)) =
      coefficientCyclotomeEquiv.symm
        ((first.toKummerRootRealization.mul
            second.toKummerRootRealization).ratioCyclotome g)
  rw [KummerRootRealization.mul_ratioCyclotome, map_mul]

/-- The trivial roots give the identity class in local continuous H1. -/
theorem oneOn_localClass
    [IsMulCommutative A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (subgroup : OpenSubgroup G)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    (oneOn pair coefficientAction coefficientCyclotomeEquiv subgroup).localClass
        equivariant =
      1 := by
  apply congrArg ContinuousH1.classOf
  apply ContinuousOneCocycle.ext
  intro g
  let trivial :=
    oneOn pair coefficientAction
      coefficientCyclotomeEquiv subgroup
  change
      coefficientCyclotomeEquiv.symm
        (trivial.toKummerRootRealization.ratioCyclotome g) =
      1
  apply coefficientCyclotomeEquiv.injective
  rw [map_one, coefficientCyclotomeEquiv.apply_symm_apply]
  ext q
  rfl

/-- Products of roots compute products of local continuous H1 classes. -/
theorem mulSame_localClass
    [IsMulCommutative A]
    {subgroup : OpenSubgroup G}
    {firstValue secondValue : pair.arithmeticMonoid.carrier}
    (first :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup firstValue)
    (second :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup secondValue)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    (first.mulSame second).localClass equivariant =
      first.localClass equivariant *
        second.localClass equivariant := by
  change
    ContinuousH1.classOf
        ((first.mulSame second).cocycle equivariant) =
      ContinuousH1.classOf (first.cocycle equivariant) *
        ContinuousH1.classOf (second.cocycle equivariant)
  rw [← ContinuousH1.classOf_mul]
  apply congrArg ContinuousH1.classOf
  apply ContinuousOneCocycle.ext
  intro g
  change
    coefficientCyclotomeEquiv.symm
        ((first.toKummerRootRealization.mulSame
            second.toKummerRootRealization).ratioCyclotome g) =
      coefficientCyclotomeEquiv.symm
          (first.toKummerRootRealization.ratioCyclotome g) *
        coefficientCyclotomeEquiv.symm
          (second.toKummerRootRealization.ratioCyclotome g)
  rw [KummerRootRealization.mulSame_ratioCyclotome, map_mul]

end ContinuousKummerRootRealization

/--
The integral root-of-unity quotient between two compatible root systems for
the same monoid element.  In the literal MLF model this is the assertion that
two `n`-th roots differ by an `n`-th root of unity.
-/
structure CompatibleRootComparison
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (first second : pair.CompatibleRootSystem value) where
  comparisonUnit :
    ℚ → pair.arithmeticMonoid.carrierˣ
  comparison_spec :
    ∀ q : ℚ,
      pair.unitGrothendieckHom (comparisonUnit q) =
        (second.roots q).toMul /
          (first.roots q).toMul

namespace CompatibleRootComparison

variable
  {pair : SourceMLFGaloisTMPair G}
  {value : pair.arithmeticMonoid.carrier}
  {first second : pair.CompatibleRootSystem value}

/--
Every quotient of compatible roots is represented by an actual unit of the
arithmetic monoid.  This is the integral root-of-unity assertion in Absolute
Anabelian Topics III, Proposition 3.2(ii).
-/
theorem comparisonUnit_exists
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (first second : pair.CompatibleRootSystem value)
    (q : ℚ) :
    ∃ unit : pair.arithmeticMonoid.carrierˣ,
      pair.unitGrothendieckHom unit =
        (second.roots q).toMul / (first.roots q).toMul :=
  CompatibleRootSystem.quotientUnit_exists
    pair value first second q

/-- Construct the integral comparison between any two compatible root systems. -/
noncomputable def ofModel
    (pair : SourceMLFGaloisTMPair G)
    (value : pair.arithmeticMonoid.carrier)
    (first second : pair.CompatibleRootSystem value) :
    pair.CompatibleRootComparison value first second where
  comparisonUnit q :=
    Classical.choose
      (comparisonUnit_exists pair value first second q)
  comparison_spec q :=
    Classical.choose_spec
      (comparisonUnit_exists pair value first second q)

theorem comparisonUnit_zero
    (comparison :
      pair.CompatibleRootComparison value first second) :
    comparison.comparisonUnit 0 = 1 := by
  apply pair.unitGrothendieckHom_injective
  rw [comparison.comparison_spec]
  have firstZero :=
    congrArg Additive.toMul (first.roots.map_zero)
  have secondZero :=
    congrArg Additive.toMul (second.roots.map_zero)
  change (first.roots 0).toMul = 1 at firstZero
  change (second.roots 0).toMul = 1 at secondZero
  rw [firstZero, secondZero]
  rw [div_one, map_one]

theorem comparisonUnit_add
    (comparison :
      pair.CompatibleRootComparison value first second)
    (q r : ℚ) :
    comparison.comparisonUnit (q + r) =
      comparison.comparisonUnit q *
        comparison.comparisonUnit r := by
  apply pair.unitGrothendieckHom_injective
  rw [map_mul]
  rw [comparison.comparison_spec,
    comparison.comparison_spec,
    comparison.comparison_spec]
  have firstAdd :=
    congrArg Additive.toMul (first.roots.map_add q r)
  have secondAdd :=
    congrArg Additive.toMul (second.roots.map_add q r)
  change
    (first.roots (q + r)).toMul =
      (first.roots q).toMul *
        (first.roots r).toMul at firstAdd
  change
    (second.roots (q + r)).toMul =
      (second.roots q).toMul *
        (second.roots r).toMul at secondAdd
  rw [firstAdd, secondAdd]
  simp only [div_eq_mul_inv, mul_inv_rev]
  ac_rfl

def comparisonAddHom
    (comparison :
      pair.CompatibleRootComparison value first second) :
    ℚ →+ Additive pair.arithmeticMonoid.carrierˣ where
  toFun q := Additive.ofMul (comparison.comparisonUnit q)
  map_zero' :=
    congrArg Additive.ofMul comparison.comparisonUnit_zero
  map_add' q r :=
    congrArg Additive.ofMul (comparison.comparisonUnit_add q r)

theorem comparisonUnit_one
    (comparison :
      pair.CompatibleRootComparison value first second) :
    comparison.comparisonUnit 1 = 1 := by
  apply pair.unitGrothendieckHom_injective
  rw [comparison.comparison_spec]
  have firstOne := congrArg Additive.toMul first.root_one
  have secondOne := congrArg Additive.toMul second.root_one
  change
    (first.roots 1).toMul =
      Algebra.GrothendieckGroup.of value at firstOne
  change
    (second.roots 1).toMul =
      Algebra.GrothendieckGroup.of value at secondOne
  rw [firstOne, secondOne, map_one]
  simp only [div_eq_mul_inv, mul_inv_cancel]

theorem zmultiples_le_comparisonAddHom_ker
    (comparison :
      pair.CompatibleRootComparison value first second) :
    AddSubgroup.zmultiples (1 : ℚ) ≤
      comparison.comparisonAddHom.ker := by
  rw [AddSubgroup.zmultiples_le]
  change comparison.comparisonAddHom 1 = 0
  apply Additive.toMul.injective
  exact comparison.comparisonUnit_one

/-- The quotient of two compatible root systems as one element of `mu_Z(M)`. -/
def cyclotome
    (comparison :
      pair.CompatibleRootComparison value first second) :
    SourceMonoidCyclotome pair.arithmeticMonoid.carrier :=
  AddMonoidHom.toMultiplicativeLeft
    (QuotientAddGroup.lift
      (AddSubgroup.zmultiples (1 : ℚ))
      comparison.comparisonAddHom
      comparison.zmultiples_le_comparisonAddHom_ker)

@[simp]
theorem cyclotome_mk
    (comparison :
      pair.CompatibleRootComparison value first second)
    (q : ℚ) :
    comparison.cyclotome
        (Multiplicative.ofAdd
          (q : AddCircle (1 : ℚ))) =
      comparison.comparisonUnit q :=
  rfl

/--
Changing the compatible roots changes the root-ratio cocycle by the
coboundary of their quotient.
-/
theorem ratioUnit_relation
    {firstSubgroup secondSubgroup : OpenSubgroup G}
    (comparison :
      pair.CompatibleRootComparison value first second)
    (firstRealization :
      pair.KummerRootRealization
        firstSubgroup value)
    (secondRealization :
      pair.KummerRootRealization
        secondSubgroup value)
    (firstRoots :
      firstRealization.rootSystem = first)
    (secondRoots :
      secondRealization.rootSystem = second)
    (g :
      (firstSubgroup ⊓ secondSubgroup :
        OpenSubgroup G))
    (q : ℚ) :
    secondRealization.ratioUnit
        (⟨(g : G), g.property.2⟩ : secondSubgroup) q =
      (comparison.comparisonUnit q)⁻¹ *
        firstRealization.ratioUnit
            (⟨(g : G), g.property.1⟩ : firstSubgroup) q *
          Units.map (pair.action (g : G)).toMonoidHom
            (comparison.comparisonUnit q) := by
  apply pair.unitGrothendieckHom_injective
  rw [map_mul, map_mul, map_inv]
  rw [secondRealization.ratio_spec,
    firstRealization.ratio_spec,
    ← pair.unitGrothendieckHom_action]
  subst first
  subst second
  rw [comparison.comparison_spec]
  simp only [div_eq_mul_inv, mul_inv_rev, inv_inv,
    map_mul, map_inv]
  let firstRoot :=
    (firstRealization.rootSystem.roots q).toMul
  let secondRoot :=
    (secondRealization.rootSystem.roots q).toMul
  let firstImage :=
    pair.grothendieckAction (g : G) firstRoot
  let secondImage :=
    pair.grothendieckAction (g : G) secondRoot
  change
    secondImage * secondRoot⁻¹ =
      (firstRoot * secondRoot⁻¹) *
          (firstImage * firstRoot⁻¹) *
        (secondImage * firstImage⁻¹)
  calc
    secondImage * secondRoot⁻¹ =
        (firstRoot * firstRoot⁻¹) *
          (firstImage * firstImage⁻¹) *
          (secondImage * secondRoot⁻¹) := by
      simp
    _ =
        (firstRoot * secondRoot⁻¹) *
            (firstImage * firstRoot⁻¹) *
          (secondImage * firstImage⁻¹) := by
      ac_rfl

/-- The corresponding identity after descent from Q to Q/Z. -/
theorem ratioCyclotome_relation
    {firstSubgroup secondSubgroup : OpenSubgroup G}
    (comparison :
      pair.CompatibleRootComparison value first second)
    (firstRealization :
      pair.KummerRootRealization
        firstSubgroup value)
    (secondRealization :
      pair.KummerRootRealization
        secondSubgroup value)
    (firstRoots :
      firstRealization.rootSystem = first)
    (secondRoots :
      secondRealization.rootSystem = second)
    (g :
      (firstSubgroup ⊓ secondSubgroup :
        OpenSubgroup G)) :
    secondRealization.ratioCyclotome
        (⟨(g : G), g.property.2⟩ : secondSubgroup) =
      comparison.cyclotome⁻¹ *
        firstRealization.ratioCyclotome
            (⟨(g : G), g.property.1⟩ : firstSubgroup) *
          pair.cyclotomeAction (g : G)
            comparison.cyclotome := by
  apply MonoidHom.ext
  intro circle
  let additiveCircle : AddCircle (1 : ℚ) := circle.toAdd
  change
    secondRealization.ratioCyclotome
          (⟨(g : G), g.property.2⟩ : secondSubgroup)
          (Multiplicative.ofAdd additiveCircle) =
      (comparison.cyclotome⁻¹ *
          firstRealization.ratioCyclotome
              (⟨(g : G), g.property.1⟩ : firstSubgroup) *
            pair.cyclotomeAction (g : G)
              comparison.cyclotome)
        (Multiplicative.ofAdd additiveCircle)
  induction additiveCircle using Quotient.inductionOn with
  | _ q =>
      change
        secondRealization.ratioUnit
            (⟨(g : G), g.property.2⟩ : secondSubgroup) q =
          (comparison.comparisonUnit q)⁻¹ *
            firstRealization.ratioUnit
                (⟨(g : G), g.property.1⟩ : firstSubgroup) q *
              Units.map (pair.action (g : G)).toMonoidHom
                (comparison.comparisonUnit q)
      exact
        comparison.ratioUnit_relation
          firstRealization secondRealization
          firstRoots secondRoots g q

/-- Two continuous root choices for the same value represent the same H1 germ. -/
theorem representatives_equivalent
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    {coefficientAction : ContinuousGroupAction G A}
    {coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier}
    {firstSubgroup secondSubgroup : OpenSubgroup G}
    (comparison :
      pair.CompatibleRootComparison value first second)
    (firstRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        firstSubgroup value)
    (secondRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        secondSubgroup value)
    (firstRoots :
      firstRealization.toKummerRootRealization.rootSystem =
        first)
    (secondRoots :
      secondRealization.toKummerRootRealization.rootSystem =
        second)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    (firstRealization.representative equivariant).Equivalent
      (secondRealization.representative equivariant) := by
  refine
    ⟨firstSubgroup ⊓ secondSubgroup,
      fun _ membership => membership.1,
      fun _ membership => membership.2,
      coefficientCyclotomeEquiv.symm comparison.cyclotome,
      ?_⟩
  intro g
  change
    coefficientCyclotomeEquiv.symm
        (secondRealization.toKummerRootRealization.ratioCyclotome
          (⟨(g : G), g.property.2⟩ : secondSubgroup)) =
      (coefficientCyclotomeEquiv.symm comparison.cyclotome)⁻¹ *
        coefficientCyclotomeEquiv.symm
            (firstRealization.toKummerRootRealization.ratioCyclotome
              (⟨(g : G), g.property.1⟩ : firstSubgroup)) *
          coefficientAction.act (g : G)
            (coefficientCyclotomeEquiv.symm comparison.cyclotome)
  apply coefficientCyclotomeEquiv.injective
  rw [map_mul, map_mul, map_inv]
  rw [coefficientCyclotomeEquiv.apply_symm_apply,
    coefficientCyclotomeEquiv.apply_symm_apply,
    coefficientCyclotomeEquiv.apply_symm_apply,
    equivariant,
    coefficientCyclotomeEquiv.apply_symm_apply]
  exact
    comparison.ratioCyclotome_relation
      firstRealization.toKummerRootRealization
      secondRealization.toKummerRootRealization
      firstRoots secondRoots g

/-- The Kummer germ is independent of the compatible root system chosen. -/
theorem germ_eq
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    {coefficientAction : ContinuousGroupAction G A}
    {coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier}
    {firstSubgroup secondSubgroup : OpenSubgroup G}
    (comparison :
      pair.CompatibleRootComparison value first second)
    (firstRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        firstSubgroup value)
    (secondRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        secondSubgroup value)
    (firstRoots :
      firstRealization.toKummerRootRealization.rootSystem =
        first)
    (secondRoots :
      secondRealization.toKummerRootRealization.rootSystem =
        second)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    firstRealization.germ equivariant =
      secondRealization.germ equivariant :=
  Quotient.sound
    (comparison.representatives_equivalent
      firstRealization secondRealization
      firstRoots secondRoots equivariant)

/-- On one fixed open subgroup, two root choices are cohomologous. -/
theorem localCocycles_cohomologous
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    {coefficientAction : ContinuousGroupAction G A}
    {coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier}
    {subgroup : OpenSubgroup G}
    (comparison :
      pair.CompatibleRootComparison value first second)
    (firstRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup value)
    (secondRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup value)
    (firstRoots :
      firstRealization.toKummerRootRealization.rootSystem =
        first)
    (secondRoots :
      secondRealization.toKummerRootRealization.rootSystem =
        second)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    (firstRealization.cocycle equivariant).Cohomologous
      (secondRealization.cocycle equivariant) := by
  refine
    ⟨coefficientCyclotomeEquiv.symm comparison.cyclotome, ?_⟩
  apply ContinuousOneCocycle.ext
  intro g
  let both :
      (subgroup ⊓ subgroup : OpenSubgroup G) :=
    ⟨(g : G), ⟨g.property, g.property⟩⟩
  change
    coefficientCyclotomeEquiv.symm
        (secondRealization.toKummerRootRealization.ratioCyclotome g) =
      (coefficientCyclotomeEquiv.symm comparison.cyclotome)⁻¹ *
        coefficientCyclotomeEquiv.symm
            (firstRealization.toKummerRootRealization.ratioCyclotome g) *
          coefficientAction.act (g : G)
            (coefficientCyclotomeEquiv.symm comparison.cyclotome)
  apply coefficientCyclotomeEquiv.injective
  rw [map_mul, map_mul, map_inv]
  rw [coefficientCyclotomeEquiv.apply_symm_apply,
    coefficientCyclotomeEquiv.apply_symm_apply,
    coefficientCyclotomeEquiv.apply_symm_apply,
    equivariant,
    coefficientCyclotomeEquiv.apply_symm_apply]
  exact
    comparison.ratioCyclotome_relation
      firstRealization.toKummerRootRealization
      secondRealization.toKummerRootRealization
      firstRoots secondRoots both

/-- The local Kummer class is independent of compatible-root choices. -/
theorem localClass_eq
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    {coefficientAction : ContinuousGroupAction G A}
    {coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier}
    {subgroup : OpenSubgroup G}
    (comparison :
      pair.CompatibleRootComparison value first second)
    (firstRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup value)
    (secondRealization :
      pair.ContinuousKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup value)
    (firstRoots :
      firstRealization.toKummerRootRealization.rootSystem =
        first)
    (secondRoots :
      secondRealization.toKummerRootRealization.rootSystem =
        second)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    firstRealization.localClass equivariant =
      secondRealization.localClass equivariant :=
  Quotient.sound
    (comparison.localCocycles_cohomologous
      firstRealization secondRealization
      firstRoots secondRoots equivariant)

end CompatibleRootComparison

/-- A continuous compatible-root realization with its open stabilizer. -/
abbrev ContinuousKummerRootChoice
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (value : pair.arithmeticMonoid.carrier) :=
  Σ subgroup : OpenSubgroup G,
    pair.ContinuousKummerRootRealization
      coefficientAction coefficientCyclotomeEquiv
      subgroup value

/-- A packaged continuity certificate for the canonical global root ratio. -/
structure ContinuousModelKummerRootChoice
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (value : pair.arithmeticMonoid.carrier) where
  continuous_ratio :
    Continuous fun g : pair.openStabilizer value =>
      coefficientCyclotomeEquiv.symm
        ((KummerRootRealization.ofRootSystem
            pair (pair.openStabilizer value) value
            (pair.openStabilizer_fixed value)
            (CompatibleRootSystem.ofModel pair value)).ratioCyclotome g)

/--
The continuous root algorithm of Absolute Anabelian Topics III,
Proposition 3.2(ii).  The canonical instance below derives every field from the
literal MLF model and its continuous cyclotome action.
-/
structure KummerRootTheory
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier) where
  continuous_ratios :
    ∀ value : pair.arithmeticMonoid.carrier,
      pair.ContinuousModelKummerRootChoice
        coefficientAction coefficientCyclotomeEquiv value

namespace KummerRootTheory

variable
  {A : Type u}
  [Group A] [TopologicalSpace A] [IsTopologicalGroup A]

/--
Construct the complete continuous root theory from a continuous identification
of its coefficient group with the canonical profinite cyclotome.
-/
noncomputable def ofContinuousEquiv
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃ₜ* SourceMonoidCyclotome pair.arithmeticMonoid.carrier) :
    pair.KummerRootTheory
      coefficientAction coefficientCyclotomeEquiv.toMulEquiv where
  continuous_ratios value :=
    { continuous_ratio :=
        coefficientCyclotomeEquiv.symm.continuous_toFun.comp
          ((KummerRootRealization.ofRootSystem
            pair (pair.openStabilizer value) value
            (pair.openStabilizer_fixed value)
            (CompatibleRootSystem.ofModel pair value)).ratioCyclotome_continuous) }

variable
  [IsMulCommutative A]
  {pair : SourceMLFGaloisTMPair G}
  {coefficientAction : ContinuousGroupAction G A}
  {coefficientCyclotomeEquiv :
    A ≃*
      SourceMonoidCyclotome pair.arithmeticMonoid.carrier}

/-- The supplied continuity certificate for the constructed root system. -/
def chosenModel
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (value : pair.arithmeticMonoid.carrier) :
    pair.ContinuousModelKummerRootChoice
      coefficientAction coefficientCyclotomeEquiv value :=
  theory.continuous_ratios value

/-- Assemble the continuous realization from the residual source obligations. -/
noncomputable def chosen
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (value : pair.arithmeticMonoid.carrier) :
    pair.ContinuousKummerRootChoice
      coefficientAction coefficientCyclotomeEquiv value :=
  ⟨pair.openStabilizer value,
    { toKummerRootRealization :=
        KummerRootRealization.ofRootSystem
          pair (pair.openStabilizer value) value
          (pair.openStabilizer_fixed value)
          (CompatibleRootSystem.ofModel pair value)
      continuous_ratio :=
        (theory.chosenModel value).continuous_ratio }⟩

/-- The chosen realization really uses the literal-model root system. -/
theorem chosen_rootSystem
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (value : pair.arithmeticMonoid.carrier) :
    (theory.chosen value).2.toKummerRootRealization.rootSystem =
      CompatibleRootSystem.ofModel pair value :=
  rfl

/-- A fixed comparison; its resulting H1 equality is independent of this choice. -/
noncomputable def chosenComparison
    (_theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (value : pair.arithmeticMonoid.carrier)
    (first second : pair.CompatibleRootSystem value) :
    pair.CompatibleRootComparison value first second :=
  CompatibleRootComparison.ofModel pair value first second

/-- The Kummer class of one monoid element, obtained from compatible roots. -/
noncomputable def kummerValue
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient))
    (value : pair.arithmeticMonoid.carrier) :
    ContinuousH1Germ coefficientAction :=
  (theory.chosen value).2.germ equivariant

theorem kummerValue_one
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    theory.kummerValue equivariant 1 = 1 := by
  let chosenRealization := (theory.chosen (1 : pair.arithmeticMonoid.carrier)).2
  let trivialRealization :=
    ContinuousKummerRootRealization.one
      pair coefficientAction coefficientCyclotomeEquiv
  let comparison :=
    theory.chosenComparison 1
      chosenRealization.toKummerRootRealization.rootSystem
      trivialRealization.toKummerRootRealization.rootSystem
  calc
    theory.kummerValue equivariant 1 =
        chosenRealization.germ equivariant := rfl
    _ = trivialRealization.germ equivariant :=
      comparison.germ_eq
        chosenRealization trivialRealization
        rfl rfl equivariant
    _ = 1 :=
      ContinuousKummerRootRealization.one_germ
        pair coefficientAction coefficientCyclotomeEquiv
        equivariant

theorem kummerValue_mul
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient))
    (first second : pair.arithmeticMonoid.carrier) :
    theory.kummerValue equivariant (first * second) =
      theory.kummerValue equivariant first *
        theory.kummerValue equivariant second := by
  let firstRealization := (theory.chosen first).2
  let secondRealization := (theory.chosen second).2
  let productRealization := firstRealization.mul secondRealization
  let chosenProduct := (theory.chosen (first * second)).2
  let comparison :=
    theory.chosenComparison (first * second)
      chosenProduct.toKummerRootRealization.rootSystem
      productRealization.toKummerRootRealization.rootSystem
  calc
    theory.kummerValue equivariant (first * second) =
        chosenProduct.germ equivariant := rfl
    _ = productRealization.germ equivariant :=
      comparison.germ_eq
        chosenProduct productRealization
        rfl rfl equivariant
    _ =
        firstRealization.germ equivariant *
          secondRealization.germ equivariant :=
      ContinuousKummerRootRealization.mul_germ
        firstRealization secondRealization equivariant
    _ =
        theory.kummerValue equivariant first *
          theory.kummerValue equivariant second := rfl

/--
The full monoid Kummer map of Proposition 3.2(ii), rather than a supplied map
on units.  Its monoid laws are consequences of root-choice independence.
-/
noncomputable def kummerMap
    (theory :
      pair.KummerRootTheory
        coefficientAction coefficientCyclotomeEquiv)
    (equivariant :
      ∀ g coefficient,
        coefficientCyclotomeEquiv
            (coefficientAction.act g coefficient) =
          pair.cyclotomeAction g
            (coefficientCyclotomeEquiv coefficient)) :
    pair.arithmeticMonoid.carrier →*
      ContinuousH1Germ coefficientAction where
  toFun := theory.kummerValue equivariant
  map_one' := theory.kummerValue_one equivariant
  map_mul' := theory.kummerValue_mul equivariant

/-- The canonical global root theory with no caller-supplied realization data. -/
noncomputable def canonical
    (pair : SourceMLFGaloisTMPair G) :
    pair.KummerRootTheory
      pair.continuousCyclotomeAction
      (ContinuousMulEquiv.refl
        (SourceMonoidCyclotome pair.arithmeticMonoid.carrier)).toMulEquiv :=
  ofContinuousEquiv pair pair.continuousCyclotomeAction
    (ContinuousMulEquiv.refl
      (SourceMonoidCyclotome pair.arithmeticMonoid.carrier))

/--
The source-constructed map
`M -> colim_J H^1(J, mu_Z(M))` of Proposition 3.2(ii).
-/
noncomputable def canonicalKummerMap
    (pair : SourceMLFGaloisTMPair G) :
    pair.arithmeticMonoid.carrier →*
      ContinuousH1Germ pair.continuousCyclotomeAction :=
  (canonical pair).kummerMap (by
    intro _ _
    rfl)

end KummerRootTheory

/-- A packaged continuity certificate for a canonical local root ratio. -/
structure ContinuousLocalModelKummerRootRealization
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (subgroup : OpenSubgroup G)
    (value : pair.fixedSubmonoid subgroup) where
  continuous_ratio :
    Continuous fun g : subgroup =>
      coefficientCyclotomeEquiv.symm
        ((KummerRootRealization.ofRootSystem
            pair subgroup (value : pair.arithmeticMonoid.carrier)
            value.2
            (CompatibleRootSystem.ofModel pair
              (value : pair.arithmeticMonoid.carrier))).ratioCyclotome g)

/--
The continuous root algorithm over a specified open subgroup `H`, with domain
the actual fixed submonoid `M^H`.  Its canonical instance is constructed below.
-/
structure LocalKummerRootTheory
    {A : Type u}
    [Group A] [TopologicalSpace A] [IsTopologicalGroup A]
    (pair : SourceMLFGaloisTMPair G)
    (coefficientAction : ContinuousGroupAction G A)
    (coefficientCyclotomeEquiv :
      A ≃*
        SourceMonoidCyclotome pair.arithmeticMonoid.carrier)
    (subgroup : OpenSubgroup G) where
  continuous_ratios :
    ∀ value : pair.fixedSubmonoid subgroup,
      pair.ContinuousLocalModelKummerRootRealization
        coefficientAction coefficientCyclotomeEquiv
        subgroup value

namespace LocalKummerRootTheory

variable
  {A : Type u}
